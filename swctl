cmd_resolve_pr_list() {
    local repo="${1:-shopware/shopware}"

    printf '\n%b%-8s %-12s %-50s %-10s%b\n' \
        "${COLOR_BOLD:-}" "PR" "Issue" "Title" "Status" "${COLOR_RESET:-}"
    printf '%-8s %-12s %-50s %-10s\n' \
        "--------" "------------" "--------------------------------------------------" "----------"

    # Scan all resolve instances for branches, check if they have PRs
    local registry_dir="${SWCTL_REGISTRY_DIR:-$SWCTL_STATE_DIR/instances}"
    for meta_file in "$registry_dir"/*/*.env; do
        [ -f "$meta_file" ] || continue
        (
            # shellcheck source=/dev/null  # dynamic path: per-instance metadata
            source "$meta_file" 2>/dev/null || exit 0
            [ -n "${CLAUDE_SESSION_ID:-}" ] || exit 0  # Only resolve sessions

            local pr_info
            pr_info="$(gh pr list --head "${BRANCH:-}" --repo "$repo" --json number,title,state --jq '.[] | "\(.number)\t\(.title)\t\(.state)"' 2>/dev/null)" || exit 0

            if [ -n "$pr_info" ]; then
                local pr_num pr_title pr_state
                pr_num="$(printf '%s' "$pr_info" | cut -f1)"
                pr_title="$(printf '%s' "$pr_info" | cut -f2 | cut -c1-50)"
                pr_state="$(printf '%s' "$pr_info" | cut -f3)"

                local sc=""
                case "$pr_state" in
                    OPEN)   sc="${COLOR_GREEN:-}" ;;
                    MERGED) sc="${COLOR_BLUE:-}" ;;
                    CLOSED) sc="${COLOR_RED:-}" ;;
                esac

                printf '%-8s %-12s %-50s %b%-10s%b\n' \
                    "#$pr_num" "#${ISSUE_ID:-}" "$pr_title" "$sc" "$pr_state" "${COLOR_RESET:-}"
            fi
        )
    done
    printf '\n'
}

