    local total
    total="$(printf '%s\n' "$issues" | grep -c '.' || echo 0)"
    info "Will resolve $total issue(s) with Claude Code."
    # Split newline-separated issues into positional args for cmd_resolve.
    # shellcheck disable=SC2046  # intentional word-split: each issue → one arg
    cmd_resolve $(printf '%s\n' "$issues" | tr '\n' ' ')
}

