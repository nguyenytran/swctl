    COMPOSE_ENV_FILE="$SWCTL_TMP_DIR/${COMPOSE_PROJECT}.compose.env"
    cat >"$COMPOSE_ENV_FILE" <<EOF
SW_PHP_IMAGE=${SW_PHP_IMAGE}
SW_WORKTREE_PATH=${WORKTREE_PATH}
