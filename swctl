resolve_instance_file_by_issue() {
    local issue_input="$1"
    local issue_id
    local hits
    local first_hit

    issue_id="$(sanitize_slug "$issue_input")"
    hits=""

    while IFS= read -r file; do
        if [ -n "$hits" ]; then
            hits="${hits}
$file"
        else
            hits="$file"
        fi
    done <<EOF
$(find "$SWCTL_REGISTRY_DIR" -type f -path "*/${issue_id}.env" 2>/dev/null | sort)
EOF

    if [ -z "$hits" ]; then
        return 1
    fi

    first_hit="$(printf '%s\n' "$hits" | sed -n '1p')"
    if [ -n "${SW_PROJECT_SLUG:-}" ]; then
        if [ -f "$(instance_file "$SW_PROJECT_SLUG" "$issue_id")" ]; then
            printf '%s\n' "$(instance_file "$SW_PROJECT_SLUG" "$issue_id")"
            return 0
        fi
    fi

    if [ "$(printf '%s\n' "$hits" | grep -c '.' || true)" -gt 1 ]; then
        err "Issue '$issue_input' exists in multiple projects."
        printf '%s\n' "$hits" >&2
        return 1
    fi

    printf '%s\n' "$first_hit"
    return 0
}

# --- Project registry ---

ensure_projects_file() {
    [ -f "$SWCTL_PROJECTS_FILE" ] || touch "$SWCTL_PROJECTS_FILE"
}

read_project() {
    local name="$1"
    ensure_projects_file
    grep -E "^${name}	" "$SWCTL_PROJECTS_FILE" 2>/dev/null | head -1
}

read_project_field() {
    local entry="$1" field="$2"
    case "$field" in
        name)       printf '%s' "$entry" | cut -f1 ;;
        type)       printf '%s' "$entry" | cut -f2 ;;
        path)       printf '%s' "$entry" | cut -f3 ;;
        parent)     printf '%s' "$entry" | cut -f4 ;;
        plugin_dir) printf '%s' "$entry" | cut -f5 ;;
        workflow)   local wf; wf="$(printf '%s' "$entry" | cut -f6)"; printf '%s' "${wf:--}" ;;
    esac
}

list_projects() {
    ensure_projects_file
    grep -v '^#' "$SWCTL_PROJECTS_FILE" 2>/dev/null | grep -v '^$' || true
}

add_project_entry() {
    local name="$1" type="$2" proj_path="$3" parent="${4:--}" plugin_dir="${5:--}" workflow="${6:--}"
    ensure_projects_file
    if grep -qE "^${name}	" "$SWCTL_PROJECTS_FILE" 2>/dev/null; then
        die "Project '$name' already registered. Use 'swctl project remove $name' first."
    fi
    [ -d "$proj_path" ] || die "Path does not exist: $proj_path"
    case "$type" in
        platform|plugin-embedded|plugin-external) ;;
        *) die "Invalid project type: $type (expected: platform, plugin-embedded, plugin-external)" ;;
    esac
    if [ "$type" != "platform" ] && [ "$parent" = "-" ]; then
        die "Plugin projects require --parent <platform-name>."
    fi
    if [ "$type" != "platform" ] && [ "$parent" != "-" ]; then
        read_project "$parent" >/dev/null || die "Parent project '$parent' not found in registry."
    fi
    if [ "$type" = "plugin-embedded" ] && [ "$plugin_dir" = "-" ]; then
        die "Embedded plugins require --plugin-dir <relative-path>."
    fi
    printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$name" "$type" "$proj_path" "$parent" "$plugin_dir" "$workflow" \
        >> "$SWCTL_PROJECTS_FILE"
    ok "Registered project '$name' ($type)."
}

remove_project_entry() {
    local name="$1"
    ensure_projects_file
    if ! grep -qE "^${name}	" "$SWCTL_PROJECTS_FILE" 2>/dev/null; then
        die "Project '$name' not found in registry."
    fi
    local tmp="$SWCTL_PROJECTS_FILE.tmp"
    grep -vE "^${name}	" "$SWCTL_PROJECTS_FILE" > "$tmp"
    mv "$tmp" "$SWCTL_PROJECTS_FILE"
    ok "Removed project '$name' from registry."
}

auto_register_project() {
    # Auto-register the current project if not already in the registry
    local slug="${SW_PROJECT_SLUG:-}"
    [ -n "$slug" ] || return
    ensure_projects_file
    if ! grep -qE "^${slug}	" "$SWCTL_PROJECTS_FILE" 2>/dev/null; then
        printf '%s\t%s\t%s\t%s\t%s\n' "$slug" "platform" "$PROJECT_ROOT" "-" "-" \
            >> "$SWCTL_PROJECTS_FILE"
    fi
}

resolve_plugin_name_from_composer() {
    local composer_file="$1"
    if [ -f "$composer_file" ]; then
        # Extract the last segment of the composer name (e.g. "swag/commercial" → "SwagCommercial")
        # Fallback to directory name
        local dir_name
        dir_name="$(basename "$(dirname "$composer_file")")"
        printf '%s' "$dir_name"
    fi
}

cmd_project() {
    local action="${1:-list}"
    shift || true
    ensure_projects_file

    case "$action" in
        add)
            local name="" proj_path="" type="platform" parent="-" plugin_dir="-"
            while [ $# -gt 0 ]; do
                case "$1" in
                    --type)       type="$2"; shift 2 ;;
                    --parent)     parent="$2"; shift 2 ;;
                    --plugin-dir) plugin_dir="$2"; shift 2 ;;
                    *)
                        if [ -z "$name" ]; then
                            name="$1"
                        elif [ -z "$proj_path" ] || [ "$proj_path" = "" ]; then
                            proj_path="$1"
                        fi
                        shift
                        ;;
                esac
            done
            [ -n "$name" ] || die "Usage: swctl project add <name> <path> --type <type> [--parent <name>] [--plugin-dir <dir>]"
            [ -n "$proj_path" ] || die "Usage: swctl project add <name> <path> --type <type> [--parent <name>] [--plugin-dir <dir>]"
            # Resolve to absolute path
            if [ -d "$proj_path" ]; then
                proj_path="$(cd "$proj_path" && pwd -P)"
            fi
            case "$proj_path" in
                /*) ;; # absolute path — OK
                *)  die "Path must be absolute: $proj_path" ;;
            esac
            [ -d "$proj_path/.git" ] || warn "Not a git repository: $proj_path (path may not be mounted yet)"
            add_project_entry "$name" "$type" "$proj_path" "$parent" "$plugin_dir"
            ;;

        list)
            local entries
            entries="$(list_projects)"
            if [ -z "$entries" ]; then
                info "No projects registered. Use 'swctl project add' or 'swctl project init'."
                return
            fi
            printf "${COLOR_BOLD}%-20s %-18s %-40s %-12s %-30s${COLOR_RESET}\n" \
                "NAME" "TYPE" "PATH" "PARENT" "PLUGIN DIR"
            printf '%.0s─' {1..120}; printf '\n'
            while IFS=$'\t' read -r p_name p_type p_path p_parent p_pdir; do
                printf "%-20s %-18s %-40s %-12s %-30s\n" \
                    "$p_name" "$p_type" "$p_path" "$p_parent" "$p_pdir"
            done <<< "$entries"
            ;;

        remove)
            local name="${1:-}"
            [ -n "$name" ] || die "Usage: swctl project remove <name>"
            remove_project_entry "$name"
            ;;

        init)
            maybe_load_project_config >/dev/null 2>&1 || die "Run from a project directory with .swctl.conf."
            auto_register_project
            local plugins_dir="$PROJECT_ROOT/custom/plugins"
            [ -d "$plugins_dir" ] || { info "No custom/plugins directory found."; return; }
            local count=0
            for plugin_path in "$plugins_dir"/*/; do
                [ -d "$plugin_path" ] || continue
                local pname
                pname="$(basename "$plugin_path")"
                [ "$pname" = "*" ] && continue
                [ -f "$plugin_path/composer.json" ] || continue
                if [ -d "$plugin_path/.git" ]; then
                    # Plugin has its own git repo — discovered dynamically via --plugin flag
                    info "Found plugin with own repo: $pname (use --plugin $pname with create)"
                    count=$((count + 1))
                else
                    # Plugin is part of platform repo — register as embedded
                    local slug
                    slug="$(sanitize_slug "$pname")"
                    if grep -qE "^${slug}	" "$SWCTL_PROJECTS_FILE" 2>/dev/null; then
                        info "Already registered: $slug"
                        continue
                    fi
                    local rel_path="custom/plugins/$pname"
                    printf '%s\t%s\t%s\t%s\t%s\n' "$slug" "plugin-embedded" "$PROJECT_ROOT" "$SW_PROJECT_SLUG" "$rel_path" \
                        >> "$SWCTL_PROJECTS_FILE"
                    ok "Registered embedded plugin: $slug ($rel_path)"
                    count=$((count + 1))
                fi
            done
            info "Discovered $count plugin(s)."
            ;;

        plugins)
            local proj_name="${1:-}"
            [ -n "$proj_name" ] || die "Usage: swctl project plugins <project-name>"
            local entry
            entry="$(read_project "$proj_name")" || die "Project '$proj_name' not found."
            local proj_path
            proj_path="$(read_project_field "$entry" path)"
            list_available_plugins "$proj_path"
            ;;

        *)
            die "Usage: swctl project [add|list|remove|init|plugins]"
            ;;
    esac
}

container_exists() {
    docker ps -a --format '{{.Names}}' | grep -Fxq "$1"
}

container_running() {
    docker ps --format '{{.Names}}' | grep -Fxq "$1"
}

ensure_docker() {
    require_cmd docker
    docker info >/dev/null 2>&1 || die "Docker daemon is not reachable."
}

ensure_network() {
    if docker network inspect "$SW_TRAEFIK_NETWORK" >/dev/null 2>&1; then
        ok "Docker network '$SW_TRAEFIK_NETWORK' already exists."
    else
        docker network create "$SW_TRAEFIK_NETWORK" >/dev/null
        ok "Created Docker network '$SW_TRAEFIK_NETWORK'."
    fi
}

start_or_create_container() {
    local name="$1"
    shift

    if container_exists "$name"; then
        if container_running "$name"; then
            ok "Container '$name' is already running."
        else
            docker start "$name" >/dev/null
            ok "Started container '$name'."
        fi
    else
        docker run -d --name "$name" "$@" >/dev/null
        ok "Created container '$name'."
    fi
}

resolve_db_container() {
    # In OrbStack/trunk mode, find the DB container on the trunk network.
    if [ -n "${SW_PROJECT_NETWORK:-}" ] && [ "$(detect_runtime)" = "orbstack" ]; then
        local trunk_db
        trunk_db="$(docker ps --filter "network=${SW_PROJECT_NETWORK}" --filter "ancestor=mariadb" --format '{{.Names}}' 2>/dev/null | head -1)"
        if [ -z "$trunk_db" ]; then
            trunk_db="$(docker ps --filter "network=${SW_PROJECT_NETWORK}" --format '{{.Names}}' 2>/dev/null | grep -i database | head -1)"
        fi
        if [ -n "$trunk_db" ]; then
            printf '%s' "$trunk_db"
            return
        fi
    fi
    printf '%s' "${SW_INFRA_DB_CONTAINER:-swctl-mariadb}"
}

mysql_exec() {
    local sql="$1"
    local db_container
    db_container="$(resolve_db_container)"
    docker exec -i "$db_container" mariadb \
        -u "$SW_DB_ROOT_USER" \
        "-p$SW_DB_ROOT_PASSWORD" \
        -Nse "$sql"
}

mysql_db_exists() {
    local db_name="$1"
    local result
    result="$(mysql_exec "SELECT SCHEMA_NAME FROM information_schema.SCHEMATA WHERE SCHEMA_NAME='${db_name}';" 2>/dev/null || true)"
    [ "$result" = "$db_name" ]
}

mysql_db_has_tables() {
    local db_name="$1"
    local result
    result="$(mysql_exec "SELECT COUNT(*) FROM information_schema.TABLES WHERE TABLE_SCHEMA='${db_name}';" 2>/dev/null || printf '0')"
    [ "${result:-0}" -gt 0 ]
}

wait_for_mysql() {
    local attempt=0
    while [ "$attempt" -lt 30 ]; do
        if mysql_exec 'SELECT 1;' >/dev/null 2>&1; then
            ok "MariaDB is reachable on ${SW_DB_HOST}:${SW_DB_PORT}."
            return 0
        fi
        attempt=$((attempt + 1))
        sleep 2
    done

    die "MariaDB did not become ready in time."
}

init_infra() {
    ensure_docker
    maybe_load_project_config >/dev/null 2>&1 || true

    local runtime
    runtime="$(detect_runtime)"
    SW_TRAEFIK_NETWORK="${SW_TRAEFIK_NETWORK:-swctl-proxy}"
    SW_INFRA_TRAEFIK_CONTAINER="${SW_INFRA_TRAEFIK_CONTAINER:-swctl-traefik}"
    SW_INFRA_DB_CONTAINER="${SW_INFRA_DB_CONTAINER:-swctl-mariadb}"
    SW_INFRA_REDIS_CONTAINER="${SW_INFRA_REDIS_CONTAINER:-swctl-redis}"
    SW_DB_ROOT_USER="${SW_DB_ROOT_USER:-root}"
    SW_DB_ROOT_PASSWORD="${SW_DB_ROOT_PASSWORD:-shopware}"
    SW_DB_PORT="${SW_DB_PORT:-3306}"

    if [ "$runtime" = "traefik" ]; then
        ensure_network

        start_or_create_container "$SW_INFRA_TRAEFIK_CONTAINER" \
            --restart unless-stopped \
            --network "$SW_TRAEFIK_NETWORK" \
            -p 80:80 \
            -p 8080:8080 \
            -v /var/run/docker.sock:/var/run/docker.sock:ro \
            -v swctl-traefik-data:/data \
            traefik:v3.1 \
            --api.dashboard=true \
            --api.insecure=true \
            --providers.docker=true \
            --providers.docker.exposedByDefault=false \
            --entrypoints.web.address=:80
    else
        info "OrbStack detected. Skipping Traefik — OrbStack handles DNS routing."
    fi

    start_or_create_container "$SW_INFRA_DB_CONTAINER" \
        --restart unless-stopped \
        -p "${SW_DB_PORT}:3306" \
        -e "MARIADB_ROOT_PASSWORD=${SW_DB_ROOT_PASSWORD}" \
        -e "MARIADB_ROOT_HOST=%" \
        -v swctl-mariadb-data:/var/lib/mysql \
        mariadb:11

    start_or_create_container "$SW_INFRA_REDIS_CONTAINER" \
        --restart unless-stopped \
        -p 6379:6379 \
        -v swctl-redis-data:/data \
        redis:7-alpine \
        redis-server \
        --appendonly yes

    wait_for_mysql
    ok "Shared infrastructure is ready."
    if [ "$runtime" = "traefik" ]; then
        info "Traefik dashboard: http://localhost:8080"
    else
        info "Runtime: OrbStack (domains via *.orb.local)"
    fi
}

ensure_infra_ready() {
    ensure_docker
    local runtime
    runtime="$(detect_runtime)"

    if [ "$runtime" = "traefik" ]; then
        if ! docker network inspect "${SW_TRAEFIK_NETWORK:-swctl-proxy}" >/dev/null 2>&1 || \
            ! container_running "${SW_INFRA_TRAEFIK_CONTAINER:-swctl-traefik}" || \
            ! container_running "${SW_INFRA_DB_CONTAINER:-swctl-mariadb}" || \
            ! container_running "${SW_INFRA_REDIS_CONTAINER:-swctl-redis}"; then
            warn "Shared infrastructure is missing or stopped. Running 'swctl init'."
            init_infra
        fi
    else
        # OrbStack mode: worktrees connect to trunk's network.
        # Just verify the trunk network exists.
        if [ -n "${SW_PROJECT_NETWORK:-}" ] && docker network inspect "$SW_PROJECT_NETWORK" >/dev/null 2>&1; then
            ok "Project network '$SW_PROJECT_NETWORK' is available."
        else
            warn "Project network '${SW_PROJECT_NETWORK:-trunk_default}' not found. Start your project first: cd $PROJECT_ROOT && docker compose up -d"
        fi
    fi
}

git_base_ref() {
    if git -C "$PROJECT_ROOT" rev-parse --verify "$SW_BASE_BRANCH" >/dev/null 2>&1; then
        printf '%s\n' "$SW_BASE_BRANCH"
        return 0
    fi

    if git -C "$PROJECT_ROOT" rev-parse --verify "origin/$SW_BASE_BRANCH" >/dev/null 2>&1; then
        printf '%s\n' "origin/$SW_BASE_BRANCH"
        return 0
    fi

    die "Base branch '$SW_BASE_BRANCH' was not found locally or under origin/."
}

check_branch_staleness() {
    local merge_base
    local commits_behind=0
    local days_behind=0

    merge_base="$(git -C "$WORKTREE_PATH" merge-base "$BASE_REF" HEAD 2>/dev/null || true)"
    [ -n "$merge_base" ] || return 0

    commits_behind="$(git -C "$WORKTREE_PATH" rev-list --count "$merge_base..${BASE_REF}" 2>/dev/null || printf '0')"
    days_behind="$(( ( $(date +%s) - $(git -C "$WORKTREE_PATH" log -1 --format=%ct "$merge_base" 2>/dev/null || printf '%s' "$(date +%s)") ) / 86400 ))"

    if [ "$commits_behind" -gt 100 ] || [ "$days_behind" -gt 14 ]; then
        warn "Branch '$BRANCH' is ${commits_behind} commits / ${days_behind} days behind '${SW_BASE_BRANCH}'."
        warn "The DB is cloned from current trunk — schema mismatches are likely."
        warn "Recommended: rebase the branch first, then create the worktree."
        warn "  cd $WORKTREE_PATH && git rebase $BASE_REF"
        warn "  OR ask the developer to rebase and push."
    elif [ "$commits_behind" -gt 20 ]; then
        info "Branch is ${commits_behind} commits behind '${SW_BASE_BRANCH}' (${days_behind} days). Consider rebasing for best results."
    fi
}

worktree_exists() {
    git -C "$PROJECT_ROOT" worktree list --porcelain | grep -Fxq "worktree $1"
}

create_worktree() {
    mkdir -p "$SW_WORKTREE_ROOT"

    # All git worktree operations (check, remove, add, reset) are serialized per repo.
    # Concurrent `git worktree add/remove/list` on the same repo race on internal locks
    # (.git/config.lock, index.lock) causing "Could not reset index file" errors.
    _do_worktree_create() {
        if worktree_exists "$WORKTREE_PATH"; then
            ok "Git worktree already exists at '$WORKTREE_PATH'."
            return 0
        fi

        if [ -d "$WORKTREE_PATH" ]; then
            # Check if this is a leftover from a failed/interrupted create
            if [ "${STATUS:-}" = "creating" ] || [ "${STATUS:-}" = "failed" ]; then
                warn "Cleaning up leftover directory from previous failed create: $WORKTREE_PATH"
                git -C "$PROJECT_ROOT" worktree remove --force "$WORKTREE_PATH" 2>/dev/null || rm -rf "$WORKTREE_PATH"
            else
                die "Target worktree path already exists and is not a registered Git worktree: $WORKTREE_PATH"
            fi
        fi

        # Retry loop: git worktree add can fail transiently due to concurrent git
        # operations holding locks (config.lock, index.lock). We retry up to 3 times
        # with cleanup between attempts.
        local _wt_attempt=0
        local _wt_max=3
        local _wt_ok=0

        while [ "$_wt_attempt" -lt "$_wt_max" ] && [ "$_wt_ok" -eq 0 ]; do
            _wt_attempt=$((_wt_attempt + 1))

            # Clean up stale git lock files before each attempt
            local config_lock="$PROJECT_ROOT/.git/config.lock"
            if [ -f "$config_lock" ]; then
                if find "$config_lock" -mmin +0.08 -print -quit 2>/dev/null | grep -q .; then
                    warn "Removing stale lock file: $config_lock"
                    rm -f "$config_lock"
                fi
            fi

            # Attempt git worktree add (capture exit code, don't abort on failure)
            local _wt_rc=0
            if git -C "$PROJECT_ROOT" show-ref --verify --quiet "refs/heads/$BRANCH"; then
                git -C "$PROJECT_ROOT" worktree add "$WORKTREE_PATH" "$BRANCH" 2>&1 || _wt_rc=$?
            elif git -C "$PROJECT_ROOT" show-ref --verify --quiet "refs/remotes/origin/$BRANCH"; then
                git -C "$PROJECT_ROOT" worktree add -b "$BRANCH" "$WORKTREE_PATH" "origin/$BRANCH" 2>&1 || _wt_rc=$?
            else
                git -C "$PROJECT_ROOT" worktree add -b "$BRANCH" "$WORKTREE_PATH" "$BASE_REF" 2>&1 || _wt_rc=$?
            fi

            # Verify: directory exists AND has checked-out files
            if [ -f "$WORKTREE_PATH/composer.json" ]; then
                _wt_ok=1
            elif [ -d "$WORKTREE_PATH" ] && [ -f "$WORKTREE_PATH/.git" ]; then
                # Directory exists but checkout incomplete (e.g. "Could not reset index file").
                # The worktree is registered in git but files weren't checked out. Recover.
                warn "Worktree checkout incomplete (attempt $_wt_attempt/$_wt_max) — recovering with git reset."
                local gitdir=""
                gitdir="$(sed -n 's/^gitdir: //p' "$WORKTREE_PATH/.git" 2>/dev/null)" || true
                [ -n "$gitdir" ] && rm -f "$gitdir/index.lock" 2>/dev/null || true
                if git -C "$WORKTREE_PATH" reset --hard HEAD 2>&1; then
                    _wt_ok=1
                    ok "Worktree checkout recovered."
                else
                    warn "Recovery failed. Cleaning up for retry."
                    git -C "$PROJECT_ROOT" worktree remove --force "$WORKTREE_PATH" 2>/dev/null || rm -rf "$WORKTREE_PATH"
                fi
            else
                # Directory not created at all — git failed completely
                if [ "$_wt_attempt" -lt "$_wt_max" ]; then
                    warn "git worktree add failed (attempt $_wt_attempt/$_wt_max, rc=$_wt_rc). Retrying in 2s..."
                    git -C "$PROJECT_ROOT" worktree remove --force "$WORKTREE_PATH" 2>/dev/null || true
                    rm -rf "$WORKTREE_PATH" 2>/dev/null || true
                    sleep 2
                fi
            fi
        done

        if [ "$_wt_ok" -eq 0 ]; then
            die "Failed to create worktree at '$WORKTREE_PATH' after $_wt_max attempts."
        fi

        ok "Worktree ready at '$WORKTREE_PATH'."
    }
    local repo_slug
    repo_slug="$(echo "$PROJECT_ROOT" | tr '/' '-')"
    swctl_lock "git-worktree${repo_slug}" _do_worktree_create

    sync_lock_files
}

sync_lock_files() {
    [ -d "$WORKTREE_PATH" ] || return 0
    local file=""
    for file in composer.lock pnpm-lock.yaml yarn.lock package-lock.json; do
        if [ -f "$PROJECT_ROOT/$file" ] && [ ! -f "$WORKTREE_PATH/$file" ]; then
            cp "$PROJECT_ROOT/$file" "$WORKTREE_PATH/$file"
            ok "Copied gitignored '$file' into worktree."
        fi
    done
}

sync_build_artifacts() {
    # Called AFTER count_changes so ADMIN_CHANGES/STOREFRONT_CHANGES are set.
    # Diff-driven: only sync what's needed. Use APFS clones when available.

    # Read artifact lists from workflow.yaml if available
    local sync_files="" sync_dirs=""
    if [ -n "${SWCTL_WORKFLOW_DIR:-}" ] && [ -f "$SWCTL_WORKFLOW_DIR/workflow.yaml" ]; then
        eval "$(python3 -c "
import yaml, sys
with open(sys.argv[1]) as f:
    data = yaml.safe_load(f) or {}
sa = data.get('sync_artifacts', {})
files = sa.get('files', [])
dirs = sa.get('directories', [])
print('sync_files=\"{}\"'.format(' '.join(files)))
print('sync_dirs=\"{}\"'.format(' '.join(dirs)))
" "$SWCTL_WORKFLOW_DIR/workflow.yaml" 2>/dev/null)" || true
    fi

    # Defaults (Shopware 6)
    sync_files="${sync_files:-var/theme-files.json var/plugins.json}"
    if [ -z "$sync_dirs" ]; then
        sync_dirs="public/theme public/bundles"
        sync_dirs="$sync_dirs src/Storefront/Resources/app/storefront/vendor"
        sync_dirs="$sync_dirs src/Storefront/Resources/app/storefront/dist"
        sync_dirs="$sync_dirs src/Administration/Resources/public"
        sync_dirs="$sync_dirs src/Storefront/Resources/public"
        sync_dirs="$sync_dirs src/Administration/Resources/app/administration/node_modules"
        sync_dirs="$sync_dirs src/Storefront/Resources/app/storefront/node_modules"
    fi

    # Sync individual files
    local f
    for f in $sync_files; do
        if [ -f "$PROJECT_ROOT/$f" ]; then
            mkdir -p "$WORKTREE_PATH/$(dirname "$f")"
            cp "$PROJECT_ROOT/$f" "$WORKTREE_PATH/$f" 2>/dev/null || true
        fi
    done

    # Sync directories in parallel — each is independent (APFS clone or rsync)
    local _sync_pids=()
    local dir
    for dir in $sync_dirs; do
        (
            src_dir="$PROJECT_ROOT/$dir"
            dst_dir="$WORKTREE_PATH/$dir"
            if [ -d "$src_dir" ]; then
                src_count="$(find "$src_dir" -mindepth 1 -maxdepth 1 -not -name '.gitkeep' 2>/dev/null | wc -l | tr -d ' ')"
                dst_count="$( (find "$dst_dir" -mindepth 1 -maxdepth 1 -not -name '.gitkeep' 2>/dev/null || true) | wc -l | tr -d ' ')"
                if [ "$src_count" -gt 0 ] && [ "${dst_count:-0}" -lt "$src_count" ]; then
                    mkdir -p "$dst_dir"
                    # APFS clone (cp -c): instant copy-on-write. Clone to temp, swap in.
                    tmp_clone="${dst_dir}.swctl-clone"
                    rm -rf "$tmp_clone"
                    if cp -cR "$src_dir" "$tmp_clone" 2>/dev/null; then
                        rm -rf "$dst_dir"
                        mv "$tmp_clone" "$dst_dir"
                    else
                        rm -rf "$tmp_clone" 2>/dev/null || true
                        # Fallback: rsync or regular copy
                        mkdir -p "$dst_dir"
                        if command -v rsync >/dev/null 2>&1; then
                            rsync -a "$src_dir/" "$dst_dir/" 2>/dev/null || true
                        else
                            cp -R "$src_dir"/* "$dst_dir"/ 2>/dev/null || true
                        fi
                    fi
                    echo "  ✓ Synced '$dir/'."
                fi
            fi
        ) &
        _sync_pids+=($!)
    done
    # Wait for all parallel syncs to complete
    for pid in "${_sync_pids[@]}"; do
        wait "$pid" 2>/dev/null || true
    done

    # Mark synced artifacts as git-excluded so they don't pollute worktree git status.
    # Two mechanisms needed:
    #   1. info/exclude — hides untracked synced files
    #   2. assume-unchanged — hides tracked synced files that differ from branch
    local git_dir
    git_dir="$(git -C "$WORKTREE_PATH" rev-parse --git-dir 2>/dev/null)" || true
    if [ -n "$git_dir" ]; then
        # Make path absolute if relative
        case "$git_dir" in
            /*) ;;
            *)  git_dir="$WORKTREE_PATH/$git_dir" ;;
        esac
        local exclude_file="$git_dir/info/exclude"
        mkdir -p "$(dirname "$exclude_file")"
        # Add exclude entries for untracked synced artifacts
        if ! grep -q '# swctl synced artifacts' "$exclude_file" 2>/dev/null; then
            {
                echo ""
                echo "# swctl synced artifacts"
                for f in $sync_files; do
                    echo "/$f"
                done
                for dir in $sync_dirs; do
                    echo "/$dir/"
                done
            } >> "$exclude_file"
        fi

        # Mark tracked synced files as assume-unchanged
        for dir in $sync_dirs; do
            if [ -d "$WORKTREE_PATH/$dir" ]; then
                git -C "$WORKTREE_PATH" ls-files -z "$dir" 2>/dev/null \
                    | xargs -0 git -C "$WORKTREE_PATH" update-index --assume-unchanged 2>/dev/null || true
            fi
        done
        for f in $sync_files; do
            if [ -f "$WORKTREE_PATH/$f" ]; then
                git -C "$WORKTREE_PATH" update-index --assume-unchanged "$f" 2>/dev/null || true
            fi
        done
    fi
}

count_changes() {
    local diff_files="$1"

    # Read patterns from workflow.yaml if available, otherwise use Shopware defaults
    local pat_migration pat_entity pat_admin pat_storefront pat_composer pat_package pat_backend
    if [ -n "${SWCTL_WORKFLOW_DIR:-}" ] && [ -f "$SWCTL_WORKFLOW_DIR/workflow.yaml" ]; then
        eval "$(python3 -c "
import yaml, sys
with open(sys.argv[1]) as f:
    data = yaml.safe_load(f) or {}
d = data.get('detect', {})
print('pat_migration=\"{}\"'.format(d.get('migration', '(^|/)Migrations?/')))
print('pat_entity=\"{}\"'.format(d.get('entity', '(^|/)Entity/')))
print('pat_admin=\"{}\"'.format(d.get('admin', 'Resources/app/administration/.*\\\\.(js|ts|vue|scss)\$')))
print('pat_storefront=\"{}\"'.format(d.get('storefront', '(Resources/app/storefront/.*\\\\.(js|ts|vue|scss)\$|\\\\.twig\$)')))
print('pat_composer=\"{}\"'.format(d.get('composer', '(^|/)composer\\\\.(json|lock)\$')))
print('pat_package=\"{}\"'.format(d.get('package', '(^|/)(package\\\\.json|package-lock\\\\.json|pnpm-lock\\\\.yaml|yarn\\\\.lock)\$')))
print('pat_backend=\"{}\"'.format(d.get('backend', '\\\\.php\$')))
" "$SWCTL_WORKFLOW_DIR/workflow.yaml" 2>/dev/null)" || true
    fi

    # Defaults (Shopware 6 patterns)
    pat_migration="${pat_migration:-(^|/)Migrations?/}"
    pat_entity="${pat_entity:-(^|/)Entity/}"
    pat_admin="${pat_admin:-Resources/app/administration/.*\.(js|ts|vue|scss)$}"
    pat_storefront="${pat_storefront:-(Resources/app/storefront/.*\.(js|ts|vue|scss)$|\.twig$)}"
    pat_composer="${pat_composer:-(^|/)composer\.(json|lock)$}"
    pat_package="${pat_package:-(^|/)(package\.json|package-lock\.json|pnpm-lock\.yaml|yarn\.lock)$}"
    pat_backend="${pat_backend:-\.php$}"

    MIGRATION_CHANGES="$(printf '%s\n' "$diff_files" | grep -Ec "$pat_migration" || true)"
    ENTITY_CHANGES="$(printf '%s\n' "$diff_files" | grep -Ec "$pat_entity" || true)"
    ADMIN_CHANGES="$(printf '%s\n' "$diff_files" | grep -Ec "$pat_admin" || true)"
    STOREFRONT_CHANGES="$(printf '%s\n' "$diff_files" | grep -Ec "$pat_storefront" || true)"
    COMPOSER_CHANGES="$(printf '%s\n' "$diff_files" | grep -Ec "$pat_composer" || true)"
    PACKAGE_CHANGES="$(printf '%s\n' "$diff_files" | grep -Ec "$pat_package" || true)"
    BACKEND_CHANGES="$(printf '%s\n' "$diff_files" | grep -E "$pat_backend" | grep -Evc "$pat_migration|$pat_entity" || true)"
    # Backward compat: FRONTEND_CHANGES = ADMIN + STOREFRONT
    FRONTEND_CHANGES="$((ADMIN_CHANGES + STOREFRONT_CHANGES))"
}

sync_worktree_deps() {
    # QA mode: always symlink vendor (read-only, no installs).
    # Dev mode: symlink only when no composer/dependency changes.
    if [ -d "$PROJECT_ROOT/vendor" ] && [ ! -e "$WORKTREE_PATH/vendor" ]; then
        if [ "$SWCTL_MODE" = "qa" ]; then
            # QA mode: vendor is bind-mounted read-only via compose override.
            info "Vendor will be mounted read-only from project root (QA mode)."
        elif [ "$((MIGRATION_CHANGES + ENTITY_CHANGES + COMPOSER_CHANGES))" -gt 0 ]; then
            info "Dependency changes detected. Vendor will be installed fresh inside container."
        else
            ln -s "$PROJECT_ROOT/vendor" "$WORKTREE_PATH/vendor"
            ok "Symlinked vendor/ from project root (no composer changes)."
        fi
    fi
}

resolve_vendor_volume() {
    local issue_id="$1"
    if [ "$((MIGRATION_CHANGES + ENTITY_CHANGES + COMPOSER_CHANGES))" -gt 0 ]; then
        printf '%s' "vendor-${issue_id}"
    else
        printf '%s' "vendor-base-${SW_PROJECT_SLUG}"
    fi
}

resolve_node_modules_volume() {
    local issue_id="$1"
    if [ "$((MIGRATION_CHANGES + ENTITY_CHANGES + PACKAGE_CHANGES))" -gt 0 ]; then
        printf '%s' "node_modules-${issue_id}"
    else
        printf '%s' "node_modules-base-${SW_PROJECT_SLUG}"
    fi
}

detect_package_install_command() {
    local path="$1"

    if [ -f "$path/pnpm-lock.yaml" ]; then
        printf '%s\n' "pnpm install --frozen-lockfile"
        return
    fi

    if [ -f "$path/yarn.lock" ]; then
        printf '%s\n' "yarn install --frozen-lockfile"
        return
    fi

    if [ -f "$path/package-lock.json" ]; then
        printf '%s\n' "npm ci"
        return
    fi

    if [ -f "$path/package.json" ]; then
        printf '%s\n' "npm install"
    fi
}

write_env_file() {
    local env_file="$WORKTREE_PATH/$SW_ENV_FILE_NAME"
    local backup_file="$WORKTREE_PATH/${SW_ENV_FILE_NAME}.pre-swctl"

    if [ -f "$env_file" ] && ! grep -Fq "Managed by swctl" "$env_file"; then
        if [ ! -f "$backup_file" ]; then
            cp "$env_file" "$backup_file"
            warn "Backed up existing $SW_ENV_FILE_NAME to $(basename "$backup_file")."
        fi
    fi

    # Generate a stable APP_SECRET per worktree (deterministic from project+issue)
    local app_secret
    app_secret="$(printf '%s-%s' "$SW_PROJECT_SLUG" "$ISSUE_ID" | openssl dgst -sha256 | sed 's/.*= //')"

    cat >"$env_file" <<EOF
# Managed by swctl. Re-generated on $(timestamp_utc)
APP_ENV=dev
APP_URL=${APP_URL}
APP_SECRET=${app_secret}
DATABASE_URL=mysql://${SW_DB_ROOT_USER}:${SW_DB_ROOT_PASSWORD}@${SW_DB_HOST}:${SW_DB_PORT}/${DB_NAME}
MAILER_DSN=${SW_MAILER_DSN}
REDIS_URL=${SW_REDIS_URL}
OPENSEARCH_URL=${SW_OPENSEARCH_URL:-}
ADMIN_OPENSEARCH_URL=${SW_OPENSEARCH_URL:-}
WORKTREE_ID=${WORKTREE_ID}
COMPOSE_PROJECT_NAME=${COMPOSE_PROJECT}
SWCTL_PROJECT=${SW_PROJECT}
SWCTL_ISSUE=${ISSUE_ID}
EOF

    ok "Generated ${SW_ENV_FILE_NAME}."

    # Symfony Dotenv requires .env to exist for .env.local to be loaded.
    if [ ! -f "$WORKTREE_PATH/.env" ]; then
        touch "$WORKTREE_PATH/.env"
    fi
}

