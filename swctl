#!/usr/bin/env bash
set -euo pipefail

SWCTL_VERSION="0.2.0"

_swctl_resolve_script() {
    local src="${BASH_SOURCE[0]}"
    while [ -L "$src" ]; do
        local dir
        dir="$(cd "$(dirname "$src")" && pwd -P)"
        src="$(readlink "$src")"
        [[ "$src" != /* ]] && src="$dir/$src"
    done
    cd "$(dirname "$src")" && pwd -P
}
SCRIPT_DIR="$(_swctl_resolve_script)"
SWCTL_TEMPLATE_DIR="${SWCTL_TEMPLATE_DIR:-$SCRIPT_DIR}"
SWCTL_STATE_DIR="${SWCTL_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/swctl}"
SWCTL_REGISTRY_DIR="$SWCTL_STATE_DIR/instances"
SWCTL_INFRA_DIR="$SWCTL_STATE_DIR/infra"
SWCTL_PROJECTS_FILE="$SWCTL_STATE_DIR/projects.conf"
SWCTL_TMP_DIR="${TMPDIR:-/tmp}/swctl"

COLOR_RESET=""
COLOR_DIM=""
COLOR_RED=""
COLOR_GREEN=""
COLOR_YELLOW=""
COLOR_BLUE=""
COLOR_CYAN=""
COLOR_BOLD=""

if [ -t 1 ] && command -v tput >/dev/null 2>&1; then
    colors="$(tput colors 2>/dev/null || printf '0')"
    if [ "${colors:-0}" -ge 8 ]; then
        COLOR_RESET="$(tput sgr0)"
        COLOR_DIM="$(tput dim)"
        COLOR_RED="$(tput setaf 1)"
        COLOR_GREEN="$(tput setaf 2)"
        COLOR_YELLOW="$(tput setaf 3)"
        COLOR_BLUE="$(tput setaf 4)"
        COLOR_CYAN="$(tput setaf 6)"
        COLOR_BOLD="$(tput bold)"
    fi
fi

log() {
    printf '%b[%s]%b %s\n' "$1" "$2" "$COLOR_RESET" "$3"
}

ok() {
    log "$COLOR_GREEN" "OK" "$1"
}

warn() {
    log "$COLOR_YELLOW" "WARN" "$1"
}

err() {
    log "$COLOR_RED" "ERR" "$1" >&2
}

info() {
    log "$COLOR_CYAN" "INFO" "$1"
}

die() {
    SWCTL_LAST_ERROR="$1"
    err "$1"
    exit 1
}

ensure_state_dirs() {
    mkdir -p "$SWCTL_REGISTRY_DIR" "$SWCTL_INFRA_DIR" "$SWCTL_TMP_DIR"
}

require_cmd() {
    local cmd="$1"
    command -v "$cmd" >/dev/null 2>&1 || die "Missing required command: $cmd"
}

compose() {
    if docker compose version >/dev/null 2>&1; then
        docker compose "$@"
        return
    fi

    if command -v docker-compose >/dev/null 2>&1; then
        docker-compose "$@"
        return
    fi

    die "Docker Compose is required. Install the Docker Compose plugin or docker-compose."
}


sanitize_slug() {
    printf '%s' "$1" \
        | tr '[:upper:]' '[:lower:]' \
        | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-{2,}/-/g'
}

sanitize_db_identifier() {
    printf '%s' "$1" \
        | tr '[:upper:]' '[:lower:]' \
        | sed -E 's/[^a-z0-9]+/_/g; s/^_+//; s/_+$//; s/_{2,}/_/g'
}

sanitize_router_id() {
    printf '%s' "$1" \
        | tr '[:upper:]' '[:lower:]' \
        | sed -E 's/[^a-z0-9]+/_/g; s/^_+//; s/_+$//; s/_{2,}/_/g'
}

resolve_path() {
    local base="$1"
    local target="$2"
    local dir=""
    local path_input=""
    local part=""
    local output=""
    local old_ifs="$IFS"
    local parts=()
    local stack=()
    local index=0

    if [[ "$target" = /* ]]; then
        printf '%s\n' "$target"
        return
    fi

    dir="$(cd "$base" && pwd -P)"
    path_input="${dir}/${target}"
    IFS='/'
    read -r -a parts <<< "$path_input"
    IFS="$old_ifs"

    for part in "${parts[@]}"; do
        case "$part" in
            ""|".")
                continue
                ;;
            "..")
                if [ "$index" -gt 0 ]; then
                    index=$((index - 1))
                    unset "stack[$index]"
                fi
                ;;
            *)
                stack[$index]="$part"
                index=$((index + 1))
                ;;
        esac
    done

    output="/"
    index=0
    while [ "$index" -lt "${#stack[@]}" ]; do
        output="${output}${stack[$index]}"
        if [ "$index" -lt $(( ${#stack[@]} - 1 )) ]; then
            output="${output}/"
        fi
        index=$((index + 1))
    done

    printf '%s\n' "$output"
}

find_config() {
    local dir="$PWD"

    while [ "$dir" != "/" ]; do
        if [ -f "$dir/.swctl.conf" ]; then
            printf '%s/.swctl.conf\n' "$dir"
            return 0
        fi
        dir="$(dirname "$dir")"
    done

    return 1
}

detect_runtime() {
    if [ -n "${SW_RUNTIME:-}" ]; then
        printf '%s\n' "$SW_RUNTIME"
        return
    fi
    if command -v orbctl >/dev/null 2>&1 && docker context show 2>/dev/null | grep -q orbstack; then
        printf 'orbstack\n'
        return
    fi
    printf 'traefik\n'
}

detect_template_path() {
    local runtime="${SW_RUNTIME:-traefik}"
    local orbstack_suffix=".orbstack"

    if [ -n "${SW_COMPOSE_TEMPLATE:-}" ]; then
        if [ -f "$SW_COMPOSE_TEMPLATE" ]; then
            printf '%s\n' "$SW_COMPOSE_TEMPLATE"
            return 0
        fi
        if [ -f "$PROJECT_ROOT/$SW_COMPOSE_TEMPLATE" ]; then
            printf '%s\n' "$PROJECT_ROOT/$SW_COMPOSE_TEMPLATE"
            return 0
        fi
    fi

    if [ "$runtime" = "orbstack" ]; then
        if [ -f "$PROJECT_ROOT/docker-compose.swctl.orbstack.yml" ]; then
            printf '%s/docker-compose.swctl.orbstack.yml\n' "$PROJECT_ROOT"
            return 0
        fi
        if [ -f "$SWCTL_TEMPLATE_DIR/docker-compose.swctl.orbstack.yml" ]; then
            printf '%s/docker-compose.swctl.orbstack.yml\n' "$SWCTL_TEMPLATE_DIR"
            return 0
        fi
    fi

    if [ -f "$PROJECT_ROOT/docker-compose.swctl.yml" ]; then
        printf '%s/docker-compose.swctl.yml\n' "$PROJECT_ROOT"
        return 0
    fi

    if [ -f "$SWCTL_TEMPLATE_DIR/docker-compose.swctl.yml" ]; then
        printf '%s/docker-compose.swctl.yml\n' "$SWCTL_TEMPLATE_DIR"
        return 0
    fi

    return 1
}

# Build the -f flag chain for docker compose: base template + project override + per-worktree override.
# Supports both SW_COMPOSE_* (from config) and COMPOSE_* (from metadata) variable names.
compose_file_args() {
    local base="${SW_COMPOSE_TEMPLATE:-${COMPOSE_TEMPLATE:-}}"
    local project_override="${SW_COMPOSE_PROJECT_OVERRIDE:-${COMPOSE_PROJECT_OVERRIDE:-}}"
    local volume_override="${COMPOSE_VOLUME_OVERRIDE:-}"
    printf '%s' "-f $base"
    [ -n "$project_override" ] && [ -f "$project_override" ] && printf ' %s' "-f $project_override"
    [ -n "$volume_override" ] && [ -f "$volume_override" ] && printf ' %s' "-f $volume_override"
}

load_project_config() {
    local config_path="${1:-}"

    if [ -z "$config_path" ]; then
        config_path="$(find_config)" || die "Could not locate .swctl.conf in the current directory tree."
    fi

    PROJECT_CONFIG="$config_path"
    PROJECT_ROOT="$(cd "$(dirname "$config_path")" && pwd -P)"

    # shellcheck disable=SC1090
    . "$config_path"

    SW_PROJECT="${SW_PROJECT:-$(basename "$PROJECT_ROOT")}"
    SW_PROJECT_SLUG="$(sanitize_slug "$SW_PROJECT")"
    SW_BASE_BRANCH="${SW_BASE_BRANCH:-main}"
    SW_DOMAIN_SUFFIX="${SW_DOMAIN_SUFFIX:-sw.localhost}"
    SW_WORKTREE_ROOT="${SW_WORKTREE_ROOT:-../_worktrees}"
    SW_WORKTREE_ROOT="$(resolve_path "$PROJECT_ROOT" "$SW_WORKTREE_ROOT")"
    SW_PHP_IMAGE="${SW_PHP_IMAGE:-ghcr.io/your-org/shopware-php:8.2-dev}"
    SW_DB_HOST="${SW_DB_HOST:-host.docker.internal}"
    SW_DB_PORT="${SW_DB_PORT:-3306}"
    SW_DB_ROOT_USER="${SW_DB_ROOT_USER:-root}"
    SW_DB_ROOT_PASSWORD="${SW_DB_ROOT_PASSWORD:-shopware}"
    SW_DB_NAME_PREFIX="${SW_DB_NAME_PREFIX:-$SW_PROJECT_SLUG}"
    SW_DB_SHARED_NAME="${SW_DB_SHARED_NAME:-${SW_PROJECT_SLUG}_shared}"
    SW_REDIS_URL="${SW_REDIS_URL:-redis://host.docker.internal:6379}"
    SW_MAILER_DSN="${SW_MAILER_DSN:-null://localhost}"
    SW_OPENSEARCH_URL="${SW_OPENSEARCH_URL:-}"
    SW_PROJECT_NETWORK="${SW_PROJECT_NETWORK:-trunk_default}"
    SW_BIN_CONSOLE="${SW_BIN_CONSOLE:-bin/console}"
    SW_APP_HTTP_PORT="${SW_APP_HTTP_PORT:-8000}"
    SW_TRAEFIK_NETWORK="${SW_TRAEFIK_NETWORK:-swctl-proxy}"
    SW_INFRA_TRAEFIK_CONTAINER="${SW_INFRA_TRAEFIK_CONTAINER:-swctl-traefik}"
    SW_INFRA_DB_CONTAINER="${SW_INFRA_DB_CONTAINER:-swctl-mariadb}"
    SW_INFRA_REDIS_CONTAINER="${SW_INFRA_REDIS_CONTAINER:-swctl-redis}"
    SW_INSTALL_ARGS="${SW_INSTALL_ARGS:---basic-setup --force --no-interaction}"
    SW_SHARED_DB_INSTALL_ARGS="${SW_SHARED_DB_INSTALL_ARGS:-$SW_INSTALL_ARGS}"
    SW_WORKTREE_PREFIX="${SW_WORKTREE_PREFIX:-$SW_PROJECT_SLUG}"
    SW_DOCKER_PLATFORM="${SW_DOCKER_PLATFORM:-}"
    SW_UID="${SW_UID:-$(id -u 2>/dev/null || printf '1000')}"
    SW_GID="${SW_GID:-$(id -g 2>/dev/null || printf '1000')}"
    SW_ENV_FILE_NAME="${SW_ENV_FILE_NAME:-.env.local}"
    SW_COMPOSER_ROOT_VERSION="${SW_COMPOSER_ROOT_VERSION:-}"
    SW_RUNTIME="$(detect_runtime)"
    SW_SERVICE_NAME="app"
    if [ "$SW_RUNTIME" = "orbstack" ]; then
        SW_SERVICE_NAME="web"
    fi
    SW_COMPOSE_TEMPLATE="$(detect_template_path)" || die "Could not find docker-compose.swctl.yml. Put it in the project root or export SWCTL_TEMPLATE_DIR."

    # Project-level compose override (optional)
    # Project-level compose override (optional, swctl-namespaced to avoid
    # conflicts with the project's own compose.override.yaml)
    SW_COMPOSE_PROJECT_OVERRIDE=""
    if [ -f "$PROJECT_ROOT/docker-compose.swctl.override.yml" ]; then
        SW_COMPOSE_PROJECT_OVERRIDE="$PROJECT_ROOT/docker-compose.swctl.override.yml"
    elif [ -f "$PROJECT_ROOT/docker-compose.swctl.override.yaml" ]; then
        SW_COMPOSE_PROJECT_OVERRIDE="$PROJECT_ROOT/docker-compose.swctl.override.yaml"
    fi

    auto_register_project
}

maybe_load_project_config() {
    local config_path=""
    if config_path="$(find_config 2>/dev/null)"; then
        load_project_config "$config_path"
        return 0
    fi
    return 1
}

timestamp_utc() {
    date -u '+%Y-%m-%dT%H:%M:%SZ'
}

instance_dir() {
    printf '%s/%s\n' "$SWCTL_REGISTRY_DIR" "$1"
}

instance_file() {
    printf '%s/%s/%s.env\n' "$SWCTL_REGISTRY_DIR" "$1" "$2"
}

list_instance_files() {
    local scope="${1:-all}"

    if [ "$scope" = "project" ] && [ -n "${SW_PROJECT_SLUG:-}" ]; then
        find "$(instance_dir "$SW_PROJECT_SLUG")" -type f -name '*.env' 2>/dev/null | sort
        return
    fi

    find "$SWCTL_REGISTRY_DIR" -type f -name '*.env' 2>/dev/null | sort
}

load_instance_metadata() {
    local file="$1"
    # shellcheck disable=SC1090
    . "$file"
}

