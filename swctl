#!/usr/bin/env bash
set -euo pipefail

# Raise FD limit for parallel worktree creation.
# Each create spawns many subprocesses (docker compose, docker exec, git, mysql).
# Running 4+ creates in parallel can exhaust the default soft limit (256 on macOS).
ulimit -n 65536 2>/dev/null || ulimit -n 10240 2>/dev/null || true

SWCTL_VERSION="0.5.9"

_swctl_resolve_script() {
    local src="${BASH_SOURCE[0]}"
    while [ -L "$src" ]; do
        local dir
        dir="$(cd "$(dirname "$src")" && pwd -P)"
        src="$(readlink "$src")"
        [[ "$src" != /* ]] && src="$dir/$src"
    done
    cd "$(dirname "$src")" && pwd -P
}
SCRIPT_DIR="$(_swctl_resolve_script)"
SWCTL_TEMPLATE_DIR="${SWCTL_TEMPLATE_DIR:-$SCRIPT_DIR}"
SWCTL_STATE_DIR="${SWCTL_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/swctl}"
SWCTL_REGISTRY_DIR="${SWCTL_REGISTRY_DIR:-$SWCTL_STATE_DIR/instances}"
SWCTL_INFRA_DIR="${SWCTL_INFRA_DIR:-$SWCTL_STATE_DIR/infra}"
SWCTL_PROJECTS_FILE="$SWCTL_STATE_DIR/projects.conf"
SWCTL_TMP_DIR="${TMPDIR:-/tmp}/swctl"

COLOR_RESET=""
COLOR_DIM=""
COLOR_RED=""
COLOR_GREEN=""
COLOR_YELLOW=""
COLOR_BLUE=""
COLOR_CYAN=""
COLOR_BOLD=""

if [ -t 1 ] && command -v tput >/dev/null 2>&1; then
    colors="$(tput colors 2>/dev/null || printf '0')"
    if [ "${colors:-0}" -ge 8 ]; then
        COLOR_RESET="$(tput sgr0)"
        # shellcheck disable=SC2034
        COLOR_DIM="$(tput dim)"
        COLOR_RED="$(tput setaf 1)"
        COLOR_GREEN="$(tput setaf 2)"
        COLOR_YELLOW="$(tput setaf 3)"
        COLOR_BLUE="$(tput setaf 4)"
        COLOR_CYAN="$(tput setaf 6)"
        COLOR_BOLD="$(tput bold)"
    fi
fi

log() {
    printf '%b[%s]%b %s\n' "$1" "$2" "$COLOR_RESET" "$3"
}

ok() {
    log "$COLOR_GREEN" "OK" "$1"
}

warn() {
    log "$COLOR_YELLOW" "WARN" "$1"
}

err() {
    log "$COLOR_RED" "ERR" "$1" >&2
}

info() {
    log "$COLOR_CYAN" "INFO" "$1"
}

die() {
    SWCTL_LAST_ERROR="$1"
    err "$1"
    exit 1
}

ensure_state_dirs() {
    mkdir -p "$SWCTL_REGISTRY_DIR" "$SWCTL_INFRA_DIR" "$SWCTL_TMP_DIR"
}

require_cmd() {
    local cmd="$1"
    command -v "$cmd" >/dev/null 2>&1 || die "Missing required command: $cmd"
}

# Cooperative lock for parallel-safe operations.
# Usage: swctl_lock <name> <command...>
# Serializes concurrent access using mkdir (atomic on all filesystems, works on macOS + Linux).
swctl_lock() {
    local name="$1"; shift
    local lockdir="$SWCTL_TMP_DIR/.lock-${name}"
    mkdir -p "$SWCTL_TMP_DIR"

    local waited=0
    while ! mkdir "$lockdir" 2>/dev/null; do
        # Check for stale locks (process that created it crashed)
        if [ -f "$lockdir/pid" ]; then
            local lock_pid
            lock_pid="$(cat "$lockdir/pid" 2>/dev/null)" || true
            if [ -n "$lock_pid" ] && ! kill -0 "$lock_pid" 2>/dev/null; then
                warn "Removing stale lock '$name' (pid $lock_pid is dead)"
                rm -rf "$lockdir"
                continue
            fi
        fi
        if [ "$waited" -ge 120 ]; then
            warn "Lock timeout for '$name' after 120s — proceeding anyway"
            rm -rf "$lockdir"
            continue
        fi
        sleep 1
        waited=$((waited + 1))
    done
    # Record our PID for stale lock detection
    echo $$ > "$lockdir/pid"

    # Run the command, then release lock
    local rc=0
    "$@" || rc=$?
    rm -rf "$lockdir"
    return $rc
}

compose() {
    if docker compose version >/dev/null 2>&1; then
        docker compose "$@"
        return
    fi

    if command -v docker-compose >/dev/null 2>&1; then
        docker-compose "$@"
        return
    fi

    die "Docker Compose is required. Install the Docker Compose plugin or docker-compose."
}


sanitize_slug() {
    printf '%s' "$1" \
        | tr '[:upper:]' '[:lower:]' \
        | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-{2,}/-/g'
}

sanitize_db_identifier() {
    printf '%s' "$1" \
        | tr '[:upper:]' '[:lower:]' \
        | sed -E 's/[^a-z0-9]+/_/g; s/^_+//; s/_+$//; s/_{2,}/_/g'
}

# Resolve the per-instance database name that cmd_clean should drop.
# Extracted + testable because the inline logic has historically had a
# subtle orphan-creating bug: when metadata was written with an empty
# DB_NAME (e.g. pre-v0.5.8 resolve instances that used `swctl create
# --no-provision` and then provisioned via /api/stream/refresh without
# re-writing metadata), the drop branch was skipped entirely and the
# DB survived the clean, accumulating as `shopware_<N>` clutter on the
# mariadb server.
#
# Resolution order (first non-empty wins):
#   1. explicit (from metadata's DB_NAME= field)
#   2. fallback: sanitize("${prefix}_${issue}") — the convention used by
#      provision_database_and_app when it creates the DB (see line ~2607).
#
# Returns non-zero when none of those can produce a name — caller must
# skip the drop in that case (rather than dropping "shopware" by accident).
#
# Args:
#   $1 = explicit DB name (may be empty)
#   $2 = prefix (defaults to SW_DB_NAME_PREFIX / "shopware")
#   $3 = issue id  (defaults to ISSUE_ID)
#
# Zero-arg calls are the norm inside cmd_clean (they let the env-var
# defaults kick in).  The unit tests in tests/cleanup_db_name.bats
# exercise the arg form.  Shellcheck's SC2119/SC2120 would warn about
# "unused params" but that's a deliberate API choice here.
# shellcheck disable=SC2120
_resolve_cleanup_db_name() {
    local explicit="${1-${DB_NAME:-}}"
    local prefix="${2-${SW_DB_NAME_PREFIX:-shopware}}"
    local issue="${3-${ISSUE_ID:-}}"

    if [ -n "$explicit" ]; then
        printf '%s' "$explicit"
        return 0
    fi
    if [ -n "$issue" ] && [ -n "$prefix" ]; then
        sanitize_db_identifier "${prefix}_${issue}"
        return 0
    fi
    return 1
}

sanitize_router_id() {
    printf '%s' "$1" \
        | tr '[:upper:]' '[:lower:]' \
        | sed -E 's/[^a-z0-9]+/_/g; s/^_+//; s/_+$//; s/_{2,}/_/g'
}

resolve_path() {
    local base="$1"
    local target="$2"
    local dir=""
    local path_input=""
    local part=""
    local output=""
    local old_ifs="$IFS"
    local parts=()
    local stack=()
    local index=0

    if [[ "$target" = /* ]]; then
        printf '%s\n' "$target"
        return
    fi

    dir="$(cd "$base" && pwd -P)"
    path_input="${dir}/${target}"
    IFS='/'
    read -r -a parts <<< "$path_input"
    IFS="$old_ifs"

    for part in "${parts[@]}"; do
        case "$part" in
            ""|".")
                continue
                ;;
            "..")
                if [ "$index" -gt 0 ]; then
                    index=$((index - 1))
                    unset "stack[$index]"
                fi
                ;;
            *)
                stack[index]="$part"
                index=$((index + 1))
                ;;
        esac
    done

    output="/"
    index=0
    while [ "$index" -lt "${#stack[@]}" ]; do
        output="${output}${stack[$index]}"
        if [ "$index" -lt $(( ${#stack[@]} - 1 )) ]; then
            output="${output}/"
        fi
        index=$((index + 1))
    done

    printf '%s\n' "$output"
}

find_config() {
    local dir="$PWD"

    while [ "$dir" != "/" ]; do
        if [ -f "$dir/.swctl.conf" ]; then
            printf '%s/.swctl.conf\n' "$dir"
            return 0
        fi
        dir="$(dirname "$dir")"
    done

    return 1
}

detect_runtime() {
    if [ -n "${SW_RUNTIME:-}" ]; then
        printf '%s\n' "$SW_RUNTIME"
        return
    fi
    if command -v orbctl >/dev/null 2>&1 && docker context show 2>/dev/null | grep -q orbstack; then
        printf 'orbstack\n'
        return
    fi
    printf 'traefik\n'
}

# --- Workflow system ---

SWCTL_WORKFLOW_DIR=""       # Resolved path to active workflow directory
WORKFLOW_CONSOLE=""         # Console binary from workflow.yaml
WORKFLOW_PLUGIN_DIR=""      # Plugin directory from workflow.yaml
WORKFLOW_STATIC_PLUGIN_DIR="" # Static plugin directory
WORKFLOW_ENV_FILE=""        # Env file name from workflow.yaml

resolve_workflow_dir() {
    local workflow_name="${1:-shopware6}"

    # 1. Project-local workflows/
    if [ -n "${PROJECT_ROOT:-}" ] && [ -d "$PROJECT_ROOT/workflows/$workflow_name" ]; then
        printf '%s\n' "$PROJECT_ROOT/workflows/$workflow_name"
        return 0
    fi

    # 2. Bundled with swctl (pkgshare or script dir)
    if [ -d "$SWCTL_TEMPLATE_DIR/workflows/$workflow_name" ]; then
        printf '%s\n' "$SWCTL_TEMPLATE_DIR/workflows/$workflow_name"
        return 0
    fi

    # 3. User custom dir
    local user_dir="${XDG_CONFIG_HOME:-$HOME/.config}/swctl/workflows/$workflow_name"
    if [ -d "$user_dir" ]; then
        printf '%s\n' "$user_dir"
        return 0
    fi

    return 1
}

load_workflow() {
    local workflow_name="${SWCTL_WORKFLOW:-shopware6}"

    SWCTL_WORKFLOW_DIR="$(resolve_workflow_dir "$workflow_name")" \
        || die "Workflow '$workflow_name' not found. Searched: project workflows/, $SWCTL_TEMPLATE_DIR/workflows/, ~/.config/swctl/workflows/"

    local yaml_file="$SWCTL_WORKFLOW_DIR/workflow.yaml"
    if [ ! -f "$yaml_file" ]; then
        warn "No workflow.yaml in '$SWCTL_WORKFLOW_DIR'. Using defaults."
        WORKFLOW_CONSOLE="${SW_BIN_CONSOLE:-bin/console}"
        WORKFLOW_PLUGIN_DIR="custom/plugins"
        WORKFLOW_STATIC_PLUGIN_DIR="custom/static-plugins"
        WORKFLOW_ENV_FILE=".env.local"
        return
    fi

    # Parse workflow.yaml via python3 (same approach as read_plugin_deps)
    eval "$(python3 -c "
import yaml, sys
with open(sys.argv[1]) as f:
    data = yaml.safe_load(f) or {}
print('WORKFLOW_CONSOLE=\"{}\"'.format(data.get('console', 'bin/console')))
plugins = data.get('plugins', {})
print('WORKFLOW_PLUGIN_DIR=\"{}\"'.format(plugins.get('directory', 'custom/plugins')))
print('WORKFLOW_STATIC_PLUGIN_DIR=\"{}\"'.format(plugins.get('static_directory', 'custom/static-plugins')))
print('WORKFLOW_ENV_FILE=\"{}\"'.format(data.get('env_file', '.env.local')))
" "$yaml_file" 2>/dev/null)" || {
        warn "Failed to parse $yaml_file. Using defaults."
        WORKFLOW_CONSOLE="${SW_BIN_CONSOLE:-bin/console}"
        WORKFLOW_PLUGIN_DIR="custom/plugins"
        # shellcheck disable=SC2034
        WORKFLOW_STATIC_PLUGIN_DIR="custom/static-plugins"
        # shellcheck disable=SC2034
        WORKFLOW_ENV_FILE=".env.local"
    }

    # Allow .swctl.conf to override workflow defaults
    [ -n "${SW_BIN_CONSOLE:-}" ] && WORKFLOW_CONSOLE="$SW_BIN_CONSOLE"
    # shellcheck disable=SC2034
    [ -n "${SW_ENV_FILE_NAME:-}" ] && WORKFLOW_ENV_FILE="$SW_ENV_FILE_NAME"

    export WORKFLOW_CONSOLE
}

run_workflow_hook() {
    local hook_name="$1"
    shift

    if [ -z "${SWCTL_WORKFLOW_DIR:-}" ]; then
        warn "No workflow loaded. Skipping hook '$hook_name'."
        return 0
    fi

    local hook_file="$SWCTL_WORKFLOW_DIR/hooks/${hook_name}.sh"
    if [ ! -f "$hook_file" ]; then
        # Hook not defined — skip silently
        return 0
    fi

    # Source the hook so it has access to all swctl functions and variables
    # shellcheck disable=SC1090
    . "$hook_file"
}

list_available_workflows() {
    local -a dirs=()

    # Bundled workflows
    if [ -d "$SWCTL_TEMPLATE_DIR/workflows" ]; then
        dirs+=("$SWCTL_TEMPLATE_DIR/workflows")
    fi

    # User custom workflows
    local user_dir="${XDG_CONFIG_HOME:-$HOME/.config}/swctl/workflows"
    if [ -d "$user_dir" ]; then
        dirs+=("$user_dir")
    fi

    local seen=""
    for d in "${dirs[@]}"; do
        for wf in "$d"/*/workflow.yaml; do
            [ -f "$wf" ] || continue
            local name
            name="$(basename "$(dirname "$wf")")"
            # Deduplicate (bundled takes priority)
            if ! printf '%s\n' "$seen" | grep -qxF "$name"; then
                seen="$seen
$name"
                local desc=""
                desc="$(python3 -c "
import yaml, sys
with open(sys.argv[1]) as f:
    data = yaml.safe_load(f) or {}
print(data.get('description', ''))
" "$wf" 2>/dev/null)" || desc=""
                printf '%s\t%s\n' "$name" "$desc"
            fi
        done
    done
}

detect_template_path() {
    local runtime="${SW_RUNTIME:-traefik}"
    # shellcheck disable=SC2034
    local orbstack_suffix=".orbstack"

    if [ -n "${SW_COMPOSE_TEMPLATE:-}" ]; then
        if [ -f "$SW_COMPOSE_TEMPLATE" ]; then
            printf '%s\n' "$SW_COMPOSE_TEMPLATE"
            return 0
        fi
        if [ -f "$PROJECT_ROOT/$SW_COMPOSE_TEMPLATE" ]; then
            printf '%s\n' "$PROJECT_ROOT/$SW_COMPOSE_TEMPLATE"
            return 0
        fi
    fi

    if [ "$runtime" = "orbstack" ]; then
        if [ -f "$PROJECT_ROOT/docker-compose.swctl.orbstack.yml" ]; then
            printf '%s/docker-compose.swctl.orbstack.yml\n' "$PROJECT_ROOT"
            return 0
        fi
        # Workflow dir
        if [ -n "${SWCTL_WORKFLOW_DIR:-}" ] && [ -f "$SWCTL_WORKFLOW_DIR/docker-compose.orbstack.yml" ]; then
            printf '%s/docker-compose.orbstack.yml\n' "$SWCTL_WORKFLOW_DIR"
            return 0
        fi
        if [ -f "$SWCTL_TEMPLATE_DIR/docker-compose.swctl.orbstack.yml" ]; then
            printf '%s/docker-compose.swctl.orbstack.yml\n' "$SWCTL_TEMPLATE_DIR"
            return 0
        fi
    fi

    if [ -f "$PROJECT_ROOT/docker-compose.swctl.yml" ]; then
        printf '%s/docker-compose.swctl.yml\n' "$PROJECT_ROOT"
        return 0
    fi

    # Workflow dir
    if [ -n "${SWCTL_WORKFLOW_DIR:-}" ] && [ -f "$SWCTL_WORKFLOW_DIR/docker-compose.yml" ]; then
        printf '%s/docker-compose.yml\n' "$SWCTL_WORKFLOW_DIR"
        return 0
    fi

    if [ -f "$SWCTL_TEMPLATE_DIR/docker-compose.swctl.yml" ]; then
        printf '%s/docker-compose.swctl.yml\n' "$SWCTL_TEMPLATE_DIR"
        return 0
    fi

    return 1
}

# Build the -f flag chain for docker compose: base template + project override + per-worktree override.
# Supports both SW_COMPOSE_* (from config) and COMPOSE_* (from metadata) variable names.
compose_file_args() {
    local base="${SW_COMPOSE_TEMPLATE:-${COMPOSE_TEMPLATE:-}}"
    local project_override="${SW_COMPOSE_PROJECT_OVERRIDE:-${COMPOSE_PROJECT_OVERRIDE:-}}"
    local volume_override="${COMPOSE_VOLUME_OVERRIDE:-}"
    printf '%s' "-f $base"
    [ -n "$project_override" ] && [ -f "$project_override" ] && printf ' %s' "-f $project_override"
    [ -n "$volume_override" ] && [ -f "$volume_override" ] && printf ' %s' "-f $volume_override"
}

load_project_config() {
    local config_path="${1:-}"

    if [ -z "$config_path" ]; then
        config_path="$(find_config)" || die "Could not locate .swctl.conf in the current directory tree."
    fi

    PROJECT_CONFIG="$config_path"
    PROJECT_ROOT="$(cd "$(dirname "$config_path")" && pwd -P)"

    # shellcheck disable=SC1090
    . "$config_path"

    SW_PROJECT="${SW_PROJECT:-$(basename "$PROJECT_ROOT")}"
    SW_PROJECT_SLUG="$(sanitize_slug "$SW_PROJECT")"
    SW_BASE_BRANCH="${SW_BASE_BRANCH:-main}"
    SW_DOMAIN_SUFFIX="${SW_DOMAIN_SUFFIX:-sw.localhost}"
    SW_WORKTREE_ROOT="${SW_WORKTREE_ROOT:-../_worktrees}"
    SW_WORKTREE_ROOT="$(resolve_path "$PROJECT_ROOT" "$SW_WORKTREE_ROOT")"
    SW_PHP_IMAGE="${SW_PHP_IMAGE:-ghcr.io/your-org/shopware-php:8.2-dev}"
    SW_DB_HOST="${SW_DB_HOST:-host.docker.internal}"
    SW_DB_PORT="${SW_DB_PORT:-3306}"
    SW_DB_ROOT_USER="${SW_DB_ROOT_USER:-root}"
    SW_DB_ROOT_PASSWORD="${SW_DB_ROOT_PASSWORD:-shopware}"
    SW_DB_NAME_PREFIX="${SW_DB_NAME_PREFIX:-$SW_PROJECT_SLUG}"
    SW_DB_SHARED_NAME="${SW_DB_SHARED_NAME:-${SW_PROJECT_SLUG}_shared}"
    SW_REDIS_URL="${SW_REDIS_URL:-redis://host.docker.internal:6379}"
    SW_MAILER_DSN="${SW_MAILER_DSN:-null://localhost}"
    SW_OPENSEARCH_URL="${SW_OPENSEARCH_URL:-}"
    SW_PROJECT_NETWORK="${SW_PROJECT_NETWORK:-trunk_default}"
    SW_BIN_CONSOLE="${SW_BIN_CONSOLE:-bin/console}"
    SW_APP_HTTP_PORT="${SW_APP_HTTP_PORT:-8000}"
    SW_TRAEFIK_NETWORK="${SW_TRAEFIK_NETWORK:-swctl-proxy}"
    SW_INFRA_TRAEFIK_CONTAINER="${SW_INFRA_TRAEFIK_CONTAINER:-swctl-traefik}"
    SW_INFRA_DB_CONTAINER="${SW_INFRA_DB_CONTAINER:-swctl-mariadb}"
    SW_INFRA_REDIS_CONTAINER="${SW_INFRA_REDIS_CONTAINER:-swctl-redis}"
    SW_INSTALL_ARGS="${SW_INSTALL_ARGS:---basic-setup --force --no-interaction}"
    SW_SHARED_DB_INSTALL_ARGS="${SW_SHARED_DB_INSTALL_ARGS:-$SW_INSTALL_ARGS}"
    SW_WORKTREE_PREFIX="${SW_WORKTREE_PREFIX:-$SW_PROJECT_SLUG}"
    SW_DOCKER_PLATFORM="${SW_DOCKER_PLATFORM:-}"
    SW_UID="${SW_UID:-$(id -u 2>/dev/null || printf '1000')}"
    SW_GID="${SW_GID:-$(id -g 2>/dev/null || printf '1000')}"
    SW_ENV_FILE_NAME="${SW_ENV_FILE_NAME:-.env.local}"
    SW_COMPOSER_ROOT_VERSION="${SW_COMPOSER_ROOT_VERSION:-}"
    SW_RUNTIME="$(detect_runtime)"
    SW_SERVICE_NAME="app"
    if [ "$SW_RUNTIME" = "orbstack" ]; then
        SW_SERVICE_NAME="web"
    fi
    # Load workflow (must be after PROJECT_ROOT and SW_BIN_CONSOLE are set)
    SWCTL_WORKFLOW="${SWCTL_WORKFLOW:-shopware6}"
    load_workflow

    SW_COMPOSE_TEMPLATE="$(detect_template_path)" || die "Could not find docker-compose template. Put it in the project root, workflow dir, or export SWCTL_TEMPLATE_DIR."

    # Project-level compose override (optional)
    # Project-level compose override (optional, swctl-namespaced to avoid
    # conflicts with the project's own compose.override.yaml)
    SW_COMPOSE_PROJECT_OVERRIDE=""
    if [ -f "$PROJECT_ROOT/docker-compose.swctl.override.yml" ]; then
        SW_COMPOSE_PROJECT_OVERRIDE="$PROJECT_ROOT/docker-compose.swctl.override.yml"
    elif [ -f "$PROJECT_ROOT/docker-compose.swctl.override.yaml" ]; then
        SW_COMPOSE_PROJECT_OVERRIDE="$PROJECT_ROOT/docker-compose.swctl.override.yaml"
    fi

    auto_register_project
}

maybe_load_project_config() {
    local config_path=""
    if config_path="$(find_config 2>/dev/null)"; then
        load_project_config "$config_path"
        return 0
    fi
    return 1
}

timestamp_utc() {
    date -u '+%Y-%m-%dT%H:%M:%SZ'
}

instance_dir() {
    printf '%s/%s\n' "$SWCTL_REGISTRY_DIR" "$1"
}

instance_file() {
    printf '%s/%s/%s.env\n' "$SWCTL_REGISTRY_DIR" "$1" "$2"
}

list_instance_files() {
    local scope="${1:-all}"

    if [ "$scope" = "project" ] && [ -n "${SW_PROJECT_SLUG:-}" ]; then
        # Include both direct project instances AND plugin instances whose
        # parent project matches (plugin-external stores PROJECT_SLUG=<parent>).
        grep -rl "^PROJECT_SLUG=${SW_PROJECT_SLUG}$" "$SWCTL_REGISTRY_DIR" 2>/dev/null \
            | grep '\.env$' | sort
        return
    fi

    find "$SWCTL_REGISTRY_DIR" -type f -name '*.env' 2>/dev/null | sort
}

load_instance_metadata() {
    local file="$1"
    # shellcheck disable=SC1090
    . "$file"
    # Backfill: pre-v0.5.7 instances don't have RESOLVE_BACKEND set.
    # They were all driven by Claude (the only backend at the time),
    # so default to claude.  Live value overrides if metadata was
    # written by a newer swctl.
    RESOLVE_BACKEND="${RESOLVE_BACKEND:-claude}"
}

write_metadata() {
    local meta_file="$1"

    mkdir -p "$(dirname "$meta_file")"
    {
        printf 'SWCTL_META_VERSION=%q\n' "2"
        printf 'ISSUE=%q\n' "${ISSUE:-}"
        printf 'ISSUE_ID=%q\n' "${ISSUE_ID:-}"
        printf 'PROJECT=%q\n' "${SW_PROJECT:-}"
        printf 'PROJECT_SLUG=%q\n' "${SW_PROJECT_SLUG:-}"
        printf 'PROJECT_ROOT=%q\n' "${PROJECT_ROOT:-}"
        printf 'CONFIG_PATH=%q\n' "${PROJECT_CONFIG:-}"
        printf 'BRANCH=%q\n' "${BRANCH:-}"
        printf 'BASE_REF=%q\n' "${BASE_REF:-}"
        printf 'WORKTREE_PATH=%q\n' "${WORKTREE_PATH:-}"
        printf 'WORKTREE_ID=%q\n' "${WORKTREE_ID:-}"
        printf 'DOMAIN=%q\n' "${DOMAIN:-}"
        printf 'APP_URL=%q\n' "${APP_URL:-}"
        printf 'DB_NAME=%q\n' "${DB_NAME:-}"
        printf 'DB_STATE=%q\n' "${DB_STATE:-}"
        printf 'COMPOSE_PROJECT=%q\n' "${COMPOSE_PROJECT:-}"
        printf 'COMPOSE_ENV_FILE=%q\n' "${COMPOSE_ENV_FILE:-}"
        printf 'COMPOSE_TEMPLATE=%q\n' "${SW_COMPOSE_TEMPLATE:-}"
        printf 'COMPOSE_PROJECT_OVERRIDE=%q\n' "${SW_COMPOSE_PROJECT_OVERRIDE:-}"
        printf 'COMPOSE_VOLUME_OVERRIDE=%q\n' "${COMPOSE_VOLUME_OVERRIDE:-}"
        printf 'VENDOR_VOLUME=%q\n' "${VENDOR_VOLUME:-}"
        printf 'NODE_MODULES_VOLUME=%q\n' "${NODE_MODULES_VOLUME:-}"
        printf 'ADMIN_NM_VOLUME=%q\n' "${ADMIN_NM_VOLUME:-}"
        printf 'STOREFRONT_NM_VOLUME=%q\n' "${STOREFRONT_NM_VOLUME:-}"
        printf 'MIGRATION_CHANGES=%q\n' "${MIGRATION_CHANGES:-0}"
        printf 'ENTITY_CHANGES=%q\n' "${ENTITY_CHANGES:-0}"
        printf 'ADMIN_CHANGES=%q\n' "${ADMIN_CHANGES:-0}"
        printf 'STOREFRONT_CHANGES=%q\n' "${STOREFRONT_CHANGES:-0}"
        printf 'COMPOSER_CHANGES=%q\n' "${COMPOSER_CHANGES:-0}"
        printf 'PACKAGE_CHANGES=%q\n' "${PACKAGE_CHANGES:-0}"
        printf 'BACKEND_CHANGES=%q\n' "${BACKEND_CHANGES:-0}"
        printf 'FRONTEND_CHANGES=%q\n' "${FRONTEND_CHANGES:-0}"
        printf 'SWCTL_MODE=%q\n' "${SWCTL_MODE:-dev}"
        printf 'PROJECT_TYPE=%q\n' "${PROJECT_TYPE:-platform}"
        printf 'PLUGIN_NAME=%q\n' "${PLUGIN_NAME:-}"
        printf 'LINKED_PLUGINS=%q\n' "${LINKED_PLUGINS:-}"
        printf 'PLUGIN_WORKTREE_PATHS=%q\n' "${PLUGIN_WORKTREE_PATHS:-}"
