render_tui_menu() {
    printf '%s\n' "[1] Create worktree   [2] Instance detail   [3] Exec command"
    printf '%s\n' "[4] Logs (follow)     [5] Stop container    [6] Start container"
    printf '%s\n' "[7] Restart           [8] Refresh (pull)    [9] Switch mode"
    printf '%s\n' "[0] Clean worktree    [o] Open in browser   [d] Live dashboard"
    printf '%s\n' "[b] Batch create      [i] Init infra        [r] Reload"
    printf '%s\n' "[q] Quit"
    printf '\n'
