#!/usr/bin/env bash
set -euo pipefail

SWCTL_VERSION="0.2.0"

_swctl_resolve_script() {
    local src="${BASH_SOURCE[0]}"
    while [ -L "$src" ]; do
        local dir
        dir="$(cd "$(dirname "$src")" && pwd -P)"
        src="$(readlink "$src")"
        [[ "$src" != /* ]] && src="$dir/$src"
    done
    cd "$(dirname "$src")" && pwd -P
}
SCRIPT_DIR="$(_swctl_resolve_script)"
SWCTL_TEMPLATE_DIR="${SWCTL_TEMPLATE_DIR:-$SCRIPT_DIR}"
SWCTL_STATE_DIR="${SWCTL_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/swctl}"
SWCTL_REGISTRY_DIR="$SWCTL_STATE_DIR/instances"
SWCTL_INFRA_DIR="$SWCTL_STATE_DIR/infra"
SWCTL_TMP_DIR="${TMPDIR:-/tmp}/swctl"

COLOR_RESET=""
COLOR_DIM=""
COLOR_RED=""
COLOR_GREEN=""
COLOR_YELLOW=""
COLOR_BLUE=""
COLOR_CYAN=""
COLOR_BOLD=""

if [ -t 1 ] && command -v tput >/dev/null 2>&1; then
    colors="$(tput colors 2>/dev/null || printf '0')"
    if [ "${colors:-0}" -ge 8 ]; then
        COLOR_RESET="$(tput sgr0)"
        COLOR_DIM="$(tput dim)"
        COLOR_RED="$(tput setaf 1)"
        COLOR_GREEN="$(tput setaf 2)"
        COLOR_YELLOW="$(tput setaf 3)"
        COLOR_BLUE="$(tput setaf 4)"
        COLOR_CYAN="$(tput setaf 6)"
        COLOR_BOLD="$(tput bold)"
    fi
fi

log() {
    printf '%b[%s]%b %s\n' "$1" "$2" "$COLOR_RESET" "$3"
}

ok() {
    log "$COLOR_GREEN" "OK" "$1"
}

warn() {
    log "$COLOR_YELLOW" "WARN" "$1"
}

err() {
    log "$COLOR_RED" "ERR" "$1" >&2
}

info() {
    log "$COLOR_CYAN" "INFO" "$1"
}

die() {
    err "$1"
    exit 1
}

ensure_state_dirs() {
    mkdir -p "$SWCTL_REGISTRY_DIR" "$SWCTL_INFRA_DIR" "$SWCTL_TMP_DIR"
}

require_cmd() {
    local cmd="$1"
    command -v "$cmd" >/dev/null 2>&1 || die "Missing required command: $cmd"
}

compose() {
    if docker compose version >/dev/null 2>&1; then
        docker compose "$@"
        return
    fi

    if command -v docker-compose >/dev/null 2>&1; then
        docker-compose "$@"
        return
    fi

    die "Docker Compose is required. Install the Docker Compose plugin or docker-compose."
}


sanitize_slug() {
    printf '%s' "$1" \
        | tr '[:upper:]' '[:lower:]' \
        | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-{2,}/-/g'
}

sanitize_db_identifier() {
    printf '%s' "$1" \
        | tr '[:upper:]' '[:lower:]' \
        | sed -E 's/[^a-z0-9]+/_/g; s/^_+//; s/_+$//; s/_{2,}/_/g'
}

sanitize_router_id() {
    printf '%s' "$1" \
        | tr '[:upper:]' '[:lower:]' \
        | sed -E 's/[^a-z0-9]+/_/g; s/^_+//; s/_+$//; s/_{2,}/_/g'
}

resolve_path() {
    local base="$1"
    local target="$2"
    local dir=""
    local path_input=""
    local part=""
    local output=""
    local old_ifs="$IFS"
    local parts=()
    local stack=()
    local index=0

    if [[ "$target" = /* ]]; then
        printf '%s\n' "$target"
        return
    fi

    dir="$(cd "$base" && pwd -P)"
    path_input="${dir}/${target}"
    IFS='/'
    read -r -a parts <<< "$path_input"
    IFS="$old_ifs"

    for part in "${parts[@]}"; do
        case "$part" in
            ""|".")
                continue
                ;;
            "..")
                if [ "$index" -gt 0 ]; then
                    index=$((index - 1))
                    unset "stack[$index]"
                fi
                ;;
            *)
                stack[$index]="$part"
                index=$((index + 1))
                ;;
        esac
    done

    output="/"
    index=0
    while [ "$index" -lt "${#stack[@]}" ]; do
        output="${output}${stack[$index]}"
        if [ "$index" -lt $(( ${#stack[@]} - 1 )) ]; then
            output="${output}/"
        fi
        index=$((index + 1))
    done

    printf '%s\n' "$output"
}

find_config() {
    local dir="$PWD"

    while [ "$dir" != "/" ]; do
        if [ -f "$dir/.swctl.conf" ]; then
            printf '%s/.swctl.conf\n' "$dir"
            return 0
        fi
        dir="$(dirname "$dir")"
    done

    return 1
}

detect_runtime() {
    if [ -n "${SW_RUNTIME:-}" ]; then
        printf '%s\n' "$SW_RUNTIME"
        return
    fi
    if command -v orbctl >/dev/null 2>&1 && docker context show 2>/dev/null | grep -q orbstack; then
        printf 'orbstack\n'
        return
    fi
    printf 'traefik\n'
}

detect_template_path() {
    local runtime="${SW_RUNTIME:-traefik}"
    local orbstack_suffix=".orbstack"

    if [ -n "${SW_COMPOSE_TEMPLATE:-}" ]; then
        if [ -f "$SW_COMPOSE_TEMPLATE" ]; then
            printf '%s\n' "$SW_COMPOSE_TEMPLATE"
            return 0
        fi
        if [ -f "$PROJECT_ROOT/$SW_COMPOSE_TEMPLATE" ]; then
            printf '%s\n' "$PROJECT_ROOT/$SW_COMPOSE_TEMPLATE"
            return 0
        fi
    fi

    if [ "$runtime" = "orbstack" ]; then
        if [ -f "$PROJECT_ROOT/docker-compose.swctl.orbstack.yml" ]; then
            printf '%s/docker-compose.swctl.orbstack.yml\n' "$PROJECT_ROOT"
            return 0
        fi
        if [ -f "$SWCTL_TEMPLATE_DIR/docker-compose.swctl.orbstack.yml" ]; then
            printf '%s/docker-compose.swctl.orbstack.yml\n' "$SWCTL_TEMPLATE_DIR"
            return 0
        fi
    fi

    if [ -f "$PROJECT_ROOT/docker-compose.swctl.yml" ]; then
        printf '%s/docker-compose.swctl.yml\n' "$PROJECT_ROOT"
        return 0
    fi

    if [ -f "$SWCTL_TEMPLATE_DIR/docker-compose.swctl.yml" ]; then
        printf '%s/docker-compose.swctl.yml\n' "$SWCTL_TEMPLATE_DIR"
        return 0
    fi

    return 1
}

load_project_config() {
    local config_path="${1:-}"

    if [ -z "$config_path" ]; then
        config_path="$(find_config)" || die "Could not locate .swctl.conf in the current directory tree."
    fi

    PROJECT_CONFIG="$config_path"
    PROJECT_ROOT="$(cd "$(dirname "$config_path")" && pwd -P)"

    # shellcheck disable=SC1090
    . "$config_path"

    SW_PROJECT="${SW_PROJECT:-$(basename "$PROJECT_ROOT")}"
    SW_PROJECT_SLUG="$(sanitize_slug "$SW_PROJECT")"
    SW_BASE_BRANCH="${SW_BASE_BRANCH:-main}"
    SW_DOMAIN_SUFFIX="${SW_DOMAIN_SUFFIX:-sw.localhost}"
    SW_WORKTREE_ROOT="${SW_WORKTREE_ROOT:-../_worktrees}"
    SW_WORKTREE_ROOT="$(resolve_path "$PROJECT_ROOT" "$SW_WORKTREE_ROOT")"
    SW_PHP_IMAGE="${SW_PHP_IMAGE:-ghcr.io/your-org/shopware-php:8.2-dev}"
    SW_DB_HOST="${SW_DB_HOST:-host.docker.internal}"
    SW_DB_PORT="${SW_DB_PORT:-3306}"
    SW_DB_ROOT_USER="${SW_DB_ROOT_USER:-root}"
    SW_DB_ROOT_PASSWORD="${SW_DB_ROOT_PASSWORD:-shopware}"
    SW_DB_NAME_PREFIX="${SW_DB_NAME_PREFIX:-$SW_PROJECT_SLUG}"
    SW_DB_SHARED_NAME="${SW_DB_SHARED_NAME:-${SW_PROJECT_SLUG}_shared}"
    SW_REDIS_URL="${SW_REDIS_URL:-redis://host.docker.internal:6379}"
    SW_MAILER_DSN="${SW_MAILER_DSN:-null://localhost}"
    SW_OPENSEARCH_URL="${SW_OPENSEARCH_URL:-}"
    SW_TRUNK_NETWORK="${SW_TRUNK_NETWORK:-trunk_default}"
    SW_BIN_CONSOLE="${SW_BIN_CONSOLE:-bin/console}"
    SW_APP_HTTP_PORT="${SW_APP_HTTP_PORT:-8000}"
    SW_TRAEFIK_NETWORK="${SW_TRAEFIK_NETWORK:-swctl-proxy}"
    SW_INFRA_TRAEFIK_CONTAINER="${SW_INFRA_TRAEFIK_CONTAINER:-swctl-traefik}"
    SW_INFRA_DB_CONTAINER="${SW_INFRA_DB_CONTAINER:-swctl-mariadb}"
    SW_INFRA_REDIS_CONTAINER="${SW_INFRA_REDIS_CONTAINER:-swctl-redis}"
    SW_INSTALL_ARGS="${SW_INSTALL_ARGS:---basic-setup --force --no-interaction}"
    SW_SHARED_DB_INSTALL_ARGS="${SW_SHARED_DB_INSTALL_ARGS:-$SW_INSTALL_ARGS}"
    SW_WORKTREE_PREFIX="${SW_WORKTREE_PREFIX:-$SW_PROJECT_SLUG}"
    SW_DOCKER_PLATFORM="${SW_DOCKER_PLATFORM:-}"
    SW_UID="${SW_UID:-$(id -u 2>/dev/null || printf '1000')}"
    SW_GID="${SW_GID:-$(id -g 2>/dev/null || printf '1000')}"
    SW_ENV_FILE_NAME="${SW_ENV_FILE_NAME:-.env.local}"
    SW_COMPOSER_ROOT_VERSION="${SW_COMPOSER_ROOT_VERSION:-}"
    SW_RUNTIME="$(detect_runtime)"
    SW_SERVICE_NAME="app"
    if [ "$SW_RUNTIME" = "orbstack" ]; then
        SW_SERVICE_NAME="web"
    fi
    SW_COMPOSE_TEMPLATE="$(detect_template_path)" || die "Could not find docker-compose.swctl.yml. Put it in the project root or export SWCTL_TEMPLATE_DIR."
}

maybe_load_project_config() {
    local config_path=""
    if config_path="$(find_config 2>/dev/null)"; then
        load_project_config "$config_path"
        return 0
    fi
    return 1
}

timestamp_utc() {
    date -u '+%Y-%m-%dT%H:%M:%SZ'
}

instance_dir() {
    printf '%s/%s\n' "$SWCTL_REGISTRY_DIR" "$1"
}

instance_file() {
    printf '%s/%s/%s.env\n' "$SWCTL_REGISTRY_DIR" "$1" "$2"
}

list_instance_files() {
    local scope="${1:-all}"

    if [ "$scope" = "project" ] && [ -n "${SW_PROJECT_SLUG:-}" ]; then
        find "$(instance_dir "$SW_PROJECT_SLUG")" -type f -name '*.env' 2>/dev/null | sort
        return
    fi

    find "$SWCTL_REGISTRY_DIR" -type f -name '*.env' 2>/dev/null | sort
}

load_instance_metadata() {
    local file="$1"
    # shellcheck disable=SC1090
    . "$file"
}

write_metadata() {
    local meta_file="$1"

    mkdir -p "$(dirname "$meta_file")"
    {
        printf 'SWCTL_META_VERSION=%q\n' "1"
        printf 'ISSUE=%q\n' "$ISSUE"
        printf 'ISSUE_ID=%q\n' "$ISSUE_ID"
        printf 'PROJECT=%q\n' "$SW_PROJECT"
        printf 'PROJECT_SLUG=%q\n' "$SW_PROJECT_SLUG"
        printf 'PROJECT_ROOT=%q\n' "$PROJECT_ROOT"
        printf 'CONFIG_PATH=%q\n' "$PROJECT_CONFIG"
        printf 'BRANCH=%q\n' "$BRANCH"
        printf 'BASE_REF=%q\n' "$BASE_REF"
        printf 'WORKTREE_PATH=%q\n' "$WORKTREE_PATH"
        printf 'WORKTREE_ID=%q\n' "$WORKTREE_ID"
        printf 'DOMAIN=%q\n' "$DOMAIN"
        printf 'APP_URL=%q\n' "$APP_URL"
        printf 'DB_NAME=%q\n' "$DB_NAME"
        printf 'DB_STATE=%q\n' "$DB_STATE"
        printf 'COMPOSE_PROJECT=%q\n' "$COMPOSE_PROJECT"
        printf 'COMPOSE_ENV_FILE=%q\n' "$COMPOSE_ENV_FILE"
        printf 'COMPOSE_TEMPLATE=%q\n' "$SW_COMPOSE_TEMPLATE"
        printf 'COMPOSE_VOLUME_OVERRIDE=%q\n' "${COMPOSE_VOLUME_OVERRIDE:-}"
        printf 'VENDOR_VOLUME=%q\n' "$VENDOR_VOLUME"
        printf 'NODE_MODULES_VOLUME=%q\n' "$NODE_MODULES_VOLUME"
        printf 'MIGRATION_CHANGES=%q\n' "$MIGRATION_CHANGES"
        printf 'ENTITY_CHANGES=%q\n' "$ENTITY_CHANGES"
        printf 'ADMIN_CHANGES=%q\n' "${ADMIN_CHANGES:-0}"
        printf 'STOREFRONT_CHANGES=%q\n' "${STOREFRONT_CHANGES:-0}"
        printf 'COMPOSER_CHANGES=%q\n' "${COMPOSER_CHANGES:-0}"
        printf 'PACKAGE_CHANGES=%q\n' "${PACKAGE_CHANGES:-0}"
        printf 'BACKEND_CHANGES=%q\n' "${BACKEND_CHANGES:-0}"
        printf 'FRONTEND_CHANGES=%q\n' "$FRONTEND_CHANGES"
        printf 'SWCTL_MODE=%q\n' "${SWCTL_MODE:-dev}"
        printf 'CREATED_AT=%q\n' "$(timestamp_utc)"
    } >"$meta_file"
}

resolve_instance_file_by_issue() {
    local issue_input="$1"
    local issue_id
    local hits
    local first_hit

    issue_id="$(sanitize_slug "$issue_input")"
    hits=""

    while IFS= read -r file; do
        if [ -n "$hits" ]; then
            hits="${hits}
$file"
        else
            hits="$file"
        fi
    done <<EOF
$(find "$SWCTL_REGISTRY_DIR" -type f -path "*/${issue_id}.env" 2>/dev/null | sort)
EOF

    if [ -z "$hits" ]; then
        return 1
    fi

    first_hit="$(printf '%s\n' "$hits" | sed -n '1p')"
    if [ -n "${SW_PROJECT_SLUG:-}" ]; then
        if [ -f "$(instance_file "$SW_PROJECT_SLUG" "$issue_id")" ]; then
            printf '%s\n' "$(instance_file "$SW_PROJECT_SLUG" "$issue_id")"
            return 0
        fi
    fi

    if [ "$(printf '%s\n' "$hits" | grep -c '.' || true)" -gt 1 ]; then
        err "Issue '$issue_input' exists in multiple projects."
        printf '%s\n' "$hits" >&2
        return 1
    fi

    printf '%s\n' "$first_hit"
    return 0
}

container_exists() {
    docker ps -a --format '{{.Names}}' | grep -Fxq "$1"
}

container_running() {
    docker ps --format '{{.Names}}' | grep -Fxq "$1"
}

ensure_docker() {
    require_cmd docker
    docker info >/dev/null 2>&1 || die "Docker daemon is not reachable."
}

ensure_network() {
    if docker network inspect "$SW_TRAEFIK_NETWORK" >/dev/null 2>&1; then
        ok "Docker network '$SW_TRAEFIK_NETWORK' already exists."
    else
        docker network create "$SW_TRAEFIK_NETWORK" >/dev/null
        ok "Created Docker network '$SW_TRAEFIK_NETWORK'."
    fi
}

start_or_create_container() {
    local name="$1"
    shift

    if container_exists "$name"; then
        if container_running "$name"; then
            ok "Container '$name' is already running."
        else
            docker start "$name" >/dev/null
            ok "Started container '$name'."
        fi
    else
        docker run -d --name "$name" "$@" >/dev/null
        ok "Created container '$name'."
    fi
}

resolve_db_container() {
    # In OrbStack/trunk mode, find the DB container on the trunk network.
    if [ -n "${SW_TRUNK_NETWORK:-}" ] && [ "$(detect_runtime)" = "orbstack" ]; then
        local trunk_db
        trunk_db="$(docker ps --filter "network=${SW_TRUNK_NETWORK}" --filter "ancestor=mariadb" --format '{{.Names}}' 2>/dev/null | head -1)"
        if [ -z "$trunk_db" ]; then
            trunk_db="$(docker ps --filter "network=${SW_TRUNK_NETWORK}" --format '{{.Names}}' 2>/dev/null | grep -i database | head -1)"
        fi
        if [ -n "$trunk_db" ]; then
            printf '%s' "$trunk_db"
            return
        fi
    fi
    printf '%s' "${SW_INFRA_DB_CONTAINER:-swctl-mariadb}"
}

mysql_exec() {
    local sql="$1"
    local db_container
    db_container="$(resolve_db_container)"
    docker exec -i "$db_container" mariadb \
        -u "$SW_DB_ROOT_USER" \
        "-p$SW_DB_ROOT_PASSWORD" \
        -Nse "$sql"
}

mysql_db_exists() {
    local db_name="$1"
    local result
    result="$(mysql_exec "SELECT SCHEMA_NAME FROM information_schema.SCHEMATA WHERE SCHEMA_NAME='${db_name}';" 2>/dev/null || true)"
    [ "$result" = "$db_name" ]
}

mysql_db_has_tables() {
    local db_name="$1"
    local result
    result="$(mysql_exec "SELECT COUNT(*) FROM information_schema.TABLES WHERE TABLE_SCHEMA='${db_name}';" 2>/dev/null || printf '0')"
    [ "${result:-0}" -gt 0 ]
}

wait_for_mysql() {
    local attempt=0
    while [ "$attempt" -lt 30 ]; do
        if mysql_exec 'SELECT 1;' >/dev/null 2>&1; then
            ok "MariaDB is reachable on ${SW_DB_HOST}:${SW_DB_PORT}."
            return 0
        fi
        attempt=$((attempt + 1))
        sleep 2
    done

    die "MariaDB did not become ready in time."
}

init_infra() {
    ensure_docker
    maybe_load_project_config >/dev/null 2>&1 || true

    local runtime
    runtime="$(detect_runtime)"
    SW_TRAEFIK_NETWORK="${SW_TRAEFIK_NETWORK:-swctl-proxy}"
    SW_INFRA_TRAEFIK_CONTAINER="${SW_INFRA_TRAEFIK_CONTAINER:-swctl-traefik}"
    SW_INFRA_DB_CONTAINER="${SW_INFRA_DB_CONTAINER:-swctl-mariadb}"
    SW_INFRA_REDIS_CONTAINER="${SW_INFRA_REDIS_CONTAINER:-swctl-redis}"
    SW_DB_ROOT_USER="${SW_DB_ROOT_USER:-root}"
    SW_DB_ROOT_PASSWORD="${SW_DB_ROOT_PASSWORD:-shopware}"
    SW_DB_PORT="${SW_DB_PORT:-3306}"

    if [ "$runtime" = "traefik" ]; then
        ensure_network

        start_or_create_container "$SW_INFRA_TRAEFIK_CONTAINER" \
            --restart unless-stopped \
            --network "$SW_TRAEFIK_NETWORK" \
            -p 80:80 \
            -p 8080:8080 \
            -v /var/run/docker.sock:/var/run/docker.sock:ro \
            -v swctl-traefik-data:/data \
            traefik:v3.1 \
            --api.dashboard=true \
            --api.insecure=true \
            --providers.docker=true \
            --providers.docker.exposedByDefault=false \
            --entrypoints.web.address=:80
    else
        info "OrbStack detected. Skipping Traefik — OrbStack handles DNS routing."
    fi

    start_or_create_container "$SW_INFRA_DB_CONTAINER" \
        --restart unless-stopped \
        -p "${SW_DB_PORT}:3306" \
        -e "MARIADB_ROOT_PASSWORD=${SW_DB_ROOT_PASSWORD}" \
        -e "MARIADB_ROOT_HOST=%" \
        -v swctl-mariadb-data:/var/lib/mysql \
        mariadb:11

    start_or_create_container "$SW_INFRA_REDIS_CONTAINER" \
        --restart unless-stopped \
        -p 6379:6379 \
        -v swctl-redis-data:/data \
        redis:7-alpine \
        redis-server \
        --appendonly yes

    wait_for_mysql
    ok "Shared infrastructure is ready."
    if [ "$runtime" = "traefik" ]; then
        info "Traefik dashboard: http://localhost:8080"
    else
        info "Runtime: OrbStack (domains via *.orb.local)"
    fi
}

ensure_infra_ready() {
    ensure_docker
    local runtime
    runtime="$(detect_runtime)"

    if [ "$runtime" = "traefik" ]; then
        if ! docker network inspect "${SW_TRAEFIK_NETWORK:-swctl-proxy}" >/dev/null 2>&1 || \
            ! container_running "${SW_INFRA_TRAEFIK_CONTAINER:-swctl-traefik}" || \
            ! container_running "${SW_INFRA_DB_CONTAINER:-swctl-mariadb}" || \
            ! container_running "${SW_INFRA_REDIS_CONTAINER:-swctl-redis}"; then
            warn "Shared infrastructure is missing or stopped. Running 'swctl init'."
            init_infra
        fi
    else
        # OrbStack mode: worktrees connect to trunk's network.
        # Just verify the trunk network exists.
        if [ -n "${SW_TRUNK_NETWORK:-}" ] && docker network inspect "$SW_TRUNK_NETWORK" >/dev/null 2>&1; then
            ok "Trunk network '$SW_TRUNK_NETWORK' is available."
        else
            warn "Trunk network '${SW_TRUNK_NETWORK:-trunk_default}' not found. Start your trunk project first: cd $PROJECT_ROOT && docker compose up -d"
        fi
    fi
}

git_base_ref() {
    if git -C "$PROJECT_ROOT" rev-parse --verify "$SW_BASE_BRANCH" >/dev/null 2>&1; then
        printf '%s\n' "$SW_BASE_BRANCH"
        return 0
    fi

    if git -C "$PROJECT_ROOT" rev-parse --verify "origin/$SW_BASE_BRANCH" >/dev/null 2>&1; then
        printf '%s\n' "origin/$SW_BASE_BRANCH"
        return 0
    fi

    die "Base branch '$SW_BASE_BRANCH' was not found locally or under origin/."
}

check_branch_staleness() {
    local merge_base
    local commits_behind=0
    local days_behind=0

    merge_base="$(git -C "$WORKTREE_PATH" merge-base "$BASE_REF" HEAD 2>/dev/null || true)"
    [ -n "$merge_base" ] || return 0

    commits_behind="$(git -C "$WORKTREE_PATH" rev-list --count "$merge_base..${BASE_REF}" 2>/dev/null || printf '0')"
    days_behind="$(( ( $(date +%s) - $(git -C "$WORKTREE_PATH" log -1 --format=%ct "$merge_base" 2>/dev/null || printf '%s' "$(date +%s)") ) / 86400 ))"

    if [ "$commits_behind" -gt 100 ] || [ "$days_behind" -gt 14 ]; then
        warn "Branch '$BRANCH' is ${commits_behind} commits / ${days_behind} days behind '${SW_BASE_BRANCH}'."
        warn "The DB is cloned from current trunk — schema mismatches are likely."
        warn "Recommended: rebase the branch first, then create the worktree."
        warn "  cd $WORKTREE_PATH && git rebase $BASE_REF"
        warn "  OR ask the developer to rebase and push."
    elif [ "$commits_behind" -gt 20 ]; then
        info "Branch is ${commits_behind} commits behind '${SW_BASE_BRANCH}' (${days_behind} days). Consider rebasing for best results."
    fi
}

worktree_exists() {
    git -C "$PROJECT_ROOT" worktree list --porcelain | grep -Fxq "worktree $1"
}

create_worktree() {
    mkdir -p "$SW_WORKTREE_ROOT"

    if worktree_exists "$WORKTREE_PATH"; then
        ok "Git worktree already exists at '$WORKTREE_PATH'."
        return 0
    fi

    if [ -d "$WORKTREE_PATH" ]; then
        die "Target worktree path already exists and is not a registered Git worktree: $WORKTREE_PATH"
    fi

    if git -C "$PROJECT_ROOT" show-ref --verify --quiet "refs/heads/$BRANCH"; then
        git -C "$PROJECT_ROOT" worktree add "$WORKTREE_PATH" "$BRANCH"
        ok "Attached existing branch '$BRANCH' at '$WORKTREE_PATH'."
    else
        git -C "$PROJECT_ROOT" worktree add -b "$BRANCH" "$WORKTREE_PATH" "$BASE_REF"
        ok "Created worktree '$WORKTREE_PATH' from '$BASE_REF'."
    fi

    sync_lock_files
}

sync_lock_files() {
    local file=""
    for file in composer.lock pnpm-lock.yaml yarn.lock package-lock.json; do
        if [ -f "$PROJECT_ROOT/$file" ] && [ ! -f "$WORKTREE_PATH/$file" ]; then
            cp "$PROJECT_ROOT/$file" "$WORKTREE_PATH/$file"
            ok "Copied gitignored '$file' into worktree."
        fi
    done
}

sync_build_artifacts() {
    # Called AFTER count_changes so ADMIN_CHANGES/STOREFRONT_CHANGES are set.
    # Diff-driven: only sync what's needed. Use APFS clones when available.

    # Instead of syncing all of var/ (719MB, mostly stale cache), copy only the
    # 2 small JSON files that theme:compile and bundle:dump actually need.
    mkdir -p "$WORKTREE_PATH/var"
    for f in var/theme-files.json var/plugins.json; do
        [ -f "$PROJECT_ROOT/$f" ] && cp "$PROJECT_ROOT/$f" "$WORKTREE_PATH/$f" 2>/dev/null || true
    done

    # Build sync list based on what changed:
    # - Always: public/bundles (62MB), public/theme (168MB), storefront vendor/dist (small)
    # - Only if storefront changes: storefront node_modules (721MB)
    # - Only if admin changes: admin node_modules (1.1GB)
    local sync_dirs="public/theme public/bundles"
    sync_dirs="$sync_dirs src/Storefront/Resources/app/storefront/vendor"
    sync_dirs="$sync_dirs src/Storefront/Resources/app/storefront/dist"

    if [ "${STOREFRONT_CHANGES:-0}" -gt 0 ]; then
        sync_dirs="$sync_dirs src/Storefront/Resources/app/storefront/node_modules"
    fi
    if [ "${ADMIN_CHANGES:-0}" -gt 0 ]; then
        sync_dirs="$sync_dirs src/Administration/Resources/app/administration/node_modules"
    fi

    local dir
    for dir in $sync_dirs; do
        local src_dir="$PROJECT_ROOT/$dir"
        local dst_dir="$WORKTREE_PATH/$dir"
        if [ -d "$src_dir" ]; then
            local src_count dst_count
            src_count="$(find "$src_dir" -mindepth 1 -maxdepth 1 -not -name '.gitkeep' 2>/dev/null | wc -l | tr -d ' ')"
            dst_count="$( (find "$dst_dir" -mindepth 1 -maxdepth 1 -not -name '.gitkeep' 2>/dev/null || true) | wc -l | tr -d ' ')"
            if [ "$src_count" -gt 0 ] && [ "${dst_count:-0}" -lt "$src_count" ]; then
                mkdir -p "$dst_dir"
                # APFS clone (cp -c): instant copy-on-write. Clone to temp, swap in.
                local tmp_clone="${dst_dir}.swctl-clone"
                rm -rf "$tmp_clone"
                if cp -cR "$src_dir" "$tmp_clone" 2>/dev/null; then
                    rm -rf "$dst_dir"
                    mv "$tmp_clone" "$dst_dir"
                else
                    rm -rf "$tmp_clone" 2>/dev/null || true
                    # Fallback: rsync or regular copy
                    mkdir -p "$dst_dir"
                    if command -v rsync >/dev/null 2>&1; then
                        rsync -a "$src_dir/" "$dst_dir/" 2>/dev/null || true
                    else
                        cp -R "$src_dir"/* "$dst_dir"/ 2>/dev/null || true
                    fi
                fi
                ok "Synced '$dir/'."
            fi
        fi
    done
}

count_changes() {
    local diff_files="$1"
    MIGRATION_CHANGES="$(printf '%s\n' "$diff_files" | grep -Ec '(^|/)Migrations?/' || true)"
    ENTITY_CHANGES="$(printf '%s\n' "$diff_files" | grep -Ec '(^|/)Entity/' || true)"
    ADMIN_CHANGES="$(printf '%s\n' "$diff_files" | grep -Ec 'Resources/app/administration/.*\.(js|ts|vue|scss)$' || true)"
    STOREFRONT_CHANGES="$(printf '%s\n' "$diff_files" | grep -Ec '(Resources/app/storefront/.*\.(js|ts|vue|scss)$|\.twig$)' || true)"
    COMPOSER_CHANGES="$(printf '%s\n' "$diff_files" | grep -Ec '(^|/)composer\.(json|lock)$' || true)"
    PACKAGE_CHANGES="$(printf '%s\n' "$diff_files" | grep -Ec '(^|/)(package\.json|package-lock\.json|pnpm-lock\.yaml|yarn\.lock)$' || true)"
    BACKEND_CHANGES="$(printf '%s\n' "$diff_files" | grep -E '\.php$' | grep -Evc '(^|/)Migrations?/|/Entity/' || true)"
    # Backward compat: FRONTEND_CHANGES = ADMIN + STOREFRONT
    FRONTEND_CHANGES="$((ADMIN_CHANGES + STOREFRONT_CHANGES))"
}

sync_worktree_deps() {
    # QA mode: always symlink vendor (read-only, no installs).
    # Dev mode: symlink only when no composer/dependency changes.
    if [ -d "$PROJECT_ROOT/vendor" ] && [ ! -e "$WORKTREE_PATH/vendor" ]; then
        if [ "$SWCTL_MODE" = "qa" ]; then
            # QA mode: vendor is bind-mounted read-only via compose override.
            info "Vendor will be mounted read-only from project root (QA mode)."
        elif [ "$((MIGRATION_CHANGES + ENTITY_CHANGES + COMPOSER_CHANGES))" -gt 0 ]; then
            info "Dependency changes detected. Vendor will be installed fresh inside container."
        else
            ln -s "$PROJECT_ROOT/vendor" "$WORKTREE_PATH/vendor"
            ok "Symlinked vendor/ from project root (no composer changes)."
        fi
    fi
}

resolve_vendor_volume() {
    local issue_id="$1"
    if [ "$((MIGRATION_CHANGES + ENTITY_CHANGES + COMPOSER_CHANGES))" -gt 0 ]; then
        printf '%s' "vendor-${issue_id}"
    else
        printf '%s' "vendor-base-${SW_PROJECT_SLUG}"
    fi
}

resolve_node_modules_volume() {
    local issue_id="$1"
    if [ "$((MIGRATION_CHANGES + ENTITY_CHANGES + PACKAGE_CHANGES))" -gt 0 ]; then
        printf '%s' "node_modules-${issue_id}"
    else
        printf '%s' "node_modules-base-${SW_PROJECT_SLUG}"
    fi
}

detect_package_install_command() {
    local path="$1"

    if [ -f "$path/pnpm-lock.yaml" ]; then
        printf '%s\n' "pnpm install --frozen-lockfile"
        return
    fi

    if [ -f "$path/yarn.lock" ]; then
        printf '%s\n' "yarn install --frozen-lockfile"
        return
    fi

    if [ -f "$path/package-lock.json" ]; then
        printf '%s\n' "npm ci"
        return
    fi

    if [ -f "$path/package.json" ]; then
        printf '%s\n' "npm install"
    fi
}

write_env_file() {
    local env_file="$WORKTREE_PATH/$SW_ENV_FILE_NAME"
    local backup_file="$WORKTREE_PATH/${SW_ENV_FILE_NAME}.pre-swctl"

    if [ -f "$env_file" ] && ! grep -Fq "Managed by swctl" "$env_file"; then
        if [ ! -f "$backup_file" ]; then
            cp "$env_file" "$backup_file"
            warn "Backed up existing $SW_ENV_FILE_NAME to $(basename "$backup_file")."
        fi
    fi

    # Generate a stable APP_SECRET per worktree (deterministic from project+issue)
    local app_secret
    app_secret="$(printf '%s-%s' "$SW_PROJECT_SLUG" "$ISSUE_ID" | openssl dgst -sha256 | sed 's/.*= //')"

    cat >"$env_file" <<EOF
# Managed by swctl. Re-generated on $(timestamp_utc)
APP_ENV=dev
APP_URL=${APP_URL}
APP_SECRET=${app_secret}
DATABASE_URL=mysql://${SW_DB_ROOT_USER}:${SW_DB_ROOT_PASSWORD}@${SW_DB_HOST}:${SW_DB_PORT}/${DB_NAME}
MAILER_DSN=${SW_MAILER_DSN}
REDIS_URL=${SW_REDIS_URL}
OPENSEARCH_URL=${SW_OPENSEARCH_URL:-}
ADMIN_OPENSEARCH_URL=${SW_OPENSEARCH_URL:-}
WORKTREE_ID=${WORKTREE_ID}
COMPOSE_PROJECT_NAME=${COMPOSE_PROJECT}
SWCTL_PROJECT=${SW_PROJECT}
SWCTL_ISSUE=${ISSUE_ID}
EOF

    ok "Generated ${SW_ENV_FILE_NAME}."

    # Symfony Dotenv requires .env to exist for .env.local to be loaded.
    if [ ! -f "$WORKTREE_PATH/.env" ]; then
        touch "$WORKTREE_PATH/.env"
    fi
}

