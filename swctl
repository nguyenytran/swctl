cmd_refresh() {
    local issue_input="${1:-}"
    SWCTL_ACTIVE_META_FILE=""

    [ -n "$issue_input" ] || die "Usage: swctl refresh <issue>"

    maybe_load_project_config >/dev/null 2>&1 || true
    SWCTL_ACTIVE_META_FILE="$(resolve_instance_file_by_issue "$issue_input")" || die "No tracked worktree found for issue '$issue_input'."
    load_instance_metadata "$SWCTL_ACTIVE_META_FILE"

    # Load project config from the instance's saved config path
    load_project_config ${CONFIG_PATH:+"$CONFIG_PATH"}

    # Resume failed/interrupted creates
    if [ "${STATUS:-complete}" = "failed" ] || [ "${STATUS:-complete}" = "creating" ]; then
        info "Worktree '$ISSUE_ID' has status '${STATUS}'. Resuming provisioning..."
        STATUS="creating"
        ensure_infra_ready

        # Recompute derived variables not stored in metadata
        WORKTREE_ID="${WORKTREE_ID:-$ISSUE_ID}"
        if [ -z "${COMPOSE_PROJECT:-}" ]; then
            COMPOSE_PROJECT="$(sanitize_slug "${SW_PROJECT_SLUG}-${ISSUE_ID}")"
        fi
        TRAEFIK_ROUTER="$(sanitize_router_id "${SW_PROJECT_SLUG}_${ISSUE_ID}")"
        TRAEFIK_SERVICE="$TRAEFIK_ROUTER"
        if [ -z "${WORKTREE_PATH:-}" ]; then
            WORKTREE_PATH="${SW_WORKTREE_ROOT}/${SW_WORKTREE_PREFIX}-${ISSUE_ID}"
        fi
        if [ -z "${DOMAIN:-}" ]; then
            if [ "$SW_RUNTIME" = "orbstack" ]; then
                DOMAIN="${SW_SERVICE_NAME}.${COMPOSE_PROJECT}.orb.local"
            else
                DOMAIN="${SW_PROJECT_SLUG}-${ISSUE_ID}.${SW_DOMAIN_SUFFIX}"
            fi
            APP_URL="http://${DOMAIN}"
        fi

        # On any exit while STATUS=creating, mark as failed
        trap 'if [ "${STATUS:-}" = "creating" ]; then STATUS=failed; FAILED_AT="${SWCTL_LAST_ERROR:-unknown}"; write_metadata "$SWCTL_ACTIVE_META_FILE" 2>/dev/null; fi' EXIT

        # 1. Ensure worktree exists
        if [ -n "$WORKTREE_PATH" ] && [ ! -d "$WORKTREE_PATH" ]; then
            create_worktree
        fi

        # 2. Re-compute diff and changes
        BASE_REF="$(git_base_ref)"
        DIFF_FILES="$(git -C "$PROJECT_ROOT" diff --name-only "${BASE_REF}...${BRANCH}" 2>/dev/null || true)"
        count_changes "$DIFF_FILES"

        # 3. Re-sync artifacts and deps
        sync_build_artifacts
        sync_worktree_deps
        VENDOR_VOLUME="$(resolve_vendor_volume "$ISSUE_ID")"
        NODE_MODULES_VOLUME="$(resolve_node_modules_volume "$ISSUE_ID")"

        # 4. Re-provision DB + app
        provision_database_and_app "$COMPOSE_PROJECT"

        # 5. Frontend build
        run_frontend_build_if_needed "$COMPOSE_PROJECT" 1

        # 6. Activate plugin if needed
        if [ -n "${PLUGIN_NAME:-}" ]; then
            activate_plugin "$COMPOSE_PROJECT" "$PLUGIN_NAME"
        fi

        # 7. Mark complete
        STATUS="complete"
        FAILED_AT=""
        trap - EXIT
        write_metadata "$SWCTL_ACTIVE_META_FILE"

        ok "Worktree '$ISSUE_ID' successfully provisioned."
        info "URL: ${APP_URL}"
        return
    fi

    # --- Normal refresh: pull + rebuild ---

    # Remember the old HEAD before pulling
    local old_head
    old_head="$(git -C "$WORKTREE_PATH" rev-parse HEAD 2>/dev/null)"

    # Fetch latest changes from the main repo (worktrees share the same git object store,
    # and PROJECT_ROOT is more likely to have SSH/credentials configured)
    info "Pulling latest changes for '$ISSUE_ID' (branch: $BRANCH)."
    git -C "$PROJECT_ROOT" fetch origin "$BRANCH" 2>/dev/null \
        || warn "Could not fetch latest changes. Continuing with current state."
    # Update worktree to match the fetched remote branch
    git -C "$WORKTREE_PATH" reset --hard "origin/$BRANCH" 2>/dev/null \
        || warn "Could not reset worktree to origin/$BRANCH."

    local new_head
    new_head="$(git -C "$WORKTREE_PATH" rev-parse HEAD 2>/dev/null)"

    if [ "$old_head" = "$new_head" ]; then
        info "No new commits. Nothing to refresh."
        return
    fi

    ok "Updated $old_head → $new_head"

    # Diff between old and new HEAD to detect what changed
    local diff_files
    diff_files="$(git -C "$WORKTREE_PATH" diff --name-only "$old_head...$new_head" 2>/dev/null || true)"
    count_changes "$diff_files"

    info "Changes since last build: migrations=${MIGRATION_CHANGES} entity=${ENTITY_CHANGES} admin=${ADMIN_CHANGES} storefront=${STOREFRONT_CHANGES} composer=${COMPOSER_CHANGES} package=${PACKAGE_CHANGES} backend=${BACKEND_CHANGES}"

    # Re-sync gitignored files if needed
    sync_build_artifacts

    local compose_project="$COMPOSE_PROJECT"

    # Run migrations if schema changed
    if [ $((MIGRATION_CHANGES + ENTITY_CHANGES)) -gt 0 ]; then
        info "Schema changes detected. Running migrations."
        run_app_command "$compose_project" "$WORKFLOW_CONSOLE database:migrate --all && $WORKFLOW_CONSOLE database:migrate-destructive --all" || warn "Migrations failed."
    fi

    # Composer install if dependencies changed (dev mode only)
    if [ "$((COMPOSER_CHANGES))" -gt 0 ] && [ "${SWCTL_MODE:-dev}" = "dev" ]; then
        info "Composer changes detected. Running composer install."
        run_app_command "$compose_project" "composer install --no-interaction" || warn "Composer install failed."
    fi

    # Rebuild frontend if admin/storefront changed
    if [ "${ADMIN_CHANGES:-0}" -gt 0 ]; then
        info "Admin changes detected. Running composer build:js:admin."
        run_app_command "$compose_project" "composer build:js:admin" || warn "Admin JS build failed."
    fi

    if [ "${STOREFRONT_CHANGES:-0}" -gt 0 ]; then
        info "Storefront changes detected. Running composer build:js:storefront."
        run_app_command "$compose_project" "composer build:js:storefront" || warn "Storefront JS build failed."
    fi

    # Always clear cache after any update
    run_app_command "$compose_project" "$WORKFLOW_CONSOLE cache:clear" || warn "cache:clear failed."

    # Update metadata with new HEAD
    STATUS="complete"
    write_metadata "$SWCTL_ACTIVE_META_FILE"

    ok "Refreshed '$ISSUE_ID'. Changes applied."
    info "URL: ${APP_URL}"
}

cmd_checkout() {
    local issue_input="${1:-}"
    local state_file="$SWCTL_STATE_DIR/checkout.state"

    # --- Return mode: restore main repo to base branch, re-attach worktree ---
    if [ "$issue_input" = "--return" ] || [ "$issue_input" = "-r" ]; then
        [ -f "$state_file" ] || die "No active checkout to return from."
        # shellcheck disable=SC1090
        . "$state_file"
        [ -n "${CHECKOUT_ACTIVE_ISSUE:-}" ] || die "Invalid checkout state file."

        local meta_file
        meta_file="$(resolve_instance_file_by_issue "$CHECKOUT_ACTIVE_ISSUE")" \
            || die "No tracked worktree found for issue '$CHECKOUT_ACTIVE_ISSUE'."
        load_instance_metadata "$meta_file"
        load_project_config ${CONFIG_PATH:+"$CONFIG_PATH"}

        info "Returning main repo to '${CHECKOUT_PREVIOUS_BRANCH}' and re-attaching worktree."

        # Return main repo to previous branch
        git -C "$PROJECT_ROOT" checkout "$CHECKOUT_PREVIOUS_BRANCH" \
            || die "Failed to checkout '$CHECKOUT_PREVIOUS_BRANCH' in main repo."

        # Re-attach worktree to its branch
        git -C "$WORKTREE_PATH" checkout "$BRANCH" \
            || die "Failed to re-attach worktree to branch '$BRANCH'."

        rm -f "$state_file"
        ok "Returned main repo to '$CHECKOUT_PREVIOUS_BRANCH'. Worktree '$ISSUE_ID' re-attached to '$BRANCH'."
        return
    fi

    # --- Checkout mode: detach worktree, checkout branch in main repo ---
    [ -n "$issue_input" ] || die "Usage: swctl checkout <issue>  or  swctl checkout --return"

    # Warn if there's already an active checkout
    if [ -f "$state_file" ]; then
        # shellcheck disable=SC1090
        . "$state_file"
        warn "There is already an active checkout for issue '${CHECKOUT_ACTIVE_ISSUE:-unknown}'."
        warn "Run 'swctl checkout --return' first, or this will override it."
    fi

    maybe_load_project_config >/dev/null 2>&1 || true
    local meta_file
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" \
        || die "No tracked worktree found for issue '$issue_input'."
    load_instance_metadata "$meta_file"
    load_project_config ${CONFIG_PATH:+"$CONFIG_PATH"}

    [ -n "${BRANCH:-}" ] || die "Instance '$issue_input' has no branch set."
    [ -n "${WORKTREE_PATH:-}" ] || die "Instance '$issue_input' has no worktree path."

    # Save current main repo branch
    local current_branch
    current_branch="$(git -C "$PROJECT_ROOT" branch --show-current 2>/dev/null)" || true
    [ -n "$current_branch" ] || current_branch="$(git -C "$PROJECT_ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null)" || true
    [ -n "$current_branch" ] || die "Could not determine current branch of main repo."

    info "Checking out branch '$BRANCH' (from worktree '$ISSUE_ID') into main repo."

    # 1. Detach worktree HEAD (releases the branch)
    git -C "$WORKTREE_PATH" checkout --detach HEAD 2>/dev/null \
        || die "Failed to detach worktree HEAD."
    ok "Detached worktree '$ISSUE_ID' from branch '$BRANCH'."

    # 2. Checkout branch in main repo
    git -C "$PROJECT_ROOT" checkout "$BRANCH" \
        || { git -C "$WORKTREE_PATH" checkout "$BRANCH" 2>/dev/null || true; die "Failed to checkout '$BRANCH' in main repo."; }
    ok "Main repo now on branch '$BRANCH'."

    # 3. Save state for --return
    mkdir -p "$SWCTL_STATE_DIR"
    {
        printf 'CHECKOUT_ACTIVE_ISSUE=%q\n' "$ISSUE_ID"
        printf 'CHECKOUT_PREVIOUS_BRANCH=%q\n' "$current_branch"
    } > "$state_file"

    info "To return: swctl checkout --return"
}

cmd_open() {
    local issue_input="${1:-}"
