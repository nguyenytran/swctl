cmd_clean() {
    local issue_input="${1:-}"
    local force=0
    local meta_file=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --force|-f) force=1; shift ;;
            *)          issue_input="$1"; shift ;;
        esac
    done

    [ -n "$issue_input" ] || die "Usage: swctl clean [--force] <issue>"
    maybe_load_project_config >/dev/null 2>&1 || true

    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || {
        warn "No tracked worktree found for issue '$issue_input'. Nothing to clean."
        return 0
    }

    load_instance_metadata "$meta_file"

    # Plugin-aware cleanup
    case "${PROJECT_TYPE:-platform}" in
        plugin-external)
            # Clean plugin worktree
            if [ -n "${PLUGIN_WORKTREE_PATHS:-}" ]; then
                local saved_ifs="$IFS"
                IFS=','
                local pw_arr=($PLUGIN_WORKTREE_PATHS)
                IFS="$saved_ifs"
                for pw_path in "${pw_arr[@]}"; do
                    if [ -d "$pw_path" ]; then
                        # Find the plugin's git repo to remove the worktree properly
                        local plugin_git_dir
                        plugin_git_dir="$(git -C "$pw_path" rev-parse --git-common-dir 2>/dev/null || true)"
                        if [ -n "$plugin_git_dir" ]; then
                            git -C "$(dirname "$plugin_git_dir")" worktree remove --force "$pw_path" >/dev/null 2>&1 \
                                || rm -rf "$pw_path" 2>/dev/null || true
                        else
                            rm -rf "$pw_path" 2>/dev/null || true
                        fi
                        ok "Removed plugin worktree: $pw_path"
                    fi
                done
            fi

            # Update parent platform metadata to remove linkage
            if [ -n "${PLATFORM_ISSUE_ID:-}" ] && [ -n "${SW_PROJECT_SLUG:-}" ]; then
                local platform_meta
                platform_meta="$(instance_dir "$SW_PROJECT_SLUG")/${PLATFORM_ISSUE_ID}.env"
                if [ -f "$platform_meta" ]; then
                    # Remove LINKED_PLUGINS and PLUGIN_WORKTREE_PATHS from platform metadata
                    local tmp_meta="${platform_meta}.tmp"
                    grep -vE '^(LINKED_PLUGINS|PLUGIN_WORKTREE_PATHS)=' "$platform_meta" > "$tmp_meta" 2>/dev/null || true
                    mv "$tmp_meta" "$platform_meta"
                fi
            fi

            # Remove plugin metadata
            rm -f "$meta_file"
            ok "Cleaned plugin '${PLUGIN_NAME:-$ISSUE_ID}'."
            return 0
            ;;

        platform)
            # If platform has linked plugins, require --force
            if [ -n "${LINKED_PLUGINS:-}" ] && [ "$force" -eq 0 ]; then
                die "Platform worktree has linked plugins: ${LINKED_PLUGINS}. Use --force to clean all, or clean plugins first."
            fi

            # With --force, clean linked plugin metadata
            if [ -n "${LINKED_PLUGINS:-}" ]; then
                info "Cleaning linked plugins: ${LINKED_PLUGINS}"
                local saved_ifs="$IFS"
                IFS=','
                local pl_arr=($LINKED_PLUGINS)
                IFS="$saved_ifs"
                for p_name in "${pl_arr[@]}"; do
                    local p_slug
                    p_slug="$(sanitize_slug "$p_name")"
                    local p_meta
                    p_meta="$(instance_dir "$p_slug")/${ISSUE_ID}.env"
                    if [ -f "$p_meta" ]; then
                        rm -f "$p_meta"
                        ok "Removed plugin metadata: $p_slug/$ISSUE_ID"
                    fi
                done

                # Clean plugin worktrees
                if [ -n "${PLUGIN_WORKTREE_PATHS:-}" ]; then
                    IFS=','
                    local pw_arr=($PLUGIN_WORKTREE_PATHS)
                    IFS="$saved_ifs"
                    for pw_path in "${pw_arr[@]}"; do
                        if [ -d "$pw_path" ]; then
                            rm -rf "$pw_path" 2>/dev/null || true
                            ok "Removed plugin worktree: $pw_path"
                        fi
                    done
                fi
            fi
            ;;
    esac

    # Standard cleanup (containers, volumes, networks, DB, worktree)

    # 1. Stop and remove ALL containers belonging to this compose project
    local containers
    containers="$(docker ps -aq --filter "label=com.docker.compose.project=${COMPOSE_PROJECT}" 2>/dev/null || true)"
    if [ -n "$containers" ]; then
        # shellcheck disable=SC2086
        docker rm -f $containers >/dev/null 2>&1 || true
        ok "Removed containers for '${COMPOSE_PROJECT}'."
    fi

    # 2. Remove ALL volumes belonging to this compose project
    local volumes
    volumes="$(docker volume ls -q --filter "label=com.docker.compose.project=${COMPOSE_PROJECT}" 2>/dev/null || true)"
    if [ -n "$volumes" ]; then
        # shellcheck disable=SC2086
        docker volume rm $volumes >/dev/null 2>&1 || true
        ok "Removed compose volumes for '${COMPOSE_PROJECT}'."
    fi

    # Also remove any swctl-labeled volumes for this issue
    remove_labeled_volumes

    # 3. Remove Docker networks created by this compose project
    local networks
    networks="$(docker network ls -q --filter "label=com.docker.compose.project=${COMPOSE_PROJECT}" 2>/dev/null || true)"
    if [ -n "$networks" ]; then
        # shellcheck disable=SC2086
        docker network rm $networks >/dev/null 2>&1 || true
        ok "Removed networks for '${COMPOSE_PROJECT}'."
    fi

    # 4. Drop the cloned database (never touches the source)
    local source_db
    source_db="$(sanitize_db_identifier "${SW_DB_SHARED_NAME:-shopware}")"
    if [ -n "$DB_NAME" ] && [ "$DB_NAME" != "$source_db" ]; then
        mysql_exec "DROP DATABASE IF EXISTS \`${DB_NAME}\`;" >/dev/null 2>&1 || warn "Could not drop database '${DB_NAME}'."
        ok "Dropped database '${DB_NAME}'."
    fi

    # 5. Remove the git worktree
    if [ -d "$WORKTREE_PATH" ] && git -C "$PROJECT_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        git -C "$PROJECT_ROOT" worktree remove --force "$WORKTREE_PATH" >/dev/null 2>&1 || warn "Could not remove worktree '${WORKTREE_PATH}'."
        ok "Removed worktree '${WORKTREE_PATH}'."
    else
        info "Worktree path '${WORKTREE_PATH}' is already absent."
    fi

    # 6. Clean up generated files in tmp
    rm -f "$SWCTL_TMP_DIR/${COMPOSE_PROJECT}.compose.env" \
          "$SWCTL_TMP_DIR/${COMPOSE_PROJECT}.volumes.override.yml" \
          2>/dev/null || true

    rm -f "$meta_file"
    ok "Cleaned issue '${ISSUE_ID}'."
}

