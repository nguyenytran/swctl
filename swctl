                info "Starting new session..."
                exec "$ai_bin"
            fi
            ;;
        codex)
            warn "[resolve] Codex backend is experimental; interactive flag surface may change."
            if [ -n "${CLAUDE_SESSION_ID:-}" ]; then
                info "Resuming session ${CLAUDE_SESSION_ID:0:8}..."
                exec "$ai_bin" --session "$CLAUDE_SESSION_ID" --resume
            else
                info "Starting new session..."
                exec "$ai_bin"
            fi
            ;;
    esac
}

