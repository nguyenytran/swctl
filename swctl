    [ -n "$issue_input" ] || die "Usage: swctl exec <issue> '<cmd>'"
    [ -n "$command_string" ] || die "Usage: swctl exec <issue> '<cmd>'"

    maybe_load_project_config >/dev/null 2>&1 || true
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || die "No tracked worktree found for issue '$issue_input'."
    load_instance_metadata "$meta_file"

    # Vite watch commands proxy /api to APP_URL, but inside the container
    # APP_URL resolves to the container's own IP on port 80 while Caddy
    # listens on port 8000. Override APP_URL for the Vite process only.
    case "$command_string" in
        *watch:admin*|*watch:storefront*|*"npm run dev"*)
            command_string="APP_URL=http://localhost:8000 $command_string"
            ;;
    esac

    run_app_command "$COMPOSE_PROJECT" "$command_string"
}

