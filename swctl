write_compose_volume_override() {
    COMPOSE_VOLUME_OVERRIDE="$SWCTL_TMP_DIR/${COMPOSE_PROJECT}.volumes.override.yml"
    local vendor_is_shared=0
    local node_is_shared=0

    case "$VENDOR_VOLUME" in vendor-base-*) vendor_is_shared=1 ;; esac
    case "$NODE_MODULES_VOLUME" in node_modules-base-*) node_is_shared=1 ;; esac

    # Ensure shared base volumes exist before marking them external
    if [ "$vendor_is_shared" -eq 1 ]; then
        docker volume inspect "$VENDOR_VOLUME" >/dev/null 2>&1 || \
            docker volume create "$VENDOR_VOLUME" >/dev/null
    fi
    if [ "$node_is_shared" -eq 1 ]; then
        docker volume inspect "$NODE_MODULES_VOLUME" >/dev/null 2>&1 || \
            docker volume create "$NODE_MODULES_VOLUME" >/dev/null
    fi

    {
        printf 'volumes:\n'
        printf '  vendor:\n'
        printf '    name: %s\n' "$VENDOR_VOLUME"
        if [ "$vendor_is_shared" -eq 1 ]; then
            printf '    external: true\n'
        else
            printf '    labels:\n'
            printf '      swctl.managed: "true"\n'
            printf '      swctl.project: %s\n' "$SW_PROJECT_SLUG"
            printf '      swctl.issue: %s\n' "$ISSUE_ID"
        fi
        printf '  node_modules:\n'
        printf '    name: %s\n' "$NODE_MODULES_VOLUME"
        if [ "$node_is_shared" -eq 1 ]; then
            printf '    external: true\n'
        else
            printf '    labels:\n'
            printf '      swctl.managed: "true"\n'
            printf '      swctl.project: %s\n' "$SW_PROJECT_SLUG"
            printf '      swctl.issue: %s\n' "$ISSUE_ID"
        fi
    } > "$COMPOSE_VOLUME_OVERRIDE"

    # QA mode: mount vendor from trunk as read-only bind (symlinks don't work in Docker)
    if [ "$SWCTL_MODE" = "qa" ] && [ -d "$PROJECT_ROOT/vendor" ]; then
        local svc="${SW_SERVICE_NAME:-web}"
        cat >> "$COMPOSE_VOLUME_OVERRIDE" <<QAEOF

services:
  ${svc}:
    volumes:
      - ${PROJECT_ROOT}/vendor:/var/www/html/vendor:ro
QAEOF
    fi
}

app_container_id() {
    local compose_project="$1"
    local service="${SW_SERVICE_NAME:-app}"
    local result
    result="$(docker ps -q \
        --filter "label=com.docker.compose.project=${compose_project}" \
        --filter "label=com.docker.compose.service=${service}" \
        2>/dev/null | sed -n '1p')"
    if [ -z "$result" ]; then
        # Fallback: try both service names for backward compatibility
        local alt_service="app"
        [ "$service" = "app" ] && alt_service="web"
        result="$(docker ps -q \
            --filter "label=com.docker.compose.project=${compose_project}" \
            --filter "label=com.docker.compose.service=${alt_service}" \
            2>/dev/null | sed -n '1p')"
    fi
    printf '%s' "$result"
}

app_container_exists_any_state() {
    local compose_project="$1"
    local service="${SW_SERVICE_NAME:-app}"
    local result
    result="$(docker ps -aq \
        --filter "label=com.docker.compose.project=${compose_project}" \
        --filter "label=com.docker.compose.service=${service}" \
        2>/dev/null | sed -n '1p')"
    if [ -z "$result" ]; then
        local alt_service="app"
        [ "$service" = "app" ] && alt_service="web"
        result="$(docker ps -aq \
            --filter "label=com.docker.compose.project=${compose_project}" \
            --filter "label=com.docker.compose.service=${alt_service}" \
            2>/dev/null | sed -n '1p')"
    fi
    printf '%s' "$result"
}

wait_for_app_container() {
    local compose_project="$1"
    local attempt=0
    while [ "$attempt" -lt 30 ]; do
        if [ -n "$(app_container_id "$compose_project")" ]; then
            return 0
        fi
        attempt=$((attempt + 1))
        sleep 2
    done

    die "App container for '$compose_project' did not start in time."
}

exec_in_container() {
    local container_id="$1"
    local command_string="$2"

    if [ -t 0 ] && [ -t 1 ]; then
        docker exec -it "$container_id" bash -lc "$command_string"
    else
        docker exec "$container_id" bash -lc "$command_string"
    fi
}

run_app_command() {
    local compose_project="$1"
    local command_string="$2"
    local container_id

    container_id="$(app_container_id "$compose_project")"
    [ -n "$container_id" ] || die "No running app container found for '$compose_project'."
    exec_in_container "$container_id" "$command_string"
}

fix_volume_ownership() {
    local compose_project="$1"
    local container_id
    container_id="$(app_container_id "$compose_project")"
    [ -n "$container_id" ] || return 0
    docker exec -u root "$container_id" bash -c \
        "chown ${SW_UID}:${SW_GID} /var/www/html/vendor /var/www/html/node_modules 2>/dev/null" || true
}

bootstrap_dependencies() {
    local compose_project="$1"
    local package_install_cmd=""
    local vendor_needs_install=0
    local node_needs_install=0

    fix_volume_ownership "$compose_project"

    # --- Composer / vendor ---
    if [ "$((MIGRATION_CHANGES + ENTITY_CHANGES + COMPOSER_CHANGES))" -gt 0 ]; then
        # Dedicated vendor volume — always install
        vendor_needs_install=1
        info "Dependency changes detected. Will run composer install."
    elif run_app_command "$compose_project" "test -f composer.json && test ! -f vendor/autoload.php" >/dev/null 2>&1; then
        # Shared base volume is empty (first-time populate)
        vendor_needs_install=1
        info "Shared vendor volume is empty. Will populate with composer install."
    else
        info "Reusing existing vendor volume. Skipping composer install."
    fi

    if [ "$vendor_needs_install" -eq 1 ]; then
        run_app_command "$compose_project" "composer install --no-interaction" \
            || warn "composer install failed. Continue after fixing the image or composer setup."
    fi

    # --- Node modules ---
    package_install_cmd="$(detect_package_install_command "$WORKTREE_PATH" || true)"
    if [ -n "$package_install_cmd" ]; then
        if [ "$((MIGRATION_CHANGES + ENTITY_CHANGES + PACKAGE_CHANGES))" -gt 0 ]; then
            # Dedicated node_modules volume — always install
            node_needs_install=1
            info "Package changes detected. Will run: $package_install_cmd"
        elif run_app_command "$compose_project" "test ! -f node_modules/.package-lock.json && test ! -f node_modules/.modules.yaml" >/dev/null 2>&1; then
            # Shared base volume is empty (first-time populate)
            node_needs_install=1
            info "Shared node_modules volume is empty. Will populate."
        else
            info "Reusing existing node_modules volume. Skipping npm/pnpm install."
        fi

        if [ "$node_needs_install" -eq 1 ]; then
            run_app_command "$compose_project" "$package_install_cmd" \
                || warn "Frontend dependency install failed."
        fi
    fi

    ensure_jwt_keys "$compose_project"
}

ensure_install_lock() {
    local compose_project="$1"
    run_app_command "$compose_project" "touch install.lock" || true
}

ensure_jwt_keys() {
    local compose_project="$1"
    run_app_command "$compose_project" \
        "test -f config/jwt/private.pem || (mkdir -p config/jwt && openssl genrsa -out config/jwt/private.pem 2048 2>/dev/null && openssl rsa -in config/jwt/private.pem -outform PEM -pubout -out config/jwt/public.pem 2>/dev/null && echo 'Generated JWT keys')" \
        || true
}

update_sales_channel_domain() {
    local compose_project="$1"
    local app_url="$2"

    # Each worktree has its own cloned DB — safe to update all non-headless domains.
    # Write a tiny PHP helper, execute it inside the container (uses DATABASE_URL
    # from .env.local), then remove it. This safely updates only the cloned DB.
    info "Updating sales channel domains to '$app_url'."
    cat > "$WORKTREE_PATH/.swctl-update-domain.php" <<'PHPEOF'
<?php
// Replace the base domain in all non-headless sales channel domains.
// E.g. http://web.trunk.orb.local/de-de → http://web.sw-123.orb.local/de-de
$newBase = $argv[1] ?? '';
$url = getenv('DATABASE_URL') ?: '';
if (!$url) {
    $env = file_get_contents(__DIR__ . '/.env.local');
    preg_match('/DATABASE_URL=(.+)/', $env, $m);
    $url = trim($m[1] ?? '');
}
$p = parse_url($url);
$pdo = new PDO(
    sprintf('mysql:host=%s;port=%s;dbname=%s', $p['host'], $p['port'] ?? 3306, ltrim($p['path'] ?? '', '/')),
    $p['user'] ?? 'root', $p['pass'] ?? ''
);
$rows = $pdo->query("SELECT HEX(id) as id, url FROM sales_channel_domain WHERE url NOT LIKE '%headless%'")->fetchAll(PDO::FETCH_ASSOC);
$count = 0;
foreach ($rows as $row) {
    $oldUrl = $row['url'];
    $oldParts = parse_url($oldUrl);
    $oldBase = ($oldParts['scheme'] ?? 'http') . '://' . ($oldParts['host'] ?? '') . (isset($oldParts['port']) ? ':' . $oldParts['port'] : '');
    $newUrl = str_replace($oldBase, $newBase, $oldUrl);
    if ($newUrl !== $oldUrl) {
        $pdo->prepare("UPDATE sales_channel_domain SET url = ? WHERE id = UNHEX(?)")->execute([$newUrl, $row['id']]);
        $count++;
    }
}
echo "Updated $count domain(s)\n";
PHPEOF
    run_app_command "$compose_project" "php .swctl-update-domain.php '$app_url'" \
        || warn "Could not update sales channel domain."
    rm -f "$WORKTREE_PATH/.swctl-update-domain.php"
}

run_install_command() {
    local compose_project="$1"
    local install_args="$2"
    local install_cmd

    install_cmd="$SW_BIN_CONSOLE system:install $install_args"
    info "Running Shopware system install for database '$DB_NAME'."
    run_app_command "$compose_project" "$install_cmd"
    ensure_install_lock "$compose_project"
}

run_frontend_build_if_needed() {
    local compose_project="$1"

    # Both QA and Dev: auto-detect what changed and build only that.
    local needs_bundle_dump=0

    if [ "${ADMIN_CHANGES:-0}" -gt 0 ] || [ "${STOREFRONT_CHANGES:-0}" -gt 0 ]; then
        needs_bundle_dump=1
    fi

    if [ "$needs_bundle_dump" -eq 1 ]; then
        info "Frontend changes detected. Running bundle:dump."
        run_app_command "$compose_project" "$SW_BIN_CONSOLE bundle:dump" || warn "bundle:dump failed."
    fi

    if [ "${ADMIN_CHANGES:-0}" -gt 0 ]; then
        info "Admin changes detected. Running composer build:js:admin."
        run_app_command "$compose_project" "composer build:js:admin" || warn "Admin JS build failed."
    fi

    if [ "${STOREFRONT_CHANGES:-0}" -gt 0 ]; then
        info "Storefront changes detected. Running composer build:js:storefront."
        run_app_command "$compose_project" "composer build:js:storefront" || warn "Storefront JS build failed."
    fi

    if [ "$needs_bundle_dump" -eq 0 ]; then
        # No frontend changes — register synced assets. Skip full JS builds.
        run_app_command "$compose_project" "$SW_BIN_CONSOLE bundle:dump" 2>/dev/null || true
        run_app_command "$compose_project" "$SW_BIN_CONSOLE assets:install" 2>/dev/null || true
        info "Assets registered from synced files. No frontend builds needed."
    fi

    # Clear cache for any code change
    if [ "$((BACKEND_CHANGES + ADMIN_CHANGES + STOREFRONT_CHANGES + COMPOSER_CHANGES + PACKAGE_CHANGES))" -gt 0 ] && [ "${DB_STATE:-}" != "fresh" ]; then
        run_app_command "$compose_project" "$SW_BIN_CONSOLE cache:clear" || warn "cache:clear failed."
    fi
}

create_database() {
    local db_name="$1"
    mysql_exec "DROP DATABASE IF EXISTS \`${db_name}\`; CREATE DATABASE \`${db_name}\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;"
}


clone_database() {
    local source_db="$1"
    local target_db="$2"
    local db_container
    db_container="$(resolve_db_container)"

    info "Cloning database '$source_db' → '$target_db'."
    docker exec -i "$db_container" bash -c \
        "mariadb -u '$SW_DB_ROOT_USER' -p'$SW_DB_ROOT_PASSWORD' -e 'DROP DATABASE IF EXISTS \`$target_db\`; CREATE DATABASE \`$target_db\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;' && mariadb-dump -u '$SW_DB_ROOT_USER' -p'$SW_DB_ROOT_PASSWORD' --single-transaction --quick '$source_db' | mariadb -u '$SW_DB_ROOT_USER' -p'$SW_DB_ROOT_PASSWORD' '$target_db'" \
        || die "Database clone failed."
    ok "Database cloned: $target_db"
}

provision_database_and_app() {
    local compose_project="$1"
    local source_db
    source_db="$(sanitize_db_identifier "$SW_DB_SHARED_NAME")"

    # Every worktree gets its own cloned database (never touches the source).
    DB_NAME="$(sanitize_db_identifier "${SW_DB_NAME_PREFIX}_${ISSUE_ID}")"

    # Write configs first (needed by both DB clone and compose up)
    write_env_file
    write_compose_env_file
    write_compose_volume_override

    # Check DB state and start clone + container in parallel when possible
    if mysql_db_has_tables "$DB_NAME"; then
        DB_STATE="cloned"
        info "Database '$DB_NAME' already exists. Reusing."
        compose --project-directory "$SWCTL_TMP_DIR" -f "$SW_COMPOSE_TEMPLATE" -f "$COMPOSE_VOLUME_OVERRIDE" --env-file "$COMPOSE_ENV_FILE" -p "$COMPOSE_PROJECT" up -d
    elif mysql_db_has_tables "$source_db"; then
        DB_STATE="cloned"
        # Clone DB in background while container starts
        clone_database "$source_db" "$DB_NAME" &
        local clone_pid=$!
        compose --project-directory "$SWCTL_TMP_DIR" -f "$SW_COMPOSE_TEMPLATE" -f "$COMPOSE_VOLUME_OVERRIDE" --env-file "$COMPOSE_ENV_FILE" -p "$COMPOSE_PROJECT" up -d
        wait "$clone_pid" || die "Database clone failed."
    else
        DB_STATE="fresh"
        info "Source database '$source_db' is empty. Will run fresh install."
        create_database "$DB_NAME"
        compose --project-directory "$SWCTL_TMP_DIR" -f "$SW_COMPOSE_TEMPLATE" -f "$COMPOSE_VOLUME_OVERRIDE" --env-file "$COMPOSE_ENV_FILE" -p "$COMPOSE_PROJECT" up -d
    fi
    wait_for_app_container "$COMPOSE_PROJECT"

    # Both QA and Dev modes: fully automatic provisioning based on diff analysis.
    # QA skips composer install (vendor bind-mounted from trunk).
    # Dev runs composer install if dependencies changed.
    bootstrap_dependencies "$COMPOSE_PROJECT"

    if [ "$DB_STATE" = "fresh" ]; then
        run_install_command "$COMPOSE_PROJECT" "$SW_INSTALL_ARGS"
    elif [ $((MIGRATION_CHANGES + ENTITY_CHANGES)) -gt 0 ]; then
        info "Schema changes detected. Running migrations on cloned database."
        run_app_command "$COMPOSE_PROJECT" "$SW_BIN_CONSOLE database:migrate --all && $SW_BIN_CONSOLE database:migrate-destructive --all" || warn "Migrations failed."
    fi

    update_sales_channel_domain "$COMPOSE_PROJECT" "$APP_URL"
    ensure_install_lock "$COMPOSE_PROJECT"
    run_app_command "$COMPOSE_PROJECT" "$SW_BIN_CONSOLE cache:clear" || warn "cache:clear failed."
}

cmd_create() {
    SWCTL_MODE="${SWCTL_MODE:-dev}"
    while [ $# -gt 0 ]; do
        case "$1" in
            --qa)  SWCTL_MODE="qa"; shift ;;
            --dev) SWCTL_MODE="dev"; shift ;;
            *)     break ;;
        esac
    done
    ISSUE="${1:-}"
    BRANCH="${2:-}"
    [ -n "$ISSUE" ] || die "Usage: swctl create [--qa|--dev] <issue> [<branch>]"

    if [ -z "$BRANCH" ]; then
        if [ "$SWCTL_MODE" = "qa" ]; then
            die "QA mode requires a branch: swctl create --qa <issue> <branch>"
        fi
        # Dev mode: prompt for new branch name
        BRANCH="$(prompt_text "New branch name for issue '$ISSUE'")"
        [ -n "$BRANCH" ] || die "Branch name cannot be empty."
        info "Will create new branch '$BRANCH' from ${SW_BASE_BRANCH:-trunk}."
    fi

    require_cmd git
    ensure_docker
    load_project_config
    ensure_infra_ready

    git -C "$PROJECT_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "Project root is not a Git repository: $PROJECT_ROOT"

    ISSUE_ID="$(sanitize_slug "$ISSUE")"
    WORKTREE_ID="$ISSUE_ID"
    BASE_REF="$(git_base_ref)"
    COMPOSE_PROJECT="$(sanitize_slug "${SW_PROJECT_SLUG}-${ISSUE_ID}")"

    if [ "$SW_RUNTIME" = "orbstack" ]; then
        DOMAIN="${SW_SERVICE_NAME}.${COMPOSE_PROJECT}.orb.local"
        APP_URL="http://${DOMAIN}"
    else
        DOMAIN="${SW_PROJECT_SLUG}-${ISSUE_ID}.${SW_DOMAIN_SUFFIX}"
        APP_URL="http://${DOMAIN}"
    fi

    TRAEFIK_ROUTER="$(sanitize_router_id "${SW_PROJECT_SLUG}_${ISSUE_ID}")"
    TRAEFIK_SERVICE="$TRAEFIK_ROUTER"
    WORKTREE_PATH="${SW_WORKTREE_ROOT}/${SW_WORKTREE_PREFIX}-${ISSUE_ID}"

    create_worktree

    # Check how far behind the branch is from trunk.
    # The DB is cloned from current trunk — a stale branch may have schema mismatches.
    check_branch_staleness

    # Diff analysis drives the provisioning decision matrix:
    # what changed determines DB strategy, volume sharing, and build steps.
    DIFF_FILES="$(git -C "$PROJECT_ROOT" diff --name-only "${BASE_REF}...${BRANCH}" || true)"
    count_changes "$DIFF_FILES"

    # Resolve dependencies and sync assets AFTER diff analysis
    sync_build_artifacts
    sync_worktree_deps
    VENDOR_VOLUME="$(resolve_vendor_volume "$ISSUE_ID")"
    NODE_MODULES_VOLUME="$(resolve_node_modules_volume "$ISSUE_ID")"

    info "Mode: ${SWCTL_MODE} | Diff: migrations=${MIGRATION_CHANGES} entity=${ENTITY_CHANGES} admin=${ADMIN_CHANGES} storefront=${STOREFRONT_CHANGES} composer=${COMPOSER_CHANGES} package=${PACKAGE_CHANGES} backend=${BACKEND_CHANGES}"
    info "Strategy: vendor=${VENDOR_VOLUME} node_modules=${NODE_MODULES_VOLUME}"

    provision_database_and_app "$COMPOSE_PROJECT"
    run_frontend_build_if_needed "$COMPOSE_PROJECT"
    write_metadata "$(instance_file "$SW_PROJECT_SLUG" "$ISSUE_ID")"

    ok "Worktree '${WORKTREE_ID}' is ready."
    info "URL: ${APP_URL}"
    info "Worktree: ${WORKTREE_PATH}"
}

# ---------------------------------------------------------------------------
# Batch create
# ---------------------------------------------------------------------------

parse_batch_file() {
    local file="$1"
    [ -f "$file" ] || die "Batch file not found: $file"
    while IFS= read -r line || [ -n "$line" ]; do
        line="${line%%#*}"
        line="$(printf '%s' "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
        [ -n "$line" ] || continue
        printf '%s\n' "$line"
    done < "$file"
}

parse_cli_pairs() {
    while [ $# -ge 2 ]; do
        printf '%s %s\n' "$1" "$2"
        shift 2
    done
}

parse_mr_json() {
    if ! command -v jq >/dev/null 2>&1; then
        die "jq is required for API-based batch create. Install it with: brew install jq"
    fi
    jq -r '.[] | "\(.iid) \(.source_branch)"'
}

parse_pr_json() {
    if ! command -v jq >/dev/null 2>&1; then
        die "jq is required for API-based batch create. Install it with: brew install jq"
    fi
    jq -r '.[] | "\(.number) \(.head.ref)"'
}

fetch_gitlab_mrs() {
    local project_id="$1"
    local api_url="${SWCTL_GITLAB_URL:-https://gitlab.com}/api/v4"
    local token="${SWCTL_GITLAB_TOKEN:-}"

    [ -n "$token" ] || die "SWCTL_GITLAB_TOKEN is not set."

    curl -sSf -H "PRIVATE-TOKEN: $token" \
        "${api_url}/projects/${project_id}/merge_requests?state=opened&per_page=100" \
        | parse_mr_json
}

fetch_github_prs() {
    local repo="$1"
    local token="${SWCTL_GITHUB_TOKEN:-}"
    local auth_header=""

    if [ -n "$token" ]; then
        auth_header="Authorization: token $token"
    fi

    curl -sSf ${auth_header:+-H "$auth_header"} \
        "https://api.github.com/repos/${repo}/pulls?state=open&per_page=100" \
        | parse_pr_json
}

select_from_list() {
    local label="$1"
    local pairs=()

    while IFS= read -r line; do
        [ -n "$line" ] || continue
        pairs+=("$line")
    done

    if [ ${#pairs[@]} -eq 0 ]; then
        warn "No open ${label}s found."
        return 1
    fi

    if command -v fzf >/dev/null 2>&1; then
        printf '%s\n' "${pairs[@]}" | fzf --multi --prompt="Select ${label}s> " --height=40% --reverse
        return
    fi

    local i=1
    for pair in "${pairs[@]}"; do
        printf '  [%d] %s\n' "$i" "$pair"
        i=$((i + 1))
    done
    local selection
    selection="$(prompt_text "Enter numbers (comma-separated, or 'all')")"
    if [ "$selection" = "all" ]; then
        printf '%s\n' "${pairs[@]}"
        return
    fi
    local old_ifs="$IFS"
    IFS=',' read -r -a indices <<< "$selection"
    IFS="$old_ifs"
    local idx
    for idx in "${indices[@]}"; do
        idx="$(printf '%s' "$idx" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
        if [ "$idx" -ge 1 ] 2>/dev/null && [ "$idx" -le "${#pairs[@]}" ]; then
            printf '%s\n' "${pairs[$((idx - 1))]}"
        fi
    done
}

batch_create_sequential() {
    local pairs="$1"
    local job_dir="$2"
    local issue="" branch=""

    while IFS=' ' read -r issue branch; do
        [ -n "$issue" ] && [ -n "$branch" ] || continue
        info "Creating worktree for $issue ($branch)..."
        if cmd_create "$issue" "$branch" >"$job_dir/${issue}.log" 2>&1; then
            touch "$job_dir/${issue}.ok"
            ok "Created $issue"
        else
            touch "$job_dir/${issue}.fail"
            err "Failed $issue"
        fi
    done <<< "$pairs"
}

batch_create_parallel() {
    local pairs="$1"
    local job_dir="$2"
    local max_jobs="${3:-4}"
    local pids=()
    local running=0
    local issue="" branch=""

    while IFS=' ' read -r issue branch; do
        [ -n "$issue" ] && [ -n "$branch" ] || continue

        while [ "$running" -ge "$max_jobs" ]; do
            wait -n 2>/dev/null || true
            running=$((running - 1))
        done

        (
            cmd_create "$issue" "$branch" >"$job_dir/${issue}.log" 2>&1 \
                && touch "$job_dir/${issue}.ok" \
                || touch "$job_dir/${issue}.fail"
        ) &

        pids+=($!)
        running=$((running + 1))
        info "Started background job for $issue (PID $!)"
    done <<< "$pairs"

    local pid
    for pid in "${pids[@]}"; do
        wait "$pid" 2>/dev/null || true
    done
}

cmd_batch_create() {
    local pairs=""
    local parallel=0
    local max_jobs=4
    SWCTL_MODE="${SWCTL_MODE:-dev}"
    export SWCTL_MODE

    while [ $# -gt 0 ]; do
        case "$1" in
            --qa)
                SWCTL_MODE="qa"; shift ;;
            --dev)
                SWCTL_MODE="dev"; shift ;;
            --file|-f)
                shift
                [ -n "${1:-}" ] || die "Missing argument for --file."
                pairs="$(parse_batch_file "$1")"
                shift
                ;;
            --gitlab)
                shift
                [ -n "${1:-}" ] || die "Missing argument for --gitlab."
                pairs="$(fetch_gitlab_mrs "$1" | select_from_list "MR")"
                shift
                ;;
            --github)
                shift
                [ -n "${1:-}" ] || die "Missing argument for --github."
                pairs="$(fetch_github_prs "$1" | select_from_list "PR")"
                shift
                ;;
            --parallel|-p)
                parallel=1
                shift
                ;;
            --jobs|-j)
                shift
                [ -n "${1:-}" ] || die "Missing argument for --jobs."
                max_jobs="$1"
                shift
                ;;
            -*)
                die "Unknown flag: $1"
                ;;
            *)
                pairs="$(parse_cli_pairs "$@")"
                break
                ;;
        esac
    done

    [ -n "$pairs" ] || die "No issue/branch pairs provided.\nUsage: swctl batch create [--file <path>|--gitlab <id>|--github <owner/repo>] [--parallel [-j N]] [ISSUE BRANCH ...]"

    local total=0
    local succeeded=0
    local failed=0
    local job_dir="$SWCTL_TMP_DIR/batch.$$"
    mkdir -p "$job_dir"
    trap 'rm -rf "$job_dir"' EXIT

    total="$(printf '%s\n' "$pairs" | grep -c '.' || true)"
    info "Batch creating $total worktree(s)$([ "$parallel" -eq 1 ] && printf ' in parallel (max %s jobs)' "$max_jobs")."

    if [ "$parallel" -eq 1 ]; then
        batch_create_parallel "$pairs" "$job_dir" "$max_jobs"
    else
        batch_create_sequential "$pairs" "$job_dir"
    fi

    succeeded="$(find "$job_dir" -name '*.ok' 2>/dev/null | wc -l | tr -d ' ')"
    failed="$(find "$job_dir" -name '*.fail' 2>/dev/null | wc -l | tr -d ' ')"

    printf '\n'
    ok "Batch complete: $succeeded succeeded, $failed failed out of $total."

    local fail_file issue_id
    for fail_file in "$job_dir"/*.fail; do
        [ -f "$fail_file" ] || continue
        issue_id="$(basename "$fail_file" .fail)"
        err "Failed: $issue_id"
        cat "$job_dir/${issue_id}.log" >&2
    done

    rm -rf "$job_dir"
    trap - EXIT
    [ "$failed" -eq 0 ]
}

cmd_batch() {
    local subcmd="${1:-}"
    shift || true

    case "$subcmd" in
        create) cmd_batch_create "$@" ;;
        *)      die "Usage: swctl batch create [--file <path>|--gitlab <id>|--github <owner/repo>] [--parallel [-j N]] [ISSUE BRANCH ...]" ;;
    esac
}

truncate_text() {
    local max="$1"
    local value="$2"
    if [ "${#value}" -le "$max" ]; then
        printf '%s' "$value"
        return
    fi
    if [ "$max" -le 3 ]; then
        printf '%s' "${value:0:$max}"
        return
    fi
    printf '%s...' "${value:0:$((max - 3))}"
}

status_label() {
    local compose_project="$1"
    if [ -n "$(app_container_id "$compose_project")" ]; then
        printf '%b● Running%b' "$COLOR_GREEN" "$COLOR_RESET"
        return
    fi

    if [ -n "$(app_container_exists_any_state "$compose_project")" ]; then
        printf '%b○ Stopped%b' "$COLOR_RED" "$COLOR_RESET"
        return
    fi

    printf '%b○ Missing%b' "$COLOR_YELLOW" "$COLOR_RESET"
}

render_status_table() {
    local scope="${1:-all}"
    local file=""
    local found=0

    printf '%-24s %-4s %-40s %-16s %-8s\n' "Issue" "Mode" "Domain" "Container" "DB"
    printf '%-24s %-4s %-40s %-16s %-8s\n' "------------------------" "----" "----------------------------------------" "----------------" "--------"

    while IFS= read -r file; do
        [ -n "$file" ] || continue
        found=1
        load_instance_metadata "$file"
        printf '%-24s %-4s %-40s %-16b %-8s\n' \
            "$(truncate_text 24 "$ISSUE_ID")" \
            "${SWCTL_MODE:-dev}" \
            "$(truncate_text 40 "$DOMAIN")" \
            "$(status_label "$COMPOSE_PROJECT")" \
            "$DB_STATE"
    done <<EOF
$(list_instance_files "$scope")
EOF

    if [ "$found" -eq 0 ]; then
        printf '%s\n' "No tracked worktrees."
    fi
}

cmd_status() {
    if maybe_load_project_config >/dev/null 2>&1; then
        render_status_table "project"
        return
    fi

    render_status_table "all"
}

cmd_exec() {
    local issue_input="${1:-}"
    local command_string="${2:-}"
    local meta_file=""

    [ -n "$issue_input" ] || die "Usage: swctl exec <issue> '<cmd>'"
    [ -n "$command_string" ] || die "Usage: swctl exec <issue> '<cmd>'"

    maybe_load_project_config >/dev/null 2>&1 || true
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || die "No tracked worktree found for issue '$issue_input'."
    load_instance_metadata "$meta_file"
    run_app_command "$COMPOSE_PROJECT" "$command_string"
}

cmd_logs() {
    local issue_input="${1:-}"
    local follow="${2:-}"
    local meta_file=""

    [ -n "$issue_input" ] || die "Usage: swctl logs <issue> [--follow|-f]"

    maybe_load_project_config >/dev/null 2>&1 || true
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || die "No tracked worktree found for issue '$issue_input'."
    load_instance_metadata "$meta_file"

    local container_id
    container_id="$(app_container_id "$COMPOSE_PROJECT")"
    [ -n "$container_id" ] || die "No running container for '$COMPOSE_PROJECT'."

    if [ "$follow" = "--follow" ] || [ "$follow" = "-f" ]; then
        docker logs -f "$container_id"
    else
        docker logs --tail 100 "$container_id"
    fi
}

cmd_restart() {
    local issue_input="${1:-}"
    local meta_file=""

    [ -n "$issue_input" ] || die "Usage: swctl restart <issue>"

    maybe_load_project_config >/dev/null 2>&1 || true
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || die "No tracked worktree found for issue '$issue_input'."
    load_instance_metadata "$meta_file"

    if [ -f "$COMPOSE_ENV_FILE" ] && [ -f "$COMPOSE_TEMPLATE" ]; then
        compose --project-directory "$SWCTL_TMP_DIR" -f "$COMPOSE_TEMPLATE" ${COMPOSE_VOLUME_OVERRIDE:+-f "$COMPOSE_VOLUME_OVERRIDE"} --env-file "$COMPOSE_ENV_FILE" -p "$COMPOSE_PROJECT" restart
    else
        local container_id
        container_id="$(app_container_exists_any_state "$COMPOSE_PROJECT" || true)"
        [ -n "$container_id" ] || die "No container found for '$COMPOSE_PROJECT'."
        docker restart "$container_id"
    fi
    ok "Restarted '$ISSUE_ID'."
}

cmd_refresh() {
    local issue_input="${1:-}"
    local meta_file=""

    [ -n "$issue_input" ] || die "Usage: swctl refresh <issue>"

    maybe_load_project_config >/dev/null 2>&1 || true
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || die "No tracked worktree found for issue '$issue_input'."
    load_instance_metadata "$meta_file"

    # Remember the old HEAD before pulling
    local old_head
    old_head="$(git -C "$WORKTREE_PATH" rev-parse HEAD 2>/dev/null)"

    # Pull latest changes
    info "Pulling latest changes for '$ISSUE_ID' (branch: $BRANCH)."
    git -C "$WORKTREE_PATH" pull --ff-only origin "$BRANCH" 2>/dev/null \
        || git -C "$WORKTREE_PATH" fetch origin "$BRANCH" && git -C "$WORKTREE_PATH" reset --hard "origin/$BRANCH" 2>/dev/null \
        || warn "Could not pull latest changes. Continuing with current state."

    local new_head
    new_head="$(git -C "$WORKTREE_PATH" rev-parse HEAD 2>/dev/null)"

    if [ "$old_head" = "$new_head" ]; then
        info "No new commits. Nothing to refresh."
        return
    fi

    ok "Updated $old_head → $new_head"

    # Diff between old and new HEAD to detect what changed
    local diff_files
    diff_files="$(git -C "$WORKTREE_PATH" diff --name-only "$old_head...$new_head" 2>/dev/null || true)"
    count_changes "$diff_files"

    info "Changes since last build: migrations=${MIGRATION_CHANGES} entity=${ENTITY_CHANGES} admin=${ADMIN_CHANGES} storefront=${STOREFRONT_CHANGES} composer=${COMPOSER_CHANGES} package=${PACKAGE_CHANGES} backend=${BACKEND_CHANGES}"

    # Re-sync gitignored files if needed
    sync_build_artifacts

    local compose_project="$COMPOSE_PROJECT"

    # Run migrations if schema changed
    if [ $((MIGRATION_CHANGES + ENTITY_CHANGES)) -gt 0 ]; then
        info "Schema changes detected. Running migrations."
        run_app_command "$compose_project" "$SW_BIN_CONSOLE database:migrate --all && $SW_BIN_CONSOLE database:migrate-destructive --all" || warn "Migrations failed."
    fi

    # Composer install if dependencies changed (dev mode only)
    if [ "$((COMPOSER_CHANGES))" -gt 0 ] && [ "${SWCTL_MODE:-dev}" = "dev" ]; then
        info "Composer changes detected. Running composer install."
        run_app_command "$compose_project" "composer install --no-interaction" || warn "Composer install failed."
    fi

    # Rebuild frontend if admin/storefront changed
    if [ "${ADMIN_CHANGES:-0}" -gt 0 ]; then
        info "Admin changes detected. Running composer build:js:admin."
        run_app_command "$compose_project" "composer build:js:admin" || warn "Admin JS build failed."
    fi

    if [ "${STOREFRONT_CHANGES:-0}" -gt 0 ]; then
        info "Storefront changes detected. Running composer build:js:storefront."
        run_app_command "$compose_project" "composer build:js:storefront" || warn "Storefront JS build failed."
    fi

    # Always clear cache after any update
    run_app_command "$compose_project" "$SW_BIN_CONSOLE cache:clear" || warn "cache:clear failed."

    # Update metadata with new HEAD
    write_metadata "$meta_file"

    ok "Refreshed '$ISSUE_ID'. Changes applied."
    info "URL: ${APP_URL}"
}

cmd_open() {
    local issue_input="${1:-}"
    local meta_file=""

    [ -n "$issue_input" ] || die "Usage: swctl open <issue>"

    maybe_load_project_config >/dev/null 2>&1 || true
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || die "No tracked worktree found for issue '$issue_input'."
    load_instance_metadata "$meta_file"

    local url="${APP_URL:-http://$DOMAIN}"
    info "Opening $url"
    if command -v open >/dev/null 2>&1; then
        open "$url"
    elif command -v xdg-open >/dev/null 2>&1; then
        xdg-open "$url"
    else
        warn "No browser opener found. Visit: $url"
    fi
}

cmd_code() {
    local issue_input="${1:-}"
    local meta_file=""

    [ -n "$issue_input" ] || die "Usage: swctl code <issue>"

    maybe_load_project_config >/dev/null 2>&1 || true
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || die "No tracked worktree found for issue '$issue_input'."
    load_instance_metadata "$meta_file"

    info "Opening '$WORKTREE_PATH' in PhpStorm."
    if command -v phpstorm >/dev/null 2>&1; then
        phpstorm "$WORKTREE_PATH"
    elif command -v pstorm >/dev/null 2>&1; then
        pstorm "$WORKTREE_PATH"
    elif [ -x "$HOME/Library/Application Support/JetBrains/Toolbox/scripts/phpstorm" ]; then
        "$HOME/Library/Application Support/JetBrains/Toolbox/scripts/phpstorm" "$WORKTREE_PATH"
    else
        warn "PhpStorm not found. Open manually: $WORKTREE_PATH"
    fi
}

cmd_switch() {
    local target_mode=""
    local issue_input=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --qa)  target_mode="qa"; shift ;;
            --dev) target_mode="dev"; shift ;;
            *)     issue_input="$1"; shift ;;
        esac
    done

    [ -n "$issue_input" ] || die "Usage: swctl switch <issue> --qa|--dev"
    [ -n "$target_mode" ] || die "Usage: swctl switch <issue> --qa|--dev"

    maybe_load_project_config >/dev/null 2>&1 || true
    local meta_file
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || die "No tracked worktree found for issue '$issue_input'."
    load_instance_metadata "$meta_file"

    local current_mode="${SWCTL_MODE:-dev}"
    if [ "$current_mode" = "$target_mode" ]; then
        info "Already in '$target_mode' mode. Nothing to do."
        return
    fi

    SWCTL_MODE="$target_mode"
    info "Switching '$ISSUE_ID' from $current_mode → $target_mode mode."

    # Re-run diff analysis for the worktree
    local base_ref
    base_ref="$(git_base_ref)"
    local diff_files
    diff_files="$(git -C "$WORKTREE_PATH" diff --name-only "${base_ref}...HEAD" 2>/dev/null || true)"
    count_changes "$diff_files"

    if [ "$target_mode" = "dev" ]; then
        # QA → Dev: need writable vendor + run any missing builds

        # Replace vendor symlink/bind-mount with a real writable copy
        if [ -L "$WORKTREE_PATH/vendor" ] || [ ! -d "$WORKTREE_PATH/vendor/autoload.php" ]; then
            info "Copying vendor/ for writable dev mode."
            rm -f "$WORKTREE_PATH/vendor" 2>/dev/null || true
            if [ -d "$PROJECT_ROOT/vendor" ]; then
                cp -cR "$PROJECT_ROOT/vendor" "$WORKTREE_PATH/vendor" 2>/dev/null || \
                    cp -R "$PROJECT_ROOT/vendor" "$WORKTREE_PATH/vendor"
            fi
        fi

        # Recreate compose override without QA vendor bind mount
        write_compose_volume_override

        # Restart container with new volume config
        compose --project-directory "$SWCTL_TMP_DIR" -f "$SW_COMPOSE_TEMPLATE" -f "$COMPOSE_VOLUME_OVERRIDE" --env-file "$COMPOSE_ENV_FILE" -p "$COMPOSE_PROJECT" up -d
        wait_for_app_container "$COMPOSE_PROJECT"

        # Run composer install if deps changed
        if [ "$((COMPOSER_CHANGES))" -gt 0 ]; then
            info "Running composer install for dev mode."
            run_app_command "$COMPOSE_PROJECT" "composer install --no-interaction" || warn "Composer install failed."
        fi

        # Run builds that QA skipped
        run_frontend_build_if_needed "$COMPOSE_PROJECT"

    else
        # Dev → QA: switch to read-only vendor, lighter container

        # Recreate compose override with QA vendor bind mount
        write_compose_volume_override

        # Restart container with new volume config
        compose --project-directory "$SWCTL_TMP_DIR" -f "$SW_COMPOSE_TEMPLATE" -f "$COMPOSE_VOLUME_OVERRIDE" --env-file "$COMPOSE_ENV_FILE" -p "$COMPOSE_PROJECT" up -d
        wait_for_app_container "$COMPOSE_PROJECT"
        run_app_command "$COMPOSE_PROJECT" "$SW_BIN_CONSOLE cache:clear" 2>/dev/null || true
    fi

    # Update metadata with new mode
    write_metadata "$meta_file"

    ok "Switched '$ISSUE_ID' to $target_mode mode."
    info "URL: ${APP_URL}"
}

remove_labeled_volumes() {
    local volumes
    volumes="$(docker volume ls -q --filter "label=swctl.managed=true" --filter "label=swctl.project=${PROJECT_SLUG}" --filter "label=swctl.issue=${ISSUE_ID}" || true)"
    if [ -n "$volumes" ]; then
        # shellcheck disable=SC2086
        docker volume rm $volumes >/dev/null || true
        ok "Removed worktree volumes for '${ISSUE_ID}'."
    else
        info "No labeled worktree volumes found for '${ISSUE_ID}'."
    fi
}

cmd_clean() {
    local issue_input="${1:-}"
    local meta_file=""

    [ -n "$issue_input" ] || die "Usage: swctl clean <issue>"
    maybe_load_project_config >/dev/null 2>&1 || true

    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || {
        warn "No tracked worktree found for issue '$issue_input'. Nothing to clean."
        return 0
    }

    load_instance_metadata "$meta_file"

    # 1. Stop and remove ALL containers belonging to this compose project
    local containers
    containers="$(docker ps -aq --filter "label=com.docker.compose.project=${COMPOSE_PROJECT}" 2>/dev/null || true)"
    if [ -n "$containers" ]; then
        # shellcheck disable=SC2086
        docker rm -f $containers >/dev/null 2>&1 || true
        ok "Removed containers for '${COMPOSE_PROJECT}'."
    fi

    # 2. Remove ALL volumes belonging to this compose project
    local volumes
    volumes="$(docker volume ls -q --filter "label=com.docker.compose.project=${COMPOSE_PROJECT}" 2>/dev/null || true)"
    if [ -n "$volumes" ]; then
        # shellcheck disable=SC2086
        docker volume rm $volumes >/dev/null 2>&1 || true
        ok "Removed compose volumes for '${COMPOSE_PROJECT}'."
    fi

    # Also remove any swctl-labeled volumes for this issue
    remove_labeled_volumes

    # 3. Remove Docker networks created by this compose project
    local networks
    networks="$(docker network ls -q --filter "label=com.docker.compose.project=${COMPOSE_PROJECT}" 2>/dev/null || true)"
    if [ -n "$networks" ]; then
        # shellcheck disable=SC2086
        docker network rm $networks >/dev/null 2>&1 || true
        ok "Removed networks for '${COMPOSE_PROJECT}'."
    fi

    # 4. Drop the cloned database (never touches the source)
    local source_db
    source_db="$(sanitize_db_identifier "${SW_DB_SHARED_NAME:-shopware}")"
    if [ -n "$DB_NAME" ] && [ "$DB_NAME" != "$source_db" ]; then
        mysql_exec "DROP DATABASE IF EXISTS \`${DB_NAME}\`;" >/dev/null 2>&1 || warn "Could not drop database '${DB_NAME}'."
        ok "Dropped database '${DB_NAME}'."
    fi

    # 5. Remove the git worktree
    if [ -d "$WORKTREE_PATH" ] && git -C "$PROJECT_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        git -C "$PROJECT_ROOT" worktree remove --force "$WORKTREE_PATH" >/dev/null 2>&1 || warn "Could not remove worktree '${WORKTREE_PATH}'."
        ok "Removed worktree '${WORKTREE_PATH}'."
    else
        info "Worktree path '${WORKTREE_PATH}' is already absent."
    fi

    # 6. Clean up generated files in tmp
    rm -f "$SWCTL_TMP_DIR/${COMPOSE_PROJECT}.compose.env" \
          "$SWCTL_TMP_DIR/${COMPOSE_PROJECT}.volumes.override.yml" \
          2>/dev/null || true

    rm -f "$meta_file"
    ok "Cleaned issue '${ISSUE_ID}'."
}

count_registry_entries() {
    find "$SWCTL_REGISTRY_DIR" -type f -name '*.env' 2>/dev/null | wc -l | tr -d ' '
}

count_running_swctl_containers() {
    (docker ps -q --filter label=swctl.managed=true 2>/dev/null || true) | wc -l | tr -d ' '
}

count_unique_dbs() {
    local tmp_file="$SWCTL_TMP_DIR/dbs.$$"
    : >"$tmp_file"

    while IFS= read -r file; do
        [ -n "$file" ] || continue
        load_instance_metadata "$file"
        printf '%s\n' "$DB_NAME" >>"$tmp_file"
    done <<EOF
$(list_instance_files "all")
EOF

    if [ ! -s "$tmp_file" ]; then
        rm -f "$tmp_file"
        printf '0\n'
        return
    fi

    sort -u "$tmp_file" | wc -l | tr -d ' '
    rm -f "$tmp_file"
}

clear_screen() {
    printf '\033[2J\033[H'
}

hide_cursor() {
    command -v tput >/dev/null 2>&1 && tput civis >/dev/null 2>&1 || true
}

show_cursor() {
    command -v tput >/dev/null 2>&1 && tput cnorm >/dev/null 2>&1 || true
}

tui_cleanup() {
    show_cursor
    printf '%b' "$COLOR_RESET"
}

prompt_text() {
    local prompt="$1"
    local secret="${2:-0}"
    local answer=""

    if command -v gum >/dev/null 2>&1; then
        if [ "$secret" = "1" ]; then
            answer="$(gum input --password --placeholder "$prompt")"
        else
            answer="$(gum input --placeholder "$prompt")"
        fi
        printf '%s' "$answer"
        return
    fi

    if [ "$secret" = "1" ]; then
        read -r -s -p "$prompt: " answer
        printf '\n' >&2
    else
        read -r -p "$prompt: " answer
    fi
    printf '%s' "$answer"
}

select_issue_prompt() {
    local scope="${1:-all}"
    local choices_file="$SWCTL_TMP_DIR/issues.$$"
    local selected=""
    local file=""

    : >"$choices_file"
    while IFS= read -r file; do
        [ -n "$file" ] || continue
        load_instance_metadata "$file"
        printf '%s\t%s\t%s\n' "$ISSUE_ID" "$PROJECT" "$DOMAIN" >>"$choices_file"
    done <<EOF
$(list_instance_files "$scope")
EOF

    if [ ! -s "$choices_file" ]; then
        rm -f "$choices_file"
        return 1
    fi

    if command -v fzf >/dev/null 2>&1; then
        selected="$(cut -f1 "$choices_file" | fzf --prompt='Issue> ' --height=40% --reverse || true)"
    else
        printf '%s\n' "Available issues:"
        cut -f1 "$choices_file"
        selected="$(prompt_text "Enter issue id")"
    fi

    rm -f "$choices_file"
    [ -n "$selected" ] || return 1
    printf '%s\n' "$selected"
}

pause_for_key() {
    printf '\n'
    read -r -n 1 -p "Press any key to continue..." _
    printf '\n'
}

render_tui_header() {
    printf '%b%s%b\n' "$COLOR_BOLD" "swctl TUI Dashboard" "$COLOR_RESET"
    printf '%s\n' "Date: $(date '+%Y-%m-%d %H:%M:%S')"
    printf '%s\n' "Worktrees: $(count_registry_entries)  |  Running containers: $(count_running_swctl_containers)  |  Databases: $(count_unique_dbs)"
    printf '\n'
}

render_tui_menu() {
    printf '%s\n' "[1] Init infra    [2] Create worktree    [3] Status"
    printf '%s\n' "[4] Exec command  [5] Clean worktree     [6] Live dashboard"
    printf '%s\n' "[7] Logs          [8] Restart            [9] Open in browser"
    printf '%s\n' "[r] Refresh       [q] Quit"
    printf '\n'
}

tui_create_flow() {
    local issue_input=""
    local branch_input=""

    issue_input="$(prompt_text "Issue id")"
    [ -n "$issue_input" ] || {
        warn "Issue id cannot be empty."
        return
    }

    branch_input="$(prompt_text "Branch name")"
    [ -n "$branch_input" ] || {
        warn "Branch name cannot be empty."
        return
    }

    cmd_create "$issue_input" "$branch_input"
}

tui_exec_flow() {
    local scope="all"
    local issue_input=""
    local command_string=""

    if maybe_load_project_config >/dev/null 2>&1; then
        scope="project"
    fi

    issue_input="$(select_issue_prompt "$scope" || true)"
    if [ -z "$issue_input" ]; then
        warn "No issue selected."
        return
    fi

    command_string="$(prompt_text "Command to run inside app")"
    [ -n "$command_string" ] || {
        warn "Command cannot be empty."
        return
    }

    cmd_exec "$issue_input" "$command_string"
}

tui_clean_flow() {
    local scope="all"
    local issue_input=""

    if maybe_load_project_config >/dev/null 2>&1; then
        scope="project"
    fi

    issue_input="$(select_issue_prompt "$scope" || true)"
    if [ -z "$issue_input" ]; then
        warn "No issue selected."
        return
    fi

    cmd_clean "$issue_input"
}

tui_logs_flow() {
    local scope="all"
    local issue_input=""

    if maybe_load_project_config >/dev/null 2>&1; then
        scope="project"
    fi

    issue_input="$(select_issue_prompt "$scope" || true)"
    if [ -z "$issue_input" ]; then
        warn "No issue selected."
        return
    fi

    cmd_logs "$issue_input" "--follow"
}

tui_restart_flow() {
    local scope="all"
    local issue_input=""

    if maybe_load_project_config >/dev/null 2>&1; then
        scope="project"
    fi

    issue_input="$(select_issue_prompt "$scope" || true)"
    if [ -z "$issue_input" ]; then
        warn "No issue selected."
        return
    fi

    cmd_restart "$issue_input"
}

tui_open_flow() {
    local scope="all"
    local issue_input=""

    if maybe_load_project_config >/dev/null 2>&1; then
        scope="project"
    fi

    issue_input="$(select_issue_prompt "$scope" || true)"
    if [ -z "$issue_input" ]; then
        warn "No issue selected."
        return
    fi

    cmd_open "$issue_input"
}

cmd_tui() {
    local choice=""

    trap 'tui_cleanup; exit 0' EXIT INT TERM
    hide_cursor

    while true; do
        clear_screen
        render_tui_header
        render_status_table "all"
        printf '\n'
        render_tui_menu
        printf '%bChoose an action [1-9, r, q]: %b' "$COLOR_BLUE" "$COLOR_RESET"
        read -r -n 1 choice
        printf '\n\n'

        case "$choice" in
            1) init_infra; pause_for_key ;;
            2) tui_create_flow; pause_for_key ;;
            3) cmd_status; pause_for_key ;;
            4) tui_exec_flow; pause_for_key ;;
            5) tui_clean_flow; pause_for_key ;;
            6) cmd_dashboard ;;
            7) tui_logs_flow; pause_for_key ;;
            8) tui_restart_flow; pause_for_key ;;
            9) tui_open_flow; pause_for_key ;;
            r|R) ;;
            q|Q) break ;;
            *) warn "Unknown option: $choice"; pause_for_key ;;
        esac
    done

    tui_cleanup
    trap - EXIT INT TERM
}

db_size_mb() {
    local db_name="$1"
    mysql_exec "SELECT ROUND(IFNULL(SUM(data_length + index_length), 0) / 1024 / 1024, 1) FROM information_schema.TABLES WHERE table_schema='${db_name}';" 2>/dev/null || printf 'n/a'
}

render_dashboard_db_sizes() {
    local file=""
    local seen_file="$SWCTL_TMP_DIR/seen-dbs.$$"
    : >"$seen_file"

    printf '%bDatabase Sizes%b\n' "$COLOR_BOLD" "$COLOR_RESET"
    printf '%-24s %-10s %-10s\n' "Database" "State" "Size(MB)"
    printf '%-24s %-10s %-10s\n' "------------------------" "----------" "----------"

    while IFS= read -r file; do
        [ -n "$file" ] || continue
        load_instance_metadata "$file"
        if grep -Fxq "$DB_NAME" "$seen_file" 2>/dev/null; then
            continue
        fi
        printf '%s\n' "$DB_NAME" >>"$seen_file"
        printf '%-24s %-10s %-10s\n' "$DB_NAME" "$DB_STATE" "$(db_size_mb "$DB_NAME")"
    done <<EOF
$(list_instance_files "all")
EOF

    if [ ! -s "$seen_file" ]; then
        printf '%s\n' "No tracked databases."
    fi

    rm -f "$seen_file"
}

render_dashboard_containers() {
    local container_ids=""

    container_ids="$(docker ps -q --filter label=swctl.managed=true || true)"
    printf '%bContainer Stats%b\n' "$COLOR_BOLD" "$COLOR_RESET"
    if [ -z "$container_ids" ]; then
        printf '%s\n' "No running swctl-managed containers."
        return
    fi

    # docker stats powers the live CPU/memory panel without extra dependencies.
    # shellcheck disable=SC2086
    docker stats --no-stream --format 'table {{.Name}}\t{{.CPUPerc}}\t{{.MemUsage}}' $container_ids
}

render_dashboard_worktrees() {
    printf '\n%bWorktree Status%b\n' "$COLOR_BOLD" "$COLOR_RESET"
    render_status_table "all"
}

cmd_dashboard() {
    local running=1

    trap 'running=0' INT TERM
    while [ "$running" -eq 1 ]; do
        clear_screen
        printf '%b%s%b\n' "$COLOR_BOLD" "swctl Live Dashboard" "$COLOR_RESET"
        printf '%s\n\n' "Updated: $(date '+%Y-%m-%d %H:%M:%S')"
        render_dashboard_containers
        printf '\n'
        render_dashboard_db_sizes
        render_dashboard_worktrees
        printf '\n%s\n' "Press Ctrl+C to exit."

        local tick=0
        while [ "$tick" -lt 5 ] && [ "$running" -eq 1 ]; do
            sleep 1
            tick=$((tick + 1))
        done
    done

    trap - INT TERM
    printf '\n'
}

cmd_build_base() {
    load_project_config
    ensure_docker
    ensure_infra_ready

    local vendor_base="vendor-base-${SW_PROJECT_SLUG}"
    local node_base="node_modules-base-${SW_PROJECT_SLUG}"
    local tmp_project="swctl-base-build-$$"
    local tmp_env="$SWCTL_TMP_DIR/base-build.env"

    info "Building base volumes for project '${SW_PROJECT_SLUG}'."

    # Create volumes if they don't exist
    docker volume inspect "$vendor_base" >/dev/null 2>&1 || docker volume create "$vendor_base" >/dev/null
    docker volume inspect "$node_base" >/dev/null 2>&1 || docker volume create "$node_base" >/dev/null

    # Write minimal compose env for base build
    cat >"$tmp_env" <<ENVEOF
SW_PHP_IMAGE=${SW_PHP_IMAGE}
SW_WORKTREE_PATH=${PROJECT_ROOT}
SW_WORKTREE_ID=base
SW_PROJECT=${SW_PROJECT}
SW_ISSUE=base
SW_PROJECT_SLUG=${SW_PROJECT_SLUG}
SW_APP_DOMAIN=localhost
SW_APP_URL=http://localhost
SW_APP_HTTP_PORT=${SW_APP_HTTP_PORT}
SW_TRAEFIK_NETWORK=${SW_TRAEFIK_NETWORK}
SW_TRAEFIK_ROUTER=swctl_base
SW_TRAEFIK_SERVICE=swctl_base
SW_DB_HOST=${SW_DB_HOST}
SW_DB_PORT=${SW_DB_PORT}
SW_DB_NAME=swctl_base_tmp
SW_DB_ROOT_USER=${SW_DB_ROOT_USER}
SW_DB_ROOT_PASSWORD=${SW_DB_ROOT_PASSWORD}
SW_REDIS_URL=${SW_REDIS_URL}
SW_MAILER_DSN=${SW_MAILER_DSN}
SW_VENDOR_VOLUME=${vendor_base}
SW_NODE_MODULES_VOLUME=${node_base}
SW_UID=${SW_UID}
SW_GID=${SW_GID}
SW_DOCKER_PLATFORM=${SW_DOCKER_PLATFORM}
SW_COMPOSER_ROOT_VERSION=${SW_COMPOSER_ROOT_VERSION}
ENVEOF

    # Start temporary container with base volumes
    compose --project-directory "$SWCTL_TMP_DIR" \
        -f "$SW_COMPOSE_TEMPLATE" --env-file "$tmp_env" \
        -p "$tmp_project" up -d

    wait_for_app_container "$tmp_project"
    fix_volume_ownership "$tmp_project"

    info "Running composer install into base vendor volume."
    run_app_command "$tmp_project" "composer install --no-interaction" || warn "composer install failed."

    local pkg_cmd
    pkg_cmd="$(detect_package_install_command "$PROJECT_ROOT" || true)"
    if [ -n "$pkg_cmd" ]; then
        info "Running $pkg_cmd into base node_modules volume."
        run_app_command "$tmp_project" "$pkg_cmd" || warn "Node install failed."
    fi

    # Tear down temporary container
    compose --project-directory "$SWCTL_TMP_DIR" \
        -f "$SW_COMPOSE_TEMPLATE" --env-file "$tmp_env" \
        -p "$tmp_project" down --remove-orphans >/dev/null || true

    rm -f "$tmp_env"
    ok "Base volumes populated: $vendor_base, $node_base"
}

cmd_clean_base() {
    load_project_config
    local vendor_base="vendor-base-${SW_PROJECT_SLUG}"
    local node_base="node_modules-base-${SW_PROJECT_SLUG}"
    docker volume rm "$vendor_base" 2>/dev/null && ok "Removed $vendor_base" || info "$vendor_base not found."
    docker volume rm "$node_base" 2>/dev/null && ok "Removed $node_base" || info "$node_base not found."
}

show_help() {
    cat <<EOF
swctl ${SWCTL_VERSION}

Usage:
  swctl init
  swctl create [--qa|--dev] <issue> [<branch>]
  swctl batch create [--file <path>|--gitlab <id>|--github <owner/repo>] [--parallel [-j N]] [ISSUE BRANCH ...]
  swctl status
  swctl exec <issue> '<cmd>'
  swctl logs <issue> [--follow|-f]
  swctl restart <issue>
  swctl refresh <issue>
  swctl open <issue>
  swctl code <issue>
  swctl switch <issue> --qa|--dev
  swctl clean <issue>
  swctl tui
  swctl dashboard
  swctl --version
  swctl help

Commands:
  init        Idempotent setup of Traefik, MariaDB, Redis, and the swctl Docker network.
  create      Create a worktree. --qa: auto-build everything needed (vendor from trunk). --dev: writable vendor (default).
  batch       Batch create worktrees from CLI pairs, a file, or GitLab/GitHub MRs.
  status      Show tracked worktrees, routed domains, container state, and DB mode.
  exec        Execute a command inside the worktree's app container.
  logs        Show or follow container logs for a worktree.
  restart     Restart the app container for a worktree without full recreate.
  refresh     Pull latest changes, detect what changed, rebuild only the delta.
  open        Open the worktree URL in the default browser.
  code        Open the worktree in PhpStorm.
  switch      Switch a worktree between QA and Dev mode (rebuilds only what's needed).
  clean       Stop the container, remove labeled volumes, drop dedicated DBs, and remove the worktree.
  tui         Open the interactive ANSI dashboard.
  dashboard   Open the live monitoring dashboard.
  build-base  Pre-populate shared vendor and node_modules base volumes from the project root.
  clean-base  Remove shared base volumes for the current project.

Environment:
  swctl auto-detects .swctl.conf in the current directory or a parent directory.
  Set SWCTL_TEMPLATE_DIR if docker-compose.swctl.yml lives beside the installed binary.
EOF
}

cmd_version() {
    printf 'swctl %s\n' "$SWCTL_VERSION"
}

main() {
    local command="${1:-help}"

    case "$command" in
        init)
            ensure_state_dirs
            init_infra
            ;;
        create)
            ensure_state_dirs
            shift
            cmd_create "$@"
            ;;
        batch)
            ensure_state_dirs
            shift
            cmd_batch "$@"
            ;;
        status)
            ensure_state_dirs
            cmd_status
            ;;
        exec)
            ensure_state_dirs
            shift
            cmd_exec "${1:-}" "${2:-}"
            ;;
        clean)
            ensure_state_dirs
            shift
            cmd_clean "${1:-}"
            ;;
        logs)
            ensure_state_dirs
            shift
            cmd_logs "${1:-}" "${2:-}"
            ;;
        restart)
            ensure_state_dirs
            shift
            cmd_restart "${1:-}"
            ;;
        refresh)
            ensure_state_dirs
            shift
            cmd_refresh "${1:-}"
            ;;
        open)
            ensure_state_dirs
            shift
            cmd_open "${1:-}"
            ;;
        code)
            ensure_state_dirs
            shift
            cmd_code "${1:-}"
            ;;
        switch)
            ensure_state_dirs
            shift
            cmd_switch "$@"
            ;;
        tui)
            ensure_state_dirs
            cmd_tui
            ;;
        dashboard)
            ensure_state_dirs
            cmd_dashboard
            ;;
        build-base)
            ensure_state_dirs
            cmd_build_base
            ;;
        clean-base)
            ensure_state_dirs
            cmd_clean_base
            ;;
        --version|-v)
            cmd_version
            ;;
        help|-h|--help)
            show_help
            ;;
        *)
            die "Unknown command: $command"
            ;;
    esac
}

if [ "${SWCTL_SOURCED:-0}" != "1" ]; then
    main "$@"
fi
