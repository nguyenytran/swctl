        # Claude Code resolve session tracking
        printf 'CLAUDE_SESSION_ID=%q\n' "${CLAUDE_SESSION_ID:-}"
        printf 'CLAUDE_RESOLVE_STATUS=%q\n' "${CLAUDE_RESOLVE_STATUS:-}"
        printf 'CLAUDE_RESOLVE_STEP=%q\n' "${CLAUDE_RESOLVE_STEP:-}"
        printf 'CLAUDE_RESOLVE_STARTED=%q\n' "${CLAUDE_RESOLVE_STARTED:-}"
        printf 'CLAUDE_RESOLVE_COST=%q\n' "${CLAUDE_RESOLVE_COST:-0}"
        # Which AI CLI backend (claude|codex) drove this resolve session.
        # Defaults to claude for backwards compat with pre-v0.5.7 metadata —
        # any instance without RESOLVE_BACKEND is assumed claude at load time.
        printf 'RESOLVE_BACKEND=%q\n' "${RESOLVE_BACKEND:-claude}"
    } >"$meta_file"
}

resolve_instance_file_by_issue() {
    local issue_input="$1"
    local issue_id
    local hits
    local first_hit

    issue_id="$(sanitize_slug "$issue_input")"
    hits=""

    while IFS= read -r file; do
        if [ -n "$hits" ]; then
            hits="${hits}
$file"
        else
            hits="$file"
        fi
    done <<EOF
$(find "$SWCTL_REGISTRY_DIR" -type f -path "*/${issue_id}.env" 2>/dev/null | sort)
EOF

    if [ -z "$hits" ]; then
        return 1
    fi

    first_hit="$(printf '%s\n' "$hits" | sed -n '1p')"
    if [ -n "${SW_PROJECT_SLUG:-}" ]; then
        if [ -f "$(instance_file "$SW_PROJECT_SLUG" "$issue_id")" ]; then
            printf '%s\n' "$(instance_file "$SW_PROJECT_SLUG" "$issue_id")"
            return 0
        fi
    fi

    if [ "$(printf '%s\n' "$hits" | grep -c '.' || true)" -gt 1 ]; then
        err "Issue '$issue_input' exists in multiple projects."
        printf '%s\n' "$hits" >&2
        return 1
    fi

    printf '%s\n' "$first_hit"
    return 0
}

# --- Orphan-state recovery ----------------------------------------------------
#
# When a `swctl create` (typically driven by `swctl resolve`) crashes after
# `git worktree add -b <branch>` but before writing the metadata env file,
# subsequent `swctl clean <issue>` invocations bail with "no tracked
# worktree found" — even though the half-baked branch (and sometimes a bare
# directory) still blocks the next create.  This helper sweeps that state.
#
# What it removes:
#   - PROJECT_ROOT branches matching the issue id pattern
#       fix/<id>     feat/<id>     chore/<id>
#       fix/<id>-*   feat/<id>-*   chore/<id>-*
#     (only when the branch has zero commits ahead of $BASE_REF; with
#     --force, deletion is unconditional).
#   - The default worktree path "$SW_WORKTREE_ROOT/sw-<id>" if it exists on
#     disk but isn't registered with `git worktree list`.
#
# Returns 0 if it found and acted on anything (caller treats as a success
# clean); 1 if there was no orphan state (caller falls through to its
# "nothing to clean" warning).
#
# Safe to call even when PROJECT_ROOT or SW_WORKTREE_ROOT are unset — both
# paths short-circuit and the function returns 1.
_clean_orphan_state() {
    local issue_input="$1"
    local force="${2:-0}"
    local issue_id
    issue_id="$(sanitize_slug "$issue_input")"

    [ -n "$issue_id" ] || return 1
    [ -n "${PROJECT_ROOT:-}" ] || return 1
    [ -d "${PROJECT_ROOT}/.git" ] || [ -f "${PROJECT_ROOT}/.git" ] || return 1

    local found=0

    # 1. Orphan worktree directory — exists on disk but not registered.
    # Compare canonical paths in both directions: on macOS `/var/folders/…`
    # resolves to `/private/var/folders/…`, and `git worktree list` prints
    # the resolved form, so a literal grep would always think the dir is
    # unregistered.
    if [ -n "${SW_WORKTREE_ROOT:-}" ]; then
        local default_path="$SW_WORKTREE_ROOT/sw-${issue_id}"
        if [ -d "$default_path" ]; then
            local default_real registered=0
            default_real="$(cd "$default_path" 2>/dev/null && pwd -P)"
            local _wt_line _wt_path _wt_real
            while IFS= read -r _wt_line; do
                case "$_wt_line" in
                    worktree\ *)
                        _wt_path="${_wt_line#worktree }"
                        _wt_real="$(cd "$_wt_path" 2>/dev/null && pwd -P || printf '%s' "$_wt_path")"
                        if [ "$_wt_real" = "$default_real" ]; then
                            registered=1
                            break
                        fi
                        ;;
                esac
            done < <(git -C "$PROJECT_ROOT" worktree list --porcelain 2>/dev/null)

            if [ "$registered" = "0" ]; then
                warn "Found orphan worktree directory: $default_path"
                git -C "$PROJECT_ROOT" worktree prune 2>/dev/null || true
                if rm -rf "$default_path" 2>/dev/null; then
                    ok "Removed orphan directory '$default_path'."
                else
                    warn "Could not remove '$default_path' (permissions?)."
                fi
                found=1
            fi
        fi
    fi

    # 2. Resolve a base ref to evaluate "is this branch empty" against.
    # git_base_ref dies on missing branch; suppress and fall back to the
    # configured SW_BASE_BRANCH name (still useful for rev-list count).
    local base_ref=""
    base_ref="$(git_base_ref 2>/dev/null || true)"
    [ -n "$base_ref" ] || base_ref="${SW_BASE_BRANCH:-trunk}"

    # 3. Orphan branches.  for-each-ref accepts glob patterns at the ref
    # component level, so we list every branch-prefix combination once.
    local branch ahead worktree_holder
    while IFS= read -r branch; do
        [ -n "$branch" ] || continue

        # Skip if the branch is currently checked out somewhere — that's
        # not an orphan, it's an active worktree (which the metadata-driven
        # path should be handling).  `git branch -D` would refuse anyway,
        # but the explicit check gives a clearer error.
        worktree_holder="$(git -C "$PROJECT_ROOT" worktree list --porcelain 2>/dev/null \
            | awk -v b="refs/heads/$branch" '
                /^worktree / { wt=$2 }
                $1=="branch" && $2==b { print wt; exit }
            ')"
        if [ -n "$worktree_holder" ]; then
            warn "Skipping orphan branch '$branch' — checked out at '$worktree_holder'."
            found=1
            continue
        fi

        if [ "$force" = "1" ]; then
            if git -C "$PROJECT_ROOT" branch -D "$branch" >/dev/null 2>&1; then
                ok "Deleted orphan branch '$branch' (forced)."
            else
                warn "Could not delete orphan branch '$branch'."
            fi
            found=1
            continue
        fi

        # Empty branch (zero commits ahead of base) → safe to delete.
        ahead="$(git -C "$PROJECT_ROOT" rev-list --count "$base_ref..$branch" 2>/dev/null || printf '0')"
        if [ "$ahead" = "0" ]; then
            if git -C "$PROJECT_ROOT" branch -D "$branch" >/dev/null 2>&1; then
                ok "Deleted empty orphan branch '$branch'."
            else
                warn "Could not delete orphan branch '$branch'."
            fi
        else
            warn "Skipping orphan branch '$branch' — has $ahead commit(s) ahead of $base_ref. Use 'swctl clean --force ${issue_id}' to delete anyway."
        fi
        found=1
    done < <(
        git -C "$PROJECT_ROOT" for-each-ref \
            --format='%(refname:short)' \
            "refs/heads/fix/${issue_id}" \
            "refs/heads/feat/${issue_id}" \
            "refs/heads/chore/${issue_id}" \
            "refs/heads/fix/${issue_id}-*" \
            "refs/heads/feat/${issue_id}-*" \
            "refs/heads/chore/${issue_id}-*" \
            2>/dev/null
    )

    [ "$found" = "1" ]
}

# --- Project registry ---

ensure_projects_file() {
    [ -f "$SWCTL_PROJECTS_FILE" ] || touch "$SWCTL_PROJECTS_FILE"
}

read_project() {
    local name="$1"
    ensure_projects_file
    grep -E "^${name}	" "$SWCTL_PROJECTS_FILE" 2>/dev/null | head -1
}

read_project_field() {
    local entry="$1" field="$2"
    case "$field" in
        name)       printf '%s' "$entry" | cut -f1 ;;
        type)       printf '%s' "$entry" | cut -f2 ;;
        path)       printf '%s' "$entry" | cut -f3 ;;
        parent)     printf '%s' "$entry" | cut -f4 ;;
        plugin_dir) printf '%s' "$entry" | cut -f5 ;;
        workflow)   local wf; wf="$(printf '%s' "$entry" | cut -f6)"; printf '%s' "${wf:--}" ;;
    esac
}

list_projects() {
    ensure_projects_file
    grep -v '^#' "$SWCTL_PROJECTS_FILE" 2>/dev/null | grep -v '^$' || true
}

add_project_entry() {
    local name="$1" type="$2" proj_path="$3" parent="${4:--}" plugin_dir="${5:--}" workflow="${6:--}"
    ensure_projects_file
    if grep -qE "^${name}	" "$SWCTL_PROJECTS_FILE" 2>/dev/null; then
        die "Project '$name' already registered. Use 'swctl project remove $name' first."
    fi
    [ -d "$proj_path" ] || die "Path does not exist: $proj_path"
    case "$type" in
        platform|plugin-embedded|plugin-external) ;;
        *) die "Invalid project type: $type (expected: platform, plugin-embedded, plugin-external)" ;;
    esac
    if [ "$type" != "platform" ] && [ "$parent" = "-" ]; then
        die "Plugin projects require --parent <platform-name>."
    fi
    if [ "$type" != "platform" ] && [ "$parent" != "-" ]; then
        read_project "$parent" >/dev/null || die "Parent project '$parent' not found in registry."
    fi
    if [ "$type" = "plugin-embedded" ] && [ "$plugin_dir" = "-" ]; then
        die "Embedded plugins require --plugin-dir <relative-path>."
    fi
    printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$name" "$type" "$proj_path" "$parent" "$plugin_dir" "$workflow" \
        >> "$SWCTL_PROJECTS_FILE"
    ok "Registered project '$name' ($type)."
}

remove_project_entry() {
    local name="$1"
    ensure_projects_file
    if ! grep -qE "^${name}	" "$SWCTL_PROJECTS_FILE" 2>/dev/null; then
        die "Project '$name' not found in registry."
    fi
    local tmp="$SWCTL_PROJECTS_FILE.tmp"
    grep -vE "^${name}	" "$SWCTL_PROJECTS_FILE" > "$tmp"
    mv "$tmp" "$SWCTL_PROJECTS_FILE"
    ok "Removed project '$name' from registry."
}

auto_register_project() {
    # Auto-register the current project if not already in the registry
    local slug="${SW_PROJECT_SLUG:-}"
    [ -n "$slug" ] || return
    ensure_projects_file
    if ! grep -qE "^${slug}	" "$SWCTL_PROJECTS_FILE" 2>/dev/null; then
        printf '%s\t%s\t%s\t%s\t%s\n' "$slug" "platform" "$PROJECT_ROOT" "-" "-" \
            >> "$SWCTL_PROJECTS_FILE"
    fi
}

resolve_plugin_name_from_composer() {
    local composer_file="$1"
    if [ -f "$composer_file" ]; then
        # Extract the last segment of the composer name (e.g. "swag/commercial" → "SwagCommercial")
        # Fallback to directory name
        local dir_name
        dir_name="$(basename "$(dirname "$composer_file")")"
        printf '%s' "$dir_name"
    fi
}

cmd_project() {
    local action="${1:-list}"
    shift || true
    ensure_projects_file

    case "$action" in
        add)
            local name="" proj_path="" type="platform" parent="-" plugin_dir="-"
            while [ $# -gt 0 ]; do
                case "$1" in
                    --type)       type="$2"; shift 2 ;;
                    --parent)     parent="$2"; shift 2 ;;
                    --plugin-dir) plugin_dir="$2"; shift 2 ;;
                    *)
                        if [ -z "$name" ]; then
                            name="$1"
                        elif [ -z "$proj_path" ] || [ "$proj_path" = "" ]; then
                            proj_path="$1"
                        fi
                        shift
                        ;;
                esac
            done
            [ -n "$name" ] || die "Usage: swctl project add <name> <path> --type <type> [--parent <name>] [--plugin-dir <dir>]"
            [ -n "$proj_path" ] || die "Usage: swctl project add <name> <path> --type <type> [--parent <name>] [--plugin-dir <dir>]"
            # Resolve to absolute path
            if [ -d "$proj_path" ]; then
                proj_path="$(cd "$proj_path" && pwd -P)"
            fi
            case "$proj_path" in
                /*) ;; # absolute path — OK
                *)  die "Path must be absolute: $proj_path" ;;
            esac
            [ -d "$proj_path/.git" ] || warn "Not a git repository: $proj_path (path may not be mounted yet)"
            add_project_entry "$name" "$type" "$proj_path" "$parent" "$plugin_dir"
            ;;

        list)
            local entries
            entries="$(list_projects)"
            if [ -z "$entries" ]; then
                info "No projects registered. Use 'swctl project add' or 'swctl project init'."
                return
            fi
            printf "${COLOR_BOLD}%-20s %-18s %-40s %-12s %-30s${COLOR_RESET}\n" \
                "NAME" "TYPE" "PATH" "PARENT" "PLUGIN DIR"
            printf '%.0s─' {1..120}; printf '\n'
            while IFS=$'\t' read -r p_name p_type p_path p_parent p_pdir; do
                printf "%-20s %-18s %-40s %-12s %-30s\n" \
                    "$p_name" "$p_type" "$p_path" "$p_parent" "$p_pdir"
            done <<< "$entries"
            ;;

        remove)
            local name="${1:-}"
            [ -n "$name" ] || die "Usage: swctl project remove <name>"
            remove_project_entry "$name"
            ;;

        init)
            maybe_load_project_config >/dev/null 2>&1 || die "Run from a project directory with .swctl.conf."
            auto_register_project
            local plugins_dir="$PROJECT_ROOT/custom/plugins"
            [ -d "$plugins_dir" ] || { info "No custom/plugins directory found."; return; }
            local count=0
            for plugin_path in "$plugins_dir"/*/; do
                [ -d "$plugin_path" ] || continue
                local pname
                pname="$(basename "$plugin_path")"
                [ "$pname" = "*" ] && continue
                [ -f "$plugin_path/composer.json" ] || continue
                if [ -d "$plugin_path/.git" ]; then
                    # Plugin has its own git repo — discovered dynamically via --plugin flag
                    info "Found plugin with own repo: $pname (use --plugin $pname with create)"
                    count=$((count + 1))
                else
                    # Plugin is part of platform repo — register as embedded
                    local slug
                    slug="$(sanitize_slug "$pname")"
                    if grep -qE "^${slug}	" "$SWCTL_PROJECTS_FILE" 2>/dev/null; then
                        info "Already registered: $slug"
                        continue
                    fi
                    local rel_path="custom/plugins/$pname"
                    printf '%s\t%s\t%s\t%s\t%s\n' "$slug" "plugin-embedded" "$PROJECT_ROOT" "$SW_PROJECT_SLUG" "$rel_path" \
                        >> "$SWCTL_PROJECTS_FILE"
                    ok "Registered embedded plugin: $slug ($rel_path)"
                    count=$((count + 1))
                fi
            done
            info "Discovered $count plugin(s)."
            ;;

        plugins)
            local proj_name="${1:-}"
            [ -n "$proj_name" ] || die "Usage: swctl project plugins <project-name>"
            local entry
            entry="$(read_project "$proj_name")" || die "Project '$proj_name' not found."
            local proj_path
            proj_path="$(read_project_field "$entry" path)"
            list_available_plugins "$proj_path"
            ;;

        *)
            die "Usage: swctl project [add|list|remove|init|plugins]"
            ;;
    esac
}

container_exists() {
    docker ps -a --format '{{.Names}}' | grep -Fxq "$1"
}

container_running() {
    docker ps --format '{{.Names}}' | grep -Fxq "$1"
}

# Portable `timeout CMD ...` — macOS doesn't ship coreutils `timeout`.
# Prefer gtimeout (brew coreutils) / timeout when available; otherwise
# fork + monitor + kill.  Returns 124 on timeout (matching coreutils).
_run_with_timeout() {
    local secs="$1"; shift
    if command -v timeout >/dev/null 2>&1; then
        timeout "$secs" "$@"; return $?
    fi
    if command -v gtimeout >/dev/null 2>&1; then
        gtimeout "$secs" "$@"; return $?
    fi
    # Fallback: background + watchdog.
    ( "$@" ) &
    local pid=$!
    ( sleep "$secs" && kill -TERM "$pid" 2>/dev/null ) &
    local watchdog=$!
    wait "$pid" 2>/dev/null
    local rc=$?
    kill "$watchdog" 2>/dev/null; wait "$watchdog" 2>/dev/null
    return "$rc"
}

ensure_docker() {
    require_cmd docker
    # Fast path: daemon already responsive.  Bound with 5 s timeout so a
    # wedged daemon doesn't make us hang in the probe itself.
    if _run_with_timeout 5 docker info >/dev/null 2>&1; then
        return 0
    fi

    # Slow path: daemon EOF / timeout.  On macOS this is almost always
    # OrbStack's VirtioFS or docker-proxy wedged by sustained IO pressure
    # (heavy parallel bind-mount reads during batch-create was the
    # reproducer we saw).  Attempt one auto-recovery before failing.
    warn "Docker daemon is not reachable. Checking OrbStack…"
    if ! command -v orbctl >/dev/null 2>&1; then
        die "Docker daemon is not reachable and orbctl is not installed (not on OrbStack?)."
    fi

    local state
    state="$(_run_with_timeout 3 orbctl status 2>/dev/null | tr -d '[:space:]')"
    info "OrbStack state: ${state:-unknown}"

    case "$state" in
        Running)
            # OrbStack's VM is up but the Docker daemon inside isn't
            # answering — classic wedged-VirtioFS.  Restart the VM.
            info "Restarting OrbStack to recover wedged Docker daemon…"
            orbctl restart >/dev/null 2>&1 || warn "orbctl restart returned non-zero (continuing)."
            ;;
        Stopped|Paused|"")
            info "Starting OrbStack…"
            orbctl start >/dev/null 2>&1 || warn "orbctl start returned non-zero (continuing)."
            ;;
        Starting|Stopping)
            info "OrbStack is transitioning; waiting for Running…"
            ;;
        *)
            warn "Unrecognised OrbStack state '$state'; attempting start."
            orbctl start >/dev/null 2>&1 || true
            ;;
    esac

    # Wait up to 60 s for docker to come back.  Poll with modest backoff.
    local attempts=0
    while [ $attempts -lt 30 ]; do
        attempts=$((attempts + 1))
        if _run_with_timeout 3 docker info >/dev/null 2>&1; then
            ok "Docker daemon is back online (after ${attempts}x2s probes)."
            return 0
        fi
        sleep 2
    done

    die "Docker daemon is still unreachable after OrbStack recovery attempt.
Try:
    orbctl stop && orbctl start
If that still fails, reboot your machine or check OrbStack logs at
    ~/Library/Logs/OrbStack/"
}

ensure_network() {
    if docker network inspect "$SW_TRAEFIK_NETWORK" >/dev/null 2>&1; then
        ok "Docker network '$SW_TRAEFIK_NETWORK' already exists."
    else
        docker network create "$SW_TRAEFIK_NETWORK" >/dev/null
        ok "Created Docker network '$SW_TRAEFIK_NETWORK'."
    fi
}

start_or_create_container() {
    local name="$1"
    shift

    if container_exists "$name"; then
        if container_running "$name"; then
            ok "Container '$name' is already running."
        else
            docker start "$name" >/dev/null
            ok "Started container '$name'."
        fi
    else
        docker run -d --name "$name" "$@" >/dev/null
        ok "Created container '$name'."
    fi
}

resolve_db_container() {
    # In OrbStack/trunk mode, find the DB container on the trunk network.
    if [ -n "${SW_PROJECT_NETWORK:-}" ] && [ "$(detect_runtime)" = "orbstack" ]; then
        local trunk_db
        trunk_db="$(docker ps --filter "network=${SW_PROJECT_NETWORK}" --filter "ancestor=mariadb" --format '{{.Names}}' 2>/dev/null | head -1)"
        if [ -z "$trunk_db" ]; then
            trunk_db="$(docker ps --filter "network=${SW_PROJECT_NETWORK}" --format '{{.Names}}' 2>/dev/null | grep -i database | head -1)"
        fi
        if [ -n "$trunk_db" ]; then
            printf '%s' "$trunk_db"
            return
        fi
    fi
    printf '%s' "${SW_INFRA_DB_CONTAINER:-swctl-mariadb}"
}

mysql_exec() {
    local sql="$1"
    local db_container
    db_container="$(resolve_db_container)"
    docker exec -i "$db_container" mariadb \
        -u "$SW_DB_ROOT_USER" \
        "-p$SW_DB_ROOT_PASSWORD" \
        -Nse "$sql"
}

mysql_db_exists() {
    local db_name="$1"
    local result
    result="$(mysql_exec "SELECT SCHEMA_NAME FROM information_schema.SCHEMATA WHERE SCHEMA_NAME='${db_name}';" 2>/dev/null || true)"
    [ "$result" = "$db_name" ]
}

mysql_db_has_tables() {
    local db_name="$1"
    local result
    result="$(mysql_exec "SELECT COUNT(*) FROM information_schema.TABLES WHERE TABLE_SCHEMA='${db_name}';" 2>/dev/null || printf '0')"
    [ "${result:-0}" -gt 0 ]
}

wait_for_mysql() {
    local attempt=0
    while [ "$attempt" -lt 30 ]; do
        if mysql_exec 'SELECT 1;' >/dev/null 2>&1; then
            ok "MariaDB is reachable on ${SW_DB_HOST}:${SW_DB_PORT}."
            return 0
        fi
        attempt=$((attempt + 1))
        sleep 2
    done

    die "MariaDB did not become ready in time."
}

init_infra() {
    ensure_docker
    maybe_load_project_config >/dev/null 2>&1 || true

    local runtime
    runtime="$(detect_runtime)"
    SW_TRAEFIK_NETWORK="${SW_TRAEFIK_NETWORK:-swctl-proxy}"
    SW_INFRA_TRAEFIK_CONTAINER="${SW_INFRA_TRAEFIK_CONTAINER:-swctl-traefik}"
    SW_INFRA_DB_CONTAINER="${SW_INFRA_DB_CONTAINER:-swctl-mariadb}"
    SW_INFRA_REDIS_CONTAINER="${SW_INFRA_REDIS_CONTAINER:-swctl-redis}"
    SW_DB_ROOT_USER="${SW_DB_ROOT_USER:-root}"
    SW_DB_ROOT_PASSWORD="${SW_DB_ROOT_PASSWORD:-shopware}"
    SW_DB_PORT="${SW_DB_PORT:-3306}"

    if [ "$runtime" = "traefik" ]; then
        ensure_network

        start_or_create_container "$SW_INFRA_TRAEFIK_CONTAINER" \
            --restart unless-stopped \
            --network "$SW_TRAEFIK_NETWORK" \
            -p 80:80 \
            -p 8080:8080 \
            -v /var/run/docker.sock:/var/run/docker.sock:ro \
            -v swctl-traefik-data:/data \
            traefik:v3.1 \
            --api.dashboard=true \
            --api.insecure=true \
            --providers.docker=true \
            --providers.docker.exposedByDefault=false \
            --entrypoints.web.address=:80
    else
        info "OrbStack detected. Skipping Traefik — OrbStack handles DNS routing."
    fi

    # Guard: refuse to create swctl-mariadb when the project network
    # (trunk_default or whatever SW_PROJECT_NETWORK is set to) already
    # has another container aliased as `database`.  Two containers
    # sharing a DNS alias → Docker round-robins → intermittent
    # "Unknown database" errors at runtime.  Skip silently when not in
    # Traefik mode (OrbStack users almost always use their own compose).
    if [ "$runtime" != "traefik" ]; then
        local _proj_net="${SW_PROJECT_NETWORK:-trunk_default}"
        local _existing_db
        _existing_db="$(_find_alias_owner "$_proj_net" database)"
        if [ -n "$_existing_db" ]; then
            warn "Network '$_proj_net' already has '$_existing_db' aliased as 'database'."
            warn "  Skipping swctl-mariadb — your project compose already provides it."
            warn "  (Having two 'database' aliases on one network causes DNS round-robin + intermittent 'Unknown database' errors.)"
            ok "Shared infrastructure: reusing '$_existing_db' for database on network '$_proj_net'."
            return 0
        fi
    fi

    start_or_create_container "$SW_INFRA_DB_CONTAINER" \
        --restart unless-stopped \
        -p "${SW_DB_PORT}:3306" \
        -e "MARIADB_ROOT_PASSWORD=${SW_DB_ROOT_PASSWORD}" \
        -e "MARIADB_ROOT_HOST=%" \
        -v swctl-mariadb-data:/var/lib/mysql \
        mariadb:11

    start_or_create_container "$SW_INFRA_REDIS_CONTAINER" \
        --restart unless-stopped \
        -p 6379:6379 \
        -v swctl-redis-data:/data \
        redis:7-alpine \
        redis-server \
        --appendonly yes

    wait_for_mysql
    ok "Shared infrastructure is ready."
    if [ "$runtime" = "traefik" ]; then
        info "Traefik dashboard: http://localhost:8080"
    else
        info "Runtime: OrbStack (domains via *.orb.local)"
    fi
}

ensure_infra_ready() {
    ensure_docker
    local runtime
    runtime="$(detect_runtime)"

    if [ "$runtime" = "traefik" ]; then
        if ! docker network inspect "${SW_TRAEFIK_NETWORK:-swctl-proxy}" >/dev/null 2>&1 || \
            ! container_running "${SW_INFRA_TRAEFIK_CONTAINER:-swctl-traefik}" || \
            ! container_running "${SW_INFRA_DB_CONTAINER:-swctl-mariadb}" || \
            ! container_running "${SW_INFRA_REDIS_CONTAINER:-swctl-redis}"; then
            warn "Shared infrastructure is missing or stopped. Running 'swctl init'."
            init_infra
        fi
    else
        # OrbStack mode: worktrees connect to trunk's network.
        # Just verify the trunk network exists.
        if [ -n "${SW_PROJECT_NETWORK:-}" ] && docker network inspect "$SW_PROJECT_NETWORK" >/dev/null 2>&1; then
            ok "Project network '$SW_PROJECT_NETWORK' is available."
        else
            warn "Project network '${SW_PROJECT_NETWORK:-trunk_default}' not found. Start your project first: cd $PROJECT_ROOT && docker compose up -d"
        fi
    fi
}

git_base_ref() {
    if git -C "$PROJECT_ROOT" rev-parse --verify "$SW_BASE_BRANCH" >/dev/null 2>&1; then
        printf '%s\n' "$SW_BASE_BRANCH"
        return 0
    fi

    if git -C "$PROJECT_ROOT" rev-parse --verify "origin/$SW_BASE_BRANCH" >/dev/null 2>&1; then
        printf '%s\n' "origin/$SW_BASE_BRANCH"
        return 0
    fi

    die "Base branch '$SW_BASE_BRANCH' was not found locally or under origin/."
}

check_branch_staleness() {
    local merge_base
    local commits_behind=0
    local days_behind=0

    merge_base="$(git -C "$WORKTREE_PATH" merge-base "$BASE_REF" HEAD 2>/dev/null || true)"
    [ -n "$merge_base" ] || return 0

    commits_behind="$(git -C "$WORKTREE_PATH" rev-list --count "$merge_base..${BASE_REF}" 2>/dev/null || printf '0')"
    days_behind="$(( ( $(date +%s) - $(git -C "$WORKTREE_PATH" log -1 --format=%ct "$merge_base" 2>/dev/null || printf '%s' "$(date +%s)") ) / 86400 ))"

    if [ "$commits_behind" -gt 0 ]; then
        info "Branch '$BRANCH' is ${commits_behind} commits behind '${SW_BASE_BRANCH}'. Rebasing..."
        if git -C "$WORKTREE_PATH" rebase "$BASE_REF" 2>&1; then
            ok "Rebased '$BRANCH' onto '${SW_BASE_BRANCH}' (was ${commits_behind} commits behind)."
        else
            warn "Rebase has conflicts. Aborting rebase — worktree will use the branch as-is."
            git -C "$WORKTREE_PATH" rebase --abort 2>/dev/null || true
            if [ "$commits_behind" -gt 100 ] || [ "$days_behind" -gt 14 ]; then
                warn "Branch is ${commits_behind} commits / ${days_behind} days behind. Schema mismatches are likely."
            fi
        fi
    fi
}

worktree_exists() {
    git -C "$PROJECT_ROOT" worktree list --porcelain | grep -Fxq "worktree $1"
}

create_worktree() {
    mkdir -p "$SW_WORKTREE_ROOT"

    # All git worktree operations (check, remove, add, reset) are serialized per repo.
    # Concurrent `git worktree add/remove/list` on the same repo race on internal locks
    # (.git/config.lock, index.lock) causing "Could not reset index file" errors.
    _do_worktree_create() {
        if worktree_exists "$WORKTREE_PATH"; then
            ok "Git worktree already exists at '$WORKTREE_PATH'."
            return 0
        fi

        if [ -d "$WORKTREE_PATH" ]; then
            # Directory exists but is not a registered git worktree — leftover from
            # a previous failed/cleaned create.  Remove it so we can start fresh.
            warn "Cleaning up leftover directory: $WORKTREE_PATH"
            git -C "$PROJECT_ROOT" worktree remove --force "$WORKTREE_PATH" 2>/dev/null || rm -rf "$WORKTREE_PATH"
        fi

        # Retry loop: git worktree add can fail transiently due to concurrent git
        # operations holding locks (config.lock, index.lock). We retry up to 3 times
        # with cleanup between attempts.
        local _wt_attempt=0
        local _wt_max=3
        local _wt_ok=0

        while [ "$_wt_attempt" -lt "$_wt_max" ] && [ "$_wt_ok" -eq 0 ]; do
            _wt_attempt=$((_wt_attempt + 1))

            # Clean up stale git lock files before each attempt
            local config_lock="$PROJECT_ROOT/.git/config.lock"
            if [ -f "$config_lock" ]; then
                if find "$config_lock" -mmin +0.08 -print -quit 2>/dev/null | grep -q .; then
                    warn "Removing stale lock file: $config_lock"
                    rm -f "$config_lock"
                fi
            fi

            # Attempt git worktree add (capture exit code, don't abort on failure)
            local _wt_rc=0
            if git -C "$PROJECT_ROOT" show-ref --verify --quiet "refs/heads/$BRANCH"; then
                git -C "$PROJECT_ROOT" worktree add "$WORKTREE_PATH" "$BRANCH" 2>&1 || _wt_rc=$?
            elif git -C "$PROJECT_ROOT" show-ref --verify --quiet "refs/remotes/origin/$BRANCH"; then
                git -C "$PROJECT_ROOT" worktree add -b "$BRANCH" "$WORKTREE_PATH" "origin/$BRANCH" 2>&1 || _wt_rc=$?
            else
                git -C "$PROJECT_ROOT" worktree add -b "$BRANCH" "$WORKTREE_PATH" "$BASE_REF" 2>&1 || _wt_rc=$?
            fi

            # Verify: directory exists AND has checked-out files
            if [ -f "$WORKTREE_PATH/composer.json" ]; then
                _wt_ok=1
            elif [ -d "$WORKTREE_PATH" ] && [ -f "$WORKTREE_PATH/.git" ]; then
                # Directory exists but checkout incomplete (e.g. "Could not reset index file").
                # The worktree is registered in git but files weren't checked out. Recover.
                warn "Worktree checkout incomplete (attempt $_wt_attempt/$_wt_max) — recovering with git reset."
                local gitdir=""
                gitdir="$(sed -n 's/^gitdir: //p' "$WORKTREE_PATH/.git" 2>/dev/null)" || true
                # shellcheck disable=SC2015
                [ -n "$gitdir" ] && rm -f "$gitdir/index.lock" 2>/dev/null || true
                if git -C "$WORKTREE_PATH" reset --hard HEAD 2>&1; then
                    _wt_ok=1
                    ok "Worktree checkout recovered."
                else
                    warn "Recovery failed. Cleaning up for retry."
                    git -C "$PROJECT_ROOT" worktree remove --force "$WORKTREE_PATH" 2>/dev/null || rm -rf "$WORKTREE_PATH"
                fi
            else
                # Directory not created at all — git failed completely
                if [ "$_wt_attempt" -lt "$_wt_max" ]; then
                    warn "git worktree add failed (attempt $_wt_attempt/$_wt_max, rc=$_wt_rc). Retrying in 2s..."
                    git -C "$PROJECT_ROOT" worktree remove --force "$WORKTREE_PATH" 2>/dev/null || true
                    rm -rf "$WORKTREE_PATH" 2>/dev/null || true
                    sleep 2
                fi
            fi
        done

        if [ "$_wt_ok" -eq 0 ]; then
            die "Failed to create worktree at '$WORKTREE_PATH' after $_wt_max attempts."
        fi

        ok "Worktree ready at '$WORKTREE_PATH'."
    }
    local repo_slug
    repo_slug="$(echo "$PROJECT_ROOT" | tr '/' '-')"
    swctl_lock "git-worktree${repo_slug}" _do_worktree_create
}

# ---------------------------------------------------------------------------
# Worktree sync: copy ALL non-git state from trunk into a new worktree.
#
# Git worktrees only contain tracked, non-ignored files. Everything else
# (lock files, vendor, plugins with their own repos, compiled assets) must
# be explicitly copied. These four helpers run in a fixed order and are
# usually called together via sync_worktree_from_trunk().
# ---------------------------------------------------------------------------

sync_worktree_from_trunk() {
    # One-stop sync: call the four helpers in the right order.
    # 1. Lock files first (composer.lock etc.) — needed by dep install decisions
    # 2. Gitignored plugins — separate-repo plugins active in the cloned DB
    # 3. Build artifacts — compiled JS, bundles, theme files from trunk
    # 4. Vendor/node_modules — PHP + JS dependency trees
    sync_lock_files
    sync_gitignored_plugins
    sync_build_artifacts
    sync_worktree_deps
}

sync_lock_files() {
    [ -d "$WORKTREE_PATH" ] || return 0
    local file=""
    for file in composer.lock pnpm-lock.yaml yarn.lock package-lock.json; do
        if [ -f "$PROJECT_ROOT/$file" ] && [ ! -f "$WORKTREE_PATH/$file" ]; then
            cp "$PROJECT_ROOT/$file" "$WORKTREE_PATH/$file"
            ok "Copied gitignored '$file' into worktree."
        fi
    done
}

sync_gitignored_plugins() {
    # Collect gitignored plugins from trunk that are NOT explicitly linked
    # (via --plugin / deps). These exist in trunk's DB as active but aren't
    # on the worktree filesystem — they'd crash the Symfony DI container.
    #
    # Instead of copying them (slow, may have unsatisfied deps), we just
    # mark them for deactivation. If a plugin is needed, the user configures
    # it explicitly via the plugin flow or deps.
    [ -d "$WORKTREE_PATH" ] || return 0

    local plugins_dir="${WORKFLOW_PLUGIN_DIR:-custom/plugins}"
    local src_plugins="$PROJECT_ROOT/$plugins_dir"
    [ -d "$src_plugins" ] || return 0

    local _deactivate_plugins=""
    local plugin_path pname
    for plugin_path in "$src_plugins"/*/; do
        [ -d "$plugin_path" ] || continue
        pname="$(basename "$plugin_path")"
        [ "$pname" = "*" ] && continue
        [ -f "$plugin_path/composer.json" ] || continue

        # Only care about gitignored plugins (separate repos).
        git -C "$PROJECT_ROOT" check-ignore -q "$plugins_dir/$pname" 2>/dev/null || continue

        # Skip if this plugin is bind-mounted by the plugin flow
        case ",${LINKED_PLUGINS:-}," in
            *,"$pname",*) continue ;;
        esac

        _deactivate_plugins="${_deactivate_plugins:+${_deactivate_plugins},}${pname}"
    done

    # Store for deactivation after container starts.
    SWCTL_SKIPPED_PLUGINS="${_deactivate_plugins}"
}

sync_build_artifacts() {
    # Called AFTER count_changes so ADMIN_CHANGES/STOREFRONT_CHANGES are set.
    # Diff-driven: only sync what's needed. Use APFS clones when available.

    # Skip entirely when --no-provision was requested.  Build artifacts
    # (public/bundles, node_modules, vendor) are only needed for serving the
    # application and for JS/theme builds — both happen during provisioning.
    # For analysis-only worktrees this saves 30-120s of copying.
    if [ "${SWCTL_NO_PROVISION:-0}" = "1" ]; then
        info "Skipping build-artifact sync (--no-provision): vendor, node_modules, public/bundles"
        return 0
    fi

    # Read artifact lists from workflow.yaml if available
    local sync_files="" sync_dirs=""
    if [ -n "${SWCTL_WORKFLOW_DIR:-}" ] && [ -f "$SWCTL_WORKFLOW_DIR/workflow.yaml" ]; then
        eval "$(python3 -c "
import yaml, sys
with open(sys.argv[1]) as f:
    data = yaml.safe_load(f) or {}
sa = data.get('sync_artifacts', {})
files = sa.get('files', [])
dirs = sa.get('directories', [])
print('sync_files=\"{}\"'.format(' '.join(files)))
print('sync_dirs=\"{}\"'.format(' '.join(dirs)))
" "$SWCTL_WORKFLOW_DIR/workflow.yaml" 2>/dev/null)" || true
    fi

    # Defaults (Shopware 6).
    # NOTE: vendor/ and the two node_modules/ trees are deliberately NOT in
    # sync_dirs.  They come from docker volumes (populated once per project
    # from trunk, then mounted into every worktree's container — see
    # write_compose_volume_override).  Rsyncing them through VirtioFS is what
    # made creates take 10+ min with truncation-and-retry.
    sync_files="${sync_files:-var/theme-files.json var/plugins.json}"
    if [ -z "$sync_dirs" ]; then
        sync_dirs="public/theme public/bundles"
        sync_dirs="$sync_dirs src/Storefront/Resources/app/storefront/vendor"
        sync_dirs="$sync_dirs src/Storefront/Resources/app/storefront/dist"
        sync_dirs="$sync_dirs src/Administration/Resources/public"
        sync_dirs="$sync_dirs src/Storefront/Resources/public"
    fi

    # Sync individual files
    local f
    for f in $sync_files; do
        if [ -f "$PROJECT_ROOT/$f" ]; then
            mkdir -p "$WORKTREE_PATH/$(dirname "$f")"
            cp "$PROJECT_ROOT/$f" "$WORKTREE_PATH/$f" 2>/dev/null || true
        fi
    done

    # Sync directories in parallel — each is independent (APFS clone or rsync).
    # Under VirtioFS bind mounts (swctl running inside the swctl-ui container)
    # the parallel rsync pass can truncate large node_modules trees under I/O
    # contention. We detect that by file count and retry serially. A sentinel
    # file signals failure to the post-wait check below.
    local _sync_sentinel="${SWCTL_TMP_DIR:-/tmp}/sync-failed.${ISSUE_ID:-$$}"
    rm -f "$_sync_sentinel" 2>/dev/null || true
    local _sync_pids=()
    local dir
    for dir in $sync_dirs; do
        (
            src_dir="$PROJECT_ROOT/$dir"
            dst_dir="$WORKTREE_PATH/$dir"
            if [ -d "$src_dir" ]; then
                # Count files recursively (not just top-level dirs) so we detect
                # empty directory shells left by git checkout vs real content.
                src_count="$(find "$src_dir" -type f -not -name '.gitkeep' 2>/dev/null | wc -l | tr -d ' ')"
                dst_count="$( (find "$dst_dir" -type f -not -name '.gitkeep' 2>/dev/null || true) | wc -l | tr -d ' ')"
                if [ "$src_count" -gt 0 ] && [ "${dst_count:-0}" -lt "$src_count" ]; then
                    mkdir -p "$dst_dir"
                    # APFS clone (cp -c): instant copy-on-write. Clone to temp, swap in.
                    tmp_clone="${dst_dir}.swctl-clone"
                    rm -rf "$tmp_clone"
                    if cp -cR "$src_dir" "$tmp_clone" 2>/dev/null; then
                        rm -rf "$dst_dir"
                        mv "$tmp_clone" "$dst_dir"
                    else
                        rm -rf "$tmp_clone" 2>/dev/null || true
                        # Fallback: rsync or regular copy
                        mkdir -p "$dst_dir"
                        if command -v rsync >/dev/null 2>&1; then
                            rsync -a "$src_dir/" "$dst_dir/" 2>/dev/null || true
                        else
                            cp -R "$src_dir"/* "$dst_dir"/ 2>/dev/null || true
                        fi
                    fi
                    echo "  ✓ Synced '$dir/'."
                fi
            fi
        ) &
        _sync_pids+=($!)
    done
    # Wait for all parallel syncs to complete
    for pid in "${_sync_pids[@]}"; do
        wait "$pid" 2>/dev/null || true
    done

    # Post-sync verification: compare dst file counts to src. If any dir is
    # materially short (>5% missing), retry once SERIALLY with rsync --delete.
    # This catches the VirtioFS parallel-contention truncation that silently
    # drops tens of thousands of files from large node_modules trees.
    for dir in $sync_dirs; do
        src_dir="$PROJECT_ROOT/$dir"
        dst_dir="$WORKTREE_PATH/$dir"
        [ -d "$src_dir" ] || continue
        src_count="$(find "$src_dir" -type f -not -name '.gitkeep' 2>/dev/null | wc -l | tr -d ' ')"
        [ "$src_count" -gt 0 ] || continue
        dst_count="$( (find "$dst_dir" -type f -not -name '.gitkeep' 2>/dev/null || true) | wc -l | tr -d ' ')"
        # 95% threshold: .DS_Store, .lock and transient files yield noise
        # well below this, but a real truncation (tens of thousands of files
        # missing out of 100k+) is comfortably above.
        local threshold=$(( src_count * 95 / 100 ))
        if [ "${dst_count:-0}" -lt "$threshold" ]; then
            warn "sync '$dir' truncated (${dst_count}/${src_count} files). Retrying serially with rsync."
            local _retry_log="${SWCTL_TMP_DIR:-/tmp}/sync-retry.$$.log"
            if command -v rsync >/dev/null 2>&1; then
                rsync -a --delete "$src_dir/" "$dst_dir/" 2>"$_retry_log" || true
            else
                rm -rf "$dst_dir" 2>/dev/null || true
                mkdir -p "$dst_dir"
                cp -R "$src_dir"/* "$dst_dir"/ 2>"$_retry_log" || true
            fi
            dst_count="$( (find "$dst_dir" -type f -not -name '.gitkeep' 2>/dev/null || true) | wc -l | tr -d ' ')"
            if [ "${dst_count:-0}" -lt "$threshold" ]; then
                err "sync '$dir' FAILED after retry: ${dst_count}/${src_count} files."
                if [ -s "$_retry_log" ]; then
                    err "  rsync stderr tail:"
                    tail -n 5 "$_retry_log" 2>/dev/null | sed 's/^/    /' >&2 || true
                fi
                : >"$_sync_sentinel"
            else
                info "sync '$dir' recovered on retry (${dst_count}/${src_count})."
            fi
            rm -f "$_retry_log" 2>/dev/null || true
        fi
    done

    if [ -f "$_sync_sentinel" ]; then
        rm -f "$_sync_sentinel" 2>/dev/null || true
        die "sync_build_artifacts: one or more directory syncs failed. See errors above."
    fi

    # Mark synced artifacts as git-excluded so they don't pollute worktree git status.
    # Two mechanisms needed:
    #   1. info/exclude — hides untracked synced files
    #   2. assume-unchanged — hides tracked synced files that differ from branch
    local git_dir
    git_dir="$(git -C "$WORKTREE_PATH" rev-parse --git-dir 2>/dev/null)" || true
    if [ -n "$git_dir" ]; then
        # Make path absolute if relative
        case "$git_dir" in
            /*) ;;
            *)  git_dir="$WORKTREE_PATH/$git_dir" ;;
        esac
        local exclude_file="$git_dir/info/exclude"
        mkdir -p "$(dirname "$exclude_file")"
        # Add exclude entries for untracked synced artifacts
        if ! grep -q '# swctl synced artifacts' "$exclude_file" 2>/dev/null; then
            {
                echo ""
                echo "# swctl synced artifacts"
                for f in $sync_files; do
                    echo "/$f"
                done
                for dir in $sync_dirs; do
                    echo "/$dir/"
                done
            } >> "$exclude_file"
        fi

        # Mark tracked synced files as assume-unchanged
        for dir in $sync_dirs; do
            if [ -d "$WORKTREE_PATH/$dir" ]; then
                git -C "$WORKTREE_PATH" ls-files -z "$dir" 2>/dev/null \
                    | xargs -0 git -C "$WORKTREE_PATH" update-index --assume-unchanged 2>/dev/null || true
            fi
        done
        for f in $sync_files; do
            if [ -f "$WORKTREE_PATH/$f" ]; then
                git -C "$WORKTREE_PATH" update-index --assume-unchanged "$f" 2>/dev/null || true
            fi
        done
    fi
}

count_changes() {
    local diff_files="$1"

    # Read patterns from workflow.yaml if available, otherwise use Shopware defaults
    local pat_migration pat_entity pat_admin pat_storefront pat_composer pat_package pat_backend
    if [ -n "${SWCTL_WORKFLOW_DIR:-}" ] && [ -f "$SWCTL_WORKFLOW_DIR/workflow.yaml" ]; then
        eval "$(python3 -c "
import yaml, sys
with open(sys.argv[1]) as f:
    data = yaml.safe_load(f) or {}
d = data.get('detect', {})
print('pat_migration=\"{}\"'.format(d.get('migration', '(^|/)Migrations?/')))
print('pat_entity=\"{}\"'.format(d.get('entity', '(^|/)Entity/')))
print('pat_admin=\"{}\"'.format(d.get('admin', 'Resources/app/administration/.*\\\\.(js|ts|vue|scss)\$')))
print('pat_storefront=\"{}\"'.format(d.get('storefront', '(Resources/app/storefront/.*\\\\.(js|ts|vue|scss)\$|\\\\.twig\$)')))
print('pat_composer=\"{}\"'.format(d.get('composer', '(^|/)composer\\\\.(json|lock)\$')))
print('pat_package=\"{}\"'.format(d.get('package', '(^|/)(package\\\\.json|package-lock\\\\.json|pnpm-lock\\\\.yaml|yarn\\\\.lock)\$')))
print('pat_backend=\"{}\"'.format(d.get('backend', '\\\\.php\$')))
" "$SWCTL_WORKFLOW_DIR/workflow.yaml" 2>/dev/null)" || true
    fi

    # Defaults (Shopware 6 patterns)
    pat_migration="${pat_migration:-(^|/)Migrations?/}"
    pat_entity="${pat_entity:-(^|/)Entity/}"
    pat_admin="${pat_admin:-Resources/app/administration/.*\.(js|ts|vue|scss)$}"
    pat_storefront="${pat_storefront:-(Resources/app/storefront/.*\.(js|ts|vue|scss)$|\.twig$)}"
    pat_composer="${pat_composer:-(^|/)composer\.(json|lock)$}"
    pat_package="${pat_package:-(^|/)(package\.json|package-lock\.json|pnpm-lock\.yaml|yarn\.lock)$}"
    pat_backend="${pat_backend:-\.php$}"

    MIGRATION_CHANGES="$(printf '%s\n' "$diff_files" | grep -Ec "$pat_migration" || true)"
    ENTITY_CHANGES="$(printf '%s\n' "$diff_files" | grep -Ec "$pat_entity" || true)"
    ADMIN_CHANGES="$(printf '%s\n' "$diff_files" | grep -Ec "$pat_admin" || true)"
    STOREFRONT_CHANGES="$(printf '%s\n' "$diff_files" | grep -Ec "$pat_storefront" || true)"
    COMPOSER_CHANGES="$(printf '%s\n' "$diff_files" | grep -Ec "$pat_composer" || true)"
    PACKAGE_CHANGES="$(printf '%s\n' "$diff_files" | grep -Ec "$pat_package" || true)"
    BACKEND_CHANGES="$(printf '%s\n' "$diff_files" | grep -E "$pat_backend" | grep -Evc "$pat_migration|$pat_entity" || true)"
    # Backward compat: FRONTEND_CHANGES = ADMIN + STOREFRONT
    FRONTEND_CHANGES="$((ADMIN_CHANGES + STOREFRONT_CHANGES))"
}

sync_worktree_deps() {
    # Vendor is now provided to the container via a docker volume populated
    # once per project from trunk (see write_compose_volume_override +
    # _ensure_base_volume_populated).  Rsyncing it through VirtioFS into each
    # worktree was the single biggest time sink (60–90 s per create × N
    # parallel creates of I/O contention).  Nothing on the host needs vendor/
    # under the worktree anymore; the container sees it via the mount.
    return 0
}

resolve_vendor_volume() {
    local issue_id="$1"
    if [ "$((MIGRATION_CHANGES + ENTITY_CHANGES + COMPOSER_CHANGES))" -gt 0 ]; then
        printf '%s' "vendor-${issue_id}"
    else
        printf '%s' "vendor-base-${SW_PROJECT_SLUG}"
    fi
}

resolve_node_modules_volume() {
    local issue_id="$1"
    if [ "$((MIGRATION_CHANGES + ENTITY_CHANGES + PACKAGE_CHANGES))" -gt 0 ]; then
        printf '%s' "node_modules-${issue_id}"
    else
        printf '%s' "node_modules-base-${SW_PROJECT_SLUG}"
    fi
}

# Per-app node_modules volumes for Administration + Storefront.  Populated
# once per project from trunk's bind-mounted node_modules tree, then each
# worktree either mounts the shared base read-only (the common case — no
# package-lock changes) or gets a dedicated writable copy cloned from base
# (when PACKAGE_CHANGES > 0 or the plugin has admin/storefront source that
# needs a per-instance build scratch).  The dedicated volume is always
# populated from base first, so creates never rsync node_modules through
# VirtioFS.
resolve_admin_nm_volume() {
    local issue_id="$1"
    if [ "$((ADMIN_CHANGES + PACKAGE_CHANGES))" -gt 0 ]; then
        printf '%s' "admin-nm-${issue_id}"
    else
        printf '%s' "admin-nm-base-${SW_PROJECT_SLUG}"
    fi
}

resolve_storefront_nm_volume() {
    local issue_id="$1"
    if [ "$((STOREFRONT_CHANGES + PACKAGE_CHANGES))" -gt 0 ]; then
        printf '%s' "storefront-nm-${issue_id}"
    else
        printf '%s' "storefront-nm-base-${SW_PROJECT_SLUG}"
    fi
}

# Ensure the alpine:latest image is available locally.  Every
# volume populate / clone spawns a throwaway `alpine` container,
# and Docker's implicit pull-on-run is silent + eats errors under
# our 2>/dev/null redirects — a pull failure surfaces as "Failed
# to populate volume X" with no actionable detail.  Pulling once
# upfront (idempotent) converts any network-level issue into a
# clear error BEFORE the populate starts.
#
# Idempotent: if the image is already cached, this is a ~50 ms
# docker daemon round-trip with no network I/O.  Callable anywhere;
# both _ensure_base_volume_populated and _clone_docker_volume now
# call it before their docker run.
_ensure_alpine_image() {
    if docker image inspect alpine:latest >/dev/null 2>&1; then
        return 0
    fi
    info "Pulling alpine image (one-time, used for volume populate/clone)…"
    # Sanitised DOCKER_CONFIG: when this swctl runs INSIDE the swctl-ui
    # container, the bind-mounted host HOME means the docker CLI sees
    # the host's `~/.docker/config.json`, which on macOS references
    # `docker-credential-osxkeychain` — a binary that doesn't exist
    # in the Linux container.  The pull fails with
    #   "exec: docker-credential-osxkeychain: executable file not found"
    # even though alpine:latest is a public image needing no auth.
    #
    # An empty DOCKER_CONFIG dir bypasses the credsStore lookup
    # entirely.  Idempotent: only used for this pull invocation.
    local empty_cfg pull_err
    empty_cfg="$(mktemp -d)"
    pull_err="$(DOCKER_CONFIG="$empty_cfg" docker pull alpine:latest 2>&1 >/dev/null)"
    local rc=$?
    rm -rf "$empty_cfg"
    if [ $rc -ne 0 ]; then
        err "Failed to pull alpine:latest. Check network / Docker daemon."
        [ -n "$pull_err" ] && printf '  %s\n' "$pull_err" >&2
        return 1
    fi
}

# Populate a docker volume once from a source path on the host.  Idempotent —
# if the volume already has a sentinel file (which a prior populate leaves),
# returns immediately.  This is how we avoid rsyncing giant trees (vendor,
# node_modules) through VirtioFS on every create.
#
# $1 volume name          (e.g. vendor-base-trunk)
# $2 host source path     (e.g. /Users/ytran/Shopware/trunk/vendor)
# $3 sentinel relpath     (a file inside the source that proves population
#                         succeeded — e.g. composer/installed.json for vendor,
#                         package-lock.json for node_modules)
_ensure_base_volume_populated() {
    local vol="$1"
    local src="$2"
    local sentinel="${3:-.swctl-populated}"

    docker volume inspect "$vol" >/dev/null 2>&1 || \
        docker volume create "$vol" >/dev/null

    # Fast-path check — both the content sentinel AND .ready must exist.
    # .ready is written LAST after cp -a completes; without it, another
    # create could see the content sentinel mid-populate and skip repopulating
    # a stale or partially-empty volume.
    if docker run --rm -v "${vol}:/v" alpine sh -c \
        "test -f /v/.ready && test -f /v/${sentinel}" 2>/dev/null; then
        return 0
    fi

    [ -d "$src" ] || { warn "Source '$src' missing; volume '$vol' will stay empty."; return 1; }

    # Pull alpine BEFORE the populate run.  A failed implicit pull
    # inside the populate's `2>/dev/null` used to surface as "Failed
    # to populate volume X from Y" with no hint that Docker couldn't
    # reach its registry.
    _ensure_alpine_image || return 1

    info "Populating volume '$vol' from '$src' (one-time, ~1–2 min)…"
    # Use a throwaway container with the source bind-mounted RO and the
    # volume mounted RW.  cp -a preserves symlinks and perms + overwrites
    # same-content files idempotently — so we deliberately do NOT wipe
    # the destination first.  Wiping creates a window in which another
    # container that already has this volume mounted :ro sees files
    # disappear out from under it.  The dst is content-addressed via the
    # populate key; repopulates from the same src are byte-identical.
    #
    # Ownership: OrbStack VirtioFS surfaces host files as root inside the
    # populate container, and `cp -a` preserves that apparent ownership.
    # The Shopware dev image runs as www-data (uid 1000) — without an
    # explicit chown, www-data can't write into node_modules/.vite-temp/
    # during admin builds (EACCES).  We chown -R to 1000:1000 at the end.
    #
    # `.ready` is touched BEFORE the chown so that the final chown covers
    # the sentinel too — keeping the invariant that every file in the
    # populated volume is owned by uid 1000.  The chown is LAST so any
    # concurrent reader that sees `.ready` finds a fully-chowned tree.
    #
    # Capture stderr to a temp file so the "Failed to populate" error
    # carries the actual docker/cp message instead of leaving the user
    # guessing.  Previously stderr was redirected to /dev/null and any
    # real problem (pull failure, bind-mount permission, OOM, corrupt
    # volume) was invisible.
    local run_err
    run_err="$(mktemp)"
    if ! docker run --rm \
        -v "${src}:/src:ro" \
        -v "${vol}:/dst" \
        alpine sh -c 'cp -a /src/. /dst/ && touch /dst/.ready && chown -R 1000:1000 /dst' 2>"$run_err" >/dev/null; then
        err "Failed to populate volume '$vol' from '$src'."
        if [ -s "$run_err" ]; then
            # Indent so it's obviously the docker output, not swctl's own.
            sed 's/^/  /' "$run_err" >&2
        fi
        rm -f "$run_err"
        return 1
    fi
    rm -f "$run_err"
    ok "Volume '$vol' populated."
}

# Clone a docker volume (dst <- src) via a throwaway container.  Used when
# a worktree has dependency changes and needs a writable dedicated copy —
# we clone the shared base volume to a per-instance volume (fast, same host
# FS, no VirtioFS) instead of rsyncing from trunk.  Chown to www-data
# (uid 1000) so the Shopware dev container can write into the volume
# (Vite writes .vite-temp/, composer writes vendor/composer/ during
# autoload dump, etc.).  `.ready` sentinel is written LAST so mid-clone
# reads can't look like a completed clone.
_clone_docker_volume() {
    local src="$1"
    local dst="$2"

    docker volume inspect "$dst" >/dev/null 2>&1 || \
        docker volume create "$dst" >/dev/null

    # Same alpine + stderr guards as _ensure_base_volume_populated —
    # a silent pull/clone failure is the hardest flake to diagnose.
    _ensure_alpine_image || return 1

    local run_err
    run_err="$(mktemp)"
    if ! docker run --rm \
        -v "${src}:/src:ro" \
        -v "${dst}:/dst" \
        alpine sh -c 'cp -a /src/. /dst/ && touch /dst/.ready && chown -R 1000:1000 /dst' 2>"$run_err" >/dev/null; then
        err "Failed to clone volume '$src' → '$dst'."
        if [ -s "$run_err" ]; then
            sed 's/^/  /' "$run_err" >&2
        fi
        rm -f "$run_err"
        return 1
    fi
    rm -f "$run_err"
}

# Plugin build cache — skip `composer build:js:admin` when the same plugin
# HEAD + package-lock combination has already been built in a previous
# create.  Cache key uses the plugin's git HEAD (automatic invalidation on
# commit) and md5(package-lock.json) (invalidates on dep bumps).  Storage
# is a docker volume `pb-<key>` holding the plugin's Resources/public/
# directory; we mount it RO at the plugin's public path, skipping the
# admin/storefront npm build entirely.
_resolve_plugin_build_key() {
    local plugin_name="$1"
    local plugin_worktree_path="$2"
    [ -n "$plugin_name" ] && [ -d "$plugin_worktree_path" ] || return 1

    local head lock_md5
    head="$(git -C "$plugin_worktree_path" rev-parse --short=10 HEAD 2>/dev/null)" || return 1
    if [ -f "$plugin_worktree_path/package-lock.json" ]; then
        lock_md5="$(md5 -q "$plugin_worktree_path/package-lock.json" 2>/dev/null \
            || md5sum "$plugin_worktree_path/package-lock.json" 2>/dev/null | awk '{print $1}')"
    fi
    lock_md5="${lock_md5:-no-lock}"
    # Sanitize plugin name for volume use (docker volume names: [a-zA-Z0-9][a-zA-Z0-9_.-]*)
    local name_safe
    name_safe="$(printf '%s' "$plugin_name" | tr -c '[:alnum:]._-' '-' | tr '[:upper:]' '[:lower:]')"
    printf 'pb-%s-%s-%s' "$name_safe" "$head" "${lock_md5:0:8}"
}

# Returns 0 if the volume exists AND contains the sentinel file that a
# populated build leaves behind.  Non-zero → cache miss.
_plugin_build_cache_hit() {
    local vol="$1"
    [ -n "$vol" ] || return 1
    docker volume inspect "$vol" >/dev/null 2>&1 || return 1
    # Both the content sentinel (admin entrypoints.json) AND .ready must
    # exist — prevents reading a half-populated volume from a concurrent
    # or crashed create.
    docker run --rm -v "${vol}:/v" alpine sh -c \
        'test -f /v/.ready && test -f /v/administration/.vite/entrypoints.json' 2>/dev/null
}

# Populate a cache volume from the plugin worktree's Resources/public/ after
# a successful build.  Safe to call repeatedly — cp -a overwrites existing
# files idempotently (same plugin HEAD + package-lock yields byte-identical
# output).  Labelled so `swctl volume list` can find them for LRU display.
#
# `.ready` sentinel is touched LAST (chained with && so it only appears on
# successful cp); `_plugin_build_cache_hit` gates on it to avoid mid-populate
# reads from another container.
#
# NOTE: we deliberately do NOT wipe the dst first.  Wiping creates a window
# in which concurrent RO readers (other containers with the same cache
# volume mounted) see their files disappear — which was the root cause of
# the "admin UI missing after parallel creates" bug.
_populate_plugin_build_cache() {
    local vol="$1"
    local plugin_worktree_path="$2"
    local pub="$plugin_worktree_path/src/Resources/public"

    [ -d "$pub" ] || { warn "Plugin's Resources/public/ missing at '$pub'; cache not populated."; return 1; }
    [ -f "$pub/administration/.vite/entrypoints.json" ] || {
        warn "No administration/.vite/entrypoints.json in '$pub'; build likely failed, cache not populated."
        return 1
    }

    docker volume inspect "$vol" >/dev/null 2>&1 || \
        docker volume create --label swctl.managed=true --label swctl.kind=plugin-build "$vol" >/dev/null

    info "Populating plugin build cache '$vol'…"
    # chown -R 1000:1000 so the Shopware dev container (runs as www-data)
    # can read + serve the cached files RO; the volume mount is also RO so
    # no writes are expected, but ownership still matters for execute/read
    # permissions across uids.  `.ready` touched LAST.
    if ! docker run --rm \
        -v "${pub}:/src:ro" \
        -v "${vol}:/dst" \
        alpine sh -c 'cp -a /src/. /dst/ && touch /dst/.ready && chown -R 1000:1000 /dst' 2>/dev/null; then
        err "Failed to populate plugin build cache '$vol'."
        return 1
    fi
    ok "Plugin build cache '$vol' populated."
}

# Locked populate: called via swctl_lock from cmd_create.  Re-checks hit
# inside the lock — if another create populated during our wait, skip.
# Without this, two parallel creates of the same plugin commit would both
# finish building concurrently and both populate the same cache volume,
# racing on the same files.
_populate_plugin_build_cache_if_missing() {
    local vol="$1"
    local pw="$2"
    if _plugin_build_cache_hit "$vol"; then
        info "Plugin build cache '$vol' was populated by another create — skipping."
        return 0
    fi
    _populate_plugin_build_cache "$vol" "$pw"
}

detect_package_install_command() {
    local path="$1"

    if [ -f "$path/pnpm-lock.yaml" ]; then
        printf '%s\n' "pnpm install --frozen-lockfile"
        return
    fi

    if [ -f "$path/yarn.lock" ]; then
        printf '%s\n' "yarn install --frozen-lockfile"
        return
    fi

    if [ -f "$path/package-lock.json" ]; then
        printf '%s\n' "npm ci"
        return
    fi

    if [ -f "$path/package.json" ]; then
        printf '%s\n' "npm install"
    fi
}

write_env_file() {
    local env_file="$WORKTREE_PATH/$SW_ENV_FILE_NAME"
    local backup_file="$WORKTREE_PATH/${SW_ENV_FILE_NAME}.pre-swctl"

    if [ -f "$env_file" ] && ! grep -Fq "Managed by swctl" "$env_file"; then
        if [ ! -f "$backup_file" ]; then
            cp "$env_file" "$backup_file"
            warn "Backed up existing $SW_ENV_FILE_NAME to $(basename "$backup_file")."
        fi
    fi

    # Generate a stable APP_SECRET per worktree (deterministic from project+issue)
    local app_secret
    app_secret="$(printf '%s-%s' "$SW_PROJECT_SLUG" "$ISSUE_ID" | openssl dgst -sha256 | sed 's/.*= //')"

    cat >"$env_file" <<EOF
# Managed by swctl. Re-generated on $(timestamp_utc)
APP_ENV=dev
APP_URL=${APP_URL}
APP_SECRET=${app_secret}
DATABASE_URL=mysql://${SW_DB_ROOT_USER}:${SW_DB_ROOT_PASSWORD}@${SW_DB_HOST}:${SW_DB_PORT}/${DB_NAME}
MAILER_DSN=${SW_MAILER_DSN}
REDIS_URL=${SW_REDIS_URL}
OPENSEARCH_URL=${SW_OPENSEARCH_URL:-}
ADMIN_OPENSEARCH_URL=${SW_OPENSEARCH_URL:-}
WORKTREE_ID=${WORKTREE_ID}
COMPOSE_PROJECT_NAME=${COMPOSE_PROJECT}
SWCTL_PROJECT=${SW_PROJECT}
SWCTL_ISSUE=${ISSUE_ID}
EOF

    ok "Generated ${SW_ENV_FILE_NAME}."

    # Symfony Dotenv requires .env to exist for .env.local to be loaded.
    if [ ! -f "$WORKTREE_PATH/.env" ]; then
        touch "$WORKTREE_PATH/.env"
    fi
}

