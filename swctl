cmd_resolve_diff() {
    local issue_input="${1:-}"
    [ -n "$issue_input" ] || die "Usage: swctl resolve diff <issue>"

    maybe_load_project_config >/dev/null 2>&1 || true
    local meta_file=""
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || die "No instance for '$issue_input'."
    load_instance_metadata "$meta_file"

    local wt="$WORKTREE_PATH"
    [ -d "$wt" ] || die "Worktree not found: $wt"

    local base="${BASE_REF:-trunk}"

    info "Changes in $BRANCH vs $base:"
    printf '\n'

    # Show stat summary first
    git -C "$wt" diff "$base...$BRANCH" --stat 2>/dev/null

    printf '\n'

    # Full diff with color, piped to pager
    if command -v delta >/dev/null 2>&1; then
        git -C "$wt" diff "$base...$BRANCH" | delta
    elif command -v bat >/dev/null 2>&1; then
        git -C "$wt" diff "$base...$BRANCH" --color=always | bat --style=plain
    else
        git -C "$wt" diff "$base...$BRANCH" --color=always | ${PAGER:-less -R}
    fi
}

cmd_resolve_ask() {
    local issue_input="${1:-}"
    shift || true
    local message="$*"

    [ -n "$issue_input" ] || die "Usage: swctl resolve ask <issue> \"message\""
    [ -n "$message" ] || die "Message required.\nUsage: swctl resolve ask <issue> \"explain the changes\""

    maybe_load_project_config >/dev/null 2>&1 || true
    local meta_file=""
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || die "No instance for '$issue_input'."
    load_instance_metadata "$meta_file"

    local backend="${RESOLVE_BACKEND:-claude}"
    local ai_bin
    ai_bin="$(_ai_backend_binary "$backend")" || die "Unknown resolve backend '$backend'."

    case "$backend" in
        claude)
            if [ -n "${CLAUDE_SESSION_ID:-}" ]; then
                info "[resolve] Asking Claude (resuming session ${CLAUDE_SESSION_ID:0:8}...):"
                "$ai_bin" -p "$message" \
                    --resume "$CLAUDE_SESSION_ID" \
                    --permission-mode acceptEdits \
                    --add-dir "$WORKTREE_PATH" \
                    2>/dev/null
            else
                info "[resolve] Asking Claude (new session in worktree):"
                "$ai_bin" -p "$message" \
                    --permission-mode acceptEdits \
                    --add-dir "$WORKTREE_PATH" \
                    2>/dev/null
            fi
            ;;
        codex)
            warn "[resolve] Codex backend is experimental; flag mapping may change in a future release."
            if [ -n "${CLAUDE_SESSION_ID:-}" ]; then
                info "[resolve] Asking Codex (resuming session ${CLAUDE_SESSION_ID:0:8}...):"
                "$ai_bin" exec \
                    --session "$CLAUDE_SESSION_ID" \
                    --resume \
                    --cd "$WORKTREE_PATH" \
                    --message "$message" \
                    2>/dev/null
            else
                info "[resolve] Asking Codex (new session in worktree):"
                "$ai_bin" exec \
                    --cd "$WORKTREE_PATH" \
                    --message "$message" \
                    2>/dev/null
            fi
            ;;
        *)
            die "Unsupported resolve backend '$backend'."
            ;;
    esac
}

cmd_resolve_chat() {
