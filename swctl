tui_select_project() {
    local projects_list=""
    projects_list="$(list_projects)"
    if [ -z "$projects_list" ]; then
        warn "No projects registered. Run 'swctl project add' first."
        return 1
    fi

    local names=""
    names="$(printf '%s\n' "$projects_list" | cut -f1)"
    local count
    count="$(printf '%s\n' "$names" | wc -l | tr -d ' ')"

    if [ "$count" -eq 1 ]; then
        printf '%s' "$names"
        return
    fi

    if command -v fzf >/dev/null 2>&1; then
        printf '%s\n' "$names" | fzf --prompt='Project> ' --height=40% --reverse || return 1
    else
        printf '%s\n' "Available projects:" >&2
        local i=1
        while IFS= read -r name; do
            printf '  [%d] %s\n' "$i" "$name" >&2
            i=$((i + 1))
        done <<< "$names"
        local choice
        choice="$(prompt_text "Select project [1-$count]")"
        printf '%s\n' "$names" | sed -n "${choice}p"
    fi
}

tui_select_mode() {
    if command -v fzf >/dev/null 2>&1; then
        printf 'dev\nqa\n' | fzf --prompt='Mode> ' --height=20% --reverse || printf 'dev'
    else
        printf '%s\n' "  [1] dev  [2] qa" >&2
        local choice
        choice="$(prompt_text "Select mode [1-2]")"
        case "$choice" in
            2) printf 'qa' ;;
            *) printf 'dev' ;;
        esac
    fi
}

tui_select_branch() {
    local project_path="$1"
    local mode="$2"

    # Fetch both local and remote branches, dedup, sorted by recent commit
    local branches=""
    branches="$(git -C "$project_path" for-each-ref --sort=-committerdate \
        --format='%(refname:short)' refs/heads/ refs/remotes/origin/ --count=200 2>/dev/null \
        | sed 's|^origin/||' | grep -v '^HEAD$' | awk '!seen[$0]++' || true)"

    if command -v fzf >/dev/null 2>&1 && [ -n "$branches" ]; then
        local selected=""
        selected="$(printf '%s\n' "$branches" | fzf --prompt='Branch> ' --height=40% --reverse --print-query | tail -1 || true)"
        [ -n "$selected" ] && { printf '%s' "$selected"; return; }
    fi

    prompt_text "Branch name"
}

tui_select_plugin() {
    local project_path="$1"
    local plugins=""
    plugins="$(list_available_plugins "$project_path")"
    [ -n "$plugins" ] || return 0

    # Add "none" option at the top
    local options=""
    options="$(printf '%s\n%s' "(none - platform only)" "$plugins")"

    local selected=""
    if command -v fzf >/dev/null 2>&1; then
        selected="$(printf '%s\n' "$options" | fzf --prompt='Plugin (optional)> ' --height=40% --reverse || true)"
    else
        printf '%s\n' "Available plugins:" >&2
        printf '  [0] (none - platform only)\n' >&2
        local i=1
        while IFS= read -r name; do
            printf '  [%d] %s\n' "$i" "$name" >&2
            i=$((i + 1))
        done <<< "$plugins"
        local choice
        choice="$(prompt_text "Select plugin [0-$((i - 1))]")"
        [ "$choice" = "0" ] && return 0
        [ -n "$choice" ] && selected="$(printf '%s\n' "$plugins" | sed -n "${choice}p")"
    fi

    case "$selected" in
        "(none"*|"") return 0 ;;
        *) printf '%s' "$selected" ;;
    esac
}

tui_create_flow() {
    local issue_input=""
    local branch_input=""
    local project_input=""
    local plugin_input=""
    local mode_input=""

    # Select project (platform only)
    project_input="$(tui_select_project || true)"
    [ -n "$project_input" ] || { warn "No project selected."; return; }

    # Resolve project path
    local project_path=""
    project_path="$(list_projects | awk -F'\t' -v p="$project_input" '$1==p {print $3}')"

    # Select plugin (optional — only for platform projects)
    local project_type=""
    project_type="$(list_projects | awk -F'\t' -v p="$project_input" '$1==p {print $2}')"
    if [ "$project_type" = "platform" ]; then
        plugin_input="$(tui_select_plugin "$project_path" || true)"
    fi

    # Select mode
    mode_input="$(tui_select_mode)"

    issue_input="$(prompt_text "Issue id")"
    [ -n "$issue_input" ] || {
        warn "Issue id cannot be empty."
        return
    }

    # Branch listing: use plugin repo if a plugin was selected
    local branch_repo_path="$project_path"
    if [ -n "$plugin_input" ]; then
        branch_repo_path="$project_path/custom/plugins/$plugin_input"
    fi

    branch_input="$(tui_select_branch "$branch_repo_path" "$mode_input")"
    [ -n "$branch_input" ] || {
        warn "Branch name cannot be empty."
        return
    }

    local create_args="--$mode_input --project $project_input"
    [ -n "$plugin_input" ] && create_args="$create_args --plugin $plugin_input"
    cmd_create $create_args "$issue_input" "$branch_input"
}

tui_batch_create_flow() {
    local project_input=""
    local plugin_input=""
    local mode_input=""
    local issues=""
    local pairs=""
    local parallel_flag=""

    # Select project
    project_input="$(tui_select_project || true)"
    [ -n "$project_input" ] || { warn "No project selected."; return; }

    local project_path=""
    project_path="$(list_projects | awk -F'\t' -v p="$project_input" '$1==p {print $3}')"

    # Select plugin (optional — only for platform projects)
    local project_type=""
    project_type="$(list_projects | awk -F'\t' -v p="$project_input" '$1==p {print $2}')"
    if [ "$project_type" = "platform" ]; then
        plugin_input="$(tui_select_plugin "$project_path" || true)"
    fi

    # Select mode
    mode_input="$(tui_select_mode)"

    # Collect issue IDs
    info "Enter issue IDs one per line. Press Enter on an empty line to finish."
    while true; do
        local issue_line=""
        issue_line="$(prompt_text "Issue ID (empty to finish)")"
        [ -n "$issue_line" ] || break
        local branch_name=""
        if [ "$mode_input" = "dev" ]; then
            branch_name="feature/$issue_line"
        else
            branch_name="$(prompt_text "Branch for $issue_line")"
            [ -n "$branch_name" ] || { warn "Branch required in QA mode."; continue; }
        fi
        pairs="$pairs $issue_line $branch_name"
    done

    [ -n "$pairs" ] || { warn "No issues entered."; return; }

    # Ask about parallel
    local parallel_answer=""
    parallel_answer="$(prompt_text "Run in parallel? [y/N]")"
    if [[ "$parallel_answer" =~ ^[yY] ]]; then
        parallel_flag="--parallel"
    fi

    # Build and run
    local batch_args="--project $project_input --$mode_input"
    [ -n "$plugin_input" ] && batch_args="$batch_args --plugin $plugin_input"
    [ -n "$parallel_flag" ] && batch_args="$batch_args $parallel_flag"

    cmd_batch_create $batch_args $pairs
}

