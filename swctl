tui_detail_flow() {
    local scope="all"
    if maybe_load_project_config >/dev/null 2>&1; then scope="project"; fi
    local issue_input=""
    issue_input="$(select_issue_prompt "$scope" || true)"
    [ -n "$issue_input" ] || { warn "No issue selected."; return; }

    maybe_load_project_config >/dev/null 2>&1 || true
    local meta_file=""
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || { warn "No worktree found for '$issue_input'."; return; }
    load_instance_metadata "$meta_file"

    local container_state=""
    if [ -n "$(app_container_id "$COMPOSE_PROJECT" 2>/dev/null)" ]; then
        container_state="running"
    elif [ -n "$(app_container_exists_any_state "$COMPOSE_PROJECT" 2>/dev/null)" ]; then
        container_state="stopped"
    else
        container_state="missing"
    fi

    local choice=""
    while true; do
        clear_screen
        printf '%b── Instance: %s ──%b\n\n' "$COLOR_BOLD" "$ISSUE_ID" "$COLOR_RESET"
        printf '  %-16s %s\n' "Issue:" "$ISSUE_ID"
        printf '  %-16s %s\n' "Branch:" "${BRANCH:---}"
        printf '  %-16s %s\n' "Base Ref:" "${BASE_REF:---}"
        printf '  %-16s %s\n' "Mode:" "${SWCTL_MODE:-dev}"
        printf '  %-16s %s (%s)\n' "Project:" "$PROJECT" "${PROJECT_TYPE:-platform}"
        printf '  %-16s %s\n' "Domain:" "${DOMAIN:---}"
        printf '  %-16s %s\n' "App URL:" "${APP_URL:---}"
        printf '  %-16s %s (%s)\n' "Database:" "${DB_NAME:---}" "${DB_STATE:-unknown}"
        printf '  %-16s %s\n' "Compose:" "${COMPOSE_PROJECT:---}"
        printf '  %-16s %s\n' "Worktree:" "${WORKTREE_PATH:---}"
        printf '  %-16s %b\n' "Container:" "$(status_label "$COMPOSE_PROJECT")"
        printf '  %-16s %s\n' "Created:" "${CREATED_AT:---}"
        [ -z "${PLUGIN_NAME:-}" ] || printf '  %-16s %s\n' "Plugin:" "$PLUGIN_NAME"
        printf '\n'

        printf '%s\n' "[l] Logs (follow)    [e] Exec command    [o] Open in browser"
        if [ "$container_state" = "running" ]; then
            printf '%s\n' "[s] Stop            [r] Restart         [w] Switch mode"
        elif [ "$container_state" = "stopped" ]; then
            printf '%s\n' "[s] Start           [r] Restart         [w] Switch mode"
        fi
        printf '%s\n' "[f] Refresh (pull)  [d] Delete          [b] Back"
        printf '\n'
        printf '%bAction: %b' "$COLOR_BLUE" "$COLOR_RESET"
        read -r -n 1 choice
        printf '\n\n'

        case "$choice" in
            l) show_cursor; cmd_logs "$ISSUE_ID" "--follow"; hide_cursor; pause_for_key ;;
            e)
                show_cursor
                local cmd_str=""
                cmd_str="$(prompt_text "Command")"
                if [ -n "$cmd_str" ]; then
                    cmd_exec "$ISSUE_ID" "$cmd_str"
                fi
                hide_cursor
                pause_for_key
                ;;
            o) cmd_open "$ISSUE_ID"; pause_for_key ;;
            s)
                if [ "$container_state" = "running" ]; then
                    cmd_stop "$ISSUE_ID"; container_state="stopped"
                else
                    cmd_start "$ISSUE_ID"; container_state="running"
                fi
                pause_for_key
                ;;
            r) cmd_restart "$ISSUE_ID"; pause_for_key ;;
            w)
                show_cursor
                local new_mode=""
                new_mode="$(tui_select_mode)"
                cmd_switch "$ISSUE_ID" "--$new_mode"
                hide_cursor
                pause_for_key
                ;;
            f) cmd_refresh "$ISSUE_ID"; pause_for_key ;;
            d) cmd_clean "$ISSUE_ID"; pause_for_key; return ;;
            b|q) return ;;
            *) warn "Unknown option: $choice"; pause_for_key ;;
        esac
    done
}

cmd_tui() {
    local choice=""

    trap 'tui_cleanup; exit 0' EXIT INT TERM
    hide_cursor

    while true; do
        clear_screen
        render_tui_header
        render_status_table "all"
        printf '\n'
        render_tui_menu
        printf '%bAction: %b' "$COLOR_BLUE" "$COLOR_RESET"
        read -r -n 1 choice
        printf '\n\n'

        case "$choice" in
            1) show_cursor; tui_create_flow; hide_cursor; pause_for_key ;;
            2) tui_detail_flow ;;
            3) show_cursor; tui_exec_flow; hide_cursor; pause_for_key ;;
            4) show_cursor; tui_logs_flow; hide_cursor; pause_for_key ;;
            5) show_cursor; tui_stop_flow; hide_cursor; pause_for_key ;;
            6) show_cursor; tui_start_flow; hide_cursor; pause_for_key ;;
            7) show_cursor; tui_restart_flow; hide_cursor; pause_for_key ;;
            8) show_cursor; tui_refresh_flow; hide_cursor; pause_for_key ;;
            9) show_cursor; tui_switch_mode_flow; hide_cursor; pause_for_key ;;
            0) show_cursor; tui_clean_flow; hide_cursor; pause_for_key ;;
            o|O) show_cursor; tui_open_flow; hide_cursor; pause_for_key ;;
            b|B) show_cursor; tui_batch_create_flow; hide_cursor; pause_for_key ;;
            d|D) cmd_dashboard ;;
            i|I) init_infra; pause_for_key ;;
            r|R) ;;
            q|Q) break ;;
            *) warn "Unknown option: $choice"; pause_for_key ;;
        esac
    done

    tui_cleanup
    trap - EXIT INT TERM
}

db_size_mb() {
    local db_name="$1"
    mysql_exec "SELECT ROUND(IFNULL(SUM(data_length + index_length), 0) / 1024 / 1024, 1) FROM information_schema.TABLES WHERE table_schema='${db_name}';" 2>/dev/null || printf 'n/a'
}

render_dashboard_db_sizes() {
    local file=""
    local seen_file="$SWCTL_TMP_DIR/seen-dbs.$$"
    : >"$seen_file"

    printf '%bDatabase Sizes%b\n' "$COLOR_BOLD" "$COLOR_RESET"
    printf '%-24s %-10s %-10s\n' "Database" "State" "Size(MB)"
    printf '%-24s %-10s %-10s\n' "------------------------" "----------" "----------"

    while IFS= read -r file; do
        [ -n "$file" ] || continue
        load_instance_metadata "$file"
        if grep -Fxq "$DB_NAME" "$seen_file" 2>/dev/null; then
            continue
        fi
        printf '%s\n' "$DB_NAME" >>"$seen_file"
        printf '%-24s %-10s %-10s\n' "$DB_NAME" "$DB_STATE" "$(db_size_mb "$DB_NAME")"
    done <<EOF
$(list_instance_files "all")
EOF

    if [ ! -s "$seen_file" ]; then
        printf '%s\n' "No tracked databases."
    fi

    rm -f "$seen_file"
}

render_dashboard_containers() {
    local container_ids=""

    container_ids="$(docker ps -q --filter label=swctl.managed=true || true)"
    printf '%bContainer Stats%b\n' "$COLOR_BOLD" "$COLOR_RESET"
    if [ -z "$container_ids" ]; then
        printf '%s\n' "No running swctl-managed containers."
        return
    fi

    # docker stats powers the live CPU/memory panel without extra dependencies.
    # shellcheck disable=SC2086
    docker stats --no-stream --format 'table {{.Name}}\t{{.CPUPerc}}\t{{.MemUsage}}' $container_ids
}

render_dashboard_worktrees() {
    printf '\n%bWorktree Status%b\n' "$COLOR_BOLD" "$COLOR_RESET"
    render_status_table "all"
}

cmd_dashboard() {
    local running=1

    trap 'running=0' INT TERM
    while [ "$running" -eq 1 ]; do
        clear_screen
        printf '%b%s%b\n' "$COLOR_BOLD" "swctl Live Dashboard" "$COLOR_RESET"
        printf '%s\n\n' "Updated: $(date '+%Y-%m-%d %H:%M:%S')"
        render_dashboard_containers
        printf '\n'
        render_dashboard_db_sizes
        render_dashboard_worktrees
        printf '\n%s\n' "Press Ctrl+C to exit."

        local tick=0
        while [ "$tick" -lt 5 ] && [ "$running" -eq 1 ]; do
            sleep 1
            tick=$((tick + 1))
        done
    done

    trap - INT TERM
    printf '\n'
}

cmd_build_base() {
    load_project_config
    ensure_docker
    ensure_infra_ready

    local vendor_base="vendor-base-${SW_PROJECT_SLUG}"
    local node_base="node_modules-base-${SW_PROJECT_SLUG}"
    local tmp_project="swctl-base-build-$$"
    local tmp_env="$SWCTL_TMP_DIR/base-build.env"

    info "Building base volumes for project '${SW_PROJECT_SLUG}'."

    # Create volumes if they don't exist
    docker volume inspect "$vendor_base" >/dev/null 2>&1 || docker volume create "$vendor_base" >/dev/null
    docker volume inspect "$node_base" >/dev/null 2>&1 || docker volume create "$node_base" >/dev/null

    # Write minimal compose env for base build
    cat >"$tmp_env" <<ENVEOF
SW_PHP_IMAGE=${SW_PHP_IMAGE}
SW_WORKTREE_PATH=${PROJECT_ROOT}
SW_WORKTREE_ID=base
SW_PROJECT=${SW_PROJECT}
SW_ISSUE=base
SW_PROJECT_SLUG=${SW_PROJECT_SLUG}
SW_APP_DOMAIN=localhost
SW_APP_URL=http://localhost
SW_APP_HTTP_PORT=${SW_APP_HTTP_PORT}
SW_TRAEFIK_NETWORK=${SW_TRAEFIK_NETWORK}
SW_TRAEFIK_ROUTER=swctl_base
SW_TRAEFIK_SERVICE=swctl_base
SW_DB_HOST=${SW_DB_HOST}
SW_DB_PORT=${SW_DB_PORT}
SW_DB_NAME=swctl_base_tmp
SW_DB_ROOT_USER=${SW_DB_ROOT_USER}
SW_DB_ROOT_PASSWORD=${SW_DB_ROOT_PASSWORD}
SW_REDIS_URL=${SW_REDIS_URL}
SW_MAILER_DSN=${SW_MAILER_DSN}
SW_VENDOR_VOLUME=${vendor_base}
SW_NODE_MODULES_VOLUME=${node_base}
SW_UID=${SW_UID}
SW_GID=${SW_GID}
SW_DOCKER_PLATFORM=${SW_DOCKER_PLATFORM}
SW_COMPOSER_ROOT_VERSION=${SW_COMPOSER_ROOT_VERSION}
ENVEOF

    # Start temporary container with base volumes
    local base_compose_args="-f $SW_COMPOSE_TEMPLATE"
    [ -n "${SW_COMPOSE_PROJECT_OVERRIDE:-}" ] && [ -f "${SW_COMPOSE_PROJECT_OVERRIDE:-}" ] && base_compose_args="$base_compose_args -f $SW_COMPOSE_PROJECT_OVERRIDE"
    compose --project-directory "$SWCTL_TMP_DIR" \
        $base_compose_args --env-file "$tmp_env" \
        -p "$tmp_project" up -d

    wait_for_app_container "$tmp_project"
    fix_volume_ownership "$tmp_project"

    info "Running composer install into base vendor volume."
    run_app_command "$tmp_project" "composer install --no-interaction" || warn "composer install failed."

    local pkg_cmd
    pkg_cmd="$(detect_package_install_command "$PROJECT_ROOT" || true)"
    if [ -n "$pkg_cmd" ]; then
        info "Running $pkg_cmd into base node_modules volume."
        run_app_command "$tmp_project" "$pkg_cmd" || warn "Node install failed."
    fi

    # Tear down temporary container
    compose --project-directory "$SWCTL_TMP_DIR" \
        $base_compose_args --env-file "$tmp_env" \
        -p "$tmp_project" down --remove-orphans >/dev/null || true

    rm -f "$tmp_env"
    ok "Base volumes populated: $vendor_base, $node_base"
}

cmd_build_shared_db() {
    local force=false
    while [ $# -gt 0 ]; do
        case "$1" in
            --force|-f) force=true; shift ;;
            *) die "Unknown option: $1" ;;
        esac
    done

    load_project_config
    ensure_docker
    ensure_infra_ready

    local shared_db
    shared_db="$(sanitize_db_identifier "$SW_DB_SHARED_NAME")"

    if mysql_db_has_tables "$shared_db" && [ "$force" = false ]; then
        warn "Shared database '$shared_db' already has tables."
        warn "Use --force to drop and rebuild it."
        return 1
    fi

    # Find the main project's running web container
    local main_container
    main_container="$(docker ps --filter "network=${SW_PROJECT_NETWORK}" \
        --format '{{.Names}}' 2>/dev/null | grep -E "^${SW_PROJECT}-web-" | head -1)"
    [ -n "$main_container" ] || die "Main project container not found. Start your project first: cd $PROJECT_ROOT && docker compose up -d"

    info "Building shared database '$shared_db' using container '$main_container'."

    # Create/reset the shared DB
    create_database "$shared_db"

    # Run system:install against the shared DB by overriding DATABASE_URL
    local install_url="mysql://${SW_DB_ROOT_USER}:${SW_DB_ROOT_PASSWORD}@${SW_DB_HOST}:${SW_DB_PORT}/${shared_db}"
    docker exec -e "DATABASE_URL=$install_url" "$main_container" \
        $SW_BIN_CONSOLE system:install $SW_SHARED_DB_INSTALL_ARGS \
        || die "system:install failed."

    ok "Shared database '$shared_db' built for project '${SW_PROJECT_SLUG}'."
}

cmd_clean_base() {
    load_project_config
    local vendor_base="vendor-base-${SW_PROJECT_SLUG}"
    local node_base="node_modules-base-${SW_PROJECT_SLUG}"
    docker volume rm "$vendor_base" 2>/dev/null && ok "Removed $vendor_base" || info "$vendor_base not found."
    docker volume rm "$node_base" 2>/dev/null && ok "Removed $node_base" || info "$node_base not found."
}

SWCTL_GITHUB_TOKEN_FILE="$SWCTL_STATE_DIR/github.token"

cmd_auth() {
    local action="${1:-status}"

    case "$action" in
        login)
            # Try gh CLI first — simplest path, works with private repos
            if command -v gh >/dev/null 2>&1; then
                local gh_token
                gh_token="$(gh auth token 2>/dev/null)" || true
                if [ -n "$gh_token" ]; then
                    mkdir -p "$SWCTL_STATE_DIR"
                    printf '%s' "$gh_token" > "$SWCTL_GITHUB_TOKEN_FILE"
                    chmod 600 "$SWCTL_GITHUB_TOKEN_FILE"

                    local user_login
                    user_login="$(curl -sS -H "Authorization: token $gh_token" \
                        -H 'Accept: application/vnd.github.v3+json' \
                        'https://api.github.com/user' 2>/dev/null | sed -n 's/.*"login"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')"

                    ok "Authenticated as ${COLOR_BOLD}${user_login:-unknown}${COLOR_RESET} (via gh CLI)"
                    info "Token saved to $SWCTL_GITHUB_TOKEN_FILE"
                    return 0
                fi
                warn "gh CLI found but no active session. Falling back to Device Flow."
            fi

            # Fall back to Device Flow if gh CLI not available
            local client_id="${SWCTL_GITHUB_CLIENT_ID:-}"
            if [ -z "$client_id" ]; then
                die "SWCTL_GITHUB_CLIENT_ID is not set and gh CLI is not available.\nInstall gh CLI: https://cli.github.com and run 'gh auth login'\nOr create a GitHub App and export SWCTL_GITHUB_CLIENT_ID."
            fi

            info "Starting GitHub Device Flow authentication..."

            # Step 1: Request device code
            local device_response
            device_response="$(curl -sS -X POST 'https://github.com/login/device/code' \
                -H 'Accept: application/json' \
                -H 'Content-Type: application/json' \
                -d "{\"client_id\":\"${client_id}\",\"scope\":\"repo read:org\"}")"

            local user_code verification_uri device_code interval
            user_code="$(printf '%s' "$device_response" | sed -n 's/.*"user_code"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')"
            verification_uri="$(printf '%s' "$device_response" | sed -n 's/.*"verification_uri"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')"
            device_code="$(printf '%s' "$device_response" | sed -n 's/.*"device_code"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')"
            interval="$(printf '%s' "$device_response" | sed -n 's/.*"interval"[[:space:]]*:[[:space:]]*\([0-9]*\).*/\1/p')"
            interval="${interval:-5}"

            if [ -z "$user_code" ] || [ -z "$device_code" ]; then
                die "Failed to start device flow. Response: $device_response"
            fi

            printf '\n'
            printf '  %b%bOpen:%b  %s\n' "$COLOR_BOLD" "$COLOR_CYAN" "$COLOR_RESET" "$verification_uri"
            printf '  %b%bCode:%b  %s\n' "$COLOR_BOLD" "$COLOR_GREEN" "$COLOR_RESET" "$user_code"
            printf '\n'

            # Try to open browser
            if command -v open >/dev/null 2>&1; then
                open "$verification_uri" 2>/dev/null || true
            elif command -v xdg-open >/dev/null 2>&1; then
                xdg-open "$verification_uri" 2>/dev/null || true
            fi

            info "Waiting for authorization (press Ctrl+C to cancel)..."

            # Step 2: Poll for authorization
            while true; do
                sleep "$interval"
                local poll_response
                poll_response="$(curl -sS -X POST 'https://github.com/login/oauth/access_token' \
                    -H 'Accept: application/json' \
                    -H 'Content-Type: application/json' \
                    -d "{\"client_id\":\"${client_id}\",\"device_code\":\"${device_code}\",\"grant_type\":\"urn:ietf:params:oauth:grant-type:device_code\"}")"

                local access_token error_code
                access_token="$(printf '%s' "$poll_response" | sed -n 's/.*"access_token"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')"
                error_code="$(printf '%s' "$poll_response" | sed -n 's/.*"error"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')"

                if [ -n "$access_token" ]; then
                    mkdir -p "$SWCTL_STATE_DIR"
                    printf '%s' "$access_token" > "$SWCTL_GITHUB_TOKEN_FILE"
                    chmod 600 "$SWCTL_GITHUB_TOKEN_FILE"

                    # Fetch username
                    local user_login
                    user_login="$(curl -sS -H "Authorization: token $access_token" \
                        -H 'Accept: application/vnd.github.v3+json' \
                        'https://api.github.com/user' | sed -n 's/.*"login"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')"

                    printf '\n'
                    ok "Authenticated as ${COLOR_BOLD}${user_login:-unknown}${COLOR_RESET}"
                    info "Token saved to $SWCTL_GITHUB_TOKEN_FILE"
                    return 0
                fi

                case "$error_code" in
                    authorization_pending) ;;
                    slow_down) interval=$((interval + 5)) ;;
                    expired_token)
                        printf '\n'
                        die "Device code expired. Run 'swctl auth login' to try again."
                        ;;
                    *)
                        printf '\n'
                        die "Authentication failed: $error_code"
                        ;;
                esac
            done
            ;;

        logout)
            if [ -f "$SWCTL_GITHUB_TOKEN_FILE" ]; then
                rm -f "$SWCTL_GITHUB_TOKEN_FILE"
                ok "GitHub token removed."
            else
                info "Not logged in."
            fi
            ;;

        status)
            local token="" token_source=""
            if [ -f "$SWCTL_GITHUB_TOKEN_FILE" ]; then
                token="$(cat "$SWCTL_GITHUB_TOKEN_FILE")"
                token_source="token file"
            elif [ -n "${SWCTL_GITHUB_TOKEN:-}" ]; then
                token="$SWCTL_GITHUB_TOKEN"
                token_source="environment variable"
            elif command -v gh >/dev/null 2>&1; then
                token="$(gh auth token 2>/dev/null)" || true
                token_source="gh CLI"
            fi

            if [ -z "$token" ]; then
                info "Not authenticated. Run 'swctl auth login' to connect your GitHub account."
                return 0
            fi

            local user_response
            user_response="$(curl -sS -H "Authorization: token $token" \
                -H 'Accept: application/vnd.github.v3+json' \
                'https://api.github.com/user' 2>/dev/null)" || true

            local user_login
            user_login="$(printf '%s' "$user_response" | sed -n 's/.*"login"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')"

            if [ -n "$user_login" ]; then
                ok "Authenticated as ${COLOR_BOLD}${user_login}${COLOR_RESET} (${token_source})"
            else
                warn "Token exists but may be invalid. Run 'swctl auth login' to re-authenticate."
            fi
            ;;

        *)
            die "Usage: swctl auth [login|logout|status]"
            ;;
    esac
}

show_help() {
    cat <<EOF
swctl ${SWCTL_VERSION}

Usage:
  swctl init
  swctl create [--qa|--dev] <issue> [<branch>]
  swctl batch create [--file <path>|--gitlab <id>|--github <owner/repo>] [--parallel [-j N]] [ISSUE BRANCH ...]
  swctl status
  swctl exec <issue> '<cmd>'
  swctl logs <issue> [--follow|-f]
  swctl restart <issue>
  swctl refresh <issue>
  swctl open <issue>
  swctl code <issue> [--claude|--codex|--phpstorm|--code|--cursor]
  swctl switch <issue> --qa|--dev
  swctl clean <issue>
  swctl auth [login|logout|status]
  swctl tui
  swctl dashboard
  swctl --version
  swctl help

Commands:
  init        Idempotent setup of Traefik, MariaDB, Redis, and the swctl Docker network.
  create      Create a worktree. --qa: auto-build everything needed (vendor from trunk). --dev: writable vendor (default).
  batch       Batch create worktrees from CLI pairs, a file, or GitLab/GitHub MRs.
  status      Show tracked worktrees, routed domains, container state, and DB mode.
  exec        Execute a command inside the worktree's app container.
  logs        Show or follow container logs for a worktree.
  restart     Restart the app container for a worktree without full recreate.
  refresh     Pull latest changes, detect what changed, rebuild only the delta.
  open        Open the worktree URL in the default browser.
  code        Open worktree in an editor: --phpstorm (default), --claude, --codex, --code, --cursor.
  switch      Switch a worktree between QA and Dev mode (rebuilds only what's needed).
  clean       Stop the container, remove labeled volumes, drop dedicated DBs, and remove the worktree.
  auth        Authenticate with GitHub using Device Flow. Subcommands: login, logout, status.
  tui         Open the interactive ANSI dashboard.
  dashboard   Open the live monitoring dashboard.
  ui          Start/stop the web UI (http://swctl.orb.local). Usage: swctl ui [start|stop|logs]
  project     Manage registered projects: swctl project [add|list|remove|init]
  build-base  Pre-populate shared vendor and node_modules base volumes from the project root.
  clean-base  Remove shared base volumes for the current project.

Environment:
  swctl auto-detects .swctl.conf in the current directory or a parent directory.
  Set SWCTL_TEMPLATE_DIR if docker-compose.swctl.yml lives beside the installed binary.
EOF
}

cmd_ui() {
    local action="${1:-start}"
    local ui_compose="$SWCTL_TEMPLATE_DIR/app/docker-compose.ui.yml"
    [ -f "$ui_compose" ] || die "UI compose file not found: $ui_compose"

    # Try loading config from current dir, or fall back to first registered platform project
    if ! maybe_load_project_config >/dev/null 2>&1; then
        ensure_projects_file
        local platform_entry
        platform_entry="$(grep -E $'\tplatform\t' "$SWCTL_PROJECTS_FILE" | head -1)" || true
        if [ -n "$platform_entry" ]; then
            local platform_path
            platform_path="$(printf '%s' "$platform_entry" | cut -f3)"
            load_project_config "$platform_path/.swctl.conf"
        else
            die "No .swctl.conf found and no platform project registered. Run 'swctl project add' first."
        fi
    fi

    export SWCTL_SCRIPT_DIR="$SWCTL_TEMPLATE_DIR"
    export SWCTL_PROJECT_ROOT="$PROJECT_ROOT"
    export SWCTL_WORKTREE_ROOT="$SW_WORKTREE_ROOT"
    export SWCTL_STATE_DIR="$SWCTL_STATE_DIR"
    export SW_RUNTIME="${SW_RUNTIME:-$(detect_runtime)}"
    export SWCTL_EDITOR="${SWCTL_EDITOR:-phpstorm}"
    export SWCTL_BROWSE_ROOT="${SWCTL_BROWSE_ROOT:-$HOME}"
    # Load GitHub token from file if not set via env
    if [ -z "${SWCTL_GITHUB_TOKEN:-}" ] && [ -f "$SWCTL_GITHUB_TOKEN_FILE" ]; then
        SWCTL_GITHUB_TOKEN="$(cat "$SWCTL_GITHUB_TOKEN_FILE")"
    fi
    export SWCTL_GITHUB_TOKEN="${SWCTL_GITHUB_TOKEN:-}"
    export SWCTL_GITHUB_CLIENT_ID="${SWCTL_GITHUB_CLIENT_ID:-}"

    case "$action" in
        start)
            compose --project-directory "$SWCTL_TEMPLATE_DIR/app" -f "$ui_compose" -p swctl-ui up -d --build
            ok "swctl UI running at http://swctl.orb.local"
            ;;
        stop)
            compose --project-directory "$SWCTL_TEMPLATE_DIR/app" -f "$ui_compose" -p swctl-ui down
            ok "swctl UI stopped."
            ;;
        logs)
            compose --project-directory "$SWCTL_TEMPLATE_DIR/app" -f "$ui_compose" -p swctl-ui logs -f
            ;;
        *)
            die "Usage: swctl ui [start|stop|logs]"
            ;;
    esac
}

cmd_version() {
    printf 'swctl %s\n' "$SWCTL_VERSION"
}

main() {
    local command="${1:-help}"

    case "$command" in
        init)
            ensure_state_dirs
            init_infra
            ;;
        create)
            ensure_state_dirs
            shift
            cmd_create "$@"
            ;;
        batch)
            ensure_state_dirs
            shift
            cmd_batch "$@"
            ;;
        status)
            ensure_state_dirs
            cmd_status
            ;;
        exec)
            ensure_state_dirs
            shift
            cmd_exec "${1:-}" "${2:-}"
            ;;
        clean)
            ensure_state_dirs
            shift
            cmd_clean "${1:-}"
            ;;
        logs)
            ensure_state_dirs
            shift
            cmd_logs "${1:-}" "${2:-}"
            ;;
        restart)
            ensure_state_dirs
            shift
            cmd_restart "${1:-}"
            ;;
        stop)
            ensure_state_dirs
            shift
            cmd_stop "${1:-}"
            ;;
        start)
            ensure_state_dirs
            shift
            cmd_start "${1:-}"
            ;;
        kill-exec)
            ensure_state_dirs
            shift
            cmd_kill_exec "${1:-}"
            ;;
        refresh)
            ensure_state_dirs
            shift
            cmd_refresh "${1:-}"
            ;;
        open)
            ensure_state_dirs
            shift
            cmd_open "${1:-}"
            ;;
        code)
            ensure_state_dirs
            shift
            cmd_code "$@"
            ;;
        switch)
            ensure_state_dirs
            shift
            cmd_switch "$@"
            ;;
        tui)
            ensure_state_dirs
            cmd_tui
            ;;
        dashboard)
            ensure_state_dirs
            cmd_dashboard
            ;;
        auth)
            ensure_state_dirs
            shift
            cmd_auth "${1:-status}"
            ;;
        ui)
            ensure_state_dirs
            shift
            cmd_ui "${1:-start}"
            ;;
        build-base)
            ensure_state_dirs
            cmd_build_base
            ;;
        build-shared-db)
            ensure_state_dirs
            shift
            cmd_build_shared_db "$@"
            ;;
        clean-base)
            ensure_state_dirs
            cmd_clean_base
            ;;
        project)
            ensure_state_dirs
            shift
            cmd_project "$@"
            ;;
        --version|-v)
            cmd_version
            ;;
        help|-h|--help)
            show_help
            ;;
        *)
            die "Unknown command: $command"
            ;;
    esac
}

if [ "${SWCTL_SOURCED:-0}" != "1" ]; then
    main "$@"
fi
