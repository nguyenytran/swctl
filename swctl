write_compose_volume_override() {
    COMPOSE_VOLUME_OVERRIDE="$SWCTL_TMP_DIR/${COMPOSE_PROJECT}.volumes.override.yml"

    # Resolve per-app node_modules volumes (admin + storefront).  Kept on
    # ADMIN_NM_VOLUME / STOREFRONT_NM_VOLUME so callers outside this function
    # (metadata serialization, doctor) can see which ones are in use.
    ADMIN_NM_VOLUME="${ADMIN_NM_VOLUME:-$(resolve_admin_nm_volume "$ISSUE_ID")}"
    STOREFRONT_NM_VOLUME="${STOREFRONT_NM_VOLUME:-$(resolve_storefront_nm_volume "$ISSUE_ID")}"

    local vendor_is_shared=0
    local admin_nm_is_shared=0
    local sf_nm_is_shared=0

    case "$VENDOR_VOLUME" in vendor-base-*) vendor_is_shared=1 ;; esac
    case "$ADMIN_NM_VOLUME" in admin-nm-base-*) admin_nm_is_shared=1 ;; esac
    case "$STOREFRONT_NM_VOLUME" in storefront-nm-base-*) sf_nm_is_shared=1 ;; esac

    # Ensure shared base volumes exist + are populated BEFORE compose up.
    # Dedicated (per-instance) volumes are cloned from the matching base so
    # we never rsync these trees through VirtioFS on a per-create basis.
    # All volume ops are locked per-volume to avoid TOCTOU races when
    # multiple creates run in parallel.
    local _trunk_root="${PROJECT_ROOT:-/Users/ytran/Shopware/trunk}"
    # Vendor
    if [ "$vendor_is_shared" -eq 1 ]; then
        swctl_lock "volume-$VENDOR_VOLUME" _ensure_base_volume_populated \
            "$VENDOR_VOLUME" "$_trunk_root/vendor" "autoload.php"
    else
        # Dedicated vendor volume — clone from base, then the container's
        # composer install step (triggered by the compose/provision path)
        # applies the lockfile diff.
        local _vendor_base="vendor-base-${SW_PROJECT_SLUG}"
        swctl_lock "volume-$_vendor_base" _ensure_base_volume_populated \
            "$_vendor_base" "$_trunk_root/vendor" "autoload.php"
        swctl_lock "volume-$VENDOR_VOLUME" _clone_docker_volume \
            "$_vendor_base" "$VENDOR_VOLUME" \
            || warn "Failed to clone vendor base → $VENDOR_VOLUME; container will install from scratch."
    fi
    # Admin node_modules
    local _admin_src="$_trunk_root/src/Administration/Resources/app/administration/node_modules"
    if [ "$admin_nm_is_shared" -eq 1 ]; then
        swctl_lock "volume-$ADMIN_NM_VOLUME" _ensure_base_volume_populated \
            "$ADMIN_NM_VOLUME" "$_admin_src" ".package-lock.json"
    else
        local _admin_base="admin-nm-base-${SW_PROJECT_SLUG}"
        swctl_lock "volume-$_admin_base" _ensure_base_volume_populated \
            "$_admin_base" "$_admin_src" ".package-lock.json"
        swctl_lock "volume-$ADMIN_NM_VOLUME" _clone_docker_volume \
            "$_admin_base" "$ADMIN_NM_VOLUME" \
            || warn "Failed to clone admin_nm base → $ADMIN_NM_VOLUME; build may need npm install."
    fi
    # Storefront node_modules
    local _sf_src="$_trunk_root/src/Storefront/Resources/app/storefront/node_modules"
    if [ "$sf_nm_is_shared" -eq 1 ]; then
        swctl_lock "volume-$STOREFRONT_NM_VOLUME" _ensure_base_volume_populated \
            "$STOREFRONT_NM_VOLUME" "$_sf_src" ".package-lock.json"
    else
        local _sf_base="storefront-nm-base-${SW_PROJECT_SLUG}"
        swctl_lock "volume-$_sf_base" _ensure_base_volume_populated \
            "$_sf_base" "$_sf_src" ".package-lock.json"
        swctl_lock "volume-$STOREFRONT_NM_VOLUME" _clone_docker_volume \
            "$_sf_base" "$STOREFRONT_NM_VOLUME" \
            || warn "Failed to clone storefront_nm base → $STOREFRONT_NM_VOLUME; build may need npm install."
    fi

    # RO flag for shared base volumes (safe — nothing in the container writes
    # to trunk's vendor or node_modules under normal dev-mode operation).
    # Dedicated volumes stay RW.
    local _vendor_ro="" _admin_nm_ro="" _sf_nm_ro=""
    [ "$vendor_is_shared" -eq 1 ] && _vendor_ro=":ro"
    [ "$admin_nm_is_shared" -eq 1 ] && _admin_nm_ro=":ro"
    [ "$sf_nm_is_shared" -eq 1 ] && _sf_nm_ro=":ro"

    {
        printf 'volumes:\n'
        printf '  vendor:\n'
        printf '    name: %s\n' "$VENDOR_VOLUME"
        printf '    external: true\n'
        printf '  admin_node_modules:\n'
        printf '    name: %s\n' "$ADMIN_NM_VOLUME"
        printf '    external: true\n'
        printf '  storefront_node_modules:\n'
        printf '    name: %s\n' "$STOREFRONT_NM_VOLUME"
        printf '    external: true\n'
    } > "$COMPOSE_VOLUME_OVERRIDE"

    local svc="${SW_SERVICE_NAME:-web}"
    # Vendor + node_modules overlays are appended as service-level mounts so
    # the RO flag can vary per-instance.  Leading indentation (6 spaces) is
    # required by the compose merge format.
    local extra_volumes=""
    extra_volumes="${extra_volumes}      - vendor:/var/www/html/vendor${_vendor_ro}
"
    extra_volumes="${extra_volumes}      - admin_node_modules:/var/www/html/src/Administration/Resources/app/administration/node_modules${_admin_nm_ro}
"
    extra_volumes="${extra_volumes}      - storefront_node_modules:/var/www/html/src/Storefront/Resources/app/storefront/node_modules${_sf_nm_ro}
"

    # Media + thumbnail sharing strategy
    #
    # The naive approach — bind-mount trunk's public/media read-only into
    # every worktree — saves disk but breaks admin uploads with
    # "mkdir(): Read-only file system".  Uploads need write access and
    # the worktree's DB records expect those files by path.
    #
    # Fix: when DB_STATE=cloned, give the worktree its OWN copy under
    # ${WORKTREE_PATH}/public/{media,thumbnail} (RW) and populate it once
    # from trunk.  On APFS (`cp -c`) the clone is copy-on-write and
    # near-instant + near-zero disk cost; on other filesystems it's a
    # regular rsync (~5 s for ~300 MB).  Subsequent restarts reuse the
    # existing dir.
    #
    # DB_STATE=fresh still mounts trunk directly RW because system:install
    # writes into it and the two paths would disagree.
    if [ "$SW_RUNTIME" = "orbstack" ]; then
        if [ "${DB_STATE:-}" = "fresh" ]; then
            # Fresh install: bind-mount trunk RW.  Kept for backward
            # compat — system:install writes media directly there.
            if [ -d "$PROJECT_ROOT/public/media" ]; then
                extra_volumes="${extra_volumes}      - ${PROJECT_ROOT}/public/media:/var/www/html/public/media:cached
"
            fi
            if [ -d "$PROJECT_ROOT/public/thumbnail" ]; then
                extra_volumes="${extra_volumes}      - ${PROJECT_ROOT}/public/thumbnail:/var/www/html/public/thumbnail:cached
"
            fi
        else
            # Cloned DB or unknown: per-worktree RW copy.
            local _m _src _dst
            for _m in public/media public/thumbnail; do
                _src="$PROJECT_ROOT/$_m"
                _dst="$WORKTREE_PATH/$_m"
                [ -d "$_src" ] || continue
                # Populate once.  Reuse existing content if dst already
                # has files (survives container restart without re-cloning).
                if [ ! -d "$_dst" ] || [ -z "$(ls -A "$_dst" 2>/dev/null)" ]; then
                    info "Populating ${_m}/ in worktree (per-worktree RW copy)…"
                    mkdir -p "$(dirname "$_dst")"
                    if cp -cR "$_src" "$_dst" 2>/dev/null; then
                        : # APFS clone succeeded
                    else
                        mkdir -p "$_dst"
                        rsync -a "$_src/" "$_dst/" 2>/dev/null || warn "Could not populate ${_m}/ from trunk."
                    fi
                fi
                extra_volumes="${extra_volumes}      - ${_dst}:/var/www/html/${_m}:cached
"
            done
        fi
    fi

    # Plugin mounts: bind-mount external plugin worktrees into custom/plugins/
    if [ -n "${PLUGIN_WORKTREE_PATHS:-}" ] && [ -n "${LINKED_PLUGINS:-}" ]; then
        local pw_arr pl_arr
        IFS=',' read -ra pw_arr <<< "$PLUGIN_WORKTREE_PATHS"
        IFS=',' read -ra pl_arr <<< "$LINKED_PLUGINS"
        local i
        for i in "${!pw_arr[@]}"; do
            local pw_path="${pw_arr[$i]}"
            local p_name="${pl_arr[$i]}"
            if [ -n "$pw_path" ] && [ -d "$pw_path" ] && [ -n "$p_name" ]; then
                extra_volumes="${extra_volumes}      - ${pw_path}:/var/www/html/custom/plugins/${p_name}:cached
"
            fi
        done
    fi

    # Plugin build cache (hit path): mount the cached Resources/public/ RO
    # over the plugin worktree's gitignored output dir so Shopware sees the
    # already-built entrypoints.json and bundle files without running npm.
    if [ "${PLUGIN_BUILD_CACHE_HIT:-0}" = "1" ] && [ -n "${PLUGIN_BUILD_CACHE_VOLUME:-}" ] \
       && [ -n "${PLUGIN_NAME:-}" ]; then
        # Declare as external top-level volume
        printf '  plugin_build_cache:\n    name: %s\n    external: true\n' \
            "$PLUGIN_BUILD_CACHE_VOLUME" >> "$COMPOSE_VOLUME_OVERRIDE"
        extra_volumes="${extra_volumes}      - plugin_build_cache:/var/www/html/custom/plugins/${PLUGIN_NAME}/src/Resources/public:ro
"
    fi

    if [ -n "$extra_volumes" ]; then
        printf '\nservices:\n  %s:\n    volumes:\n%s' "$svc" "$extra_volumes" \
            >> "$COMPOSE_VOLUME_OVERRIDE"
    fi
}

app_container_id() {
    local compose_project="$1"
    local service="${SW_SERVICE_NAME:-app}"
    local result
    result="$(docker ps -q \
        --filter "label=com.docker.compose.project=${compose_project}" \
        --filter "label=com.docker.compose.service=${service}" \
        2>/dev/null | sed -n '1p')"
    if [ -z "$result" ]; then
        # Fallback: try both service names for backward compatibility
        local alt_service="app"
        [ "$service" = "app" ] && alt_service="web"
        result="$(docker ps -q \
            --filter "label=com.docker.compose.project=${compose_project}" \
            --filter "label=com.docker.compose.service=${alt_service}" \
            2>/dev/null | sed -n '1p')"
    fi
    printf '%s' "$result"
}

app_container_exists_any_state() {
    local compose_project="$1"
    local service="${SW_SERVICE_NAME:-app}"
    local result
    result="$(docker ps -aq \
        --filter "label=com.docker.compose.project=${compose_project}" \
        --filter "label=com.docker.compose.service=${service}" \
        2>/dev/null | sed -n '1p')"
    if [ -z "$result" ]; then
        local alt_service="app"
        [ "$service" = "app" ] && alt_service="web"
        result="$(docker ps -aq \
            --filter "label=com.docker.compose.project=${compose_project}" \
            --filter "label=com.docker.compose.service=${alt_service}" \
            2>/dev/null | sed -n '1p')"
    fi
    printf '%s' "$result"
}

wait_for_app_container() {
    local compose_project="$1"
    local attempt=0
    while [ "$attempt" -lt 60 ]; do
        if [ -n "$(app_container_id "$compose_project")" ]; then
            return 0
        fi
        attempt=$((attempt + 1))
        sleep 1
    done

    die "App container for '$compose_project' did not start in time."
}

# Gracefully restart PHP-FPM workers to clear the FPM OPcache.
# OrbStack probes the container immediately after "docker compose up", causing
# PHP-FPM to cache bytecode before provisioning finishes. SIGUSR2 tells the
# FPM master to respawn all worker processes with a clean OPcache.
restart_php_fpm() {
    local compose_project="$1"
    local container_id
    container_id="$(app_container_id "$compose_project")"
    [ -n "$container_id" ] || return 0
    docker exec "$container_id" bash -c 'kill -USR2 $(pgrep -o php-fpm) 2>/dev/null' >/dev/null 2>&1 || true
}

exec_in_container() {
    local container_id="$1"
    local command_string="$2"

    if [ -t 0 ] && [ -t 1 ]; then
        docker exec -it "$container_id" bash -lc "$command_string"
    else
        # Non-interactive: wrap command to track PID so it can be killed remotely.
        # docker exec does NOT kill the container process when the client dies.
        # Close stdin (<&-) to avoid holding the pipe FD from the server process.
        docker exec "$container_id" bash -c '
            bash -lc "$1" &
            child=$!
            echo "$child" > /tmp/.swctl-exec.pid
            wait "$child" 2>/dev/null
            code=$?
            rm -f /tmp/.swctl-exec.pid
            exit $code
        ' _ "$command_string" <&-
    fi
}

cmd_kill_exec() {
    local issue_input="${1:-}"
    [ -n "$issue_input" ] || return 1

    maybe_load_project_config >/dev/null 2>&1 || true
    local meta_file
    meta_file="$(resolve_instance_file_by_issue "$issue_input" 2>/dev/null)" || return 1
    load_instance_metadata "$meta_file"

    local container_id
    container_id="$(app_container_id "$COMPOSE_PROJECT" 2>/dev/null)" || return 1
    [ -n "$container_id" ] || return 1

    # Kill all processes spawned by swctl exec / watch commands.
    # docker exec orphans get reparented to PID 0 or 1. BusyBox ps shows
    # "MainThread" for node, so we can't rely on comm names. Instead:
    # 1. Kill tracked PID tree via /proc
    # 2. Kill any orphaned process (PPID 0) that isn't a core service
    docker exec "$container_id" sh -c '
        kill_tree() {
            local pid=$1
            # Kill children first (depth-first)
            for child in $(ps -o pid,ppid 2>/dev/null | awk -v p="$pid" "\$2==p {print \$1}"); do
                kill_tree "$child"
            done
            kill -TERM "$pid" 2>/dev/null
        }

        # 1. Kill tracked PID tree
        pid=$(cat /tmp/.swctl-exec.pid 2>/dev/null)
        rm -f /tmp/.swctl-exec.pid
        [ -n "$pid" ] && kill_tree "$pid"

        # 2. Kill orphaned exec processes (PPID 0, not core services)
        #    Core services: PID 1 (supervisord), caddy, php-fpm, ps itself
        for p in $(ps -o pid,ppid,comm 2>/dev/null | awk "\$2==0 && \$1!=1 {print \$1}"); do
            # Read cmdline to check if it is a core service
            cmdline=$(cat /proc/$p/cmdline 2>/dev/null | tr "\0" " ")
            case "$cmdline" in
                *supervisord*|*caddy*|*php-fpm*|*ps*) continue ;;
            esac
            kill_tree "$p"
        done

        sleep 1

        # 3. Force kill any survivors
        for p in $(ps -o pid,ppid 2>/dev/null | awk "\$2==0 && \$1!=1 {print \$1}"); do
            cmdline=$(cat /proc/$p/cmdline 2>/dev/null | tr "\0" " ")
            case "$cmdline" in
                *supervisord*|*caddy*|*php-fpm*|*ps*) continue ;;
            esac
            kill -9 "$p" 2>/dev/null
        done
    ' 2>/dev/null || true
    ok "Killed exec process for '$issue_input'."
}

run_app_command() {
    local compose_project="$1"
    local command_string="$2"
    local container_id

    container_id="$(app_container_id "$compose_project")"
    [ -n "$container_id" ] || die "No running app container found for '$compose_project'."
    exec_in_container "$container_id" "$command_string"
}

fix_volume_ownership() {
    local compose_project="$1"
    local container_id
    container_id="$(app_container_id "$compose_project")"
    [ -n "$container_id" ] || return 0
    docker exec -u root "$container_id" bash -c \
        "chown ${SW_UID}:${SW_GID} /var/www/html/vendor /var/www/html/node_modules 2>/dev/null" || true
}

_composer_update_missing() {
    # When `composer install` fails because the lock is stale (branch's composer.json
    # has packages not in the lock), extract the missing package names and update ONLY
    # those.  A bare `composer update` is dangerous — it resolves everything from
    # composer.json and can REMOVE packages needed by synced plugins (e.g. shopware/commercial).
    local compose_project="$1"
    local missing_output
    missing_output="$(run_app_command "$compose_project" \
        "composer install --dry-run --no-interaction 2>&1 || true" 2>/dev/null)" || true
    local missing_pkgs=""
    missing_pkgs="$(echo "$missing_output" | grep 'is not present in the lock file' \
        | sed 's/.*package "\([^"]*\)".*/\1/' | tr '\n' ' ')" || true

    if [ -n "${missing_pkgs// /}" ]; then
        info "Lock is missing packages: $missing_pkgs— running targeted composer update."
        run_app_command "$compose_project" "composer update --no-interaction $missing_pkgs" \
            || warn "composer update failed for: $missing_pkgs"
    else
        warn "composer install failed for unknown reason. Trying full composer update."
        run_app_command "$compose_project" "composer update --no-interaction" \
            || warn "composer update failed."
    fi
}

bootstrap_dependencies() {
    local compose_project="$1"
    local package_install_cmd=""
    local vendor_needs_install=0
    local node_needs_install=0

    fix_volume_ownership "$compose_project"

    # --- Composer / vendor ---
    if [ "$((MIGRATION_CHANGES + ENTITY_CHANGES + COMPOSER_CHANGES))" -gt 0 ]; then
        # Dedicated vendor volume — always install
        vendor_needs_install=1
        info "Dependency changes detected. Will run composer install."
    elif run_app_command "$compose_project" "test -f composer.json && test ! -f vendor/autoload.php" >/dev/null 2>&1; then
        # Shared base volume is empty (first-time populate)
        vendor_needs_install=1
        info "Shared vendor volume is empty. Will populate with composer install."
    else
        info "Reusing existing vendor. Skipping composer install."
    fi

    # --- Node modules ---
    package_install_cmd="$(detect_package_install_command "$WORKTREE_PATH" || true)"
    if [ -n "$package_install_cmd" ]; then
        if [ "$((MIGRATION_CHANGES + ENTITY_CHANGES + PACKAGE_CHANGES))" -gt 0 ]; then
            # Dedicated node_modules volume — always install
            node_needs_install=1
            info "Package changes detected. Will run: $package_install_cmd"
        elif run_app_command "$compose_project" "test ! -f node_modules/.package-lock.json && test ! -f node_modules/.modules.yaml" >/dev/null 2>&1; then
            # Shared base volume is empty (first-time populate)
            node_needs_install=1
            info "Shared node_modules volume is empty. Will populate."
        else
            info "Reusing existing node_modules volume. Skipping npm/pnpm install."
        fi
    fi

    # --- Run installs (in parallel when both needed) ---
    if [ "$vendor_needs_install" -gt 0 ] && [ "$node_needs_install" -eq 1 ]; then
        info "Running composer install and $package_install_cmd in parallel."
        run_app_command "$compose_project" "composer install --no-interaction" &
        local composer_pid=$!
        run_app_command "$compose_project" "$package_install_cmd" &
        local node_pid=$!
        if ! wait "$composer_pid"; then
            warn "composer install failed. Trying targeted update for missing packages..."
            _composer_update_missing "$compose_project"
        fi
        wait "$node_pid" || warn "Frontend dependency install failed."
    elif [ "$vendor_needs_install" -gt 0 ]; then
        if ! run_app_command "$compose_project" "composer install --no-interaction"; then
            warn "composer install failed. Trying targeted update for missing packages..."
            _composer_update_missing "$compose_project"
        fi
    elif [ "$node_needs_install" -eq 1 ]; then
        run_app_command "$compose_project" "$package_install_cmd" \
            || warn "Frontend dependency install failed."
    fi

    ensure_jwt_keys "$compose_project"
}

ensure_install_lock() {
    local compose_project="$1"
    run_app_command "$compose_project" "touch install.lock" || true
}

ensure_jwt_keys() {
    local compose_project="$1"
    run_app_command "$compose_project" \
        "test -f config/jwt/private.pem || (mkdir -p config/jwt && openssl genrsa -out config/jwt/private.pem 2048 2>/dev/null && openssl rsa -in config/jwt/private.pem -outform PEM -pubout -out config/jwt/public.pem 2>/dev/null && echo 'Generated JWT keys')" \
        || true
}

update_sales_channel_domain() {
    local compose_project="$1"
    local app_url="$2"

    # Each worktree has its own cloned DB — safe to update all non-headless domains.
    # Write a tiny PHP helper, execute it inside the container (uses DATABASE_URL
    # from .env.local), then remove it. This safely updates only the cloned DB.
    info "Updating sales channel domains to '$app_url'."
    cat > "$WORKTREE_PATH/.swctl-update-domain.php" <<'PHPEOF'
<?php
// Replace the base domain in all non-headless sales channel domains.
// E.g. http://web.trunk.orb.local/de-de → http://web.sw-123.orb.local/de-de
$newBase = $argv[1] ?? '';
$url = getenv('DATABASE_URL') ?: '';
if (!$url) {
    $env = file_get_contents(__DIR__ . '/.env.local');
    preg_match('/DATABASE_URL=(.+)/', $env, $m);
    $url = trim($m[1] ?? '');
}
$p = parse_url($url);
$pdo = new PDO(
    sprintf('mysql:host=%s;port=%s;dbname=%s', $p['host'], $p['port'] ?? 3306, ltrim($p['path'] ?? '', '/')),
    $p['user'] ?? 'root', $p['pass'] ?? ''
);
$rows = $pdo->query("SELECT HEX(id) as id, url FROM sales_channel_domain WHERE url NOT LIKE '%headless%'")->fetchAll(PDO::FETCH_ASSOC);
$count = 0;
foreach ($rows as $row) {
    $oldUrl = $row['url'];
    $oldParts = parse_url($oldUrl);
    $oldBase = ($oldParts['scheme'] ?? 'http') . '://' . ($oldParts['host'] ?? '') . (isset($oldParts['port']) ? ':' . $oldParts['port'] : '');
    $newUrl = str_replace($oldBase, $newBase, $oldUrl);
    if ($newUrl !== $oldUrl) {
        $pdo->prepare("UPDATE sales_channel_domain SET url = ? WHERE id = UNHEX(?)")->execute([$newUrl, $row['id']]);
        $count++;
    }
}
echo "Updated $count domain(s)\n";
PHPEOF
    run_app_command "$compose_project" "php .swctl-update-domain.php '$app_url'" \
        || warn "Could not update sales channel domain."
    rm -f "$WORKTREE_PATH/.swctl-update-domain.php"
}

run_install_command() {
    local compose_project="$1"
    local install_args="$2"
    local install_cmd

    install_cmd="$SW_BIN_CONSOLE system:install $install_args"
    info "Running Shopware system install for database '$DB_NAME'."
    run_app_command "$compose_project" "$install_cmd"
    ensure_install_lock "$compose_project"
}

install_admin_deps_if_needed() {
    local compose_project="$1"
    local admin_pkg="src/Administration/Resources/app/administration/package.json"
    local storefront_pkg="src/Storefront/Resources/app/storefront/package.json"

    # If worktree's admin/storefront package.json differs from trunk's, the cloned
    # node_modules from trunk is missing new deps. Run npm install inside the container.
    local needs_admin=0 needs_storefront=0

    if [ -f "$WORKTREE_PATH/$admin_pkg" ] && [ -f "$PROJECT_ROOT/$admin_pkg" ]; then
        if ! diff -q "$PROJECT_ROOT/$admin_pkg" "$WORKTREE_PATH/$admin_pkg" >/dev/null 2>&1; then
            needs_admin=1
        fi
    fi
    if [ -f "$WORKTREE_PATH/$storefront_pkg" ] && [ -f "$PROJECT_ROOT/$storefront_pkg" ]; then
        if ! diff -q "$PROJECT_ROOT/$storefront_pkg" "$WORKTREE_PATH/$storefront_pkg" >/dev/null 2>&1; then
            needs_storefront=1
        fi
    fi

    if [ "$needs_admin" -eq 1 ]; then
        info "Admin package.json differs from trunk. Running npm install for admin."
        run_app_command "$compose_project" "cd src/Administration/Resources/app/administration && npm install --no-audit --no-fund" \
            || warn "Admin npm install failed."
    fi
    if [ "$needs_storefront" -eq 1 ]; then
        info "Storefront package.json differs from trunk. Running npm install for storefront."
        run_app_command "$compose_project" "cd src/Storefront/Resources/app/storefront && npm install --no-audit --no-fund" \
            || warn "Storefront npm install failed."
    fi
}

run_frontend_build_if_needed() {
    local compose_project="$1"
    # shellcheck disable=SC2034
    local is_first_create="${2:-0}"
    local force_plugin_build="${3:-0}"

    # Delegate to workflow build hook if available.  The hook may return 2
    # on a fatal admin build failure (see build.sh) — propagate so the
    # caller in cmd_create can abort with STATUS=failed instead of silently
    # producing a broken instance.
    if [ -n "${SWCTL_WORKFLOW_DIR:-}" ] && [ -f "$SWCTL_WORKFLOW_DIR/hooks/build.sh" ]; then
        FORCE_PLUGIN_BUILD="$force_plugin_build" run_workflow_hook "build"
        return $?
    fi

    # QA mode: all frontend assets are synced from project root. No builds needed
    # UNLESS a plugin has admin/storefront extensions that weren't in the synced
    # assets (force_plugin_build=1).
    if [ "$SWCTL_MODE" = "qa" ] && [ "$force_plugin_build" -ne 1 ]; then
        info "QA mode: skipping frontend builds (using synced assets)."
        return
    fi

    # Install missing deps when worktree's package.json diverged from trunk
    install_admin_deps_if_needed "$compose_project"

    local needs_admin_build=0
    local needs_storefront_build=0

    # Only build if actual code changes — synced artifacts from trunk handle the baseline.
    if [ "${ADMIN_CHANGES:-0}" -gt 0 ]; then
        needs_admin_build=1
    fi
    if [ "${STOREFRONT_CHANGES:-0}" -gt 0 ]; then
        needs_storefront_build=1
    fi

    if [ "$needs_admin_build" -eq 1 ] || [ "$needs_storefront_build" -eq 1 ]; then
        info "Frontend changes detected. Running bundle:dump."
        run_app_command "$compose_project" "$SW_BIN_CONSOLE bundle:dump" || warn "bundle:dump failed."

        if [ "$needs_admin_build" -eq 1 ] && [ "$needs_storefront_build" -eq 1 ]; then
            # composer build:js:admin and build:js:storefront each run
            # bundle:dump + feature:dump + npm build + assets:install.
            # Running them separately duplicates the shared PHP steps.
            # Instead: run shared prep once, npm builds in parallel, cleanup once.
            info "Admin + Storefront changes detected. Building with parallel npm."
            run_app_command "$compose_project" "$SW_BIN_CONSOLE feature:dump" || warn "feature:dump failed."
            run_app_command "$compose_project" "$SW_BIN_CONSOLE admin:generate-entity-schema-types" 2>/dev/null || true
            # shellcheck disable=SC2016
            run_app_command "$compose_project" 'set -e
ADMIN_DIR=src/Administration/Resources/app/administration
STOREFRONT_DIR=src/Storefront/Resources/app/storefront
export PROJECT_ROOT="$PWD"

# Admin npm build (background)
( cd "$ADMIN_DIR" && export PATH="$PWD/node_modules/.bin:$PATH" && npm run build ) &
ADMIN_PID=$!

# Storefront npm build (background)
( cd "$STOREFRONT_DIR" && export PATH="$PWD/node_modules/.bin:$PATH" && npm run production ) &
STOREFRONT_PID=$!

# Wait for both
ADMIN_OK=0; STOREFRONT_OK=0
wait $ADMIN_PID || ADMIN_OK=1
wait $STOREFRONT_PID || STOREFRONT_OK=1

# Storefront post-steps
cd "$STOREFRONT_DIR" && node copy-to-vendor.js
cd "$PROJECT_ROOT"

[ $ADMIN_OK -eq 0 ] || echo "[WARN] Admin npm build failed."
[ $STOREFRONT_OK -eq 0 ] || echo "[WARN] Storefront npm build failed."
exit $((ADMIN_OK + STOREFRONT_OK))
' || warn "Parallel JS build had errors."
            run_app_command "$compose_project" "$SW_BIN_CONSOLE theme:compile --sync" 2>/dev/null || true
            run_app_command "$compose_project" "$SW_BIN_CONSOLE assets:install" || warn "assets:install failed."
        elif [ "$needs_admin_build" -eq 1 ]; then
            info "Admin changes detected. Running composer build:js:admin."
            run_app_command "$compose_project" "composer build:js:admin" || warn "Admin JS build failed."
        else
            info "Storefront changes detected. Running composer build:js:storefront."
            run_app_command "$compose_project" "composer build:js:storefront" || warn "Storefront JS build failed."
        fi
    else
        # No frontend changes — register synced assets. Skip full JS builds.
        run_app_command "$compose_project" "$SW_BIN_CONSOLE bundle:dump" 2>/dev/null || true
        run_app_command "$compose_project" "$SW_BIN_CONSOLE assets:install" 2>/dev/null || true
        info "Assets registered from synced files. No frontend builds needed."
    fi

    # Clear cache for any code change
    if [ "$((BACKEND_CHANGES + ADMIN_CHANGES + STOREFRONT_CHANGES + COMPOSER_CHANGES + PACKAGE_CHANGES))" -gt 0 ] && [ "${DB_STATE:-}" != "fresh" ]; then
        run_app_command "$compose_project" "$SW_BIN_CONSOLE cache:clear" || warn "cache:clear failed."
    fi
}

create_database() {
    local db_name="$1"
    mysql_exec "DROP DATABASE IF EXISTS \`${db_name}\`; CREATE DATABASE \`${db_name}\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;"
}


clone_database() {
    local source_db="$1"
    local target_db="$2"
    local db_container
    db_container="$(resolve_db_container)"

    info "Cloning database '$source_db' → '$target_db'."
    docker exec -i "$db_container" bash -c \
        "mariadb -u '$SW_DB_ROOT_USER' -p'$SW_DB_ROOT_PASSWORD' -e 'DROP DATABASE IF EXISTS \`$target_db\`; CREATE DATABASE \`$target_db\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;' && mariadb-dump -u '$SW_DB_ROOT_USER' -p'$SW_DB_ROOT_PASSWORD' --single-transaction --quick '$source_db' | mariadb -u '$SW_DB_ROOT_USER' -p'$SW_DB_ROOT_PASSWORD' '$target_db'" \
        || die "Database clone failed."
    ok "Database cloned: $target_db"
}

# Postflight: verify an instance is actually usable, not just provisioned.
#
# Each check is independent and emits its own actionable warning on
# failure.  Returns 0 if every critical check passes, 1 otherwise.
# Non-critical warnings don't fail the function but are still printed.
#
# Designed to run at the tail of provision_database_and_app() before
# flipping STATUS=complete, so the user never sees "[OK] provisioned"
# followed by mystery 404s in the browser.
_postflight_instance_ready() {
    local compose_project="$1"
    local app_url="$2"
    local rc=0
    local container

    info "Running postflight checks on '${compose_project}'…"

    # 1. Container must be running.
    container="$(docker ps -q --filter "label=com.docker.compose.project=${compose_project}" --filter "label=com.docker.compose.service=${SW_SERVICE_NAME:-web}" 2>/dev/null | head -1)"
    if [ -z "$container" ]; then
        err "  ✗ No running container for '${compose_project}'."
        err "    Remedy: run 'swctl refresh ${ISSUE_ID}' to re-provision."
        return 1  # critical — nothing else will work
    fi
    ok "  ✓ container running (${container:0:12})"

    # 2. /admin reachable.  Use a short timeout so a wedged app doesn't
    # hang the whole provision flow.
    local http
    http="$(curl -sS -o /dev/null -w '%{http_code}' --max-time 8 "${app_url}/admin" 2>/dev/null || echo '000')"
    if [ "$http" = "200" ] || [ "$http" = "302" ] || [ "$http" = "301" ]; then
        ok "  ✓ /admin reachable (HTTP ${http})"
    else
        err "  ✗ /admin not reachable at ${app_url} (HTTP ${http})"
        err "    Remedy: check 'docker logs ${container}' for PHP-FPM/Caddy errors, then 'swctl refresh ${ISSUE_ID}'."
        rc=1
    fi

    # 3. Media dir writable by the container (admin uploads need this).
    if docker exec "$container" sh -c 'test -w /var/www/html/public/media' 2>/dev/null; then
        ok "  ✓ public/media is writable"
    else
        err "  ✗ public/media is read-only — admin uploads will fail with mkdir() errors."
        err "    Remedy: 'swctl refresh ${ISSUE_ID}' regenerates the compose override with a per-worktree RW copy."
        rc=1
    fi

    # 4. Vendor populated (admin/storefront builds depend on autoload.php).
    if docker exec "$container" test -f /var/www/html/vendor/autoload.php 2>/dev/null; then
        ok "  ✓ vendor/autoload.php present"
    else
        err "  ✗ vendor/autoload.php missing — Shopware will not boot."
        err "    Remedy: 'swctl refresh ${ISSUE_ID}' will run composer install."
        rc=1
    fi

    # 5. public/index.php must exist for Caddy to route any request.
    if docker exec "$container" test -f /var/www/html/public/index.php 2>/dev/null; then
        ok "  ✓ public/index.php present"
    else
        err "  ✗ public/index.php missing — worktree is incomplete."
        err "    Remedy: 'swctl nuke ${ISSUE_ID}' and recreate from scratch."
        rc=1
    fi

    # 6. DB reachable by the app.  Use the app's own connection so we
    # catch both "db host down" and "app can't see it".
    if docker exec "$container" sh -c 'bin/console dbal:refresh:index --dry-run >/dev/null 2>&1' 2>/dev/null; then
        ok "  ✓ database reachable"
    else
        # Not fatal — some plugin-external setups skip this path.  Warn only.
        warn "  ⚠ could not verify database via bin/console (not fatal)."
    fi

    return "$rc"
}

provision_database_and_app() {
    local compose_project="$1"
    local source_db
    source_db="$(sanitize_db_identifier "$SW_DB_SHARED_NAME")"

    # Every worktree gets its own cloned database (never touches the source).
    DB_NAME="$(sanitize_db_identifier "${SW_DB_NAME_PREFIX}_${ISSUE_ID}")"

    # Determine DB_STATE early so the compose override can adjust mount modes
    # (fresh installs need writable media mounts for system:install).
    if mysql_db_has_tables "$DB_NAME"; then
        DB_STATE="cloned"
    elif mysql_db_has_tables "$source_db"; then
        DB_STATE="cloned"
    else
        DB_STATE="fresh"
    fi

    # Resolve per-app node_modules volume names before writing the env file
    # (write_compose_env_file emits SW_ADMIN_NM_VOLUME / SW_STOREFRONT_NM_VOLUME).
    ADMIN_NM_VOLUME="$(resolve_admin_nm_volume "$ISSUE_ID")"
    STOREFRONT_NM_VOLUME="$(resolve_storefront_nm_volume "$ISSUE_ID")"

    # Write configs (needed by both DB clone and compose up)
    write_env_file
    write_compose_env_file
    write_compose_volume_override

    # Clone DB and start container.
    # Database operations are serialized per DB host to prevent concurrent
    # CREATE/DROP/DUMP from overloading MariaDB (parallel dumps cause lock contention).
    if [ "$DB_STATE" = "fresh" ]; then
        info "Source database '$source_db' is empty. Will run fresh install."
        swctl_lock "db-$SW_DB_HOST" create_database "$DB_NAME"
        # shellcheck disable=SC2046
        compose --project-directory "$SWCTL_TMP_DIR" $(compose_file_args) --env-file "$COMPOSE_ENV_FILE" -p "$COMPOSE_PROJECT" up -d
    elif mysql_db_has_tables "$DB_NAME"; then
        info "Database '$DB_NAME' already exists. Reusing."
        # shellcheck disable=SC2046
        compose --project-directory "$SWCTL_TMP_DIR" $(compose_file_args) --env-file "$COMPOSE_ENV_FILE" -p "$COMPOSE_PROJECT" up -d
    else
        # Clone DB in background while container starts
        swctl_lock "db-$SW_DB_HOST" clone_database "$source_db" "$DB_NAME" &
        local clone_pid=$!
        # shellcheck disable=SC2046
        compose --project-directory "$SWCTL_TMP_DIR" $(compose_file_args) --env-file "$COMPOSE_ENV_FILE" -p "$COMPOSE_PROJECT" up -d
        wait "$clone_pid" || die "Database clone failed."
    fi
    wait_for_app_container "$COMPOSE_PROJECT"

    # Deactivate plugins that were skipped during sync (unsatisfied deps).
    # Must happen before any bin/console call — broken plugins crash the DI container.
    if [ -n "${SWCTL_SKIPPED_PLUGINS:-}" ]; then
        local _skip_names=""
        local _old_ifs="$IFS"
        IFS=','
        for _skip_plugin in $SWCTL_SKIPPED_PLUGINS; do
            _skip_names="${_skip_names:+${_skip_names},}'${_skip_plugin}'"
            info "Deactivating skipped plugin '$_skip_plugin' in database."
        done
        IFS="$_old_ifs"
        run_app_command "$COMPOSE_PROJECT" \
            "php -r '\$p=new PDO(\"mysql:host=\${SW_DB_HOST};port=\${SW_DB_PORT};dbname=${DB_NAME}\",\"${SW_DB_ROOT_USER}\",\"${SW_DB_ROOT_PASSWORD}\");\$p->exec(\"UPDATE plugin SET active=0,installed_at=NULL WHERE name IN(${_skip_names})\");'" \
            2>/dev/null || warn "Failed to deactivate skipped plugins."
    fi

    # Export helpers so workflow hooks can call them
    export -f update_sales_channel_domain ensure_install_lock bootstrap_dependencies \
             run_install_command run_app_command clone_database mysql_db_has_tables \
             install_admin_deps_if_needed ensure_jwt_keys fix_volume_ownership \
             _composer_update_missing \
             info warn ok die sanitize_db_identifier detect_package_install_command 2>/dev/null || true
    # Aliases for hooks
    _swctl_update_sales_channel_domain() { update_sales_channel_domain "$@"; }
    _swctl_ensure_install_lock() { ensure_install_lock "$@"; }
    _swctl_bootstrap_dependencies() { bootstrap_dependencies "$@"; }
    _swctl_install_admin_deps_if_needed() { install_admin_deps_if_needed "$@"; }

    # Delegate to workflow hooks (provision → post-provision)
    run_workflow_hook "provision"
    run_workflow_hook "post-provision"

    # Restart PHP-FPM workers to flush OPcache.  OrbStack probes the container
    # right after "compose up", which can pollute the FPM OPcache with bytecode
    # compiled before provisioning finished.
    restart_php_fpm "$compose_project"
}

resolve_project_context() {
    local project_name="${1:-}"
    PROJECT_TYPE="platform"
    PLUGIN_NAME=""
    PLUGIN_REPO_PATH=""
    PLUGIN_DIR=""
    PLUGIN_WORKTREE_PATH=""
    LINKED_PLUGINS=""
    PLUGIN_WORKTREE_PATHS=""
    PLATFORM_WORKTREE_PATH=""
    PLATFORM_ISSUE_ID=""

    SELECTED_PROJECT_PATH=""
    [ -n "$project_name" ] || return 0
    local entry
    entry="$(read_project "$project_name")" || die "Project '$project_name' not registered. Run 'swctl project list' to see available projects."

    PROJECT_TYPE="$(read_project_field "$entry" type)"
    local proj_path parent plugin_dir proj_workflow
    proj_path="$(read_project_field "$entry" path)"
    SELECTED_PROJECT_PATH="$proj_path"
    parent="$(read_project_field "$entry" parent)"
    plugin_dir="$(read_project_field "$entry" plugin_dir)"
    proj_workflow="$(read_project_field "$entry" workflow)"
    # Set workflow from project registration (overridden by .swctl.conf if present)
    if [ "$proj_workflow" != "-" ] && [ -n "$proj_workflow" ]; then
        SWCTL_WORKFLOW="$proj_workflow"
    fi

    case "$PROJECT_TYPE" in
        plugin-external)
            PLUGIN_NAME="$(basename "$proj_path")"
            PLUGIN_REPO_PATH="$proj_path"
            local parent_entry
            parent_entry="$(read_project "$parent")" || die "Parent project '$parent' not found."
            PARENT_PROJECT_ROOT="$(read_project_field "$parent_entry" path)"
            PARENT_PROJECT_SLUG="$(read_project_field "$parent_entry" name)"
            ;;
        plugin-embedded)
            PLUGIN_NAME="$(basename "$plugin_dir")"
            # shellcheck disable=SC2034
            PLUGIN_DIR="$plugin_dir"
            ;;
    esac
}

# Return the name of the first container on $1 that owns alias $2, or
# empty if no such container exists.  Used by init_infra to refuse
# attaching swctl-mariadb to a network where `database` already resolves,
# and by cmd_doctor to print who owns a colliding alias.
_find_alias_owner() {
    local net="$1"
    local alias_name="$2"
    [ -n "$net" ] && [ -n "$alias_name" ] || return 0
    docker network inspect "$net" >/dev/null 2>&1 || return 0

    docker network inspect "$net" --format '{{range .Containers}}{{.Name}}
{{end}}' 2>/dev/null | while read -r n; do
        [ -n "$n" ] || continue
        if docker inspect "$n" --format '{{with (index .NetworkSettings.Networks "'"$net"'")}}{{range .Aliases}}{{.}}
{{end}}{{end}}' 2>/dev/null | grep -Fxq "$alias_name"; then
            printf '%s\n' "$n"
            return 0
        fi
    done | head -1
}

# Is this DNS alias one that an app container is likely to resolve at runtime
# for a CRITICAL dependency (DB, cache, search, mail)?  Used by cmd_doctor to
# filter out naturally-shared generic aliases like `web`/`app` that many
# compose projects joining one network will always collide on — those don't
# cause the "Unknown database" class of bug because nothing in-container
# calls `getent hosts web` during boot.
#
# Returns 0 when the alias is critical (worth warning about), 1 otherwise.
_is_critical_alias() {
    case "$1" in
        database|mysql|mariadb|postgres|postgresql|\
        redis|valkey|\
        opensearch|elasticsearch|es|\
        mailer|mailhog|mailpit|\
        rabbitmq|messagebus) return 0 ;;
        *) return 1 ;;
    esac
}

activate_plugin() {
    local compose_project="$1" plugin_name="$2"

    # Delegate to workflow hook if available
    if [ -n "${SWCTL_WORKFLOW_DIR:-}" ] && [ -f "$SWCTL_WORKFLOW_DIR/hooks/activate-plugin.sh" ]; then
        PLUGIN_NAME="$plugin_name" run_workflow_hook "activate-plugin"
        return
    fi

    # Fallback: inline Shopware commands (chained under one docker exec).
    info "Activating plugin: $plugin_name"
    run_app_command "$compose_project" \
        "$WORKFLOW_CONSOLE plugin:refresh && $WORKFLOW_CONSOLE plugin:install --activate $plugin_name" \
        || warn "Plugin refresh/activate failed for '$plugin_name'."
}

# Build the chained bin/console command for plugin prep on plugin-external
# creates: `plugin:refresh && plugin:install --activate <primary> [&& plugin:install --activate <dep>]*`.
#
# Extracted from cmd_create so the exact chain that prevents the "plugin UI
# silently missing" bug (v0.5.2) is locked down by regression tests.  The
# primary activation is MANDATORY — without it the cloned DB's active=0
# carries forward, the plugin's bundle never boots, and InfoController
# silently omits it from /api/_info/config.
#
# Args:
#   $1 primary plugin name (required)
#   $2 comma-separated dep plugin names (optional)
#   $3 bin/console binary path (default: "bin/console")
_build_plugin_prep_command() {
    local primary="$1"
    local deps="${2:-}"
    local bin="${3:-bin/console}"

    [ -n "$primary" ] || return 1

    local cmd="$bin plugin:refresh && $bin plugin:install --activate $primary"
    if [ -n "$deps" ]; then
        local _old_ifs="$IFS"
        IFS=','
        local _dep
        for _dep in $deps; do
            [ -n "$_dep" ] || continue
            cmd="$cmd && $bin plugin:install --activate $_dep"
        done
        IFS="$_old_ifs"
    fi
    printf '%s' "$cmd"
}

# ---------------------------------------------------------------------------
# User config ($HOME/.swctl/config.json)
#
# A single JSON file that the UI and the CLI both read + write.  Lives at
# a bind-mounted path so edits made in the /config page show up in the
# next `swctl resolve ...` run without a restart.
#
# Only reads keys under `.ai.*` today — schema can grow later without
# touching call sites (_user_config_read returns empty + non-zero when
# the key is missing, callers use a fallback).
#
# Env-var overrides always win over config values (see _ai_backend_binary
# etc.) so CI / tests / power users don't need a config file to poke
# around.
# ---------------------------------------------------------------------------

_user_config_file() {
    printf '%s' "${SWCTL_CONFIG_FILE:-$HOME/.swctl/config.json}"
}

# _user_config_read <jq-path>
#
# Prints the string value at <jq-path> (e.g. '.ai.claude.bin') or returns
# non-zero if the file, jq, or the key is missing.  Never raises — callers
# always wrap with `|| default`.
_user_config_read() {
    local path="$1" file v
    file="$(_user_config_file)"
    [ -f "$file" ] || return 1
    command -v jq >/dev/null 2>&1 || return 1
    v="$(jq -r "${path} // empty" "$file" 2>/dev/null || true)"
    [ -n "$v" ] || return 1
    printf '%s' "$v"
}

# _user_config_write <jq-path> <value>
#
# Sets the string at <jq-path> to <value>, creating the file + parent
# objects as needed.  Atomic — writes a temp file + renames.  Fails hard
# if jq is missing (this is a user-facing command; no silent fallbacks).
_user_config_write() {
    local path="$1" value="$2" file tmp
    file="$(_user_config_file)"
    command -v jq >/dev/null 2>&1 || die "'jq' is required to edit config. brew install jq."
    mkdir -p "$(dirname "$file")"
    [ -s "$file" ] || printf '{}\n' > "$file"
    tmp="$(mktemp)"
    # Use --arg so values are JSON-escaped correctly (quotes, backslashes).
    # `setpath` isn't quite right because the path is a jq expression
    # string — just interpolate directly, the path is trusted input.
    if ! jq --arg v "$value" "$path = \$v" "$file" > "$tmp"; then
        rm -f "$tmp"
        die "Failed to update config at $path"
    fi
    mv "$tmp" "$file"
}

# _user_config_delete <jq-path>
_user_config_delete() {
    local path="$1" file tmp
    file="$(_user_config_file)"
    [ -f "$file" ] || return 0
    command -v jq >/dev/null 2>&1 || die "'jq' is required."
    tmp="$(mktemp)"
    if ! jq "del($path)" "$file" > "$tmp"; then
        rm -f "$tmp"
        die "Failed to delete config at $path"
    fi
    mv "$tmp" "$file"
}

# ---------------------------------------------------------------------------
# AI-backend abstraction for the resolve workflow.
#
# Resolve runs are driven by a local AI assistant CLI (Claude Code by
# default, Codex CLI opt-in).  The three helpers below keep the backend
# choice out of cmd_resolve / resolve.ts so adding a new backend is a
# case-statement edit, not a spawn-site rewrite.
#
#   _ai_backend_binary    — which executable to spawn
#   _ai_backend_config_dir — where the backend stores its config + skills
#   _ai_spawn_args        — flag mapping for new/resume/ask modes
#   _ai_resolve_backend   — pick a backend with CLI-flag / env / default precedence
#
# Resolution order (first hit wins):
#   1. Env-var override:   SWCTL_CLAUDE_BIN / CLAUDE_CONFIG_DIR / SWCTL_RESOLVE_BACKEND
#   2. User config file:   ~/.swctl/config.json → .ai.<backend>.bin / .configDir / .defaultBackend
#   3. Built-in default:   "claude" / "codex" / "$HOME/.claude" / "$HOME/.codex"
# ---------------------------------------------------------------------------

_ai_backend_binary() {
    case "$1" in
        claude)
            if [ -n "${SWCTL_CLAUDE_BIN:-}" ]; then
                printf '%s' "$SWCTL_CLAUDE_BIN"
            else
                printf '%s' "$(_user_config_read '.ai.claude.bin' 2>/dev/null || echo claude)"
            fi
            ;;
        codex)
            if [ -n "${SWCTL_CODEX_BIN:-}" ]; then
                printf '%s' "$SWCTL_CODEX_BIN"
            else
                printf '%s' "$(_user_config_read '.ai.codex.bin' 2>/dev/null || echo codex)"
            fi
            ;;
        *) return 1 ;;
    esac
}

_ai_backend_config_dir() {
    case "$1" in
        claude)
            if [ -n "${CLAUDE_CONFIG_DIR:-}" ]; then
                printf '%s' "$CLAUDE_CONFIG_DIR"
            else
                printf '%s' "$(_user_config_read '.ai.claude.configDir' 2>/dev/null || echo "$HOME/.claude")"
            fi
            ;;
        codex)
            if [ -n "${CODEX_CONFIG_DIR:-}" ]; then
                printf '%s' "$CODEX_CONFIG_DIR"
            else
                printf '%s' "$(_user_config_read '.ai.codex.configDir' 2>/dev/null || echo "$HOME/.codex")"
            fi
            ;;
        *) return 1 ;;
    esac
}

# Apply the precedence:  --backend <arg> > env > config file > claude
# $1 = explicit backend passed on the CLI (may be empty).  Prints the
# resolved backend (lowercased, validated) or returns non-zero.
_ai_resolve_backend() {
    local explicit="${1:-}"
    local backend
    if [ -n "$explicit" ]; then
        backend="$explicit"
    elif [ -n "${SWCTL_RESOLVE_BACKEND:-}" ]; then
        backend="$SWCTL_RESOLVE_BACKEND"
    else
        backend="$(_user_config_read '.ai.defaultBackend' 2>/dev/null || echo claude)"
    fi
    backend="$(printf '%s' "$backend" | tr '[:upper:]' '[:lower:]')"
    case "$backend" in
        claude|codex) printf '%s' "$backend" ;;
        *) return 1 ;;
    esac
}

# Print the flag list for the given backend + mode, newline-separated.
# Callers `readarray -t` the output into an argv array — whitespace in
# prompt values stays intact because the consumer array-expands.
#
#   mode ∈ { new, resume, ask }
#   $3   — session id (required for resume/ask; generated by caller for new)
#
# Codex's real flag surface is behind a `~/.codex/config.toml` rather
# than long CLI flags.  For the MVP we emit a minimal `exec --session`
# shape; a follow-up maps the exact flags after `codex --help` is
# pinned.  The abstraction shape (mode × backend) is the stable part.
_ai_spawn_args() {
    local backend="$1" mode="$2" session_id="${3:-}"
    case "$backend" in
        claude)
            case "$mode" in
                new)
                    printf -- '--output-format\nstream-json\n--verbose\n--session-id\n%s\n--effort\nmax\n' "$session_id"
                    ;;
                resume)
                    printf -- '--resume\n%s\n--output-format\nstream-json\n--verbose\n' "$session_id"
                    ;;
                ask)
                    printf -- '--resume\n%s\n-p\n' "$session_id"
                    ;;
                *) return 1 ;;
            esac
            ;;
        codex)
            case "$mode" in
                new)
                    printf -- 'exec\n--session\n%s\n' "$session_id"
                    ;;
                resume)
                    printf -- 'exec\n--session\n%s\n--resume\n' "$session_id"
                    ;;
                ask)
                    printf -- 'exec\n--session\n%s\n--message\n' "$session_id"
                    ;;
                *) return 1 ;;
            esac
            ;;
        *) return 1 ;;
    esac
}

setup_plugin_database() {
    # Clone a separate DB for a plugin issue (no full provision — just the DB).
    local source_db
    source_db="$(sanitize_db_identifier "$SW_DB_SHARED_NAME")"
    DB_NAME="$(sanitize_db_identifier "${SW_DB_NAME_PREFIX}_${ISSUE_ID}")"

    if mysql_db_has_tables "$DB_NAME"; then
        DB_STATE="cloned"
        info "Database '$DB_NAME' already exists. Reusing."
    elif mysql_db_has_tables "$source_db"; then
        DB_STATE="cloned"
        info "Cloning database '$source_db' → '$DB_NAME'..."
        clone_database "$source_db" "$DB_NAME"
        ok "Database cloned."
    else
        DB_STATE="fresh"
        info "Source database '$source_db' is empty. Creating fresh database."
        create_database "$DB_NAME"
    fi
}

ensure_platform_worktree() {
    # For external plugins: create or reuse a platform worktree from the parent project.
    # Sets PLATFORM_WORKTREE_PATH, loads parent config, and provisions if new.
    local issue_id="$1"
    local branch="$2"
    local parent_meta
    parent_meta="$(instance_dir "$PARENT_PROJECT_SLUG")/${issue_id}.env"

    if [ -f "$parent_meta" ]; then
        # Reuse existing platform worktree
        local saved_project_type="$PROJECT_TYPE"
        local saved_plugin_name="$PLUGIN_NAME"
        local saved_plugin_repo="$PLUGIN_REPO_PATH"
        load_instance_metadata "$parent_meta"
        PLATFORM_WORKTREE_PATH="$WORKTREE_PATH"
        PLATFORM_ISSUE_ID="$ISSUE_ID"
        # Restore plugin context
        PROJECT_TYPE="$saved_project_type"
        PLUGIN_NAME="$saved_plugin_name"
        PLUGIN_REPO_PATH="$saved_plugin_repo"
        info "Reusing existing platform worktree: $PLATFORM_WORKTREE_PATH"
        return 0
    fi

    # Create new platform worktree by loading parent config and running the platform flow
    info "Creating platform worktree for parent project '$PARENT_PROJECT_SLUG'."
    load_project_config "$PARENT_PROJECT_ROOT/.swctl.conf"

    ISSUE_ID="$(sanitize_slug "$ISSUE")"
    WORKTREE_ID="$ISSUE_ID"
    BASE_REF="$(git_base_ref)"
    COMPOSE_PROJECT="$(sanitize_slug "${SW_PROJECT_SLUG}-${ISSUE_ID}")"

    if [ "$SW_RUNTIME" = "orbstack" ]; then
        DOMAIN="${SW_SERVICE_NAME}.${COMPOSE_PROJECT}.orb.local"
        APP_URL="http://${DOMAIN}"
    else
        DOMAIN="${SW_PROJECT_SLUG}-${ISSUE_ID}.${SW_DOMAIN_SUFFIX}"
        APP_URL="http://${DOMAIN}"
    fi

    TRAEFIK_ROUTER="$(sanitize_router_id "${SW_PROJECT_SLUG}_${ISSUE_ID}")"
    TRAEFIK_SERVICE="$TRAEFIK_ROUTER"
    WORKTREE_PATH="${SW_WORKTREE_ROOT}/${SW_WORKTREE_PREFIX}-${ISSUE_ID}"


    create_worktree
    check_branch_staleness

    DIFF_FILES="$(git -C "$PROJECT_ROOT" diff --name-only "${BASE_REF}...${BRANCH}" 2>/dev/null || true)"
    count_changes "$DIFF_FILES"
    sync_worktree_from_trunk
    VENDOR_VOLUME="$(resolve_vendor_volume "$ISSUE_ID")"
    NODE_MODULES_VOLUME="$(resolve_node_modules_volume "$ISSUE_ID")"

    provision_database_and_app "$COMPOSE_PROJECT"
    run_frontend_build_if_needed "$COMPOSE_PROJECT" 1

    PLATFORM_WORKTREE_PATH="$WORKTREE_PATH"
    PLATFORM_ISSUE_ID="$ISSUE_ID"

    # Write platform metadata (will be updated later with plugin linkage)
    write_metadata "$(instance_file "$SW_PROJECT_SLUG" "$ISSUE_ID")"
    ok "Platform worktree ready: $PLATFORM_WORKTREE_PATH"
}

list_available_plugins() {
    # List plugins with their own git repo in <project_root>/custom/plugins/*
    local project_root="$1"
    local plugins_dir="$project_root/custom/plugins"
    [ -d "$plugins_dir" ] || return 0
    for plugin_path in "$plugins_dir"/*/; do
        [ -d "$plugin_path" ] || continue
        local pname
        pname="$(basename "$plugin_path")"
        [ "$pname" = "*" ] && continue
        [ -f "$plugin_path/composer.json" ] || continue
        if [ -d "$plugin_path/.git" ]; then
            printf '%s\n' "$pname"
        fi
    done
}

read_plugin_deps() {
    # Read .swctl.deps.yaml from a plugin directory and print dependency names.
    local plugin_dir="$1"
    local deps_file="$plugin_dir/.swctl.deps.yaml"
    [ -f "$deps_file" ] || return 0
    python3 -c "
import yaml, sys
with open(sys.argv[1]) as f:
    data = yaml.safe_load(f)
for dep in data.get('dependencies', []):
    print(dep)
" "$deps_file" 2>/dev/null
}

create_dep_plugin_worktree() {
    # Create a git worktree for a dependency plugin at its default branch.
    local dep_name="$1"
    local dep_repo="${PROJECT_ROOT}/custom/plugins/${dep_name}"
    local dep_target="${WORKTREE_PATH}/custom/plugins/${dep_name}"

    if [ ! -d "$dep_repo/.git" ]; then
        warn "Dependency plugin repo not found: $dep_repo — skipping."
        return 1
    fi

    if [ -d "$dep_target/.git" ] || [ -f "$dep_target/.git" ]; then
        info "Dependency plugin already exists: $dep_name"
        return 0
    fi

    # Determine the dep's default branch
    local dep_default_branch
    dep_default_branch="$(git -C "$dep_repo" symbolic-ref --short HEAD 2>/dev/null)" || dep_default_branch="main"

    info "Creating dependency worktree: $dep_name (at $dep_default_branch)"
    mkdir -p "$(dirname "$dep_target")"
    rm -rf "$dep_target" 2>/dev/null || true

    git -C "$dep_repo" fetch --all --prune 2>/dev/null || true
    git -C "$dep_repo" worktree add --detach "$dep_target" "origin/$dep_default_branch" 2>/dev/null \
        || git -C "$dep_repo" worktree add --detach "$dep_target" "$dep_default_branch" 2>/dev/null \
        || { warn "Failed to create worktree for dependency: $dep_name"; return 1; }

    ok "Dependency plugin nested: custom/plugins/${dep_name} (detached at $dep_default_branch)"
}

cmd_create() {
    SWCTL_MODE="${SWCTL_MODE:-dev}"
    local selected_project=""
    local selected_plugin=""
    local selected_deps=""
    local adopt_worktree_path=""
    local no_provision=0
    while [ $# -gt 0 ]; do
        case "$1" in
            --qa)      SWCTL_MODE="qa"; shift ;;
            --dev)     SWCTL_MODE="dev"; shift ;;
            --project) selected_project="$2"; shift 2 ;;
            --plugin)  selected_plugin="$2"; shift 2 ;;
            --deps)    selected_deps="$2"; shift 2 ;;
            --adopt-worktree) adopt_worktree_path="$2"; shift 2 ;;
            --no-provision) no_provision=1; shift ;;
            *)         break ;;
        esac
    done
    export SWCTL_MODE
    export SWCTL_NO_PROVISION="$no_provision"
    ISSUE="${1:-}"
    BRANCH="${2:-}"
    [ -n "$ISSUE" ] || die "Usage: swctl create [--qa|--dev] [--project <name>] [--plugin <name>] <issue> [<branch>]"

    # When adopting an external worktree, the branch belongs to the PLUGIN,
    # not the trunk.  Record it for metadata but don't use it for the trunk
    # worktree (which will be created in detached mode at BASE_REF).
    if [ -n "${adopt_worktree_path:-}" ] && [ -z "$BRANCH" ]; then
        BRANCH="$(git -C "$adopt_worktree_path" rev-parse --abbrev-ref HEAD 2>/dev/null)" || true
        if [ -z "$BRANCH" ] || [ "$BRANCH" = "HEAD" ]; then
            BRANCH="$(git -C "$adopt_worktree_path" rev-parse --short HEAD 2>/dev/null)" || true
            info "Adopted worktree is detached at: ${BRANCH:-unknown}"
        else
            info "Inferred plugin branch from adopted worktree: $BRANCH"
        fi
    fi

    if [ -z "$BRANCH" ]; then
        if [ "$SWCTL_MODE" = "qa" ]; then
            die "QA mode requires a branch: swctl create --qa <issue> <branch>"
        fi
        # Dev mode: prompt for new branch name
        BRANCH="$(prompt_text "New branch name for issue '$ISSUE'")"
        [ -n "$BRANCH" ] || die "Branch name cannot be empty."
        info "Will create new branch '$BRANCH' from ${SW_BASE_BRANCH:-trunk}."
    fi

    require_cmd git
    ensure_docker

    # Resolve project context (platform vs plugin)
    resolve_project_context "$selected_project"

    # If --plugin was given with a platform project, set up plugin-external context dynamically
    if [ -n "$selected_plugin" ]; then
        if [ "$PROJECT_TYPE" != "platform" ]; then
            die "--plugin can only be used with a platform project, not '$PROJECT_TYPE'."
        fi
        local plugin_repo_path="${SELECTED_PROJECT_PATH:-$PROJECT_ROOT}/custom/plugins/$selected_plugin"
        [ -d "$plugin_repo_path" ] || die "Plugin not found: $plugin_repo_path"
        [ -d "$plugin_repo_path/.git" ] || die "Plugin '$selected_plugin' has no git repository at: $plugin_repo_path"
        PROJECT_TYPE="plugin-external"
        PLUGIN_NAME="$selected_plugin"
        PLUGIN_REPO_PATH="$(cd "$plugin_repo_path" && pwd -P)"
        # Read parent info from the platform project
        local parent_entry
        parent_entry="$(read_project "$selected_project")" || die "Project '$selected_project' not registered."
        PARENT_PROJECT_ROOT="$(read_project_field "$parent_entry" path)"
        PARENT_PROJECT_SLUG="$(read_project_field "$parent_entry" name)"
    fi

    # If --project was given, use the registered path to locate .swctl.conf
    local project_config_arg=""
    if [ -n "${SELECTED_PROJECT_PATH:-}" ]; then
        project_config_arg="$SELECTED_PROJECT_PATH/.swctl.conf"
    fi

    # --- Duplicate check: reject if a worktree already exists for this issue ---
    local _dup_file=""
    _dup_file="$(resolve_instance_file_by_issue "$ISSUE" 2>/dev/null)" || true
    if [ -n "$_dup_file" ] && [ -f "$_dup_file" ]; then
        local _dup_id _dup_domain _dup_project
        _dup_id="$(grep '^ISSUE_ID=' "$_dup_file" | cut -d= -f2)"
        _dup_domain="$(grep '^DOMAIN=' "$_dup_file" | cut -d= -f2)"
        _dup_project="$(grep '^PROJECT=' "$_dup_file" | cut -d= -f2)"
        die "A worktree already exists for issue '${ISSUE}' (project: ${_dup_project:-unknown}, domain: ${_dup_domain:-unknown}). Use 'swctl clean ${_dup_id:-$ISSUE}' first, or 'swctl refresh ${_dup_id:-$ISSUE}' to update it."
    fi

    case "$PROJECT_TYPE" in
        plugin-external)
            # Create a standard trunk worktree, then nest the plugin's git
            # worktree inside it at custom/plugins/<PluginName>/.
            # Since custom/ is gitignored, the plugin dir is empty in the
            # trunk worktree — we fill it with the plugin's own branch.
            info "Plugin (external): $PLUGIN_NAME → parent: $PARENT_PROJECT_SLUG"
            load_project_config "$PARENT_PROJECT_ROOT/.swctl.conf"
            ensure_infra_ready

            git -C "$PROJECT_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1 \
                || die "Project root is not a Git repository: $PROJECT_ROOT"

            ISSUE_ID="$(sanitize_slug "$ISSUE")"
            WORKTREE_ID="$ISSUE_ID"
            BASE_REF="$(git_base_ref)"

            # Use trunk's naming — this IS a trunk worktree
            COMPOSE_PROJECT="$(sanitize_slug "${SW_PROJECT_SLUG}-${ISSUE_ID}")"

            if [ "$SW_RUNTIME" = "orbstack" ]; then
                DOMAIN="${SW_SERVICE_NAME}.${COMPOSE_PROJECT}.orb.local"
                APP_URL="http://${DOMAIN}"
            else
                DOMAIN="${SW_PROJECT_SLUG}-${ISSUE_ID}.${SW_DOMAIN_SUFFIX}"
                APP_URL="http://${DOMAIN}"
            fi
            TRAEFIK_ROUTER="$(sanitize_router_id "${SW_PROJECT_SLUG}_${ISSUE_ID}")"
            TRAEFIK_SERVICE="$TRAEFIK_ROUTER"
            WORKTREE_PATH="${SW_WORKTREE_ROOT}/${SW_WORKTREE_PREFIX}-${ISSUE_ID}"

            # Early metadata — stored under trunk project slug
            SWCTL_ACTIVE_META_FILE="$(instance_file "$SW_PROJECT_SLUG" "$ISSUE_ID")"
            STATUS="creating"
            FAILED_AT=""
            DB_NAME="${DB_NAME:-}"
            DB_STATE="${DB_STATE:-}"
            VENDOR_VOLUME="${VENDOR_VOLUME:-}"
            NODE_MODULES_VOLUME="${NODE_MODULES_VOLUME:-}"
            MIGRATION_CHANGES=0; ENTITY_CHANGES=0; COMPOSER_CHANGES=0
            PACKAGE_CHANGES=0; ADMIN_CHANGES=0; STOREFRONT_CHANGES=0
            BACKEND_CHANGES=0; FRONTEND_CHANGES=0
            write_metadata "$SWCTL_ACTIVE_META_FILE"

            trap 'if [ "${STATUS:-}" = "creating" ]; then STATUS=failed; FAILED_AT="${SWCTL_LAST_ERROR:-unknown}"; write_metadata "$SWCTL_ACTIVE_META_FILE" 2>/dev/null; fi' EXIT

            # 1. Create trunk worktree at BASE_REF — the branch belongs to the
            # plugin, not the trunk.  Detached mode avoids creating a spurious
            # branch in the trunk repo.
            mkdir -p "$SW_WORKTREE_ROOT"
            if ! worktree_exists "$WORKTREE_PATH"; then
                # Remove leftover directory from a previous failed/cleaned create
                if [ -d "$WORKTREE_PATH" ]; then
                    warn "Cleaning up leftover directory: $WORKTREE_PATH"
                    git -C "$PROJECT_ROOT" worktree remove --force "$WORKTREE_PATH" 2>/dev/null || rm -rf "$WORKTREE_PATH" 2>/dev/null || true
                fi
                git -C "$PROJECT_ROOT" worktree prune 2>/dev/null || true
                git -C "$PROJECT_ROOT" worktree add --detach "$WORKTREE_PATH" "$BASE_REF"
                ok "Created trunk worktree (detached at $BASE_REF)."
            fi
            sync_lock_files

            # 2. Nest plugin git worktree inside trunk worktree
            local plugin_target="${WORKTREE_PATH}/custom/plugins/${PLUGIN_NAME}"
            PLUGIN_WORKTREE_PATH="$plugin_target"

            if [ -n "${adopt_worktree_path:-}" ]; then
                # Adopt an existing external worktree (from Claude Code / Codex)
                # by moving it into the trunk worktree via git worktree move.
                # This preserves uncommitted changes and updates git's internal pointers.
                info "Adopting external worktree: $adopt_worktree_path"
                [ -f "$adopt_worktree_path/.git" ] || [ -d "$adopt_worktree_path/.git" ] \
                    || die "Not a git worktree: $adopt_worktree_path"
                mkdir -p "$(dirname "$plugin_target")"
                rm -rf "$plugin_target" 2>/dev/null || true
                # Copy the worktree and update git's internal pointers.
                # (~/.codex/ and ~/.claude/ are typically on a different APFS volume,
                # so git worktree move would fail with "Cross-device link".)
                cp -a "$adopt_worktree_path" "$plugin_target" \
                    || die "Failed to copy worktree from $adopt_worktree_path to $plugin_target"
                # The .git file contains "gitdir: /path/to/repo/.git/worktrees/<name>".
                # Update that repo entry's gitdir to point to the new location.
                local wt_gitdir
                wt_gitdir="$(sed 's/^gitdir: //' "$plugin_target/.git" 2>/dev/null)" || true
                if [ -n "$wt_gitdir" ] && [ -f "$wt_gitdir/gitdir" ]; then
                    printf '%s\n' "$plugin_target" > "$wt_gitdir/gitdir"
                fi
                rm -rf "$adopt_worktree_path" 2>/dev/null || true
                ok "Adopted worktree moved to: custom/plugins/${PLUGIN_NAME}"
            elif [ ! -d "$plugin_target/.git" ] && [ ! -f "$plugin_target/.git" ]; then
                info "Creating plugin worktree at: $plugin_target"
                mkdir -p "$(dirname "$plugin_target")"
                rm -rf "$plugin_target" 2>/dev/null || true
                git -C "$PLUGIN_REPO_PATH" fetch --all --prune 2>/dev/null || true
                git -C "$PLUGIN_REPO_PATH" worktree prune 2>/dev/null || true
                if git -C "$PLUGIN_REPO_PATH" rev-parse --verify "origin/$BRANCH" >/dev/null 2>&1; then
                    # Try: new local branch from remote → existing local branch → detached
                    local _wt_err=""
                    git -C "$PLUGIN_REPO_PATH" worktree add "$plugin_target" \
                        -b "swctl/${ISSUE_ID}" "origin/$BRANCH" 2>/dev/null \
                        || git -C "$PLUGIN_REPO_PATH" worktree add "$plugin_target" \
                            "$BRANCH" 2>/dev/null \
                        || _wt_err="$(git -C "$PLUGIN_REPO_PATH" worktree add --detach "$plugin_target" \
                            "origin/$BRANCH" 2>&1)" \
                        || die "Failed to create plugin worktree: $_wt_err"
                elif git -C "$PLUGIN_REPO_PATH" rev-parse --verify "$BRANCH" >/dev/null 2>&1; then
                    git -C "$PLUGIN_REPO_PATH" worktree add "$plugin_target" "$BRANCH" \
                        || die "Failed to create plugin worktree."
                else
                    # Branch doesn't exist anywhere — create it from the
                    # plugin's default branch.  This is the common case when
                    # swctl is asked to create a worktree for a brand new fix
                    # branch (e.g. resolve/<issue> from the resolve workflow).
                    local _plugin_default
                    _plugin_default="$(git -C "$PLUGIN_REPO_PATH" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's@^origin/@@')"
                    [ -z "$_plugin_default" ] && _plugin_default="$(git -C "$PLUGIN_REPO_PATH" symbolic-ref --short HEAD 2>/dev/null)"
                    [ -z "$_plugin_default" ] && _plugin_default="main"
                    info "Branch '$BRANCH' not found in plugin repo — creating from '$_plugin_default'."
                    git -C "$PLUGIN_REPO_PATH" fetch origin "$_plugin_default" 2>/dev/null || true
                    git -C "$PLUGIN_REPO_PATH" worktree add -b "$BRANCH" "$plugin_target" "origin/$_plugin_default" 2>/dev/null \
                        || git -C "$PLUGIN_REPO_PATH" worktree add -b "$BRANCH" "$plugin_target" "$_plugin_default" 2>/dev/null \
                        || die "Failed to create plugin worktree on new branch '$BRANCH' from '$_plugin_default'."
                fi
                ok "Plugin worktree nested at: custom/plugins/${PLUGIN_NAME}"
            else
                info "Plugin worktree already exists at: $plugin_target"
            fi

            # Ensure plugin worktree is on a named branch (not detached HEAD).
            # Detached HEAD can happen when the local branch is already checked
            # out in another worktree, so the fallback used a remote ref.
            local plugin_head
            plugin_head="$(git -C "$plugin_target" rev-parse --abbrev-ref HEAD 2>/dev/null)" || true
            if [ "$plugin_head" = "HEAD" ]; then
                # shellcheck disable=SC2015
                git -C "$plugin_target" checkout -b "swctl/${ISSUE_ID}" 2>/dev/null \
                    && info "Created plugin branch: swctl/${ISSUE_ID}" \
                    || warn "Plugin worktree is in detached HEAD."
            fi

            # 2b. Resolve plugin dependencies (--deps flag or .swctl.deps.yaml)
            local dep_plugins=""
            local dep_worktree_paths=""
            local deps
            if [ -n "${selected_deps:-}" ]; then
                # Deps explicitly provided via --deps flag (from UI)
                deps="$(echo "$selected_deps" | tr ',' '\n')"
            else
                # Auto-read from plugin's .swctl.deps.yaml
                deps="$(read_plugin_deps "$plugin_target")"
            fi
            if [ -n "$deps" ]; then
                info "Plugin dependencies declared: $(echo "$deps" | tr '\n' ', ' | sed 's/,$//')"
                while IFS= read -r dep_name; do
                    [ -n "$dep_name" ] || continue
                    [ "$dep_name" = "$PLUGIN_NAME" ] && continue  # skip self
                    if create_dep_plugin_worktree "$dep_name"; then
                        dep_plugins="${dep_plugins:+${dep_plugins},}${dep_name}"
                        dep_worktree_paths="${dep_worktree_paths:+${dep_worktree_paths},}${WORKTREE_PATH}/custom/plugins/${dep_name}"
                    fi
                done <<< "$deps"
            fi

            # 3. Standard trunk flow: diff, sync, provision
            # For plugin-external: diff the plugin repo against its own default
            # branch, not the platform's BASE_REF.
            if [ -n "${adopt_worktree_path:-}" ]; then
                # When adopting, the trunk has no changes — the work is in the
                # plugin worktree.  Plugin detection below forces the needed builds.
                DIFF_FILES=""
                count_changes ""
            else
                local plugin_default_branch
                plugin_default_branch="$(git -C "$PLUGIN_REPO_PATH" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@' || echo main)"
                local plugin_base_ref
                if git -C "$PLUGIN_REPO_PATH" rev-parse --verify "origin/${plugin_default_branch}" >/dev/null 2>&1; then
                    plugin_base_ref="origin/${plugin_default_branch}"
                elif git -C "$PLUGIN_REPO_PATH" rev-parse --verify "${plugin_default_branch}" >/dev/null 2>&1; then
                    plugin_base_ref="${plugin_default_branch}"
                else
                    plugin_base_ref="HEAD~1"
                fi
                DIFF_FILES="$(git -C "$PLUGIN_REPO_PATH" diff --name-only "${plugin_base_ref}...origin/${BRANCH}" 2>/dev/null || true)"
                count_changes "$DIFF_FILES"
            fi

            # Plugin has admin/storefront extensions → force builds so the bundle
            # includes them.  The synced JS from trunk was compiled without this
            # plugin's source present in custom/plugins/.
            # Check primary plugin AND dependency plugins for extensions.
            local plugin_has_extensions=0
            local all_plugin_dirs="$plugin_target"
            if [ -n "$dep_worktree_paths" ]; then
                all_plugin_dirs="$all_plugin_dirs $(echo "$dep_worktree_paths" | tr ',' ' ')"
            fi
            for _pdir in $all_plugin_dirs; do
                if find "$_pdir" -maxdepth 4 -path "*/Resources/app/administration" -type d 2>/dev/null | grep -q .; then
                    ADMIN_CHANGES=$((ADMIN_CHANGES + 1))
                    plugin_has_extensions=1
                    info "$(basename "$_pdir") has admin extensions — admin build will be triggered."
                fi
                if find "$_pdir" -maxdepth 4 -path "*/Resources/app/storefront" -type d 2>/dev/null | grep -q .; then
                    STOREFRONT_CHANGES=$((STOREFRONT_CHANGES + 1))
                    plugin_has_extensions=1
                    info "$(basename "$_pdir") has storefront extensions — storefront build will be triggered."
                fi
            done

            sync_worktree_from_trunk
            VENDOR_VOLUME="$(resolve_vendor_volume "$ISSUE_ID")"
            NODE_MODULES_VOLUME="$(resolve_node_modules_volume "$ISSUE_ID")"

            # Plugin build cache — key off the plugin's current HEAD +
            # package-lock.json.  If we've built this exact combination
            # before, mount the cached Resources/public/ RO and skip the
            # 60–90 s admin/storefront npm build.  Miss → full build +
            # populate cache at end.
            PLUGIN_BUILD_CACHE_VOLUME=""
            PLUGIN_BUILD_CACHE_HIT=0
            if [ "$plugin_has_extensions" -eq 1 ]; then
                PLUGIN_BUILD_CACHE_VOLUME="$(_resolve_plugin_build_key "$PLUGIN_NAME" "$plugin_target" 2>/dev/null || true)"
                if [ -n "$PLUGIN_BUILD_CACHE_VOLUME" ] && _plugin_build_cache_hit "$PLUGIN_BUILD_CACHE_VOLUME"; then
                    PLUGIN_BUILD_CACHE_HIT=1
                    info "Plugin build cache HIT: $PLUGIN_BUILD_CACHE_VOLUME (skipping admin/storefront npm build)."
                else
                    info "Plugin build cache MISS: ${PLUGIN_BUILD_CACHE_VOLUME:-<none>} (will populate after build)."
                fi
            fi

            # Track plugin linkage in metadata (primary + dependencies)
            LINKED_PLUGINS="${PLUGIN_NAME}${dep_plugins:+,${dep_plugins}}"
            PLUGIN_WORKTREE_PATHS="${PLUGIN_WORKTREE_PATH}${dep_worktree_paths:+,${dep_worktree_paths}}"
            PLATFORM_WORKTREE_PATH="$WORKTREE_PATH"
            PLATFORM_ISSUE_ID="$ISSUE_ID"

            info "Mode: ${SWCTL_MODE} | Plugin: ${PLUGIN_NAME}"
            info "Strategy: vendor=${VENDOR_VOLUME} node_modules=${NODE_MODULES_VOLUME}"

            # Defer heavy provisioning (DB clone, Docker containers, Shopware
            # install) when --no-provision was requested.  Leaves the worktree
            # and metadata in place for 'swctl setup <issue>' to finish.
            if [ "${SWCTL_NO_PROVISION:-0}" = "1" ]; then
                STATUS="provisioning-deferred"
                trap - EXIT
                write_metadata "$SWCTL_ACTIVE_META_FILE"
                ok "Worktree '${WORKTREE_ID}' ready (provisioning deferred)."
                info "Worktree: ${WORKTREE_PATH}"
                info "Run 'swctl setup ${ISSUE_ID}' to provision database + container when ready."
                return 0
            fi

            provision_database_and_app "$COMPOSE_PROJECT"

            # Ensure the nested plugin is properly registered AND activated
            # before the admin build.  plugin:refresh alone is not enough —
            # if trunk's source DB happens to have the plugin row as
            # active=0 (deactivated at some point, reset, etc.), every
            # cloned worktree inherits active=0.  Without active=1, the
            # DbalKernelPluginLoader never requires the plugin's composer.json,
            # never registers its PSR-4 autoload, never instantiates its
            # Bundle class → /api/_info/config silently omits the plugin and
            # the admin UI can't load it.  `plugin:install --activate` is
            # idempotent, so running it unconditionally is safe.
            #
            # Chain plugin:refresh + primary activate + dep activates under
            # ONE docker exec — each bin/console invocation costs ~3 s of
            # PHP kernel boot; batching saves (2 + N_deps) × ~3 s per create.
            # See _build_plugin_prep_command + tests/plugin_prep_command.bats.
            local _plugin_prep_cmd
            _plugin_prep_cmd="$(_build_plugin_prep_command "$PLUGIN_NAME" "$dep_plugins" "$SW_BIN_CONSOLE")"
            run_app_command "$COMPOSE_PROJECT" "$_plugin_prep_cmd" 2>/dev/null \
                || warn "plugin:refresh / activation failed."

            if [ "$PLUGIN_BUILD_CACHE_HIT" = "1" ]; then
                # Cache hit — Resources/public/ is already mounted from the
                # cached volume (see write_compose_volume_override).  Just
                # register the plugin bundle so /api/_info/config picks it up.
                run_app_command "$COMPOSE_PROJECT" \
                    "$SW_BIN_CONSOLE bundle:dump && $SW_BIN_CONSOLE assets:install" \
                    2>/dev/null || warn "bundle:dump / assets:install failed."
                ok "Reused plugin build cache: $PLUGIN_BUILD_CACHE_VOLUME"
            else
                # Admin build failures return 2 from build.sh → abort the
                # create so STATUS=failed instead of silently shipping a
                # broken admin.  `|| die` only triggers on exit code 2+;
                # a clean exit continues to populate the cache below.
                if ! run_frontend_build_if_needed "$COMPOSE_PROJECT" 1 "$plugin_has_extensions"; then
                    die "Frontend build failed — see errors above.  Run 'swctl refresh ${ISSUE_ID}' after fixing to retry."
                fi
                # Populate the plugin build cache after a successful build.
                # Serialised on the cache volume name so two parallel creates
                # of the same plugin HEAD+lock don't race their cp's on the
                # same files.  The helper re-checks hit inside the lock so
                # only the first winning create actually populates.
                # If the build failed, _populate_plugin_build_cache's sentinel
                # check refuses to populate — next create will retry the build.
                if [ -n "$PLUGIN_BUILD_CACHE_VOLUME" ]; then
                    swctl_lock "volume-$PLUGIN_BUILD_CACHE_VOLUME" \
                        _populate_plugin_build_cache_if_missing \
                        "$PLUGIN_BUILD_CACHE_VOLUME" "$plugin_target" \
                        || warn "Plugin build cache not populated; next create will rebuild."
                fi
            fi
            # NOTE: build.sh's happy path already runs `assets:install` (either
            # the full-build branch at hooks/build.sh:64 or the QA skip-build
            # branch at hooks/build.sh:16).  A second assets:install here is
            # ~3 s of pure PHP kernel boot for no extra work.  Dropped.

            STATUS="complete"
            FAILED_AT=""
            trap - EXIT
            write_metadata "$SWCTL_ACTIVE_META_FILE"

            ok "Worktree '${WORKTREE_ID}' with plugin '${PLUGIN_NAME}' is ready."
            info "URL: ${APP_URL}"
            info "Worktree: ${WORKTREE_PATH}"
            info "Plugin: ${PLUGIN_WORKTREE_PATH}"
            ;;

        plugin-embedded)
            info "Plugin (embedded): $PLUGIN_NAME"
            load_project_config ${project_config_arg:+"$project_config_arg"}
            ensure_infra_ready

            git -C "$PROJECT_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "Project root is not a Git repository: $PROJECT_ROOT"

            ISSUE_ID="$(sanitize_slug "$ISSUE")"
            WORKTREE_ID="$ISSUE_ID"
            BASE_REF="$(git_base_ref)"
            COMPOSE_PROJECT="$(sanitize_slug "${SW_PROJECT_SLUG}-${ISSUE_ID}")"

            if [ "$SW_RUNTIME" = "orbstack" ]; then
                DOMAIN="${SW_SERVICE_NAME}.${COMPOSE_PROJECT}.orb.local"
                APP_URL="http://${DOMAIN}"
            else
                DOMAIN="${SW_PROJECT_SLUG}-${ISSUE_ID}.${SW_DOMAIN_SUFFIX}"
                APP_URL="http://${DOMAIN}"
            fi

            TRAEFIK_ROUTER="$(sanitize_router_id "${SW_PROJECT_SLUG}_${ISSUE_ID}")"
            TRAEFIK_SERVICE="$TRAEFIK_ROUTER"
            WORKTREE_PATH="${SW_WORKTREE_ROOT}/${SW_WORKTREE_PREFIX}-${ISSUE_ID}"

            # Write early metadata so failed creates are tracked
            SWCTL_ACTIVE_META_FILE="$(instance_file "$SW_PROJECT_SLUG" "$ISSUE_ID")"
            STATUS="creating"
            FAILED_AT=""
            DB_NAME="${DB_NAME:-}"
            DB_STATE="${DB_STATE:-}"
            VENDOR_VOLUME="${VENDOR_VOLUME:-}"
            NODE_MODULES_VOLUME="${NODE_MODULES_VOLUME:-}"
            MIGRATION_CHANGES="${MIGRATION_CHANGES:-0}"
            ENTITY_CHANGES="${ENTITY_CHANGES:-0}"
            FRONTEND_CHANGES="${FRONTEND_CHANGES:-0}"
            write_metadata "$SWCTL_ACTIVE_META_FILE"

            trap 'if [ "${STATUS:-}" = "creating" ]; then STATUS=failed; FAILED_AT="${SWCTL_LAST_ERROR:-unknown}"; write_metadata "$SWCTL_ACTIVE_META_FILE" 2>/dev/null; fi' EXIT

            create_worktree
            check_branch_staleness

            # Diff analysis — focus on plugin directory for change detection
            DIFF_FILES="$(git -C "$PROJECT_ROOT" diff --name-only "${BASE_REF}...${BRANCH}" || true)"
            count_changes "$DIFF_FILES"

            sync_worktree_from_trunk
            VENDOR_VOLUME="$(resolve_vendor_volume "$ISSUE_ID")"
            NODE_MODULES_VOLUME="$(resolve_node_modules_volume "$ISSUE_ID")"

            info "Mode: ${SWCTL_MODE} | Plugin: ${PLUGIN_NAME}"
            info "Strategy: vendor=${VENDOR_VOLUME} node_modules=${NODE_MODULES_VOLUME}"

            # Defer heavy provisioning (DB clone, Docker containers, Shopware
            # install) when --no-provision was requested.  Leaves the worktree
            # and metadata in place for 'swctl setup <issue>' to finish.
            if [ "${SWCTL_NO_PROVISION:-0}" = "1" ]; then
                STATUS="provisioning-deferred"
                trap - EXIT
                write_metadata "$SWCTL_ACTIVE_META_FILE"
                ok "Worktree '${WORKTREE_ID}' ready (provisioning deferred)."
                info "Worktree: ${WORKTREE_PATH}"
                info "Run 'swctl setup ${ISSUE_ID}' to provision database + container when ready."
                return 0
            fi

            provision_database_and_app "$COMPOSE_PROJECT"
            run_frontend_build_if_needed "$COMPOSE_PROJECT" 1
            activate_plugin "$COMPOSE_PROJECT" "$PLUGIN_NAME"

            STATUS="complete"
            FAILED_AT=""
            trap - EXIT
            write_metadata "$SWCTL_ACTIVE_META_FILE"

            ok "Worktree '${WORKTREE_ID}' with plugin '${PLUGIN_NAME}' is ready."
            info "URL: ${APP_URL}"
            info "Worktree: ${WORKTREE_PATH}"
            ;;

        platform|*)
            # --- Original platform flow ---
            load_project_config ${project_config_arg:+"$project_config_arg"}
            ensure_infra_ready

            git -C "$PROJECT_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "Project root is not a Git repository: $PROJECT_ROOT"

            ISSUE_ID="$(sanitize_slug "$ISSUE")"
            WORKTREE_ID="$ISSUE_ID"
            BASE_REF="$(git_base_ref)"
            COMPOSE_PROJECT="$(sanitize_slug "${SW_PROJECT_SLUG}-${ISSUE_ID}")"

            if [ "$SW_RUNTIME" = "orbstack" ]; then
                DOMAIN="${SW_SERVICE_NAME}.${COMPOSE_PROJECT}.orb.local"
                APP_URL="http://${DOMAIN}"
            else
                DOMAIN="${SW_PROJECT_SLUG}-${ISSUE_ID}.${SW_DOMAIN_SUFFIX}"
                APP_URL="http://${DOMAIN}"
            fi

            TRAEFIK_ROUTER="$(sanitize_router_id "${SW_PROJECT_SLUG}_${ISSUE_ID}")"
            TRAEFIK_SERVICE="$TRAEFIK_ROUTER"
            WORKTREE_PATH="${SW_WORKTREE_ROOT}/${SW_WORKTREE_PREFIX}-${ISSUE_ID}"

            # Write early metadata so failed creates are tracked
            SWCTL_ACTIVE_META_FILE="$(instance_file "$SW_PROJECT_SLUG" "$ISSUE_ID")"
            STATUS="creating"
            FAILED_AT=""
            DB_NAME="${DB_NAME:-}"
            DB_STATE="${DB_STATE:-}"
            VENDOR_VOLUME="${VENDOR_VOLUME:-}"
            NODE_MODULES_VOLUME="${NODE_MODULES_VOLUME:-}"
            MIGRATION_CHANGES="${MIGRATION_CHANGES:-0}"
            ENTITY_CHANGES="${ENTITY_CHANGES:-0}"
            FRONTEND_CHANGES="${FRONTEND_CHANGES:-0}"
            write_metadata "$SWCTL_ACTIVE_META_FILE"

            # On any exit while STATUS=creating, mark as failed
            trap 'if [ "${STATUS:-}" = "creating" ]; then STATUS=failed; FAILED_AT="${SWCTL_LAST_ERROR:-unknown}"; write_metadata "$SWCTL_ACTIVE_META_FILE" 2>/dev/null; fi' EXIT

            local step_start create_start
            create_start=$SECONDS

            step_start=$SECONDS
            create_worktree
            check_branch_staleness
            info "[timing] create_worktree: $((SECONDS - step_start))s"

            step_start=$SECONDS
            DIFF_FILES="$(git -C "$PROJECT_ROOT" diff --name-only "${BASE_REF}...${BRANCH}" || true)"
            count_changes "$DIFF_FILES"
            info "[timing] count_changes: $((SECONDS - step_start))s"

            # Resolve dependency plugins (--deps flag) for platform worktrees
            local dep_plugins=""
            local dep_worktree_paths=""
            if [ -n "${selected_deps:-}" ]; then
                local deps
                deps="$(echo "$selected_deps" | tr ',' '\n')"
                if [ -n "$deps" ]; then
                    info "Plugin dependencies declared: $(echo "$deps" | tr '\n' ', ' | sed 's/,$//')"
                    while IFS= read -r dep_name; do
                        [ -n "$dep_name" ] || continue
                        if create_dep_plugin_worktree "$dep_name"; then
                            dep_plugins="${dep_plugins:+${dep_plugins},}${dep_name}"
                            dep_worktree_paths="${dep_worktree_paths:+${dep_worktree_paths},}${WORKTREE_PATH}/custom/plugins/${dep_name}"
                        fi
                    done <<< "$deps"
                fi
            fi

            # Check dependency plugins for admin/storefront extensions
            local plugin_has_extensions=0
            if [ -n "$dep_worktree_paths" ]; then
                for _pdir in $(echo "$dep_worktree_paths" | tr ',' ' '); do
                    if find "$_pdir" -maxdepth 4 -path "*/Resources/app/administration" -type d 2>/dev/null | grep -q .; then
                        ADMIN_CHANGES=$((ADMIN_CHANGES + 1))
                        plugin_has_extensions=1
                        info "$(basename "$_pdir") has admin extensions — admin build will be triggered."
                    fi
                    if find "$_pdir" -maxdepth 4 -path "*/Resources/app/storefront" -type d 2>/dev/null | grep -q .; then
                        STOREFRONT_CHANGES=$((STOREFRONT_CHANGES + 1))
                        plugin_has_extensions=1
                        info "$(basename "$_pdir") has storefront extensions — storefront build will be triggered."
                    fi
                done
            fi

            # Track dependency plugin linkage in metadata
            if [ -n "$dep_plugins" ]; then
                LINKED_PLUGINS="${dep_plugins}"
                PLUGIN_WORKTREE_PATHS="${dep_worktree_paths}"
            fi

            step_start=$SECONDS
            sync_worktree_from_trunk
            VENDOR_VOLUME="$(resolve_vendor_volume "$ISSUE_ID")"
            NODE_MODULES_VOLUME="$(resolve_node_modules_volume "$ISSUE_ID")"
            info "[timing] sync: $((SECONDS - step_start))s"

            info "Mode: ${SWCTL_MODE} | Diff: migrations=${MIGRATION_CHANGES} entity=${ENTITY_CHANGES} admin=${ADMIN_CHANGES} storefront=${STOREFRONT_CHANGES} composer=${COMPOSER_CHANGES} package=${PACKAGE_CHANGES} backend=${BACKEND_CHANGES}"
            info "Strategy: vendor=${VENDOR_VOLUME} node_modules=${NODE_MODULES_VOLUME}"

            step_start=$SECONDS
            provision_database_and_app "$COMPOSE_PROJECT"
            info "[timing] provision: $((SECONDS - step_start))s"

            # Activate dependency plugins after provisioning
            if [ -n "$dep_plugins" ]; then
                run_app_command "$COMPOSE_PROJECT" "$SW_BIN_CONSOLE plugin:refresh" 2>/dev/null || warn "plugin:refresh failed."
                local _old_ifs="$IFS"
                IFS=','
                for _dep in $dep_plugins; do
                    run_app_command "$COMPOSE_PROJECT" \
                        "$SW_BIN_CONSOLE plugin:install --activate $_dep" 2>/dev/null \
                        || warn "Failed to activate dependency: $_dep"
                done
                IFS="$_old_ifs"
            fi

            step_start=$SECONDS
            run_frontend_build_if_needed "$COMPOSE_PROJECT" 1 "$plugin_has_extensions"
            info "[timing] frontend: $((SECONDS - step_start))s"

            # Mark complete and remove EXIT trap
            STATUS="complete"
            FAILED_AT=""
            trap - EXIT
            write_metadata "$SWCTL_ACTIVE_META_FILE"

            ok "Worktree '${WORKTREE_ID}' is ready. (total: $((SECONDS - create_start))s)"
            info "URL: ${APP_URL}"
            info "Worktree: ${WORKTREE_PATH}"
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Batch create
# ---------------------------------------------------------------------------

parse_batch_file() {
    local file="$1"
    [ -f "$file" ] || die "Batch file not found: $file"
    while IFS= read -r line || [ -n "$line" ]; do
        line="${line%%#*}"
        line="$(printf '%s' "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
        [ -n "$line" ] || continue
        printf '%s\n' "$line"
    done < "$file"
}

parse_cli_pairs() {
    while [ $# -ge 2 ]; do
        printf '%s %s\n' "$1" "$2"
        shift 2
    done
}

parse_mr_json() {
    if ! command -v jq >/dev/null 2>&1; then
        die "jq is required for API-based batch create. Install it with: brew install jq"
    fi
    jq -r '.[] | "\(.iid) \(.source_branch)"'
}

parse_pr_json() {
    if ! command -v jq >/dev/null 2>&1; then
        die "jq is required for API-based batch create. Install it with: brew install jq"
    fi
    jq -r '.[] | "\(.number) \(.head.ref)"'
}

fetch_gitlab_mrs() {
    local project_id="$1"
    local api_url="${SWCTL_GITLAB_URL:-https://gitlab.com}/api/v4"
    local token="${SWCTL_GITLAB_TOKEN:-}"

    [ -n "$token" ] || die "SWCTL_GITLAB_TOKEN is not set."

    curl -sSf -H "PRIVATE-TOKEN: $token" \
        "${api_url}/projects/${project_id}/merge_requests?state=opened&per_page=100" \
        | parse_mr_json
}

fetch_github_prs() {
    local repo="$1"
    local token=""
    if [ -f "$SWCTL_GITHUB_TOKEN_FILE" ]; then
        token="$(cat "$SWCTL_GITHUB_TOKEN_FILE")"
    fi
    local auth_header=""

    if [ -n "$token" ]; then
        auth_header="Authorization: token $token"
    fi

    curl -sSf ${auth_header:+-H "$auth_header"} \
        "https://api.github.com/repos/${repo}/pulls?state=open&per_page=100" \
        | parse_pr_json
}

select_from_list() {
    local label="$1"
    local pairs=()

    while IFS= read -r line; do
        [ -n "$line" ] || continue
        pairs+=("$line")
    done

    if [ ${#pairs[@]} -eq 0 ]; then
        warn "No open ${label}s found."
        return 1
    fi

    if command -v fzf >/dev/null 2>&1; then
        printf '%s\n' "${pairs[@]}" | fzf --multi --prompt="Select ${label}s> " --height=40% --reverse
        return
    fi

    local i=1
    for pair in "${pairs[@]}"; do
        printf '  [%d] %s\n' "$i" "$pair"
        i=$((i + 1))
    done
    local selection
    selection="$(prompt_text "Enter numbers (comma-separated, or 'all')")"
    if [ "$selection" = "all" ]; then
        printf '%s\n' "${pairs[@]}"
        return
    fi
    local old_ifs="$IFS"
    IFS=',' read -r -a indices <<< "$selection"
    IFS="$old_ifs"
    local idx
    for idx in "${indices[@]}"; do
        idx="$(printf '%s' "$idx" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
        if [ "$idx" -ge 1 ] 2>/dev/null && [ "$idx" -le "${#pairs[@]}" ]; then
            printf '%s\n' "${pairs[$((idx - 1))]}"
        fi
    done
}

batch_create_sequential() {
    # shellcheck disable=SC2178,SC2128
    local pairs="$1"
    local job_dir="$2"
    local issue="" branch=""

    # shellcheck disable=SC2128
    while IFS=' ' read -r issue branch; do
        # shellcheck disable=SC2015
        [ -n "$issue" ] && [ -n "$branch" ] || continue
        info "Creating worktree for $issue ($branch)..."
        if cmd_create "$issue" "$branch" >"$job_dir/${issue}.log" 2>&1; then
            touch "$job_dir/${issue}.ok"
            ok "Created $issue"
        else
            touch "$job_dir/${issue}.fail"
            err "Failed $issue"
        fi
    done <<< "$pairs"
}

batch_create_parallel() {
    # shellcheck disable=SC2178,SC2128
    local pairs="$1"
    local job_dir="$2"
    local max_jobs="${3:-4}"
    local pids=()
    local running=0
    local issue="" branch=""

    # shellcheck disable=SC2128
    while IFS=' ' read -r issue branch; do
        # shellcheck disable=SC2015
        [ -n "$issue" ] && [ -n "$branch" ] || continue

        while [ "$running" -ge "$max_jobs" ]; do
            wait -n 2>/dev/null || true
            running=$((running - 1))
        done

        (
            # shellcheck disable=SC2015
            cmd_create "$issue" "$branch" >"$job_dir/${issue}.log" 2>&1 \
                && touch "$job_dir/${issue}.ok" \
                || touch "$job_dir/${issue}.fail"
        ) &

        pids+=($!)
        running=$((running + 1))
        info "Started background job for $issue (PID $!)"
    done <<< "$pairs"

    local pid
    for pid in "${pids[@]}"; do
        wait "$pid" 2>/dev/null || true
    done
}

cmd_batch_create() {
    # shellcheck disable=SC2178,SC2128
    local pairs=""
    local parallel=0
    local max_jobs=4
    SWCTL_MODE="${SWCTL_MODE:-dev}"
    export SWCTL_MODE

    while [ $# -gt 0 ]; do
        case "$1" in
            --qa)
                SWCTL_MODE="qa"; shift ;;
            --dev)
                SWCTL_MODE="dev"; shift ;;
            --file|-f)
                shift
                [ -n "${1:-}" ] || die "Missing argument for --file."
                # shellcheck disable=SC2178
                pairs="$(parse_batch_file "$1")"
                shift
                ;;
            --gitlab)
                shift
                [ -n "${1:-}" ] || die "Missing argument for --gitlab."
                # shellcheck disable=SC2178
                pairs="$(fetch_gitlab_mrs "$1" | select_from_list "MR")"
                shift
                ;;
            --github)
                shift
                [ -n "${1:-}" ] || die "Missing argument for --github."
                # shellcheck disable=SC2178
                pairs="$(fetch_github_prs "$1" | select_from_list "PR")"
                shift
                ;;
            --parallel|-p)
                parallel=1
                shift
                ;;
            --jobs|-j)
                shift
                [ -n "${1:-}" ] || die "Missing argument for --jobs."
                max_jobs="$1"
                shift
                ;;
            -*)
                die "Unknown flag: $1"
                ;;
            *)
                # shellcheck disable=SC2178
                pairs="$(parse_cli_pairs "$@")"
                break
                ;;
        esac
    done

    # shellcheck disable=SC2128
    [ -n "$pairs" ] || die "No issue/branch pairs provided.\nUsage: swctl batch create [--file <path>|--gitlab <id>|--github <owner/repo>] [--parallel [-j N]] [ISSUE BRANCH ...]"

    # In QA mode, skip pairs without a branch (no linked PR/MR)
    if [ "$SWCTL_MODE" = "qa" ]; then
        local filtered=""
        local skipped=0
        # shellcheck disable=SC2128
        while IFS=' ' read -r issue branch; do
            [ -n "$issue" ] || continue
            if [ -z "$branch" ]; then
                warn "Skipping issue '$issue': no linked PR/MR (QA mode)."
                skipped=$((skipped + 1))
                continue
            fi
            filtered="${filtered:+$filtered
}$issue $branch"
        done <<< "$pairs"
        [ "$skipped" -gt 0 ] && warn "Skipped $skipped issue(s) with no linked branch."
        # shellcheck disable=SC2178
        pairs="$filtered"
        # shellcheck disable=SC2128
        [ -n "$pairs" ] || die "No issue/branch pairs remaining after filtering (all lacked linked PRs)."
    fi

    local total=0
    local succeeded=0
    local failed=0
    local job_dir="$SWCTL_TMP_DIR/batch.$$"
    mkdir -p "$job_dir"
    trap 'rm -rf "$job_dir"' EXIT

    # shellcheck disable=SC2128
    total="$(printf '%s\n' "$pairs" | grep -c '.' || true)"
    info "Batch creating $total worktree(s)$([ "$parallel" -eq 1 ] && printf ' in parallel (max %s jobs)' "$max_jobs")."

    if [ "$parallel" -eq 1 ]; then
        # shellcheck disable=SC2128
        batch_create_parallel "$pairs" "$job_dir" "$max_jobs"
    else
        # shellcheck disable=SC2128
        batch_create_sequential "$pairs" "$job_dir"
    fi

    succeeded="$(find "$job_dir" -name '*.ok' 2>/dev/null | wc -l | tr -d ' ')"
    failed="$(find "$job_dir" -name '*.fail' 2>/dev/null | wc -l | tr -d ' ')"

    printf '\n'
    ok "Batch complete: $succeeded succeeded, $failed failed out of $total."

    local fail_file issue_id
    for fail_file in "$job_dir"/*.fail; do
        [ -f "$fail_file" ] || continue
        issue_id="$(basename "$fail_file" .fail)"
        err "Failed: $issue_id"
        cat "$job_dir/${issue_id}.log" >&2
    done

    rm -rf "$job_dir"
    trap - EXIT
    [ "$failed" -eq 0 ]
}

cmd_batch() {
    local subcmd="${1:-}"
    shift || true

    case "$subcmd" in
        create) cmd_batch_create "$@" ;;
        *)      die "Usage: swctl batch create [--file <path>|--gitlab <id>|--github <owner/repo>] [--parallel [-j N]] [ISSUE BRANCH ...]" ;;
    esac
}

truncate_text() {
    local max="$1"
    local value="$2"
    if [ "${#value}" -le "$max" ]; then
        printf '%s' "$value"
        return
    fi
    if [ "$max" -le 3 ]; then
        printf '%s' "${value:0:$max}"
        return
    fi
    printf '%s...' "${value:0:$((max - 3))}"
}

status_label() {
    local compose_project="$1"
    if [ -n "$(app_container_id "$compose_project")" ]; then
        printf '%b● Running%b' "$COLOR_GREEN" "$COLOR_RESET"
        return
    fi

    if [ -n "$(app_container_exists_any_state "$compose_project")" ]; then
        printf '%b○ Stopped%b' "$COLOR_RED" "$COLOR_RESET"
        return
    fi

    printf '%b○ Missing%b' "$COLOR_YELLOW" "$COLOR_RESET"
}

render_status_table() {
    local scope="${1:-all}"
    local file=""
    local found=0

    printf '%-24s %-4s %-40s %-16s %-8s\n' "Issue" "Mode" "Domain" "Container" "DB"
    printf '%-24s %-4s %-40s %-16s %-8s\n' "------------------------" "----" "----------------------------------------" "----------------" "--------"

    while IFS= read -r file; do
        [ -n "$file" ] || continue
        found=1
        load_instance_metadata "$file"
        printf '%-24s %-4s %-40s %-16b %-8s\n' \
            "$(truncate_text 24 "$ISSUE_ID")" \
            "${SWCTL_MODE:-dev}" \
            "$(truncate_text 40 "$DOMAIN")" \
            "$(status_label "$COMPOSE_PROJECT")" \
            "$DB_STATE"
    done <<EOF
$(list_instance_files "$scope")
EOF

    if [ "$found" -eq 0 ]; then
        printf '%s\n' "No tracked worktrees."
    fi
}

cmd_status() {
    if maybe_load_project_config >/dev/null 2>&1; then
        render_status_table "project"
        return
    fi

    render_status_table "all"
}

cmd_exec() {
    local issue_input="${1:-}"
    local command_string="${2:-}"
    local meta_file=""

    [ -n "$issue_input" ] || die "Usage: swctl exec <issue> '<cmd>'"
    [ -n "$command_string" ] || die "Usage: swctl exec <issue> '<cmd>'"

    maybe_load_project_config >/dev/null 2>&1 || true
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || die "No tracked worktree found for issue '$issue_input'."
    load_instance_metadata "$meta_file"

    # Vite watch commands proxy /api to APP_URL, but inside the container
    # APP_URL resolves to the container's own IP on port 80 while Caddy
    # listens on port 8000. Override APP_URL for the Vite process only.
    case "$command_string" in
        *watch:admin*|*watch:storefront*|*"npm run dev"*)
            command_string="APP_URL=http://localhost:8000 $command_string"
            ;;
    esac

    run_app_command "$COMPOSE_PROJECT" "$command_string"
}

cmd_logs() {
    local issue_input="${1:-}"
    local follow="${2:-}"
    local meta_file=""

    [ -n "$issue_input" ] || die "Usage: swctl logs <issue> [--follow|-f]"

    maybe_load_project_config >/dev/null 2>&1 || true
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || die "No tracked worktree found for issue '$issue_input'."
    load_instance_metadata "$meta_file"

    local container_id
    container_id="$(app_container_id "$COMPOSE_PROJECT")"
    [ -n "$container_id" ] || die "No running container for '$COMPOSE_PROJECT'."

    if [ "$follow" = "--follow" ] || [ "$follow" = "-f" ]; then
        docker logs -f "$container_id"
    else
        docker logs --tail 100 "$container_id"
    fi
}

cmd_restart() {
    local issue_input="${1:-}"
    local meta_file=""

    [ -n "$issue_input" ] || die "Usage: swctl restart <issue>"

    maybe_load_project_config >/dev/null 2>&1 || true
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || die "No tracked worktree found for issue '$issue_input'."
    load_instance_metadata "$meta_file"

    if [ -f "$COMPOSE_ENV_FILE" ] && [ -f "$COMPOSE_TEMPLATE" ]; then
        # shellcheck disable=SC2046
        compose --project-directory "$SWCTL_TMP_DIR" $(compose_file_args) --env-file "$COMPOSE_ENV_FILE" -p "$COMPOSE_PROJECT" restart
    else
        local container_id
        container_id="$(app_container_exists_any_state "$COMPOSE_PROJECT" || true)"
        [ -n "$container_id" ] || die "No container found for '$COMPOSE_PROJECT'."
        docker restart "$container_id"
    fi
    ok "Restarted '$ISSUE_ID'."
}

cmd_stop() {
    local issue_input="${1:-}"
    [ -n "$issue_input" ] || die "Usage: swctl stop <issue>"

    maybe_load_project_config >/dev/null 2>&1 || true
    local meta_file
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || die "No tracked worktree found for issue '$issue_input'."
    load_instance_metadata "$meta_file"

    if [ -f "${COMPOSE_ENV_FILE:-}" ] && [ -f "${COMPOSE_TEMPLATE:-}" ]; then
        # shellcheck disable=SC2046
        compose --project-directory "$SWCTL_TMP_DIR" $(compose_file_args) --env-file "$COMPOSE_ENV_FILE" -p "$COMPOSE_PROJECT" stop
    else
        local container_id
        container_id="$(app_container_exists_any_state "$COMPOSE_PROJECT" || true)"
        [ -n "$container_id" ] || die "No container found for '$COMPOSE_PROJECT'."
        docker stop "$container_id"
    fi
    ok "Stopped '$ISSUE_ID'."
}

cmd_start() {
    local issue_input="${1:-}"
    [ -n "$issue_input" ] || die "Usage: swctl start <issue>"

    maybe_load_project_config >/dev/null 2>&1 || true
    local meta_file
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || die "No tracked worktree found for issue '$issue_input'."
    load_instance_metadata "$meta_file"

    if [ -f "${COMPOSE_ENV_FILE:-}" ] && [ -f "${COMPOSE_TEMPLATE:-}" ]; then
        # shellcheck disable=SC2046
        compose --project-directory "$SWCTL_TMP_DIR" $(compose_file_args) --env-file "$COMPOSE_ENV_FILE" -p "$COMPOSE_PROJECT" start
    else
        local container_id
        container_id="$(app_container_exists_any_state "$COMPOSE_PROJECT" || true)"
        [ -n "$container_id" ] || die "No container found for '$COMPOSE_PROJECT'."
        docker start "$container_id"
    fi
    ok "Started '$ISSUE_ID'."
}

cmd_refresh() {
    local issue_input="${1:-}"
    SWCTL_ACTIVE_META_FILE=""

    [ -n "$issue_input" ] || die "Usage: swctl refresh <issue>"

    maybe_load_project_config >/dev/null 2>&1 || true
    SWCTL_ACTIVE_META_FILE="$(resolve_instance_file_by_issue "$issue_input")" || die "No tracked worktree found for issue '$issue_input'."
    load_instance_metadata "$SWCTL_ACTIVE_META_FILE"

    # Load project config from the instance's saved config path
    load_project_config ${CONFIG_PATH:+"$CONFIG_PATH"}

    # Resume failed/interrupted/deferred creates
    if [ "${STATUS:-complete}" = "failed" ] \
       || [ "${STATUS:-complete}" = "creating" ] \
       || [ "${STATUS:-complete}" = "provisioning-deferred" ]; then
        info "Worktree '$ISSUE_ID' has status '${STATUS}'. Resuming provisioning..."
        STATUS="creating"
        ensure_infra_ready

        # Recompute derived variables not stored in metadata
        WORKTREE_ID="${WORKTREE_ID:-$ISSUE_ID}"
        if [ -z "${COMPOSE_PROJECT:-}" ]; then
            COMPOSE_PROJECT="$(sanitize_slug "${SW_PROJECT_SLUG}-${ISSUE_ID}")"
        fi
        TRAEFIK_ROUTER="$(sanitize_router_id "${SW_PROJECT_SLUG}_${ISSUE_ID}")"
        TRAEFIK_SERVICE="$TRAEFIK_ROUTER"
        if [ -z "${WORKTREE_PATH:-}" ]; then
            WORKTREE_PATH="${SW_WORKTREE_ROOT}/${SW_WORKTREE_PREFIX}-${ISSUE_ID}"
        fi
        if [ -z "${DOMAIN:-}" ]; then
            if [ "$SW_RUNTIME" = "orbstack" ]; then
                DOMAIN="${SW_SERVICE_NAME}.${COMPOSE_PROJECT}.orb.local"
            else
                DOMAIN="${SW_PROJECT_SLUG}-${ISSUE_ID}.${SW_DOMAIN_SUFFIX}"
            fi
            APP_URL="http://${DOMAIN}"
        fi

        # On any exit while STATUS=creating, mark as failed
        trap 'if [ "${STATUS:-}" = "creating" ]; then STATUS=failed; FAILED_AT="${SWCTL_LAST_ERROR:-unknown}"; write_metadata "$SWCTL_ACTIVE_META_FILE" 2>/dev/null; fi' EXIT

        # 1. Ensure worktree exists
        if [ -n "$WORKTREE_PATH" ] && [ ! -d "$WORKTREE_PATH" ]; then
            create_worktree
        fi

        # 2. Re-compute diff and changes
        BASE_REF="$(git_base_ref)"
        DIFF_FILES="$(git -C "$PROJECT_ROOT" diff --name-only "${BASE_REF}...${BRANCH}" 2>/dev/null || true)"
        count_changes "$DIFF_FILES"

        # 3. Re-sync artifacts and deps
        sync_worktree_from_trunk
        VENDOR_VOLUME="$(resolve_vendor_volume "$ISSUE_ID")"
        NODE_MODULES_VOLUME="$(resolve_node_modules_volume "$ISSUE_ID")"

        # 4. Re-provision DB + app
        provision_database_and_app "$COMPOSE_PROJECT"

        # 5. Frontend build
        # For plugin-external instances we must force the plugin build so
        # public/bundles/<slug>/administration/js/* gets generated.  A
        # PHP-only commit wouldn't otherwise bump ADMIN_CHANGES /
        # STOREFRONT_CHANGES, and without those the workflow build hook
        # falls through to "No frontend builds needed".  Mirror the
        # detection + counter bumps done in cmd_create.
        local _refresh_force_plugin_build=0
        if [ "${PROJECT_TYPE:-}" = "plugin-external" ] && [ -n "${PLUGIN_WORKTREE_PATHS:-}" ]; then
            local _old_ifs="$IFS"; IFS=','
            for _pdir in $PLUGIN_WORKTREE_PATHS; do
                if find "$_pdir" -maxdepth 4 -path "*/Resources/app/administration" -type d 2>/dev/null | grep -q .; then
                    ADMIN_CHANGES=$((${ADMIN_CHANGES:-0} + 1))
                    _refresh_force_plugin_build=1
                    info "$(basename "$_pdir") has admin extensions — admin build will be triggered."
                fi
                if find "$_pdir" -maxdepth 4 -path "*/Resources/app/storefront" -type d 2>/dev/null | grep -q .; then
                    STOREFRONT_CHANGES=$((${STOREFRONT_CHANGES:-0} + 1))
                    _refresh_force_plugin_build=1
                    info "$(basename "$_pdir") has storefront extensions — storefront build will be triggered."
                fi
            done
            IFS="$_old_ifs"
        fi
        run_frontend_build_if_needed "$COMPOSE_PROJECT" 1 "$_refresh_force_plugin_build"

        # 6. Activate plugin if needed
        if [ -n "${PLUGIN_NAME:-}" ]; then
            activate_plugin "$COMPOSE_PROJECT" "$PLUGIN_NAME"
        fi

        # 7. Postflight health check.  Catches classes of misconfiguration
        # that previously shipped green ("successfully provisioned") but
        # left the instance broken at runtime — missing container,
        # unreachable /admin, read-only media, empty vendor, dead DB.
        # Each check emits its own [WARN] with the exact remedy so the
        # user knows what to do next.  Overall failure leaves STATUS=creating
        # so the next refresh re-attempts provisioning.
        if ! _postflight_instance_ready "$COMPOSE_PROJECT" "$APP_URL"; then
            warn "Postflight checks failed for '${ISSUE_ID}'. Leaving STATUS=creating."
            die "Instance '${ISSUE_ID}' provisioned with issues — see warnings above. Run 'swctl refresh ${ISSUE_ID}' after addressing them."
        fi

        # 8. Mark complete
        STATUS="complete"
        FAILED_AT=""
        trap - EXIT
        write_metadata "$SWCTL_ACTIVE_META_FILE"

        ok "Worktree '$ISSUE_ID' successfully provisioned."
        info "URL: ${APP_URL}"
        return
    fi

    # --- Normal refresh: pull + rebuild ---

    # Remember the old HEAD before pulling
    local old_head
    old_head="$(git -C "$WORKTREE_PATH" rev-parse HEAD 2>/dev/null)"

    # Fetch latest changes from the main repo (worktrees share the same git object store,
    # and PROJECT_ROOT is more likely to have SSH/credentials configured)
    info "Pulling latest changes for '$ISSUE_ID' (branch: $BRANCH)."
    git -C "$PROJECT_ROOT" fetch origin "$BRANCH" 2>/dev/null \
        || warn "Could not fetch latest changes. Continuing with current state."
    # Update worktree to match the fetched remote branch
    git -C "$WORKTREE_PATH" reset --hard "origin/$BRANCH" 2>/dev/null \
        || warn "Could not reset worktree to origin/$BRANCH."

    local new_head
    new_head="$(git -C "$WORKTREE_PATH" rev-parse HEAD 2>/dev/null)"

    if [ "$old_head" = "$new_head" ]; then
        info "No new commits. Nothing to refresh."
        return
    fi

    ok "Updated $old_head → $new_head"

    # Diff between old and new HEAD to detect what changed
    local diff_files
    diff_files="$(git -C "$WORKTREE_PATH" diff --name-only "$old_head...$new_head" 2>/dev/null || true)"
    count_changes "$diff_files"

    info "Changes since last build: migrations=${MIGRATION_CHANGES} entity=${ENTITY_CHANGES} admin=${ADMIN_CHANGES} storefront=${STOREFRONT_CHANGES} composer=${COMPOSER_CHANGES} package=${PACKAGE_CHANGES} backend=${BACKEND_CHANGES}"

    # Re-sync gitignored files if needed
    sync_worktree_from_trunk

    local compose_project="$COMPOSE_PROJECT"

    # Run migrations if schema changed
    if [ $((MIGRATION_CHANGES + ENTITY_CHANGES)) -gt 0 ]; then
        info "Schema changes detected. Running migrations."
        run_app_command "$compose_project" "$WORKFLOW_CONSOLE database:migrate --all && $WORKFLOW_CONSOLE database:migrate-destructive --all" || warn "Migrations failed."
    fi

    # Composer install if dependencies changed (dev mode only)
    if [ "$((COMPOSER_CHANGES))" -gt 0 ] && [ "${SWCTL_MODE:-dev}" = "dev" ]; then
        info "Composer changes detected. Running composer install."
        run_app_command "$compose_project" "composer install --no-interaction" || warn "Composer install failed."
    fi

    # Rebuild frontend if admin/storefront changed
    if [ "${ADMIN_CHANGES:-0}" -gt 0 ]; then
        info "Admin changes detected. Running composer build:js:admin."
        run_app_command "$compose_project" "composer build:js:admin" || warn "Admin JS build failed."
    fi

    if [ "${STOREFRONT_CHANGES:-0}" -gt 0 ]; then
        info "Storefront changes detected. Running composer build:js:storefront."
        run_app_command "$compose_project" "composer build:js:storefront" || warn "Storefront JS build failed."
    fi

    # Always clear cache after any update
    run_app_command "$compose_project" "$WORKFLOW_CONSOLE cache:clear" || warn "cache:clear failed."

    # Update metadata with new HEAD
    STATUS="complete"
    write_metadata "$SWCTL_ACTIVE_META_FILE"

    ok "Refreshed '$ISSUE_ID'. Changes applied."
    info "URL: ${APP_URL}"
}

cmd_checkout() {
    local issue_input="${1:-}"
    local state_file="$SWCTL_STATE_DIR/checkout.state"

    # --- Return mode: restore main repo to base branch, re-attach worktree ---
    if [ "$issue_input" = "--return" ] || [ "$issue_input" = "-r" ]; then
        [ -f "$state_file" ] || die "No active checkout to return from."
        # shellcheck disable=SC1090
        . "$state_file"
        [ -n "${CHECKOUT_ACTIVE_ISSUE:-}" ] || die "Invalid checkout state file."

        local meta_file
        meta_file="$(resolve_instance_file_by_issue "$CHECKOUT_ACTIVE_ISSUE")" \
            || die "No tracked worktree found for issue '$CHECKOUT_ACTIVE_ISSUE'."
        load_instance_metadata "$meta_file"
        load_project_config ${CONFIG_PATH:+"$CONFIG_PATH"}

        info "Returning main repo to '${CHECKOUT_PREVIOUS_BRANCH}' and re-attaching worktree."

        # Return main repo to previous branch
        git -C "$PROJECT_ROOT" checkout "$CHECKOUT_PREVIOUS_BRANCH" \
            || die "Failed to checkout '$CHECKOUT_PREVIOUS_BRANCH' in main repo."

        # Re-attach worktree to its branch
        git -C "$WORKTREE_PATH" checkout "$BRANCH" \
            || die "Failed to re-attach worktree to branch '$BRANCH'."

        rm -f "$state_file"
        ok "Returned main repo to '$CHECKOUT_PREVIOUS_BRANCH'. Worktree '$ISSUE_ID' re-attached to '$BRANCH'."
        return
    fi

    # --- Checkout mode: detach worktree, checkout branch in main repo ---
    [ -n "$issue_input" ] || die "Usage: swctl checkout <issue>  or  swctl checkout --return"

    # Warn if there's already an active checkout
    if [ -f "$state_file" ]; then
        # shellcheck disable=SC1090
        . "$state_file"
        warn "There is already an active checkout for issue '${CHECKOUT_ACTIVE_ISSUE:-unknown}'."
        warn "Run 'swctl checkout --return' first, or this will override it."
    fi

    maybe_load_project_config >/dev/null 2>&1 || true
    local meta_file
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" \
        || die "No tracked worktree found for issue '$issue_input'."
    load_instance_metadata "$meta_file"
    load_project_config ${CONFIG_PATH:+"$CONFIG_PATH"}

    [ -n "${BRANCH:-}" ] || die "Instance '$issue_input' has no branch set."
    [ -n "${WORKTREE_PATH:-}" ] || die "Instance '$issue_input' has no worktree path."

    # Save current main repo branch
    local current_branch
    current_branch="$(git -C "$PROJECT_ROOT" branch --show-current 2>/dev/null)" || true
    [ -n "$current_branch" ] || current_branch="$(git -C "$PROJECT_ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null)" || true
    [ -n "$current_branch" ] || die "Could not determine current branch of main repo."

    info "Checking out branch '$BRANCH' (from worktree '$ISSUE_ID') into main repo."

    # 1. Detach worktree HEAD (releases the branch)
    git -C "$WORKTREE_PATH" checkout --detach HEAD 2>/dev/null \
        || die "Failed to detach worktree HEAD."
    ok "Detached worktree '$ISSUE_ID' from branch '$BRANCH'."

    # 2. Checkout branch in main repo
    git -C "$PROJECT_ROOT" checkout "$BRANCH" \
        || { git -C "$WORKTREE_PATH" checkout "$BRANCH" 2>/dev/null || true; die "Failed to checkout '$BRANCH' in main repo."; }
    ok "Main repo now on branch '$BRANCH'."

    # 3. Save state for --return
    mkdir -p "$SWCTL_STATE_DIR"
    {
        printf 'CHECKOUT_ACTIVE_ISSUE=%q\n' "$ISSUE_ID"
        printf 'CHECKOUT_PREVIOUS_BRANCH=%q\n' "$current_branch"
    } > "$state_file"

    info "To return: swctl checkout --return"
}

cmd_open() {
    local issue_input="${1:-}"
    local meta_file=""

    [ -n "$issue_input" ] || die "Usage: swctl open <issue>"

    maybe_load_project_config >/dev/null 2>&1 || true
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || die "No tracked worktree found for issue '$issue_input'."
    load_instance_metadata "$meta_file"

    local url="${APP_URL:-http://$DOMAIN}"
    info "Opening $url"
    if command -v open >/dev/null 2>&1; then
        open "$url"
    elif command -v xdg-open >/dev/null 2>&1; then
        xdg-open "$url"
    else
        warn "No browser opener found. Visit: $url"
    fi
}

cmd_code() {
    local issue_input=""
    local editor=""
    local meta_file=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --claude)   editor="claude"; shift ;;
            --codex)    editor="codex"; shift ;;
            --phpstorm) editor="phpstorm"; shift ;;
            --code)     editor="vscode"; shift ;;
            --cursor)   editor="cursor"; shift ;;
            *)          issue_input="$1"; shift ;;
        esac
    done

    [ -n "$issue_input" ] || die "Usage: swctl code <issue> [--claude|--codex|--phpstorm|--code|--cursor]"

    maybe_load_project_config >/dev/null 2>&1 || true
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || die "No tracked worktree found for issue '$issue_input'."
    load_instance_metadata "$meta_file"

    case "${editor:-phpstorm}" in
        claude)
            info "Opening '$WORKTREE_PATH' in Claude."
            if [ -d "/Applications/Claude.app" ]; then
                open -a Claude "$WORKTREE_PATH"
            else
                warn "Claude desktop app not found. Use CLI: cd '$WORKTREE_PATH' && claude"
            fi
            ;;
        codex)
            info "Opening '$WORKTREE_PATH' in Codex."
            if command -v codex >/dev/null 2>&1; then
                codex app "$WORKTREE_PATH"
            else
                warn "Codex not found. Install: npm i -g @anthropic-ai/codex"
            fi
            ;;
        vscode)
            info "Opening '$WORKTREE_PATH' in VS Code."
            if command -v code >/dev/null 2>&1; then
                code "$WORKTREE_PATH"
            else
                warn "VS Code not found."
            fi
            ;;
        cursor)
            info "Opening '$WORKTREE_PATH' in Cursor."
            if command -v cursor >/dev/null 2>&1; then
                cursor "$WORKTREE_PATH"
            else
                warn "Cursor not found."
            fi
            ;;
        phpstorm|*)
            info "Opening '$WORKTREE_PATH' in PhpStorm."
            if command -v phpstorm >/dev/null 2>&1; then
                phpstorm "$WORKTREE_PATH"
            elif command -v pstorm >/dev/null 2>&1; then
                pstorm "$WORKTREE_PATH"
            elif [ -x "$HOME/Library/Application Support/JetBrains/Toolbox/scripts/phpstorm" ]; then
                "$HOME/Library/Application Support/JetBrains/Toolbox/scripts/phpstorm" "$WORKTREE_PATH"
            else
                warn "PhpStorm not found. Open manually: $WORKTREE_PATH"
            fi
            ;;
    esac
}

cmd_switch() {
    local target_mode=""
    local issue_input=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --qa)  target_mode="qa"; shift ;;
            --dev) target_mode="dev"; shift ;;
            *)     issue_input="$1"; shift ;;
        esac
    done

    [ -n "$issue_input" ] || die "Usage: swctl switch <issue> --qa|--dev"
    [ -n "$target_mode" ] || die "Usage: swctl switch <issue> --qa|--dev"

    maybe_load_project_config >/dev/null 2>&1 || true
    local meta_file
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || die "No tracked worktree found for issue '$issue_input'."
    load_instance_metadata "$meta_file"

    # Load project config from the instance's saved config path
    # (needed for SW_BIN_CONSOLE, SW_BASE_BRANCH, SW_PROJECT_NETWORK, etc.)
    load_project_config ${CONFIG_PATH:+"$CONFIG_PATH"}
    ensure_infra_ready

    local current_mode="${SWCTL_MODE:-dev}"
    if [ "$current_mode" = "$target_mode" ]; then
        info "Already in '$target_mode' mode. Nothing to do."
        return
    fi

    SWCTL_MODE="$target_mode"
    info "Switching '$ISSUE_ID' from $current_mode → $target_mode mode."

    # Re-run diff analysis for the worktree
    # For plugin-external: WORKTREE_PATH points to trunk root, use BASE_REF from metadata
    local base_ref
    base_ref="$(git_base_ref)"
    local diff_files
    diff_files="$(git -C "${WORKTREE_PATH:-$PROJECT_ROOT}" diff --name-only "${base_ref}...HEAD" 2>/dev/null || true)"
    count_changes "$diff_files"

    if [ "$target_mode" = "dev" ]; then
        # QA → Dev: QA skipped all console operations (bootstrap_dependencies,
        # theme:compile, cache:clear, frontend builds). Need a full refresh.

        # Replace vendor symlink/bind-mount with a real writable copy
        if [ -L "$WORKTREE_PATH/vendor" ] || [ ! -d "$WORKTREE_PATH/vendor/autoload.php" ]; then
            info "Copying vendor/ for writable dev mode."
            rm -f "$WORKTREE_PATH/vendor" 2>/dev/null || true
            if [ -d "$PROJECT_ROOT/vendor" ]; then
                cp -cR "$PROJECT_ROOT/vendor" "$WORKTREE_PATH/vendor" 2>/dev/null || \
                    cp -R "$PROJECT_ROOT/vendor" "$WORKTREE_PATH/vendor"
            fi
        fi

        # Recreate compose override without QA vendor bind mount
        write_compose_volume_override

        # Restart container with new volume config
        # shellcheck disable=SC2046
        compose --project-directory "$SWCTL_TMP_DIR" $(compose_file_args) --env-file "$COMPOSE_ENV_FILE" -p "$COMPOSE_PROJECT" up -d
        wait_for_app_container "$COMPOSE_PROJECT"

        # Full dev provisioning — QA skipped all of this
        bootstrap_dependencies "$COMPOSE_PROJECT"

        # Run migrations if schema changes exist
        if [ $((MIGRATION_CHANGES + ENTITY_CHANGES)) -gt 0 ]; then
            info "Schema changes detected. Running migrations."
            run_app_command "$COMPOSE_PROJECT" "$SW_BIN_CONSOLE database:migrate --all && $SW_BIN_CONSOLE database:migrate-destructive --all" || warn "Migrations failed."
        fi

        # Post-provision: theme refresh + compile + cache clear
        if [ "${STOREFRONT_CHANGES:-0}" -gt 0 ]; then
            run_app_command "$COMPOSE_PROJECT" \
                "$SW_BIN_CONSOLE theme:refresh 2>/dev/null; $SW_BIN_CONSOLE theme:compile --sync || echo '[WARN] theme:compile failed.'; $SW_BIN_CONSOLE cache:clear || echo '[WARN] cache:clear failed.'" \
                || warn "Post-provision commands failed."
        else
            run_app_command "$COMPOSE_PROJECT" "$SW_BIN_CONSOLE theme:refresh 2>/dev/null; $SW_BIN_CONSOLE cache:clear" \
                || warn "Post-provision commands failed."
        fi

        # Frontend builds that QA skipped
        run_frontend_build_if_needed "$COMPOSE_PROJECT"

        # Re-activate plugin if this is a plugin instance
        if [ -n "${PLUGIN_NAME:-}" ]; then
            activate_plugin "$COMPOSE_PROJECT" "$PLUGIN_NAME"
        fi

    else
        # Dev → QA: Dev already has everything built. Just switch to
        # read-only vendor mount and restart — no refresh needed.

        # Recreate compose override with QA vendor bind mount
        write_compose_volume_override

        # Restart container with new volume config
        # shellcheck disable=SC2046
        compose --project-directory "$SWCTL_TMP_DIR" $(compose_file_args) --env-file "$COMPOSE_ENV_FILE" -p "$COMPOSE_PROJECT" up -d
        wait_for_app_container "$COMPOSE_PROJECT"
    fi

    # Update metadata with new mode
    write_metadata "$meta_file"

    ok "Switched '$ISSUE_ID' to $target_mode mode."
    info "URL: ${APP_URL}"
}

remove_labeled_volumes() {
    local volumes
    volumes="$(docker volume ls -q --filter "label=swctl.managed=true" --filter "label=swctl.project=${PROJECT_SLUG}" --filter "label=swctl.issue=${ISSUE_ID}" || true)"
    if [ -n "$volumes" ]; then
        # shellcheck disable=SC2086
        docker volume rm $volumes >/dev/null || true
        ok "Removed worktree volumes for '${ISSUE_ID}'."
    else
        info "No labeled worktree volumes found for '${ISSUE_ID}'."
    fi
}

cmd_clean() {
    local issue_input="${1:-}"
    local force=0
    local meta_file=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --force|-f) force=1; shift ;;
            *)          issue_input="$1"; shift ;;
        esac
    done

    [ -n "$issue_input" ] || die "Usage: swctl clean [--force] <issue>"
    maybe_load_project_config >/dev/null 2>&1 || true

    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || {
        # No metadata env file — but a half-failed `swctl create` can still
        # leave an orphan branch (or unregistered worktree dir) lying around
        # that blocks the next create.  Sweep that before giving up.
        if _clean_orphan_state "$issue_input" "$force"; then
            ok "Cleaned orphan state for issue '$issue_input'."
            return 0
        fi
        warn "No tracked worktree found for issue '$issue_input'. Nothing to clean."
        return 0
    }

    load_instance_metadata "$meta_file"

    # Plugin-aware cleanup: remove nested plugin worktrees before trunk cleanup
    # In the new flow, plugin-external instances ARE trunk worktrees with a
    # nested plugin git worktree inside.  We must detach that plugin worktree
    # from its repo first, then fall through to the standard container/DB/
    # worktree cleanup.
    if [ -n "${PLUGIN_WORKTREE_PATHS:-}" ]; then
        local pw_arr
        IFS=',' read -ra pw_arr <<< "$PLUGIN_WORKTREE_PATHS"
        for pw_path in "${pw_arr[@]}"; do
            if [ -d "$pw_path" ]; then
                # Find the plugin's git repo to remove the worktree properly
                local plugin_git_dir
                plugin_git_dir="$(git -C "$pw_path" rev-parse --git-common-dir 2>/dev/null || true)"
                if [ -n "$plugin_git_dir" ]; then
                    git -C "$(dirname "$plugin_git_dir")" worktree remove --force "$pw_path" >/dev/null 2>&1 \
                        || rm -rf "$pw_path" 2>/dev/null || true
                else
                    rm -rf "$pw_path" 2>/dev/null || true
                fi
                ok "Removed plugin worktree: $pw_path"
            fi
        done
    fi

    # Standard cleanup (containers, volumes, networks, DB, worktree)

    # 1. Stop and remove ALL containers belonging to this compose project
    local containers
    containers="$(docker ps -aq --filter "label=com.docker.compose.project=${COMPOSE_PROJECT}" 2>/dev/null || true)"
    if [ -n "$containers" ]; then
        # shellcheck disable=SC2086
        docker rm -f $containers >/dev/null 2>&1 || true
        ok "Removed containers for '${COMPOSE_PROJECT}'."
    fi

    # 2. Remove ALL volumes belonging to this compose project
    local volumes
    volumes="$(docker volume ls -q --filter "label=com.docker.compose.project=${COMPOSE_PROJECT}" 2>/dev/null || true)"
    if [ -n "$volumes" ]; then
        # shellcheck disable=SC2086
        docker volume rm $volumes >/dev/null 2>&1 || true
        ok "Removed compose volumes for '${COMPOSE_PROJECT}'."
    fi

    # Also remove any swctl-labeled volumes for this issue
    remove_labeled_volumes

    # 3. Remove Docker networks created by this compose project
    local networks
    networks="$(docker network ls -q --filter "label=com.docker.compose.project=${COMPOSE_PROJECT}" 2>/dev/null || true)"
    if [ -n "$networks" ]; then
        # shellcheck disable=SC2086
        docker network rm $networks >/dev/null 2>&1 || true
        ok "Removed networks for '${COMPOSE_PROJECT}'."
    fi

    # 4. Drop the cloned database (never touches the source).
    #
    # Uses _resolve_cleanup_db_name so instances with an empty metadata
    # DB_NAME (pre-v0.5.8 resolve + setup flow) still get their DB
    # dropped by falling back to the canonical naming convention.
    # Without this fallback, `swctl clean` silently left `shopware_<N>`
    # databases behind on the mariadb server.  See
    # tests/cleanup_db_name.bats for the regression guard.
    local source_db target_db
    source_db="$(sanitize_db_identifier "${SW_DB_SHARED_NAME:-shopware}")"
    # shellcheck disable=SC2119  # zero-arg call is the public API (uses env var defaults)
    target_db="$(_resolve_cleanup_db_name || true)"
    if [ -n "$target_db" ] && [ "$target_db" != "$source_db" ]; then
        if mysql_exec "DROP DATABASE IF EXISTS \`${target_db}\`;" >/dev/null 2>&1; then
            ok "Dropped database '${target_db}'."
        else
            warn "Could not drop database '${target_db}' (mariadb unreachable?)."
        fi
    elif [ "$target_db" = "$source_db" ]; then
        warn "Refusing to drop '${target_db}' (matches shared source DB)."
    fi

    # 5. Remove the git worktree
    if [ -d "$WORKTREE_PATH" ]; then
        git -C "$PROJECT_ROOT" worktree remove --force "$WORKTREE_PATH" >/dev/null 2>&1 \
            || rm -rf "$WORKTREE_PATH" 2>/dev/null \
            || warn "Could not remove worktree '${WORKTREE_PATH}'."
        ok "Removed worktree '${WORKTREE_PATH}'."
    else
        info "Worktree path '${WORKTREE_PATH}' is already absent."
    fi
    # Prune stale worktree references so git doesn't block future creates
    git -C "$PROJECT_ROOT" worktree prune 2>/dev/null || true

    # 6. Clean up generated files in tmp
    rm -f "$SWCTL_TMP_DIR/${COMPOSE_PROJECT}.compose.env" \
          "$SWCTL_TMP_DIR/${COMPOSE_PROJECT}.volumes.override.yml" \
          2>/dev/null || true

    rm -f "$meta_file"
    ok "Cleaned issue '${ISSUE_ID}'."
}

# Forceful recovery for instances whose worktree contains root-owned files
# that `cmd_clean` can't remove (OrbStack/Docker Desktop uid-leak from
# in-container root processes).  Stops containers + volumes, then `sudo
# rm -rf`'s the worktree.  Interactive — needs the user's password.
#
# Accepts either a tracked issue id (reads metadata) or a raw issue
# number with a best-guess fallback using defaults.  Idempotent.
cmd_nuke() {
    local issue_input="${1:-}"
    [ -n "$issue_input" ] || die "Usage: swctl nuke <issue>"

    maybe_load_project_config >/dev/null 2>&1 || true

    local meta_file worktree_path compose_project
    meta_file="$(resolve_instance_file_by_issue "$issue_input" 2>/dev/null || true)"
    if [ -n "$meta_file" ] && [ -f "$meta_file" ]; then
        load_instance_metadata "$meta_file"
        worktree_path="$WORKTREE_PATH"
        compose_project="$COMPOSE_PROJECT"
    else
        # No metadata — fall back to convention.
        local issue_id="${issue_input#\#}"
        worktree_path="${SW_WORKTREE_ROOT:-$HOME/Shopware/_worktrees}/${SW_WORKTREE_PREFIX:-sw}-${issue_id}"
        compose_project="${SW_PROJECT_SLUG:-trunk}-${issue_id}"
        ISSUE_ID="$issue_id"
        warn "No tracked metadata for '$issue_input'. Using conventional paths."
    fi

    info "Nuking instance '${ISSUE_ID}':"
    info "  worktree      : $worktree_path"
    info "  compose proj  : $compose_project"

    # 1. Stop + remove containers + volumes
    info "Stopping containers + volumes…"
    local containers
    containers="$(docker ps -aq --filter "label=com.docker.compose.project=${compose_project}" 2>/dev/null || true)"
    if [ -n "$containers" ]; then
        # shellcheck disable=SC2086
        docker rm -f $containers >/dev/null 2>&1 || true
    fi
    local volumes
    volumes="$(docker volume ls -q --filter "label=com.docker.compose.project=${compose_project}" 2>/dev/null || true)"
    if [ -n "$volumes" ]; then
        # shellcheck disable=SC2086
        docker volume rm $volumes >/dev/null 2>&1 || true
    fi

    # 2. Drop cloned DB if one exists
    local source_db
    source_db="$(sanitize_db_identifier "${SW_DB_SHARED_NAME:-shopware}")"
    if [ -n "${DB_NAME:-}" ] && [ "$DB_NAME" != "$source_db" ]; then
        mysql_exec "DROP DATABASE IF EXISTS \`${DB_NAME}\`;" >/dev/null 2>&1 || true
    fi

    # 3. Remove the git worktree tree via sudo (interactive).  We try git
    # worktree remove first — it's cheap and succeeds when nothing is
    # root-owned.  Then fall back to sudo rm.
    if [ -d "$worktree_path" ]; then
        git -C "${PROJECT_ROOT:-/dev/null}" worktree remove --force "$worktree_path" >/dev/null 2>&1 || true
        if [ -d "$worktree_path" ]; then
            info "Requesting sudo to remove root-owned files in '$worktree_path'…"
            if sudo rm -rf "$worktree_path"; then
                ok "Removed '$worktree_path'."
            else
                err "sudo rm failed. Check the error above and try manually."
                return 1
            fi
        else
            ok "Removed '$worktree_path' (git worktree remove)."
        fi
    fi
    git -C "${PROJECT_ROOT:-/dev/null}" worktree prune 2>/dev/null || true

    # 4. Generated compose files + metadata
    rm -f "${SWCTL_TMP_DIR:-/tmp}/${compose_project}.compose.env" \
          "${SWCTL_TMP_DIR:-/tmp}/${compose_project}.volumes.override.yml" \
          2>/dev/null || true
    if [ -n "${meta_file:-}" ]; then
        rm -f "$meta_file" 2>/dev/null || true
    fi

    ok "Nuked issue '${ISSUE_ID}'."
    info "You can now re-create it: swctl create --qa ${ISSUE_ID} <branch>"
}

# Health probe: reports the state of every component swctl depends on
# and attempts to auto-recover a wedged Docker daemon.  Designed to be
# the first thing to run when the UI starts misbehaving.
cmd_doctor() {
    local rc=0

    # Step 8 (DNS alias collision) writes a temp file to SWCTL_TMP_DIR.
    # Ensure the dir exists even when cmd_doctor is called directly as a
    # shell function (integration tests) rather than via the dispatcher,
    # which already calls ensure_state_dirs.
    mkdir -p "$SWCTL_TMP_DIR" 2>/dev/null || true

    printf '\nswctl doctor — dependency health\n'
    printf -- '---\n'

    # 1. Docker / OrbStack.  Use a short-timeout `docker info` so we
    # don't inherit a 30 s wait when the daemon is wedged.
    if command -v docker >/dev/null 2>&1; then
        if _run_with_timeout 5 docker info >/dev/null 2>&1; then
            ok  "docker daemon       : responding"
        else
            err "docker daemon       : UNREACHABLE (EOF / timeout)"
            rc=1
            if command -v orbctl >/dev/null 2>&1; then
                local state
                state="$(_run_with_timeout 3 orbctl status 2>/dev/null | tr -d '[:space:]')"
                info "  OrbStack state: ${state:-unknown}"
                info "  Attempting recovery via ensure_docker()…"
                if ensure_docker 2>/dev/null; then
                    ok "docker daemon       : recovered"
                    rc=0
                fi
            fi
        fi
    else
        err "docker binary       : NOT FOUND"; rc=1
    fi

    # 2. OrbStack version (macOS only).
    if command -v orbctl >/dev/null 2>&1; then
        local ov
        ov="$(orb version 2>/dev/null | awk '/^Version:/ {print $2}')"
        ok  "orbstack            : version ${ov:-unknown}"
    fi

    # 3. gh CLI + swctl-maintained token.
    if command -v gh >/dev/null 2>&1; then
        ok  "gh binary           : present"
    else
        warn "gh binary           : not installed (resolve/PR flows will degrade)"
    fi
    if [ -s "${SWCTL_STATE_DIR:-${HOME}/.local/state/swctl}/github.token" ]; then
        ok  "github token        : present ($(wc -c <"${SWCTL_STATE_DIR:-${HOME}/.local/state/swctl}/github.token" | tr -d ' ') bytes)"
    else
        warn "github token        : missing — run 'swctl auth login'"
    fi

    # 4. Claude CLI.
    if command -v claude >/dev/null 2>&1; then
        ok  "claude cli          : present"
    else
        warn "claude cli          : not installed (resolve flow will not run)"
    fi

    # 5. Tracked instances + their container health.
    # Also break down by resolve backend so users can see at a glance which
    # instances are Claude-backed vs Codex-backed (v0.5.7+).
    local total=0 managed_ok=0 managed_missing=0
    local backend_claude=0 backend_codex=0 backend_unknown=0
    if [ -d "${SWCTL_REGISTRY_DIR:-${HOME}/.local/state/swctl/instances}" ]; then
        total="$(find "${SWCTL_REGISTRY_DIR:-${HOME}/.local/state/swctl/instances}" -type f -name '*.env' 2>/dev/null | wc -l | tr -d ' ')"
        local f issue
        while IFS= read -r f; do
            issue="$(basename "$f" .env)"
            # shellcheck disable=SC1090
            local proj="" cont_status
            proj="$(awk -F= '/^COMPOSE_PROJECT=/ {gsub(/[\047"]/, "", $2); print $2; exit}' "$f" 2>/dev/null)"
            # Count backend irrespective of container health — that stat is
            # about what's tracked, not what's running right now.
            local this_backend
            this_backend="$(awk -F= '/^RESOLVE_BACKEND=/ {gsub(/[\047"]/, "", $2); print $2; exit}' "$f" 2>/dev/null)"
            case "$this_backend" in
                claude|"") backend_claude=$((backend_claude + 1)) ;;
                codex)     backend_codex=$((backend_codex + 1)) ;;
                *)         backend_unknown=$((backend_unknown + 1)) ;;
            esac
            [ -n "$proj" ] || continue
            if [ "$rc" -eq 0 ]; then
                cont_status="$(docker ps -a --filter "label=com.docker.compose.project=${proj}" --format '{{.Status}}' 2>/dev/null | head -1)"
                if [ -n "$cont_status" ]; then
                    managed_ok=$((managed_ok + 1))
                else
                    managed_missing=$((managed_missing + 1))
                fi
            fi
        done < <(find "${SWCTL_REGISTRY_DIR:-${HOME}/.local/state/swctl/instances}" -type f -name '*.env' 2>/dev/null)
    fi
    printf '[INFO] tracked instances   : %s (running: %s, missing container: %s)\n' \
        "$total" "$managed_ok" "$managed_missing"
    if [ "$total" -gt 0 ]; then
        local backend_summary="claude: $backend_claude, codex: $backend_codex"
        [ "$backend_unknown" -gt 0 ] && backend_summary="$backend_summary, unknown: $backend_unknown"
        printf '[INFO] resolve backends    : %s\n' "$backend_summary"
    fi

    # 6. Plugin-external instances: every linked plugin with an admin
    # source tree MUST have a built Vite entrypoints.json, otherwise the
    # admin shell silently omits the plugin from /api/_info/config and
    # the plugin UI never renders.  This catches worktrees that reached
    # STATUS=complete with a failed `composer build:js:admin` (e.g.
    # partial node_modules sync, missing ts-node).
    if [ -d "${SWCTL_REGISTRY_DIR:-${HOME}/.local/state/swctl/instances}" ]; then
        local _doctor_issue_id _doctor_plugin_paths _doctor_pdir _doctor_ep
        while IFS= read -r f; do
            [ -n "$f" ] || continue
            # Read only the fields we need — don't mutate our own vars.
            _doctor_issue_id="$(awk -F= '/^ISSUE_ID=/ {gsub(/[\047"]/, "", $2); print $2; exit}' "$f")"
            _doctor_plugin_paths="$(awk -F= '/^PLUGIN_WORKTREE_PATHS=/ {gsub(/[\047"]/, "", $2); print $2; exit}' "$f")"
            [ -n "$_doctor_plugin_paths" ] || continue
            local _old_ifs="$IFS"; IFS=','
            for _doctor_pdir in $_doctor_plugin_paths; do
                IFS="$_old_ifs"
                [ -d "$_doctor_pdir/src/Resources/app/administration" ] || continue
                _doctor_ep="$_doctor_pdir/src/Resources/public/administration/.vite/entrypoints.json"
                if [ ! -f "$_doctor_ep" ]; then
                    warn "sw-${_doctor_issue_id}: plugin $(basename "$_doctor_pdir") has admin source but no built entrypoints.json."
                    warn "  Remedy: 'swctl refresh ${_doctor_issue_id}' (or 'swctl exec ${_doctor_issue_id} composer build:js:admin')"
                    rc=1
                fi
                IFS=','
            done
            IFS="$_old_ifs"
        done < <(find "${SWCTL_REGISTRY_DIR:-${HOME}/.local/state/swctl/instances}" -type f -name '*.env' 2>/dev/null)
    fi

    # 7. Shared docker volumes for vendor + admin/storefront node_modules.
    # vendor/ and node_modules/ are no longer rsynced into each worktree;
    # they come from docker volumes populated once per project from trunk.
    # For each tracked instance, verify its vendor + node_modules volumes
    # exist and contain a sentinel file.  Empty/missing volumes mean the
    # populate step either hasn't run yet or failed — admin/composer builds
    # will crash.
    if [ -d "${SWCTL_REGISTRY_DIR:-${HOME}/.local/state/swctl/instances}" ]; then
        local _doctor_vendor _doctor_adnm _doctor_sfnm _doctor_vol _doctor_sentinel
        while IFS= read -r f; do
            [ -n "$f" ] || continue
            _doctor_issue_id="$(awk -F= '/^ISSUE_ID=/ {gsub(/[\047"]/, "", $2); print $2; exit}' "$f")"
            _doctor_vendor="$(awk -F= '/^VENDOR_VOLUME=/ {gsub(/[\047"]/, "", $2); print $2; exit}' "$f")"
            _doctor_adnm="$(awk -F= '/^ADMIN_NM_VOLUME=/ {gsub(/[\047"]/, "", $2); print $2; exit}' "$f")"
            _doctor_sfnm="$(awk -F= '/^STOREFRONT_NM_VOLUME=/ {gsub(/[\047"]/, "", $2); print $2; exit}' "$f")"

            # vendor — sentinel: autoload.php (always present in populated vendor)
            _doctor_vol="$_doctor_vendor"; _doctor_sentinel="autoload.php"
            if [ -n "$_doctor_vol" ]; then
                if ! docker volume inspect "$_doctor_vol" >/dev/null 2>&1; then
                    warn "sw-${_doctor_issue_id}: vendor volume '$_doctor_vol' does not exist."
                    warn "  Remedy: 'swctl refresh ${_doctor_issue_id}' will re-populate."
                    rc=1
                elif ! docker run --rm -v "${_doctor_vol}:/v" alpine sh -c "test -f /v/.ready && test -f /v/${_doctor_sentinel}" 2>/dev/null; then
                    warn "sw-${_doctor_issue_id}: vendor volume '$_doctor_vol' is empty or not ready (missing .ready sentinel)."
                    warn "  Remedy: 'swctl volume refresh base' then 'swctl refresh ${_doctor_issue_id}' will re-populate."
                    rc=1
                fi
            fi

            # admin node_modules — sentinel: .package-lock.json + .ready
            _doctor_vol="$_doctor_adnm"; _doctor_sentinel=".package-lock.json"
            if [ -n "$_doctor_vol" ]; then
                if ! docker volume inspect "$_doctor_vol" >/dev/null 2>&1; then
                    warn "sw-${_doctor_issue_id}: admin node_modules volume '$_doctor_vol' does not exist."
                    warn "  Remedy: 'swctl refresh ${_doctor_issue_id}' will re-populate."
                    rc=1
                elif ! docker run --rm -v "${_doctor_vol}:/v" alpine sh -c "test -f /v/.ready && test -f /v/${_doctor_sentinel}" 2>/dev/null; then
                    warn "sw-${_doctor_issue_id}: admin node_modules volume '$_doctor_vol' is empty or not ready (missing .ready sentinel)."
                    warn "  Remedy: 'swctl volume refresh base' then 'swctl refresh ${_doctor_issue_id}' will re-populate."
                    rc=1
                fi
            fi

            # storefront node_modules — sentinel: .package-lock.json + .ready
            _doctor_vol="$_doctor_sfnm"; _doctor_sentinel=".package-lock.json"
            if [ -n "$_doctor_vol" ]; then
                if ! docker volume inspect "$_doctor_vol" >/dev/null 2>&1; then
                    warn "sw-${_doctor_issue_id}: storefront node_modules volume '$_doctor_vol' does not exist."
                    warn "  Remedy: 'swctl refresh ${_doctor_issue_id}' will re-populate."
                    rc=1
                elif ! docker run --rm -v "${_doctor_vol}:/v" alpine sh -c "test -f /v/.ready && test -f /v/${_doctor_sentinel}" 2>/dev/null; then
                    warn "sw-${_doctor_issue_id}: storefront node_modules volume '$_doctor_vol' is empty or not ready (missing .ready sentinel)."
                    warn "  Remedy: 'swctl volume refresh base' then 'swctl refresh ${_doctor_issue_id}' will re-populate."
                    rc=1
                fi
            fi
        done < <(find "${SWCTL_REGISTRY_DIR:-${HOME}/.local/state/swctl/instances}" -type f -name '*.env' 2>/dev/null)
    fi

    # 8. DNS-alias collisions on project networks.
    # Symptom: docker's embedded DNS round-robins across all containers
    # sharing an alias on a network.  If `swctl init` created
    # `swctl-mariadb` (aliased as `database` on the trunk network) AND
    # the project's own compose also starts a `database` service on the
    # same network, connections intermittently land on the wrong
    # MariaDB — resulting in 50 % of requests failing with "Unknown
    # database 'shopware_<id>'" while the other 50 % work.  Catches this
    # for every network attached to a tracked swctl instance.
    local _doctor_seen_networks=""
    if [ -d "${SWCTL_REGISTRY_DIR:-${HOME}/.local/state/swctl/instances}" ]; then
        while IFS= read -r f; do
            [ -n "$f" ] || continue
            local _compose_project
            _compose_project="$(awk -F= '/^COMPOSE_PROJECT=/ {gsub(/[\047"]/, "", $2); print $2; exit}' "$f" 2>/dev/null)"
            [ -n "$_compose_project" ] || continue
            # Pull every network the compose project is attached to
            local _nets
            # shellcheck disable=SC2016
            _nets="$(docker ps -q --filter "label=com.docker.compose.project=${_compose_project}" 2>/dev/null \
                | xargs -I{} docker inspect {} --format '{{range $net, $_ := .NetworkSettings.Networks}}{{$net}}
{{end}}' 2>/dev/null | sort -u)"
            local _net
            while IFS= read -r _net; do
                [ -n "$_net" ] || continue
                # Dedup: only check each network once
                case ",$_doctor_seen_networks," in *",$_net,"*) continue ;; esac
                _doctor_seen_networks="${_doctor_seen_networks:+${_doctor_seen_networks},}${_net}"
                # For every alias that appears on ≥ 2 containers in this network,
                # warn with the remedy.  `docker network inspect` gives us
                # a flat list of "<name>\t<aliases-comma-separated>" per
                # container.
                local _conflicts
                _conflicts="$(docker network inspect "$_net" --format '{{range .Containers}}{{.Name}}
{{end}}' 2>/dev/null)"
                # Build an aliases-by-network-member map
                local _tmp="${SWCTL_TMP_DIR:-/tmp}/doctor-aliases.$$"
                : >"$_tmp"
                local _cname
                while IFS= read -r _cname; do
                    [ -n "$_cname" ] || continue
                    docker inspect "$_cname" --format '{{with (index .NetworkSettings.Networks "'"$_net"'")}}{{range .Aliases}}{{.}} '"$_cname"'
{{end}}{{end}}' 2>/dev/null >>"$_tmp"
                done <<< "$_conflicts"
                # Find aliases that appear more than once
                local _dupes
                _dupes="$(awk '{print $1}' "$_tmp" | sort | uniq -d)"
                rm -f "$_tmp"
                local _alias
                while IFS= read -r _alias; do
                    [ -n "$_alias" ] || continue
                    # Skip the automatic container-id-shortform alias —
                    # exactly 12 chars of lowercase hex.  Earlier glob
                    # `[0-9a-f]*` incorrectly matched words like "database"
                    # (starts with 'd' ∈ hex) whose length also happened
                    # to be ≤ 12.
                    case "$_alias" in
                        [0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f])
                            continue ;;
                    esac
                    # Only warn about aliases that matter to the app boot —
                    # _is_critical_alias filters out generic shared aliases
                    # like `web`/`app` that many compose projects joining
                    # one network will always collide on (harmless —
                    # nothing inside the container looks those up via DNS).
                    _is_critical_alias "$_alias" || continue
                    local _owners
                    _owners="$(docker network inspect "$_net" --format '{{range .Containers}}{{.Name}}|{{end}}' 2>/dev/null \
                        | tr '|' '\n' | while read -r n; do
                            [ -n "$n" ] || continue
                            if docker inspect "$n" --format '{{with (index .NetworkSettings.Networks "'"$_net"'")}}{{range .Aliases}}{{.}}
{{end}}{{end}}' 2>/dev/null | grep -Fxq "$_alias"; then
                                printf '%s ' "$n"
                            fi
                        done)"
                    warn "network '$_net': alias '$_alias' is claimed by multiple containers (${_owners}) — DNS will round-robin, causing intermittent 'Unknown database' / connection errors."
                    warn "  Remedy: keep one container attached; run 'docker network disconnect $_net <stale-container>'"
                    rc=1
                done <<< "$_dupes"
            done <<< "$_nets"
        done < <(find "${SWCTL_REGISTRY_DIR:-${HOME}/.local/state/swctl/instances}" -type f -name '*.env' 2>/dev/null)
    fi

    # 9. Disk free (/ and $HOME).
    local free
    free="$(df -h "${HOME}" 2>/dev/null | awk 'NR==2 {print $4}')"
    info "disk free in HOME   : ${free:-unknown}"

    printf -- '---\n'
    if [ "$rc" -eq 0 ]; then
        ok "All core components OK."
    else
        err "One or more components failed. See notes above."
    fi
    return "$rc"
}

# Manage the shared base docker volumes (vendor, admin/storefront node_modules)
# that swctl populates once from trunk and mounts into every worktree.
# Use 'refresh' after 'composer install' or 'npm install' lands new content
# in trunk — it wipes the shared base volumes so the next create repopulates
# from the current trunk state.
cmd_volume() {
    local sub="${1:-list}"
    maybe_load_project_config >/dev/null 2>&1 || true
    local slug="${SW_PROJECT_SLUG:-trunk}"
    local bases="vendor-base-${slug} admin-nm-base-${slug} storefront-nm-base-${slug}"

    case "$sub" in
        list|'')
            printf 'Shared base volumes for project "%s":\n' "$slug"
            local v
            for v in $bases; do
                if docker volume inspect "$v" >/dev/null 2>&1; then
                    local size ready
                    size="$(docker run --rm -v "${v}:/v" alpine du -sh /v 2>/dev/null | awk '{print $1}')"
                    ready="$(docker run --rm -v "${v}:/v" alpine sh -c 'test -f /v/.ready && echo ready || echo NOT_READY' 2>/dev/null)"
                    if [ "$ready" = "ready" ]; then
                        printf '  ✓ %-40s %s\n' "$v" "${size:-?}"
                    else
                        printf '  ⚠ %-40s %s  [not ready]\n' "$v" "${size:-?}"
                    fi
                else
                    printf '  ✗ %-40s (missing — will be populated on next create)\n' "$v"
                fi
            done
            # Plugin build caches (pb-<plugin>-<head>-<lock>)
            local pb_vols
            pb_vols="$(docker volume ls -q --filter 'label=swctl.kind=plugin-build' 2>/dev/null | sort)"
            if [ -n "$pb_vols" ]; then
                printf '\nPlugin build caches:\n'
                while IFS= read -r v; do
                    [ -n "$v" ] || continue
                    local size ready
                    size="$(docker run --rm -v "${v}:/v" alpine du -sh /v 2>/dev/null | awk '{print $1}')"
                    ready="$(docker run --rm -v "${v}:/v" alpine sh -c 'test -f /v/.ready && echo ready || echo NOT_READY' 2>/dev/null)"
                    if [ "$ready" = "ready" ]; then
                        printf '  • %-50s %s\n' "$v" "${size:-?}"
                    else
                        printf '  ⚠ %-50s %s  [not ready]\n' "$v" "${size:-?}"
                    fi
                done <<< "$pb_vols"
            fi
            ;;
        refresh)
            local target="${2:-base}"
            case "$target" in
                base|'')
                    info "Dropping shared base volumes for project '${slug}'…"
                    local v
                    for v in $bases; do
                        if docker volume inspect "$v" >/dev/null 2>&1; then
                            if docker volume rm "$v" >/dev/null 2>&1; then
                                ok "Removed $v"
                            else
                                err "Failed to remove $v (is something still using it?)"
                            fi
                        else
                            info "$v not present — skipping"
                        fi
                    done
                    info "Next 'swctl create' will repopulate base volumes from trunk."
                    ;;
                plugin-build|pb)
                    info "Dropping all plugin build caches (pb-*)…"
                    local pb_vols
                    pb_vols="$(docker volume ls -q --filter 'label=swctl.kind=plugin-build' 2>/dev/null)"
                    if [ -z "$pb_vols" ]; then
                        info "No plugin build caches to remove."
                    else
                        local v
                        while IFS= read -r v; do
                            [ -n "$v" ] || continue
                            if docker volume rm "$v" >/dev/null 2>&1; then
                                ok "Removed $v"
                            else
                                err "Failed to remove $v (still in use?)"
                            fi
                        done <<< "$pb_vols"
                    fi
                    ;;
                all)
                    cmd_volume refresh base
                    cmd_volume refresh plugin-build
                    ;;
                *)
                    die "Usage: swctl volume refresh [base|plugin-build|all]"
                    ;;
            esac
            ;;
        *)
            die "Usage: swctl volume [list|refresh [base|plugin-build|all]]"
            ;;
    esac
}

count_registry_entries() {
    find "$SWCTL_REGISTRY_DIR" -type f -name '*.env' 2>/dev/null | wc -l | tr -d ' '
}

count_running_swctl_containers() {
    (docker ps -q --filter label=swctl.managed=true 2>/dev/null || true) | wc -l | tr -d ' '
}

count_unique_dbs() {
    local tmp_file="$SWCTL_TMP_DIR/dbs.$$"
    : >"$tmp_file"

    while IFS= read -r file; do
        [ -n "$file" ] || continue
        load_instance_metadata "$file"
        printf '%s\n' "$DB_NAME" >>"$tmp_file"
    done <<EOF
$(list_instance_files "all")
EOF

    if [ ! -s "$tmp_file" ]; then
        rm -f "$tmp_file"
        printf '0\n'
        return
    fi

    sort -u "$tmp_file" | wc -l | tr -d ' '
    rm -f "$tmp_file"
}

clear_screen() {
    printf '\033[2J\033[H'
}

hide_cursor() {
    # shellcheck disable=SC2015
    command -v tput >/dev/null 2>&1 && tput civis >/dev/null 2>&1 || true
}

show_cursor() {
    # shellcheck disable=SC2015
    command -v tput >/dev/null 2>&1 && tput cnorm >/dev/null 2>&1 || true
}

tui_cleanup() {
    show_cursor
    printf '%b' "$COLOR_RESET"
}

prompt_text() {
    local prompt="$1"
    local secret="${2:-0}"
    local answer=""

    if command -v gum >/dev/null 2>&1; then
        if [ "$secret" = "1" ]; then
            answer="$(gum input --password --placeholder "$prompt")"
        else
            answer="$(gum input --placeholder "$prompt")"
        fi
        printf '%s' "$answer"
        return
    fi

    if [ "$secret" = "1" ]; then
        read -r -s -p "$prompt: " answer
        printf '\n' >&2
    else
        read -r -p "$prompt: " answer
    fi
    printf '%s' "$answer"
}

select_issue_prompt() {
    local scope="${1:-all}"
    local choices_file="$SWCTL_TMP_DIR/issues.$$"
    local selected=""
    local file=""

    : >"$choices_file"
    while IFS= read -r file; do
        [ -n "$file" ] || continue
        load_instance_metadata "$file"
        printf '%s\t%s\t%s\n' "$ISSUE_ID" "$PROJECT" "$DOMAIN" >>"$choices_file"
    done <<EOF
$(list_instance_files "$scope")
EOF

    if [ ! -s "$choices_file" ]; then
        rm -f "$choices_file"
        return 1
    fi

    if command -v fzf >/dev/null 2>&1; then
        selected="$(cut -f1 "$choices_file" | fzf --prompt='Issue> ' --height=40% --reverse || true)"
    else
        printf '%s\n' "Available issues:" >&2
        cut -f1 "$choices_file" >&2
        selected="$(prompt_text "Enter issue id")"
    fi

    rm -f "$choices_file"
    [ -n "$selected" ] || return 1
    printf '%s\n' "$selected"
}

pause_for_key() {
    printf '\n'
    read -r -n 1 -p "Press any key to continue..." _
    printf '\n'
}

render_tui_header() {
    printf '%b%s%b\n' "$COLOR_BOLD" "swctl TUI Dashboard" "$COLOR_RESET"
    printf '%s\n' "Date: $(date '+%Y-%m-%d %H:%M:%S')"
    printf '%s\n' "Worktrees: $(count_registry_entries)  |  Running containers: $(count_running_swctl_containers)  |  Databases: $(count_unique_dbs)"
    printf '\n'
}

render_tui_menu() {
    printf '%s\n' "[1] Create worktree   [2] Instance detail   [3] Exec command"
    printf '%s\n' "[4] Logs (follow)     [5] Stop container    [6] Start container"
    printf '%s\n' "[7] Restart           [8] Refresh (pull)    [9] Switch mode"
    printf '%s\n' "[0] Clean worktree    [o] Open in browser   [d] Live dashboard"
    printf '%s\n' "[b] Batch create      [i] Init infra        [r] Reload"
    printf '%s\n' "[R] Resolve (Claude)  [M] Manage issue      [S] Resolve status"
    printf '%s\n' "[q] Quit"
    printf '\n'
}

tui_select_project() {
    local projects_list=""
    projects_list="$(list_projects)"
    if [ -z "$projects_list" ]; then
        warn "No projects registered. Run 'swctl project add' first."
        return 1
    fi

    local names=""
    names="$(printf '%s\n' "$projects_list" | cut -f1)"
    local count
    count="$(printf '%s\n' "$names" | wc -l | tr -d ' ')"

    if [ "$count" -eq 1 ]; then
        printf '%s' "$names"
        return
    fi

    if command -v fzf >/dev/null 2>&1; then
        printf '%s\n' "$names" | fzf --prompt='Project> ' --height=40% --reverse || return 1
    else
        printf '%s\n' "Available projects:" >&2
        local i=1
        while IFS= read -r name; do
            printf '  [%d] %s\n' "$i" "$name" >&2
            i=$((i + 1))
        done <<< "$names"
        local choice
        choice="$(prompt_text "Select project [1-$count]")"
        printf '%s\n' "$names" | sed -n "${choice}p"
    fi
}

tui_select_mode() {
    if command -v fzf >/dev/null 2>&1; then
        printf 'dev\nqa\n' | fzf --prompt='Mode> ' --height=20% --reverse || printf 'dev'
    else
        printf '%s\n' "  [1] dev  [2] qa" >&2
        local choice
        choice="$(prompt_text "Select mode [1-2]")"
        case "$choice" in
            2) printf 'qa' ;;
            *) printf 'dev' ;;
        esac
    fi
}

tui_select_branch() {
    local project_path="$1"
    local mode="$2"

    # Fetch both local and remote branches, dedup, sorted by recent commit
    local branches=""
    branches="$(git -C "$project_path" for-each-ref --sort=-committerdate \
        --format='%(refname:short)' refs/heads/ refs/remotes/origin/ --count=200 2>/dev/null \
        | sed 's|^origin/||' | grep -v '^HEAD$' | awk '!seen[$0]++' || true)"

    if command -v fzf >/dev/null 2>&1 && [ -n "$branches" ]; then
        local selected=""
        selected="$(printf '%s\n' "$branches" | fzf --prompt='Branch> ' --height=40% --reverse --print-query | tail -1 || true)"
        [ -n "$selected" ] && { printf '%s' "$selected"; return; }
    fi

    prompt_text "Branch name"
}

tui_select_plugin() {
    local project_path="$1"
    local plugins=""
    plugins="$(list_available_plugins "$project_path")"
    [ -n "$plugins" ] || return 0

    # Add "none" option at the top
    local options=""
    options="$(printf '%s\n%s' "(none - platform only)" "$plugins")"

    local selected=""
    if command -v fzf >/dev/null 2>&1; then
        selected="$(printf '%s\n' "$options" | fzf --prompt='Plugin (optional)> ' --height=40% --reverse || true)"
    else
        printf '%s\n' "Available plugins:" >&2
        printf '  [0] (none - platform only)\n' >&2
        local i=1
        while IFS= read -r name; do
            printf '  [%d] %s\n' "$i" "$name" >&2
            i=$((i + 1))
        done <<< "$plugins"
        local choice
        choice="$(prompt_text "Select plugin [0-$((i - 1))]")"
        [ "$choice" = "0" ] && return 0
        [ -n "$choice" ] && selected="$(printf '%s\n' "$plugins" | sed -n "${choice}p")"
    fi

    case "$selected" in
        "(none"*|"") return 0 ;;
        *) printf '%s' "$selected" ;;
    esac
}

tui_create_flow() {
    local issue_input=""
    local branch_input=""
    local project_input=""
    local plugin_input=""
    local mode_input=""

    # Select project (platform only)
    project_input="$(tui_select_project || true)"
    [ -n "$project_input" ] || { warn "No project selected."; return; }

    # Resolve project path
    local project_path=""
    project_path="$(list_projects | awk -F'\t' -v p="$project_input" '$1==p {print $3}')"

    # Select plugin (optional — only for platform projects)
    local project_type=""
    project_type="$(list_projects | awk -F'\t' -v p="$project_input" '$1==p {print $2}')"
    if [ "$project_type" = "platform" ]; then
        plugin_input="$(tui_select_plugin "$project_path" || true)"
    fi

    # Select mode
    mode_input="$(tui_select_mode)"

    issue_input="$(prompt_text "Issue id")"
    [ -n "$issue_input" ] || {
        warn "Issue id cannot be empty."
        return
    }

    # Branch listing: use plugin repo if a plugin was selected
    local branch_repo_path="$project_path"
    if [ -n "$plugin_input" ]; then
        branch_repo_path="$project_path/custom/plugins/$plugin_input"
    fi

    branch_input="$(tui_select_branch "$branch_repo_path" "$mode_input")"
    [ -n "$branch_input" ] || {
        warn "Branch name cannot be empty."
        return
    }

    local create_args="--$mode_input --project $project_input"
    [ -n "$plugin_input" ] && create_args="$create_args --plugin $plugin_input"
    # shellcheck disable=SC2086
    cmd_create $create_args "$issue_input" "$branch_input"
}

tui_batch_create_flow() {
    local project_input=""
    local plugin_input=""
    local mode_input=""
    # shellcheck disable=SC2034
    local issues=""
    local pairs=""
    local parallel_flag=""

    # Select project
    project_input="$(tui_select_project || true)"
    [ -n "$project_input" ] || { warn "No project selected."; return; }

    local project_path=""
    project_path="$(list_projects | awk -F'\t' -v p="$project_input" '$1==p {print $3}')"

    # Select plugin (optional — only for platform projects)
    local project_type=""
    project_type="$(list_projects | awk -F'\t' -v p="$project_input" '$1==p {print $2}')"
    if [ "$project_type" = "platform" ]; then
        plugin_input="$(tui_select_plugin "$project_path" || true)"
    fi

    # Select mode
    mode_input="$(tui_select_mode)"

    # Collect issue IDs
    info "Enter issue IDs one per line. Press Enter on an empty line to finish."
    while true; do
        local issue_line=""
        issue_line="$(prompt_text "Issue ID (empty to finish)")"
        [ -n "$issue_line" ] || break
        local branch_name=""
        if [ "$mode_input" = "dev" ]; then
            branch_name="feature/$issue_line"
        else
            branch_name="$(prompt_text "Branch for $issue_line")"
            [ -n "$branch_name" ] || { warn "Branch required in QA mode."; continue; }
        fi
        pairs="$pairs $issue_line $branch_name"
    done

    [ -n "$pairs" ] || { warn "No issues entered."; return; }

    # Ask about parallel
    local parallel_answer=""
    parallel_answer="$(prompt_text "Run in parallel? [y/N]")"
    if [[ "$parallel_answer" =~ ^[yY] ]]; then
        parallel_flag="--parallel"
    fi

    # Build and run
    local batch_args="--project $project_input --$mode_input"
    [ -n "$plugin_input" ] && batch_args="$batch_args --plugin $plugin_input"
    [ -n "$parallel_flag" ] && batch_args="$batch_args $parallel_flag"

    # shellcheck disable=SC2086
    cmd_batch_create $batch_args $pairs
}

