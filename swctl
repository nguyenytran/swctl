cmd_resolve_pr_create() {
    local issue_input="${1:-}"
    [ -n "$issue_input" ] || die "Usage: swctl resolve pr create <issue>"

    maybe_load_project_config >/dev/null 2>&1 || true
    local meta_file=""
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || die "No instance for '$issue_input'."
    load_instance_metadata "$meta_file"

    # For plugin-external instances the fix commit lives in the nested
    # plugin worktree, not the trunk worktree.  Route git operations to
    # that subdir and derive the repo + base branch from the plugin's own
    # git remote (trunk is the PLATFORM default, not the plugin's).
    local git_cwd="$WORKTREE_PATH"
    if [ "${PROJECT_TYPE:-}" = "plugin-external" ] && [ -n "${PLUGIN_NAME:-}" ]; then
        git_cwd="$WORKTREE_PATH/custom/plugins/$PLUGIN_NAME"
    fi
    [ -d "$git_cwd" ] || die "Worktree git dir not found: $git_cwd"

    # Resolve repo from `origin` remote url (ssh + https forms)
    local origin_url; origin_url="$(git -C "$git_cwd" remote get-url origin 2>/dev/null || true)"
    local target_repo="shopware/shopware"
    if [ -n "$origin_url" ]; then
        # Strip trailing `.git`, then take the last two path segments.
        local clean_url="${origin_url%.git}"
        # shellcheck disable=SC2001
        clean_url="$(printf '%s' "$clean_url" | sed 's#^git@\([^:]*\):#https://\1/#')"
        local owner_repo="${clean_url#*github.com/}"
        # owner/repo is the last two segments
        target_repo="${owner_repo#*/}"
        target_repo="${owner_repo%%/*}/${owner_repo##*/}"
    fi
    if [ "$target_repo" = "shopware/shopware" ] && [ -n "${PLUGIN_NAME:-}" ]; then
        target_repo="shopware/$PLUGIN_NAME"
    fi

    # Resolve base branch from origin/HEAD (falls back to `main` for plugins, `trunk` otherwise)
    local base_branch
    base_branch="$(git -C "$git_cwd" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##')"
    if [ -z "$base_branch" ]; then
        if [ "${PROJECT_TYPE:-}" = "plugin-external" ]; then base_branch="main"; else base_branch="trunk"; fi
    fi

    # Build the canonical PR title from the original GitHub issue:
    #   <prefix>: <issue title>     (e.g. "fix: Show configuration …")
    # Fetch title + labels from GitHub; fall back to the latest commit's
    # subject if the API isn't reachable.  The default source repo is
    # shopware/shopware — override via SWCTL_RESOLVE_ISSUE_REPO env var
    # or by seeding resolve-runs.json (the UI flow does this automatically).
    local source_repo="${SWCTL_RESOLVE_ISSUE_REPO:-shopware/shopware}"
    local issue_url="https://github.com/${source_repo}/issues/${ISSUE_ID}"
    local issue_title="" labels="" prefix="fix"
    if command -v gh >/dev/null 2>&1; then
        issue_title="$(gh api "repos/${source_repo}/issues/${ISSUE_ID}" --jq '.title' 2>/dev/null || true)"
        labels="$(gh api "repos/${source_repo}/issues/${ISSUE_ID}" --jq '.labels[].name' 2>/dev/null || true)"
    fi
    [ -n "$labels" ] && prefix="$(resolve_branch_prefix_from_labels "$labels")"

    local title
    if [ -n "$issue_title" ]; then
        title="${prefix}: ${issue_title}"
    else
        title="$(git -C "$git_cwd" log --format='%s' -1 "$BRANCH" 2>/dev/null || echo "fix: resolve issue #${ISSUE_ID}")"
    fi

    # Squash every commit on $BRANCH since the merge-base with
    # origin/$base_branch into a single commit with the canonical title.
    local merge_base
    merge_base="$(git -C "$git_cwd" merge-base HEAD "origin/$base_branch" 2>/dev/null || git -C "$git_cwd" rev-list --max-parents=0 HEAD | tail -1)"
    if [ -n "$merge_base" ]; then
        local commit_count
        commit_count="$(git -C "$git_cwd" rev-list --count "${merge_base}..HEAD" 2>/dev/null || echo 0)"
        if [ "$commit_count" -gt 1 ]; then
            info "Squashing ${commit_count} commits since ${merge_base:0:7} into one."
            git -C "$git_cwd" reset --soft "$merge_base" || die "reset --soft failed"
        fi
        # Re-commit with the canonical title (amend if we didn't reset).
        if [ "${commit_count:-0}" -gt 1 ]; then
            git -C "$git_cwd" commit --allow-empty -m "$title" >/dev/null \
                || die "commit failed after squash"
        else
            git -C "$git_cwd" commit --allow-empty --amend -m "$title" >/dev/null \
                || die "commit --amend failed"
        fi
    else
        warn "Could not resolve merge-base with origin/${base_branch}; skipping squash."
    fi

    # Force-push the rewritten branch.
    info "Pushing ${BRANCH} (force-with-lease) from $git_cwd..."
    git -C "$git_cwd" push --force-with-lease -u origin "$BRANCH" 2>&1

    info "Creating draft PR on $target_repo (base: $base_branch)..."
    # Link back to the original issue.  For plugin-external runs this
    # is typically a cross-repo reference (fix is in shopware/<plugin>
    # but the issue lives on shopware/shopware), so use the full
    # owner/repo#N form when the source differs from the target.  GitHub
    # will render the link in the issue's timeline even though cross-repo
    # auto-close is not supported.
    local link_ref
    if [ "$source_repo" = "$target_repo" ]; then
        link_ref="#${ISSUE_ID}"
    else
        link_ref="${source_repo}#${ISSUE_ID}"
    fi

    # Body precedence:
    #   1. /tmp/pr-body.md if the resolve skill's Step 7 wrote one.
    #   2. On-the-fly generation via `claude -p` (Shopware #16215 style).
    #   3. Minimal fallback: Fixes link + attribution.
    local body_file="/tmp/pr-body-${ISSUE_ID}-$$.md"
    local body_source="fallback"
    local fallback_body
    # shellcheck disable=SC2016 # backticks here are literal markdown, not command sub
    fallback_body="$(printf 'Fixes %s\n\nCreated by `swctl resolve`.\n' "$link_ref")"

    if [ -s "/tmp/pr-body.md" ]; then
        local skill_body
        skill_body="$(cat /tmp/pr-body.md)"
        if printf '%s' "$skill_body" | grep -qF "Fixes ${link_ref}"; then
            printf '%s\n' "$skill_body" > "$body_file"
            body_source="skill (/tmp/pr-body.md)"
        elif [ -n "$skill_body" ]; then
            printf '%s\n\nFixes %s\n' "$skill_body" "$link_ref" > "$body_file"
            body_source="skill + Fixes inject"
        fi
    fi

    if [ "$body_source" = "fallback" ] && command -v claude >/dev/null 2>&1; then
        local issue_body diff_ctx generated prompt
        issue_body="$(gh api "repos/${source_repo}/issues/${ISSUE_ID}" --jq '.body' 2>/dev/null || true)"
        diff_ctx="$( { git -C "$git_cwd" diff --stat "origin/${base_branch}..HEAD"; echo '---'; git -C "$git_cwd" diff "origin/${base_branch}..HEAD"; } 2>/dev/null | head -c 20000)"
        prompt="$(cat <<PROMPT
You are generating a GitHub pull-request body. Follow the EXACT structure used in Shopware core PRs (example: https://github.com/shopware/shopware/pull/16215):

## Summary
- <1-3 bullets>

Fixes ${link_ref}

## Root cause
<1 short paragraph>

## Reproduction
1. <step>

## Test plan
- [ ] <check>

## Flow Builder Impact
<"None — …" or list>

RULES:
- Respond with ONLY the markdown body. No preamble, no code fences around the output.
- Do NOT invent reproduction steps — extract them from the issue body when present.
- Keep each section terse; the whole body should fit in ~40 lines.

INPUTS:

### Issue
Title: ${issue_title:-unknown}
Body:
${issue_body:-(not available)}

### PR title
${title}

### Diff (stat + patch, truncated)
${diff_ctx:-(no diff)}
PROMPT
)"
        generated="$(printf '%s' "$prompt" | claude -p --output-format text --allowedTools "" 2>/dev/null || true)"
        if [ -n "$generated" ] && printf '%s' "$generated" | grep -qF "Fixes ${link_ref}" && printf '%s' "$generated" | grep -qE '^##[[:space:]]+' ; then
            printf '%s\n' "$generated" > "$body_file"
            body_source="generated"
        fi
    fi

    if [ ! -s "$body_file" ]; then
        printf '%s\n' "$fallback_body" > "$body_file"
    fi

    info "PR body source: ${body_source}"
    gh pr create \
        --repo "$target_repo" \
        --base "$base_branch" \
        --head "$BRANCH" \
        --title "$title" \
        --body-file "$body_file" \
        --assignee @me \
        --draft \
        2>&1

    rm -f "$body_file"

    ok "Draft PR created for #$ISSUE_ID"
}

cmd_resolve_pr_merge() {
    local issue_input="${1:-}"
    [ -n "$issue_input" ] || die "Usage: swctl resolve pr merge <issue>"

    maybe_load_project_config >/dev/null 2>&1 || true
    local meta_file=""
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || die "No instance for '$issue_input'."
    load_instance_metadata "$meta_file"

    [ -n "${BRANCH:-}" ] || die "No branch for $issue_input"

    info "Merging PR for $BRANCH..."
    gh pr merge "$BRANCH" --repo "shopware/shopware" --squash --delete-branch 2>&1
    ok "PR merged for #$ISSUE_ID"
}

cmd_resolve_pr_approve() {
    local issue_input="${1:-}"
    [ -n "$issue_input" ] || die "Usage: swctl resolve pr approve <issue>"

    maybe_load_project_config >/dev/null 2>&1 || true
    local meta_file=""
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || die "No instance for '$issue_input'."
    load_instance_metadata "$meta_file"

    [ -n "${BRANCH:-}" ] || die "No branch for $issue_input"

    info "Approving PR for $BRANCH..."
    gh pr review "$BRANCH" --repo "shopware/shopware" --approve 2>&1
    ok "PR approved for #$ISSUE_ID"
}

# ── Resolve TUI management dashboard ────────────────────────────────────────

tui_resolve_manage_flow() {
    local scope="all"
    maybe_load_project_config >/dev/null 2>&1 && scope="project"

    local issue_input=""
    issue_input="$(select_issue_prompt "$scope" || true)"
    [ -n "$issue_input" ] || { warn "No issue selected."; return; }

    printf '\n'
    printf '  Actions for #%s:\n' "$issue_input"
    printf '  [d] View diff          [a] Ask Claude\n'
    printf '  [c] Chat (interactive) [s] Resolve status\n'
    printf '  [p] Push branch        [r] Create PR\n'
    printf '  [v] View PR            [m] Merge PR\n'
    printf '  [A] Approve PR         [q] Back\n'
    printf '\n  Choice: '

    local action=""
    read -r -n 1 action
    printf '\n'

    case "$action" in
        d) cmd_resolve_diff "$issue_input" ;;
        a)
            local msg=""
            msg="$(prompt_text "Ask Claude about this issue")"
            [ -n "$msg" ] && cmd_resolve_ask "$issue_input" "$msg"
            ;;
        c) cmd_resolve_chat "$issue_input" ;;
        s) render_resolve_status ;;
        p) cmd_resolve_pr_push "$issue_input" ;;
        r) cmd_resolve_pr_create "$issue_input" ;;
        v) cmd_resolve_pr_view "$issue_input" ;;
        m) cmd_resolve_pr_merge "$issue_input" ;;
        A) cmd_resolve_pr_approve "$issue_input" ;;
        q|*) return ;;
    esac
}

# ── End Claude Code resolve integration ──────────────────────────────────────

main() {
    local command="${1:-help}"

    case "$command" in
        init)
            ensure_state_dirs
            init_infra
            ;;
        create)
            ensure_state_dirs
            shift
            cmd_create "$@"
            ;;
        batch)
            ensure_state_dirs
            shift
            cmd_batch "$@"
            ;;
        status)
            ensure_state_dirs
            cmd_status
            ;;
        exec)
            ensure_state_dirs
            shift
            cmd_exec "${1:-}" "${2:-}"
            ;;
        clean)
            ensure_state_dirs
            shift
            cmd_clean "$@"
            ;;
        nuke)
            ensure_state_dirs
            shift
            cmd_nuke "${1:-}"
            ;;
        doctor|health)
            ensure_state_dirs
            cmd_doctor
            ;;
        volume)
            ensure_state_dirs
            shift
            cmd_volume "${1:-}"
            ;;
        logs)
            ensure_state_dirs
            shift
            cmd_logs "${1:-}" "${2:-}"
            ;;
        restart)
            ensure_state_dirs
            shift
            cmd_restart "${1:-}"
            ;;
        stop)
            ensure_state_dirs
            shift
            cmd_stop "${1:-}"
            ;;
        start)
            ensure_state_dirs
            shift
            cmd_start "${1:-}"
            ;;
        kill-exec)
            ensure_state_dirs
            shift
            cmd_kill_exec "${1:-}"
            ;;
        refresh)
            ensure_state_dirs
            shift
            cmd_refresh "${1:-}"
            ;;
        open)
            ensure_state_dirs
            shift
            cmd_open "${1:-}"
            ;;
        checkout)
            ensure_state_dirs
            shift
            cmd_checkout "${1:-}"
            ;;
        code)
            ensure_state_dirs
            shift
            cmd_code "$@"
            ;;
        resolve)
            # Gated feature — hidden by default.  Enable either of:
            #   - SWCTL_RESOLVE_ENABLED=1 env var
            #   - `features.resolveEnabled = true` in ~/.swctl/config.json
            #     (flip it via the UI /#/config page or `swctl config set
            #     features.resolveEnabled true`)
            if [ "${SWCTL_RESOLVE_ENABLED:-0}" != "1" ] \
               && [ "$(_user_config_read '.features.resolveEnabled' 2>/dev/null)" != "true" ]; then
                die "'resolve' is not enabled. Enable it via: swctl config set features.resolveEnabled true  (or SWCTL_RESOLVE_ENABLED=1)"
            fi
            ensure_state_dirs
            shift
            case "${1:-}" in
                resume) shift; cmd_resolve_resume "$@" ;;
                status) render_resolve_status ;;
                diff)   shift; cmd_resolve_diff "$@" ;;
                ask)    shift; cmd_resolve_ask "$@" ;;
                chat)   shift; cmd_resolve_chat "$@" ;;
                pr)     shift; cmd_resolve_pr "$@" ;;
                manage) shift; tui_resolve_manage_flow ;;
                *)      cmd_resolve "$@" ;;
            esac
            ;;
        switch)
            ensure_state_dirs
            shift
            cmd_switch "$@"
            ;;
        tui)
            ensure_state_dirs
            cmd_tui
            ;;
        dashboard)
            ensure_state_dirs
            cmd_dashboard
            ;;
        auth)
            ensure_state_dirs
            shift
            cmd_auth "${1:-status}"
            ;;
        ui)
            ensure_state_dirs
            shift
            cmd_ui "${1:-start}"
            ;;
        skill)
            shift
            cmd_skill "$@"
            ;;
        mcp)
            shift
            cmd_mcp "$@"
            ;;
        config)
            shift
            cmd_config "$@"
            ;;
        build-base)
            ensure_state_dirs
            cmd_build_base
            ;;
        build-shared-db)
            ensure_state_dirs
            shift
            cmd_build_shared_db "$@"
            ;;
        clean-base)
            ensure_state_dirs
            cmd_clean_base
            ;;
        project)
            ensure_state_dirs
            shift
            cmd_project "$@"
            ;;
        --version|-v)
            cmd_version
            ;;
        help|-h|--help)
            show_help
            ;;
        *)
            die "Unknown command: $command"
            ;;
    esac
}

if [ "${SWCTL_SOURCED:-0}" != "1" ]; then
    main "$@"
fi
