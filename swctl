cmd_ui() {
    local action="${1:-start}"
    local ui_compose="$SWCTL_TEMPLATE_DIR/app/docker-compose.ui.yml"
    [ -f "$ui_compose" ] || die "UI compose file not found: $ui_compose"

    # Try loading config from current dir, or fall back to first registered platform project.
    # If neither exists (fresh install), use minimal defaults so the UI can start
    # and let the user add projects from the dashboard.
    if ! maybe_load_project_config >/dev/null 2>&1; then
        ensure_projects_file
        local platform_entry
        platform_entry="$(grep -E $'\tplatform\t' "$SWCTL_PROJECTS_FILE" | head -1)" || true
        if [ -n "$platform_entry" ]; then
            local platform_path
            platform_path="$(printf '%s' "$platform_entry" | cut -f3)"
            load_project_config "$platform_path/.swctl.conf"
        else
            # Fresh install — no projects yet. Set minimal defaults.
            PROJECT_ROOT="${HOME}"
            SW_WORKTREE_ROOT="${HOME}"
            SW_RUNTIME="$(detect_runtime)"
            info "No projects registered yet. The UI will start with an empty dashboard."
        fi
    fi

    export SWCTL_SCRIPT_DIR="$SWCTL_TEMPLATE_DIR"
    export SWCTL_PROJECT_ROOT="$PROJECT_ROOT"
    export SWCTL_WORKTREE_ROOT="$SW_WORKTREE_ROOT"
    export SWCTL_STATE_DIR="$SWCTL_STATE_DIR"
    export SW_RUNTIME="${SW_RUNTIME:-$(detect_runtime)}"
    export SWCTL_EDITOR="${SWCTL_EDITOR:-phpstorm}"
    export SWCTL_BROWSE_ROOT="${SWCTL_BROWSE_ROOT:-$HOME}"
    export SWCTL_GITHUB_CLIENT_ID="${SWCTL_GITHUB_CLIENT_ID:-}"
    # SWCTL_PLUGINS_DIR accepts a colon-separated list (PATH convention).
    # Default: user plugins first (so local copies can override), then the
    # repo's bundled examples (discovered automatically when running from
    # source — $SWCTL_SCRIPT_DIR points at the repo root).
    local default_user_plugins="$HOME/.swctl/plugins"
    local default_bundled_plugins="$SWCTL_SCRIPT_DIR/examples/plugins"
    if [ -d "$default_bundled_plugins" ]; then
        export SWCTL_PLUGINS_DIR="${SWCTL_PLUGINS_DIR:-$default_user_plugins:$default_bundled_plugins}"
    else
        export SWCTL_PLUGINS_DIR="${SWCTL_PLUGINS_DIR:-$default_user_plugins}"
    fi
    # Only the user plugin dir is auto-created; the bundled one either exists
    # in the repo or not. Strip multi-path before mkdir'ing.
    mkdir -p "${SWCTL_PLUGINS_DIR%%:*}" 2>/dev/null || true
    # Propagate HOME so docker-compose can set it inside the container.  The
    # UI's shopware-resolve plugin needs Claude Code's auth which lives in
    # $HOME/.claude/ on the host.  $HOME is already covered by the BROWSE_ROOT
    # bind mount above, so no new volume is needed.
    export HOME="${HOME}"

    case "$action" in
        start)
            # The UI container bind-mounts ./dist into /app/dist (see
            # docker-compose.ui.yml), so the served frontend is whatever
            # the host dist/ contains — NOT what the Docker build stage
            # produced. Run the host-side Vite build first so source edits
            # actually land in the running UI. npm install is idempotent
            # and only runs if node_modules is missing.
            local ui_app_dir="$SWCTL_TEMPLATE_DIR/app"
            if [ -d "$ui_app_dir" ] && [ -f "$ui_app_dir/package.json" ]; then
                (
                    cd "$ui_app_dir" || exit 0
                    if [ ! -d node_modules ]; then
                        info "swctl ui: installing UI dependencies (first run)"
                        npm install --no-audit --no-fund >/dev/null 2>&1 || {
                            warn "swctl ui: npm install failed — falling back to image-built dist/"
                            exit 0
                        }
                    fi
                    info "swctl ui: building frontend"
                    npm run build >/dev/null 2>&1 || {
                        warn "swctl ui: npm run build failed — falling back to image-built dist/"
                    }
                )
            fi
            compose --project-directory "$SWCTL_TEMPLATE_DIR/app" -f "$ui_compose" -p swctl-ui up -d --build
            ok "swctl UI running at http://swctl.orb.local"
            ;;
        stop)
            compose --project-directory "$SWCTL_TEMPLATE_DIR/app" -f "$ui_compose" -p swctl-ui down
            ok "swctl UI stopped."
            ;;
        logs)
            compose --project-directory "$SWCTL_TEMPLATE_DIR/app" -f "$ui_compose" -p swctl-ui logs -f
            ;;
        *)
            die "Usage: swctl ui [start|stop|logs]"
            ;;
    esac
}

cmd_version() {
    printf 'swctl %s\n' "$SWCTL_VERSION"
}

# ── Claude Code skill + MCP install helpers ──────────────────────────────────
#
# Expose swctl's bundled `shopware-resolve` skill and its `swctl` MCP
# server to the user's host Claude Code installation.  Both commands
# are idempotent, print what they did, and support a `--repo` /
# `--project` flag to target the current project's `.claude/` /
# `.mcp.json` instead of `$HOME`.

# Locate the bundled skill source (pkgshare via brew, repo root via dev)
skill_bundle_path() {
    local dir="${SWCTL_SCRIPT_DIR:-$(dirname "$(readlink -f "$0" 2>/dev/null || printf '%s' "$0")")}"
    printf '%s/skills/shopware-resolve' "$dir"
}

# Locate the MCP server entry that should be wired up
mcp_bundle_path() {
    local dir="${SWCTL_SCRIPT_DIR:-$(dirname "$(readlink -f "$0" 2>/dev/null || printf '%s' "$0")")}"
    printf '%s/app/mcp/index.ts' "$dir"
}

# _ai_targets_for_install <requested> [scope]
#
# Expands a --target value ("claude", "codex", "all") into a newline-separated
# list of backends to install into.
#
#   requested="all"    → every detected backend (config dir exists) for user
#                        scope; defaults to ["claude"] for repo scope (repo
#                        scope doesn't need on-disk detection).
#   requested=""       → same default behaviour.
#   requested="claude" → just claude
#   requested="codex"  → just codex
#
# Callers must fail if the result is empty and the user asked for "all".
_ai_targets_for_install() {
    local requested="${1:-}"
    local scope="${2:-user}"

    case "$requested" in
        claude|codex)
            printf '%s\n' "$requested"
            return 0
            ;;
        ""|all)
            ;;
        *)
            return 1
            ;;
    esac

    # Repo scope: we're writing into $(pwd)/.claude or $(pwd)/.codex — no
    # host-level "detect config dir" makes sense.  Default to claude when
    # unspecified; user must opt in to codex explicitly.
    if [ "$scope" = "repo" ]; then
        printf 'claude\n'
        return 0
    fi

    # User scope, requested=all|"" → enumerate every backend whose host config
    # dir exists.  No silent fallbacks: if nothing is detected, caller fails.
    local found=0 backend
    for backend in claude codex; do
        local cfg
        cfg="$(_ai_backend_config_dir "$backend")"
        if [ -d "$cfg" ]; then
            printf '%s\n' "$backend"
            found=1
        fi
    done
    [ "$found" -eq 1 ] || return 2
}

# _ai_skill_dst <backend> <scope>
#
# Returns the install destination per (backend, scope).  The two
# backends use VERY different mechanisms:
#
#   claude → symlinked SKILL.md directory under <config>/skills/.
#            Claude Code auto-discovers anything in there and exposes
#            it as a `/shopware-resolve` slash command.
#
#   codex  → injected into <config>/AGENTS.md.  Codex doesn't have a
#            slash-command skill registry; it reads AGENTS.md as
#            ambient project / global instructions.  swctl wraps the
#            bundled SKILL.md in marker comments so reinstall is
#            idempotent and uninstall can strip cleanly.
#
# The path returned reflects WHERE we install (not WHAT shape it has):
#   - claude/user → ~/.claude/skills/shopware-resolve  (symlink)
#   - claude/repo → $(pwd)/.claude/skills/shopware-resolve
#   - codex/user  → ~/.codex/AGENTS.md                 (file with block)
#   - codex/repo  → $(pwd)/AGENTS.md                   (file with block)
_ai_skill_dst() {
    local backend="$1" scope="$2"
    case "$backend" in
        claude)
            case "$scope" in
                user)
                    local cfg
                    cfg="$(_ai_backend_config_dir "$backend")" || return 1
                    printf '%s/skills/shopware-resolve' "$cfg"
                    ;;
                repo)
                    printf '%s/.claude/skills/shopware-resolve' "$(pwd)"
                    ;;
                *) return 1 ;;
            esac
            ;;
        codex)
            case "$scope" in
                user)
                    local cfg
                    cfg="$(_ai_backend_config_dir "$backend")" || return 1
                    printf '%s/AGENTS.md' "$cfg"
                    ;;
                repo)
                    # Per-project AGENTS.md is what Codex picks up
                    # automatically when run with --cd <project>.
                    printf '%s/AGENTS.md' "$(pwd)"
                    ;;
                *) return 1 ;;
            esac
            ;;
        *) return 1 ;;
    esac
}

# Marker tags used to bracket swctl-managed content inside a Codex
# AGENTS.md.  Reinstall replaces whatever is between the tags;
# uninstall removes the tags + the content + ONE adjacent blank line
# (so files don't accumulate empty lines on re-install/uninstall).
_swctl_codex_skill_begin() { printf '<!-- swctl:shopware-resolve:begin -->'; }
_swctl_codex_skill_end()   { printf '<!-- swctl:shopware-resolve:end -->'; }

# Splice (or replace) the bundled SKILL.md content into the given
# AGENTS.md, between marker comments.  Atomic via tmp + rename so a
# concurrent reader never sees a half-written file.  If the file
# doesn't exist, creates it with just the marker block.
_codex_skill_install_block() {
    local dst="$1" src_md="$2"

    [ -f "$src_md" ] || die "Bundled skill SKILL.md not found at $src_md"
    mkdir -p "$(dirname "$dst")"

    local begin end
    begin="$(_swctl_codex_skill_begin)"
    end="$(_swctl_codex_skill_end)"

    # Build the new content: (existing-with-block-stripped) + block.
    local existing=""
    [ -f "$dst" ] && existing="$(_codex_skill_strip_block "$dst")"

    # Ensure exactly one blank line between any prior content and our block.
    local sep=""
    if [ -n "$existing" ]; then
        # Trim trailing whitespace/newlines, then re-append exactly one blank line.
        existing="$(printf '%s' "$existing" | awk '{print}' | sed -e :a -e '/^[[:space:]]*$/{$d;N;ba' -e '}')"
        sep=$'\n\n'
    fi

    local block_body
    block_body="$(cat "$src_md")"

    local tmp
    tmp="$(mktemp)"
    {
        if [ -n "$existing" ]; then printf '%s%s' "$existing" "$sep"; fi
        printf '%s\n' "$begin"
        printf '<!-- managed by swctl — do not edit between these markers; '
        # shellcheck disable=SC2016  # backticks are part of the literal markdown emitted to AGENTS.md
        printf 're-run `swctl skill install --target codex` to update -->\n'
        printf '%s\n' "$block_body"
        printf '%s\n' "$end"
    } > "$tmp"

    mv "$tmp" "$dst"
}

# Strip the swctl-managed block + its surrounding markers from
# AGENTS.md.  Prints the resulting content.  Uses awk for portability
# (BSD sed's lookbehind support is spotty across macOS / Linux).
_codex_skill_strip_block() {
    local file="$1"
    [ -f "$file" ] || { printf ''; return 0; }

    awk '
        /<!-- swctl:shopware-resolve:begin -->/ { inblock = 1; next }
        /<!-- swctl:shopware-resolve:end -->/   { inblock = 0; next }
        !inblock { print }
    ' "$file"
}

# Idempotent uninstall: removes the marker block, atomic write.
# If after stripping the file is just whitespace, deletes the file
# entirely (don't leave behind empty AGENTS.md the user didn't create).
_codex_skill_uninstall_block() {
    local dst="$1" stripped

    if [ ! -f "$dst" ]; then
        return 1   # nothing to do — caller distinguishes "no-op"
    fi

    if ! grep -q "$(_swctl_codex_skill_begin)" "$dst" 2>/dev/null; then
        return 1   # marker not present — caller treats as not-installed
    fi

    stripped="$(_codex_skill_strip_block "$dst")"
    # Trim trailing blank lines for cleanliness.
    stripped="$(printf '%s' "$stripped" | sed -e :a -e '/^[[:space:]]*$/{$d;N;ba' -e '}')"

    if [ -z "$stripped" ]; then
        # File is now empty — nothing else lived there, delete.
        rm -f "$dst"
        return 0
    fi

    local tmp
    tmp="$(mktemp)"
    printf '%s\n' "$stripped" > "$tmp"
    mv "$tmp" "$dst"
    return 0
}

# Returns 0 if the swctl-managed block is present in $1.
_codex_skill_block_present() {
    local file="$1"
    [ -f "$file" ] || return 1
    grep -q "$(_swctl_codex_skill_begin)" "$file"
}

cmd_skill_install() {
    local scope="user" target=""
    while [ $# -gt 0 ]; do
        case "${1:-}" in
            --user)    scope="user"; shift ;;
            --repo|--project) scope="repo"; shift ;;
            --target)  shift; target="${1:?Missing --target value}"; shift ;;
            --target=*) target="${1#--target=}"; shift ;;
            *) die "Unknown argument: $1" ;;
        esac
    done

    local src
    src="$(skill_bundle_path)"
    [ -d "$src" ] || die "Bundled skill not found at $src. Reinstall swctl."

    local targets rc=0
    targets="$(_ai_targets_for_install "$target" "$scope")" || rc=$?
    case "$rc" in
        0) ;;
        1) die "Unknown --target value '$target'. Use claude, codex, or all." ;;
        2) die "No AI backend config dirs detected (checked ~/.claude, ~/.codex). Use --target claude or install the backend first." ;;
    esac

    local backend
    while IFS= read -r backend; do
        [ -n "$backend" ] || continue
        local dst
        dst="$(_ai_skill_dst "$backend" "$scope")" || die "Cannot compute dest for backend '$backend'."

        case "$backend" in
            claude)
                # Symlink-based install — Claude Code auto-discovers
                # SKILL.md in this directory and registers the
                # /shopware-resolve slash command.
                mkdir -p "$(dirname "$dst")"
                if [ -L "$dst" ]; then
                    local current
                    current="$(readlink "$dst" 2>/dev/null || true)"
                    if [ "$current" = "$src" ]; then
                        ok "[claude] shopware-resolve skill already linked at $dst"
                        continue
                    fi
                    warn "[claude] Replacing existing symlink ($current → $src)"
                    ln -sfn "$src" "$dst"
                elif [ -e "$dst" ]; then
                    die "[claude] $dst already exists as a file/dir (not a symlink). Move it aside or run 'swctl skill uninstall' first."
                else
                    ln -sfn "$src" "$dst"
                fi
                ok "[claude] Linked shopware-resolve skill → $dst"
                ;;
            codex)
                # Block-injection install — Codex reads AGENTS.md as
                # ambient context (no skill registry).  Splice the
                # bundled SKILL.md between marker comments so the file
                # remains user-editable elsewhere and reinstalls are
                # idempotent.
                _codex_skill_install_block "$dst" "$src/SKILL.md"
                ok "[codex] Wrote shopware-resolve block → $dst"
                ;;
        esac
    done <<< "$targets"

    info "Run 'claude /shopware-resolve' (or invoke 'codex' on a worktree where AGENTS.md was installed) to use the skill."
}

cmd_skill_uninstall() {
    local scope="user" target=""
    while [ $# -gt 0 ]; do
        case "${1:-}" in
            --user)    scope="user"; shift ;;
            --repo|--project) scope="repo"; shift ;;
            --target)  shift; target="${1:?Missing --target value}"; shift ;;
            --target=*) target="${1#--target=}"; shift ;;
            *) die "Unknown argument: $1" ;;
        esac
    done

    local targets rc=0
    # For uninstall, empty target defaults to claude (back-compat).  "all" is
    # supported via explicit --target all.
    if [ -z "$target" ]; then
        targets="claude"
    else
        targets="$(_ai_targets_for_install "$target" "$scope")" || rc=$?
        case "$rc" in
            0) ;;
            1) die "Unknown --target value '$target'. Use claude, codex, or all." ;;
            2) warn "No AI backend config dirs detected; nothing to uninstall."; return 0 ;;
        esac
    fi

    local backend
    while IFS= read -r backend; do
        [ -n "$backend" ] || continue
        local dst
        dst="$(_ai_skill_dst "$backend" "$scope")" || die "Cannot compute dest for backend '$backend'."

        case "$backend" in
            claude)
                if [ -L "$dst" ]; then
                    rm -f "$dst"
                    ok "[claude] Removed shopware-resolve skill symlink: $dst"
                elif [ -e "$dst" ]; then
                    warn "[claude] $dst is not a symlink — refusing to delete (user-owned content)."
                else
                    info "[claude] No shopware-resolve skill linked at $dst"
                fi
                ;;
            codex)
                if _codex_skill_uninstall_block "$dst"; then
                    ok "[codex] Stripped shopware-resolve block from $dst"
                else
                    info "[codex] No shopware-resolve block in $dst"
                fi
                ;;
        esac
    done <<< "$targets"
}

cmd_skill_status() {
    local src
    src="$(skill_bundle_path)"

    printf '%bBundled source:%b %s\n' "${COLOR_BOLD:-}" "${COLOR_RESET:-}" "$src"
    if [ -d "$src" ]; then
        ok "  present"
    else
        warn "  MISSING — reinstall swctl"
    fi

    # Claude — symlink-based discovery
    local user_dst repo_dst
    user_dst="$(_ai_skill_dst "claude" "user")"
    repo_dst="$(_ai_skill_dst "claude" "repo")"
    printf '\n%b[claude] user-level link (%s):%b\n' "${COLOR_BOLD:-}" "$user_dst" "${COLOR_RESET:-}"
    if [ -L "$user_dst" ]; then
        ok "  → $(readlink "$user_dst")"
    elif [ -e "$user_dst" ]; then
        warn "  present but not a symlink (user-installed content)"
    else
        info "  not linked (run 'swctl skill install --user --target claude')"
    fi
    printf '%b[claude] repo-level link (%s):%b\n' "${COLOR_BOLD:-}" "$repo_dst" "${COLOR_RESET:-}"
    if [ -L "$repo_dst" ]; then
        ok "  → $(readlink "$repo_dst")"
    elif [ -e "$repo_dst" ]; then
        warn "  present but not a symlink"
    else
        info "  not linked"
    fi

    # Codex — block-in-AGENTS.md
    user_dst="$(_ai_skill_dst "codex" "user")"
    repo_dst="$(_ai_skill_dst "codex" "repo")"
    printf '\n%b[codex] user-level block (%s):%b\n' "${COLOR_BOLD:-}" "$user_dst" "${COLOR_RESET:-}"
    if _codex_skill_block_present "$user_dst"; then
        ok "  installed (swctl-managed block present)"
    elif [ -f "$user_dst" ]; then
        info "  AGENTS.md exists but no swctl block (run 'swctl skill install --user --target codex')"
    else
        info "  not installed (run 'swctl skill install --user --target codex')"
    fi
    printf '%b[codex] repo-level block (%s):%b\n' "${COLOR_BOLD:-}" "$repo_dst" "${COLOR_RESET:-}"
    if _codex_skill_block_present "$repo_dst"; then
        ok "  installed"
    elif [ -f "$repo_dst" ]; then
        info "  AGENTS.md exists but no swctl block"
    else
        info "  not installed"
    fi
}

cmd_skill() {
    local sub="${1:-}"
    [ -n "$sub" ] || die "Usage: swctl skill [install|uninstall|status] [--user|--repo]"
    shift
    case "$sub" in
        install)   cmd_skill_install "$@" ;;
        uninstall) cmd_skill_uninstall "$@" ;;
        status)    cmd_skill_status "$@" ;;
        *) die "Unknown skill subcommand: $sub" ;;
    esac
}

# _ai_mcp_settings <backend> <scope>
#
# Prints the path to the settings JSON file for the given backend/scope
# pair.  Repo scope uses a single flat `.mcp.json` regardless of backend
# (Claude Code's convention; Codex respects the same project-local file).
_ai_mcp_settings() {
    local backend="$1" scope="$2"
    case "$scope" in
        user)
            local cfg
            cfg="$(_ai_backend_config_dir "$backend")" || return 1
            printf '%s/settings.json' "$cfg"
            ;;
        repo)
            printf '%s/.mcp.json' "$(pwd)"
            ;;
        *) return 1 ;;
    esac
}

cmd_mcp_install() {
    local scope="user" target=""
    while [ $# -gt 0 ]; do
        case "${1:-}" in
            --user)    scope="user"; shift ;;
            --repo|--project) scope="repo"; shift ;;
            --target)  shift; target="${1:?Missing --target value}"; shift ;;
            --target=*) target="${1#--target=}"; shift ;;
            *) die "Unknown argument: $1" ;;
        esac
    done

    command -v jq >/dev/null 2>&1 || die "'jq' is required for MCP install. brew install jq."

    local src
    src="$(mcp_bundle_path)"
    [ -f "$src" ] || die "Bundled MCP server not found at $src. Reinstall swctl."

    # Repo scope writes a single .mcp.json regardless of backend; collapse to
    # claude so we only write it once.
    local targets rc=0
    if [ "$scope" = "repo" ]; then
        targets="claude"
    else
        targets="$(_ai_targets_for_install "$target" "$scope")" || rc=$?
        case "$rc" in
            0) ;;
            1) die "Unknown --target value '$target'. Use claude, codex, or all." ;;
            2) die "No AI backend config dirs detected (checked ~/.claude, ~/.codex). Use --target claude or install the backend first." ;;
        esac
    fi

    local desired
    desired="$(jq -n --arg cmd "npx" --arg tsx "tsx" --arg p "$src" \
        '{command: $cmd, args: [$tsx, $p]}')"

    local backend
    while IFS= read -r backend; do
        [ -n "$backend" ] || continue
        local target_file
        target_file="$(_ai_mcp_settings "$backend" "$scope")" || die "Cannot compute settings path for '$backend'."
        mkdir -p "$(dirname "$target_file")"
        [ -s "$target_file" ] || printf '{}\n' > "$target_file"

        local tmp; tmp="$(mktemp)"
        jq --argjson swctl "$desired" \
            '.mcpServers = (.mcpServers // {}) | .mcpServers.swctl = $swctl' \
            "$target_file" > "$tmp" && mv "$tmp" "$target_file"

        ok "[$backend] Wired swctl MCP entry into $target_file"
    done <<< "$targets"

    info "Command: npx tsx $src"
}

cmd_mcp_uninstall() {
    local scope="user" target=""
    while [ $# -gt 0 ]; do
        case "${1:-}" in
            --user)    scope="user"; shift ;;
            --repo|--project) scope="repo"; shift ;;
            --target)  shift; target="${1:?Missing --target value}"; shift ;;
            --target=*) target="${1#--target=}"; shift ;;
            *) die "Unknown argument: $1" ;;
        esac
    done

    command -v jq >/dev/null 2>&1 || die "'jq' is required."

    local targets rc=0
    if [ "$scope" = "repo" ]; then
        targets="claude"
    elif [ -z "$target" ]; then
        targets="claude"
    else
        targets="$(_ai_targets_for_install "$target" "$scope")" || rc=$?
        case "$rc" in
            0) ;;
            1) die "Unknown --target value '$target'. Use claude, codex, or all." ;;
            2) warn "No AI backend config dirs detected; nothing to uninstall."; return 0 ;;
        esac
    fi

    local backend
    while IFS= read -r backend; do
        [ -n "$backend" ] || continue
        local target_file
        target_file="$(_ai_mcp_settings "$backend" "$scope")" || continue
        if [ ! -s "$target_file" ]; then
            info "[$backend] No $target_file to edit."
            continue
        fi

        local tmp; tmp="$(mktemp)"
        jq 'if .mcpServers.swctl then .mcpServers |= del(.swctl) else . end' \
            "$target_file" > "$tmp" && mv "$tmp" "$target_file"
        ok "[$backend] Removed swctl MCP entry from $target_file"
    done <<< "$targets"
}

cmd_mcp_status() {
    local src
    src="$(mcp_bundle_path)"

    printf '%bBundled MCP source:%b %s\n' "${COLOR_BOLD:-}" "${COLOR_RESET:-}" "$src"
    if [ -f "$src" ]; then
        ok "  present"
    else
        warn "  MISSING — reinstall swctl"
    fi

    local backend
    for backend in claude codex; do
        local user_target
        user_target="$(_ai_mcp_settings "$backend" "user")"
        printf '\n%b[%s] %s:%b\n' "${COLOR_BOLD:-}" "$backend" "$user_target" "${COLOR_RESET:-}"
        if [ -s "$user_target" ] && command -v jq >/dev/null 2>&1; then
            local entry
            entry="$(jq -c '.mcpServers.swctl // null' "$user_target" 2>/dev/null || echo null)"
            if [ "$entry" != "null" ]; then
                ok "  $entry"
            else
                info "  no swctl MCP entry"
            fi
        else
            info "  (not present)"
        fi
    done

    local repo_target; repo_target="$(pwd)/.mcp.json"
    printf '\n%b[repo] %s:%b\n' "${COLOR_BOLD:-}" "$repo_target" "${COLOR_RESET:-}"
    if [ -s "$repo_target" ] && command -v jq >/dev/null 2>&1; then
        local entry
        entry="$(jq -c '.mcpServers.swctl // null' "$repo_target" 2>/dev/null || echo null)"
        if [ "$entry" != "null" ]; then
            ok "  $entry"
        else
            info "  no swctl MCP entry"
        fi
    else
        info "  (not present)"
    fi
}

cmd_mcp() {
    local sub="${1:-}"
    [ -n "$sub" ] || die "Usage: swctl mcp [install|uninstall|status] [--user|--repo]"
    shift
    case "$sub" in
        install)   cmd_mcp_install "$@" ;;
        uninstall) cmd_mcp_uninstall "$@" ;;
        status)    cmd_mcp_status "$@" ;;
        *) die "Unknown mcp subcommand: $sub" ;;
    esac
}

# ── User config (~/.swctl/config.json) ──────────────────────────────────────
#
# Shared by the CLI and the UI /config page.  Schema is deliberately loose
# (a free-form JSON object); today we only document + expose AI-related
# keys, but a future feature can squat on any subtree without migrating.
#
# Documented keys:
#   .ai.defaultBackend         "claude" | "codex"       → _ai_resolve_backend
#   .ai.claude.bin             "/path/to/claude"        → _ai_backend_binary claude
#   .ai.claude.configDir       "/path/to/.claude"       → _ai_backend_config_dir claude
#   .ai.codex.bin              "/path/to/codex"         → _ai_backend_binary codex
#   .ai.codex.configDir        "/path/to/.codex"        → _ai_backend_config_dir codex
# --------------------------------------------------------------------------

cmd_config_path() {
    printf '%s\n' "$(_user_config_file)"
}

cmd_config_get() {
    local path="${1:-}"
    [ -n "$path" ] || die "Usage: swctl config get <jq-path>   e.g. '.ai.defaultBackend'"
    # Prefix with '.' if caller gave a bare key (ai.defaultBackend → .ai.defaultBackend)
    case "$path" in
        .*) ;;
        *)  path=".$path" ;;
    esac
    local file
    file="$(_user_config_file)"
    if [ ! -f "$file" ]; then
        warn "Config file does not exist: $file"
        return 1
    fi
    command -v jq >/dev/null 2>&1 || die "'jq' is required. brew install jq."
    jq -r "$path // empty" "$file"
}

cmd_config_set() {
    local path="${1:-}" value="${2:-}"
    [ -n "$path" ]  || die "Usage: swctl config set <jq-path> <value>"
    [ -n "$value" ] || die "Usage: swctl config set <jq-path> <value>"
    case "$path" in
        .*) ;;
        *)  path=".$path" ;;
    esac
    _user_config_write "$path" "$value"
    ok "Set $path = $value in $(_user_config_file)"
}

cmd_config_unset() {
    local path="${1:-}"
    [ -n "$path" ] || die "Usage: swctl config unset <jq-path>"
    case "$path" in
        .*) ;;
        *)  path=".$path" ;;
    esac
    _user_config_delete "$path"
    ok "Removed $path from $(_user_config_file)"
}

cmd_config_show() {
    local file
    file="$(_user_config_file)"
    if [ ! -f "$file" ]; then
        info "Config file does not exist: $file"
        info "Run 'swctl config set <key> <value>' to create it, or visit /#/config in the UI."
        return 0
    fi
    if command -v jq >/dev/null 2>&1; then
        jq . "$file"
    else
        cat "$file"
    fi
}

cmd_config_edit() {
    local file
    file="$(_user_config_file)"
    mkdir -p "$(dirname "$file")"
    [ -f "$file" ] || printf '{}\n' > "$file"
    "${EDITOR:-vi}" "$file"
}

cmd_config() {
    local sub="${1:-show}"
    shift || true
    case "$sub" in
        path)  cmd_config_path  "$@" ;;
        get)   cmd_config_get   "$@" ;;
        set)   cmd_config_set   "$@" ;;
        unset) cmd_config_unset "$@" ;;
        show|list) cmd_config_show "$@" ;;
        edit)  cmd_config_edit  "$@" ;;
        *) die "Usage: swctl config [show|path|get|set|unset|edit] [...]" ;;
    esac
}

# ── Claude Code resolve integration ──────────────────────────────────────────

resolve_generate_uuid() {
    uuidgen 2>/dev/null | tr '[:upper:]' '[:lower:]' || cat /proc/sys/kernel/random/uuid 2>/dev/null || printf '%s' "$(date +%s)-$$"
}

# Parse an issue ref (URL, owner/repo#N, or just N) into owner|repo|number.
# Echoes three lines; caller reads with mapfile or three `read` calls.
resolve_parse_issue_ref() {
    local ref="$1"
    local default_repo="${2:-shopware/shopware}"
    local owner="${default_repo%/*}"
    local repo="${default_repo#*/}"
    local number=""
    case "$ref" in
        *github.com/*/*/issues/*)
            # https://github.com/<owner>/<repo>/issues/<N>
            local path="${ref#*github.com/}"
            owner="${path%%/*}"; path="${path#*/}"
            repo="${path%%/*}"
            number="${ref##*/issues/}"
            number="${number%%[!0-9]*}"
            ;;
        */*#[0-9]*)
            # owner/repo#N
            local repo_part="${ref%%#*}"
            owner="${repo_part%/*}"
            repo="${repo_part#*/}"
            number="${ref##*#}"
            ;;
        [0-9]*)
            number="$ref"
            ;;
        *)
            number="$(printf '%s' "$ref" | tr -cd '0-9')"
            ;;
    esac
    printf '%s\n%s\n%s\n' "$owner" "$repo" "$number"
}

# Fetch an issue's labels via `gh api` (preferred) or `curl` with token.
# Prints one label name per line; empty on failure.
resolve_fetch_issue_labels() {
    local ref="$1"
    local default_repo="${2:-shopware/shopware}"
    local parsed; parsed="$(resolve_parse_issue_ref "$ref" "$default_repo")"
    local owner repo number
    { IFS= read -r owner; IFS= read -r repo; IFS= read -r number; } <<<"$parsed"
    [ -n "$number" ] || return 0

    if command -v gh >/dev/null 2>&1; then
        gh api "repos/${owner}/${repo}/issues/${number}" --jq '.labels[].name' 2>/dev/null && return 0
    fi

    # Fallback: curl + swctl-stored token (same location as the UI uses)
    local token_file="${SWCTL_STATE_DIR:-$HOME/.local/state/swctl}/github.token"
    [ -f "$token_file" ] || return 0
    local token; token="$(cat "$token_file" 2>/dev/null)"
    [ -n "$token" ] || return 0
    curl -sSf -H "Authorization: Bearer $token" -H "Accept: application/vnd.github+json" \
        "https://api.github.com/repos/${owner}/${repo}/issues/${number}" 2>/dev/null \
        | jq -r '.labels[].name' 2>/dev/null
}

# Pick a conventional-commit branch prefix (fix/feat/chore) from labels.
# Default: fix.  Matches the branchPrefixFromLabels() logic in resolve.ts.
resolve_branch_prefix_from_labels() {
    local labels="$1"
    local lower; lower="$(printf '%s' "$labels" | tr '[:upper:]' '[:lower:]')"
    case "$lower" in
        *feature\ request*|*enhancement*|*improvement*|*feature*) printf 'feat'; return ;;
    esac
    case "$lower" in
        *refactor*|*chore*|*docs*|*documentation*|*tech\ debt*|*cleanup*|*tooling*|*\ ci*) printf 'chore'; return ;;
    esac
    printf 'fix'
}

# Detect a plugin-external project from `extension/<slug>` labels.
# Prints the plugin name (e.g. SwagCustomizedProducts) or empty.
# Word-based fuzzy match: every word in the label must appear in the plugin name.
resolve_detect_plugin_from_labels() {
    local labels="$1"
    [ -n "$labels" ] || return 0
    [ -f "$SWCTL_PROJECTS_FILE" ] || return 0

    # Collect registered plugin-external project names (tab-separated columns)
    local plugins_list
    plugins_list="$(grep -E $'\tplugin-external\t' "$SWCTL_PROJECTS_FILE" 2>/dev/null | cut -f1)"
    [ -n "$plugins_list" ] || return 0

    local best_plugin="" best_score=0
    while IFS= read -r label; do
        case "$label" in
            extension/*) ;;
            Extension/*) ;;
            *) continue ;;
        esac
        local slug="${label#*/}"
        # Split on non-alphanumerics, keep words ≥ 3 chars, lowercase
        local words
        words="$(printf '%s' "$slug" | tr -c '[:alnum:]' '\n' | grep -E '^[a-zA-Z0-9]{3,}$' | tr '[:upper:]' '[:lower:]')"
        [ -n "$words" ] || continue

        while IFS= read -r plugin; do
            [ -n "$plugin" ] || continue
            local target; target="$(printf '%s' "$plugin" | tr '[:upper:]' '[:lower:]')"
            # Every word must appear in the plugin name
            local all_match=1
            while IFS= read -r w; do
                [ -n "$w" ] || continue
                case "$target" in *"$w"*) ;; *) all_match=0; break ;; esac
            done <<<"$words"
            if [ "$all_match" = "1" ]; then
                # Score: sum of word lengths (longer = better match)
                local score; score="$(printf '%s' "$words" | tr -d '\n' | wc -c | tr -d ' ')"
                if [ "$score" -gt "$best_score" ]; then
                    best_plugin="$plugin"
                    best_score="$score"
                fi
            fi
        done <<<"$plugins_list"
    done <<<"$labels"

    [ -n "$best_plugin" ] && printf '%s' "$best_plugin"
}

# Build the structured /shopware-resolve prompt the UI uses.  Same ground
# rules, required artifacts, step markers, and stop criterion as
# resolve.ts so both entry points produce identical transcripts.
resolve_build_prompt() {
    local issue_url="$1"
    local issue_id="$2"
    # The skill's own SKILL.md carries the ground rules + per-step
    # artifact requirements + stop criterion (see
    # skills/shopware-resolve/SKILL.md "Ground rules" / "Required
    # artifact per step" sections).  All three entry points (swctl UI,
    # swctl CLI, direct `claude /shopware-resolve`) use those same
    # rules, so we keep the prompt minimal: just the slash command +
    # the explicit issue id for Step 5's swctl refresh.
    cat <<EOF
/shopware-resolve $issue_url

(issue id for Step 5 swctl refresh: $issue_id)
EOF
}

fetch_github_issues() {
    local repo="$1"
    local labels="${2:-}"
    local token=""
    [ -f "${SWCTL_GITHUB_TOKEN_FILE:-}" ] && token="$(cat "$SWCTL_GITHUB_TOKEN_FILE")"

    local auth_header=""
    [ -n "$token" ] && auth_header="Authorization: token $token"

    local url="https://api.github.com/repos/${repo}/issues?state=open&per_page=100"
    [ -n "$labels" ] && url="${url}&labels=${labels}"

    curl -sSf ${auth_header:+-H "$auth_header"} "$url" \
        | jq -r '.[] | select(.pull_request == null) | "\(.number)\t\(.title | .[0:70])"'
}

resolve_stream_monitor() {
    local issue_id="$1"
    local run_dir="$SWCTL_TMP_DIR/resolve/$issue_id"
    mkdir -p "$run_dir"

    local last_tool_name="" last_tool_input="" last_tool_id=""

    while IFS= read -r line; do
        printf '%s\n' "$line" >> "$run_dir/stream.jsonl"

        local msg_type
        msg_type="$(printf '%s' "$line" | jq -r '.type // empty' 2>/dev/null)" || continue

        case "$msg_type" in
            assistant)
                # Extract tool_use if present
                local tool_name
                tool_name="$(printf '%s' "$line" | jq -r '(.message.content // [])[-1].name // empty' 2>/dev/null)"
                if [ -n "$tool_name" ]; then
                    last_tool_name="$tool_name"
                    last_tool_id="$(printf '%s' "$line" | jq -r '(.message.content // [])[-1].id // empty' 2>/dev/null)"
                    last_tool_input="$(printf '%s' "$line" | jq -r '(.message.content // [])[-1].input | tostring' 2>/dev/null)"
                fi
                # Extract text for step tracking
                local text
                text="$(printf '%s' "$line" | jq -r '(.message.content // [])[] | select(.type=="text") | .text // empty' 2>/dev/null)"
                if printf '%s' "$text" | grep -q 'Step [0-9]'; then
                    printf '%s' "$text" | grep -oE 'Step [0-9]+[^.]*' | tail -1 > "$run_dir/step"
                fi
                ;;
            user)
                # Check for approval request (denied tool)
                local content
                content="$(printf '%s' "$line" | jq -r '(.message.content // [])[0].content // empty' 2>/dev/null)"
                if printf '%s' "$content" | grep -qi 'requires approval\|permission\|denied'; then
                    printf 'approval_needed\n' > "$run_dir/status"
                    printf '%s\n%s\n%s\n' "$last_tool_name" "$last_tool_id" "$last_tool_input" > "$run_dir/pending_approval"
                fi
                ;;
            result)
                local is_error cost
                is_error="$(printf '%s' "$line" | jq -r '.is_error // false' 2>/dev/null)"
                cost="$(printf '%s' "$line" | jq -r '.total_cost_usd // 0' 2>/dev/null)"
                if [ "$is_error" = "true" ]; then
                    printf 'failed\n' > "$run_dir/status"
                else
                    printf 'done\n' > "$run_dir/status"
                fi
                printf '%s\n' "$cost" > "$run_dir/cost"
                ;;
        esac
    done
}

resolve_dispatch_issue() {
    local issue_url="$1"
    local issue_id="$2"
    local worktree_path="$3"
    local session_id="$4"
    local permission_mode="${5:-acceptEdits}"
    # Optional 6th arg: explicit prompt to send Claude.  When omitted, fall
    # back to the terse `/shopware-resolve <url>` form for backwards compat.
    local prompt="${6:-/shopware-resolve $issue_url}"
    local run_dir="$SWCTL_TMP_DIR/resolve/$issue_id"

    mkdir -p "$run_dir"
    printf 'running\n' > "$run_dir/status"

    # Backend dispatch.  `RESOLVE_BACKEND` is resolved once at the top
    # of cmd_resolve and exported; resolve_one passes it through.
    local backend="${RESOLVE_BACKEND:-claude}"
    local ai_bin
    ai_bin="$(_ai_backend_binary "$backend")"

    local exit_code
    case "$backend" in
        claude)
            # - explicit allowlist so non-interactive mode doesn't hit approval prompts
            # - --effort max for a wider per-turn thinking budget
            # - --session-id makes `<bin> --resume <id>` work later
            "$ai_bin" -p "$prompt" \
                --output-format stream-json \
                --verbose \
                --permission-mode "$permission_mode" \
                --allowedTools "Bash Edit Write Read Grep Glob Task WebFetch WebSearch TodoWrite" \
                --effort max \
                --session-id "$session_id" \
                --name "resolve-$issue_id" \
                --add-dir "$worktree_path" \
                --max-budget-usd 5.00 \
                2>"$run_dir/stderr.log" \
            | resolve_stream_monitor "$issue_id"
            exit_code=${PIPESTATUS[0]}
            ;;
        codex)
            # MVP: Codex CLI support is experimental.  The flag surface
            # below is a best-effort starting point — verify against the
            # installed `codex` binary and PR updates as needed.
            # resolve_stream_monitor parses Claude's stream-json format;
            # for Codex we fall back to raw stderr teeing until the
            # format parity is wired up.
            warn "[resolve] Codex backend is experimental. Output parsing is minimal."
            "$ai_bin" exec \
                --session "$session_id" \
                --cd "$worktree_path" \
                "$prompt" \
                2>"$run_dir/stderr.log"
            exit_code=$?
            ;;
        *)
            err "[resolve] Unknown backend '$backend'."
            return 2
            ;;
    esac
    printf '%s\n' "$exit_code" > "$run_dir/exit_code"
    return "$exit_code"
}

resolve_one() {
    local issue_number="$1"
    local repo="${2:-shopware/shopware}"
    local permission_mode="${3:-acceptEdits}"

    local issue_url="https://github.com/${repo}/issues/${issue_number}"
    local issue_id
    issue_id="$(sanitize_slug "$issue_number")"
    local session_id
    session_id="$(resolve_generate_uuid)"

    # Fetch labels once; reuse for scope detection + branch prefix.  Matches
    # the UI orchestration (app/server/lib/resolve.ts:startResolveStream).
    local labels
    labels="$(resolve_fetch_issue_labels "$issue_url" "$repo" 2>/dev/null || true)"
    local detected_plugin
    detected_plugin="$(resolve_detect_plugin_from_labels "$labels")"
    local branch_prefix
    branch_prefix="$(resolve_branch_prefix_from_labels "$labels")"
    local branch_name="${branch_prefix}/${issue_number}"

    if [ -n "$labels" ]; then
        info "[resolve] labels: $(printf '%s' "$labels" | tr '\n' ' ')"
    else
        info "[resolve] no labels returned — defaulting to platform scope + fix/ prefix"
    fi
    if [ -n "$detected_plugin" ]; then
        info "[resolve] scope → $detected_plugin"
    else
        info "[resolve] scope → platform (trunk)"
    fi
    info "[resolve] branch: $branch_name"

    # Check if worktree exists; create if not
    local meta_file=""
    meta_file="$(resolve_instance_file_by_issue "$issue_id" 2>/dev/null)" || true

    if [ -z "$meta_file" ] || [ ! -f "$meta_file" ]; then
        info "[resolve] Creating worktree for issue $issue_id..."
        local create_args=(--qa --no-provision)
        [ -n "$detected_plugin" ] && create_args+=(--project "$detected_plugin")
        cmd_create "${create_args[@]}" "$issue_number" "$branch_name" || {
            err "Failed to create worktree for $issue_id"
            return 1
        }
        meta_file="$(resolve_instance_file_by_issue "$issue_id")" || {
            err "Worktree created but metadata missing for $issue_id"
            return 1
        }
    else
        # Scope-mismatch guard: if the existing instance was created against
        # a different scope than the labels now indicate, refuse and point
        # the user at `swctl clean`.  Mirrors the UI's stale-scope check.
        load_instance_metadata "$meta_file"
        if [ -n "$detected_plugin" ] && [ "$detected_plugin" != "${PLUGIN_NAME:-}" ]; then
            die "[scope] existing instance is scoped to ${PLUGIN_NAME:-platform/trunk} but the issue labels point at $detected_plugin. Run 'swctl clean $issue_id' and retry to recreate with the correct plugin scope."
        fi
    fi

    load_instance_metadata "$meta_file"

    # Store session ID + running status in metadata (enables `swctl resolve
    # resume <id>` later and parity with the UI's env fields).
    CLAUDE_SESSION_ID="$session_id"
    CLAUDE_RESOLVE_STATUS="running"
    CLAUDE_RESOLVE_STARTED="$(timestamp_utc)"
    CLAUDE_RESOLVE_STEP="0"
    write_metadata "$meta_file"

    info "[resolve] Dispatching issue #$issue_number to Claude Code (session: ${session_id:0:8}...)"

    # Build the structured prompt (same content as the UI's resolve prompt)
    local prompt
    prompt="$(resolve_build_prompt "$issue_url" "$issue_id")"
    resolve_dispatch_issue "$issue_url" "$issue_id" "$WORKTREE_PATH" \
        "$session_id" "$permission_mode" "$prompt"
    local rc=$?

    # Update metadata with final status
    local final_status="done"
    [ "$rc" -ne 0 ] && final_status="failed"

    CLAUDE_RESOLVE_STATUS="$final_status"
    local cost_file="$SWCTL_TMP_DIR/resolve/$issue_id/cost"
    [ -f "$cost_file" ] && CLAUDE_RESOLVE_COST="$(cat "$cost_file")"
    # Persist last-completed-step so the UI's Resume card can pick up
    local step_file="$SWCTL_TMP_DIR/resolve/$issue_id/step"
    if [ -f "$step_file" ]; then
        CLAUDE_RESOLVE_STEP="$(grep -oE '[0-9]+' "$step_file" 2>/dev/null | tail -1 || echo 0)"
    fi
    write_metadata "$meta_file"

    if [ "$rc" -eq 0 ]; then
        ok "[resolve] Issue #$issue_number completed. Cost: \$${CLAUDE_RESOLVE_COST:-0}"
    else
        err "[resolve] Issue #$issue_number failed (exit $rc)."
    fi

    return $rc
}

resolve_parallel() {
    local issues="$1"
    local repo="$2"
    local max_jobs="${3:-2}"
    local permission_mode="${4:-acceptEdits}"
    local job_dir="$SWCTL_TMP_DIR/resolve-batch.$$"
    mkdir -p "$job_dir"

    local running=0
    local issue_number=""

    while IFS= read -r issue_number; do
        [ -n "$issue_number" ] || continue

        # Wait if at max capacity
        while [ "$running" -ge "$max_jobs" ]; do
            wait -n 2>/dev/null || true
            running=$((running - 1))
        done

        (
            if resolve_one "$issue_number" "$repo" "$permission_mode" \
                >"$job_dir/${issue_number}.log" 2>&1; then
                touch "$job_dir/${issue_number}.ok"
            else
                touch "$job_dir/${issue_number}.fail"
            fi
        ) &

        running=$((running + 1))
        info "[resolve] Dispatched #$issue_number (job $running/$max_jobs)"
    done <<< "$issues"

    # Wait for all remaining
    wait 2>/dev/null || true

    # Summary
    local succeeded failed total
    succeeded="$(find "$job_dir" -name '*.ok' 2>/dev/null | wc -l | tr -d ' ')"
    failed="$(find "$job_dir" -name '*.fail' 2>/dev/null | wc -l | tr -d ' ')"
    total="$(printf '%s\n' "$issues" | grep -c '.' || echo 0)"

    if [ "$failed" -gt 0 ]; then
        warn "[resolve] Batch: $succeeded succeeded, $failed failed of $total."
        for f in "$job_dir"/*.fail; do
            [ -f "$f" ] || continue
            local fid
            fid="$(basename "$f" .fail)"
            warn "  #$fid failed. Log: $job_dir/${fid}.log"
        done
    else
        ok "[resolve] Batch: all $succeeded of $total succeeded."
    fi

    rm -rf "$job_dir"
    [ "$failed" -eq 0 ]
}

cmd_resolve() {
    local repo="shopware/shopware"
    local max_jobs=2
    local permission_mode="acceptEdits"
    local issues=""
    local labels=""
    local backend_arg=""

    SWCTL_GITHUB_TOKEN_FILE="${SWCTL_STATE_DIR:-$HOME/.local/state/swctl}/github.token"

    while [ $# -gt 0 ]; do
        case "$1" in
            --github)  shift; repo="${1:?Missing --github arg}"; shift ;;
            --jobs|-j) shift; max_jobs="${1:?Missing --jobs arg}"; shift ;;
            --supervised) permission_mode="default"; shift ;;
            --labels)  shift; labels="${1:?Missing --labels arg}"; shift ;;
            --backend) shift; backend_arg="${1:?Missing --backend arg}"; shift ;;
            --backend=*) backend_arg="${1#--backend=}"; shift ;;
            --select)
                shift
                local fetched
                fetched="$(fetch_github_issues "$repo" "$labels")"
                if [ -z "$fetched" ]; then
                    die "No open issues found in $repo."
                fi
                if command -v fzf >/dev/null 2>&1; then
                    issues="$(printf '%s\n' "$fetched" | fzf --multi --prompt='Select issues> ' --height=40% --reverse | awk '{print $1}')"
                else
                    printf '%s\n' "$fetched"
                    printf '\nEnter issue numbers (space-separated): '
                    read -r issues
                fi
                ;;
            -*)  die "Unknown flag: $1" ;;
            *)   issues="${issues:+$issues
}$1"; shift ;;
        esac
    done

    [ -n "$issues" ] || die "No issues specified.\nUsage: swctl resolve [--github <owner/repo>] [--select] [--labels <labels>] [--jobs N] [--supervised] [--backend=<claude|codex>] <issue...>"

    # Resolve the backend now so the rest of the run (and every child
    # invocation spawned in parallel) inherits a single decision.  Exports
    # RESOLVE_BACKEND so resolve_one / resolve_dispatch_issue / resolve.ts
    # all read the same value without re-parsing the flag.
    RESOLVE_BACKEND="$(_ai_resolve_backend "$backend_arg")" \
        || die "Invalid backend '${backend_arg:-$SWCTL_RESOLVE_BACKEND}'. Use claude or codex."
    export RESOLVE_BACKEND

    local ai_bin
    ai_bin="$(_ai_backend_binary "$RESOLVE_BACKEND")"
    command -v "$ai_bin" >/dev/null 2>&1 \
        || die "Backend '$RESOLVE_BACKEND' needs '$ai_bin' on PATH. Claude: https://docs.anthropic.com/en/docs/claude-code ; Codex: https://github.com/openai/codex"
    command -v jq >/dev/null 2>&1 || die "jq required for stream parsing."

    local total
    total="$(printf '%s\n' "$issues" | grep -c '.' || echo 0)"
    info "[resolve] Resolving $total issue(s) with ${RESOLVE_BACKEND} (max $max_jobs concurrent)."

    if [ "$total" -eq 1 ]; then
        resolve_one "$(printf '%s' "$issues" | tr -d '[:space:]')" "$repo" "$permission_mode"
    else
        resolve_parallel "$issues" "$repo" "$max_jobs" "$permission_mode"
    fi
}

cmd_resolve_resume() {
    local issue_input="${1:-}"
    [ -n "$issue_input" ] || die "Usage: swctl resolve resume <issue>"

    maybe_load_project_config >/dev/null 2>&1 || true
    local meta_file=""
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || die "No instance for '$issue_input'."
    load_instance_metadata "$meta_file"

    [ -n "${CLAUDE_SESSION_ID:-}" ] || die "No Claude session found for '$issue_input'."

    local last_step="${CLAUDE_RESOLVE_STEP:-0}"
    last_step="$(printf '%s' "$last_step" | grep -oE '[0-9]+' | tail -1 || echo 0)"
    local next_step=$(( last_step + 1 ))
    [ "$next_step" -gt 8 ] && next_step=8

    info "[resolve] Resuming session ${CLAUDE_SESSION_ID:0:8}... for #$ISSUE_ID from Step $next_step"

    local run_dir="$SWCTL_TMP_DIR/resolve/$ISSUE_ID"
    mkdir -p "$run_dir"
    printf 'running\n' > "$run_dir/status"

    CLAUDE_RESOLVE_STATUS="running"
    write_metadata "$meta_file"

    # Minimal continuation prompt — the skill's SKILL.md already carries
    # the ground rules (step markers, artifact list, stop criterion), and
    # the resumed session still has them in context from the original run.
    local resume_prompt
    resume_prompt="Continue the previous /shopware-resolve run. You stopped after Step ${last_step}. Pick up at Step ${next_step} now, following the same ground rules from the skill."

    # Dispatch on the backend recorded in metadata.  load_instance_metadata
    # back-fills RESOLVE_BACKEND=claude for pre-v0.5.7 instances so this
    # works even for sessions created before the Codex backend shipped.
    local backend="${RESOLVE_BACKEND:-claude}"
    local ai_bin
    ai_bin="$(_ai_backend_binary "$backend")"
    local rc
    case "$backend" in
        claude)
            "$ai_bin" -p "$resume_prompt" \
                --resume "$CLAUDE_SESSION_ID" \
                --output-format stream-json \
                --verbose \
                --permission-mode acceptEdits \
                --allowedTools "Bash Edit Write Read Grep Glob Task WebFetch WebSearch TodoWrite" \
                --effort max \
                --add-dir "$WORKTREE_PATH" \
                2>"$run_dir/stderr.log" \
            | resolve_stream_monitor "$ISSUE_ID"
            rc=${PIPESTATUS[0]}
            ;;
        codex)
            warn "[resolve] Codex resume is experimental."
            "$ai_bin" exec \
                --session "$CLAUDE_SESSION_ID" \
                --resume \
                --cd "$WORKTREE_PATH" \
                "$resume_prompt" \
                2>"$run_dir/stderr.log"
            rc=$?
            ;;
        *)
            err "[resolve] Unknown backend '$backend'."
            return 2
            ;;
    esac
    local final_status="done"
    [ "$rc" -ne 0 ] && final_status="failed"

    CLAUDE_RESOLVE_STATUS="$final_status"
    local cost_file="$run_dir/cost"
    [ -f "$cost_file" ] && CLAUDE_RESOLVE_COST="$(cat "$cost_file")"
    local step_file="$run_dir/step"
    if [ -f "$step_file" ]; then
        CLAUDE_RESOLVE_STEP="$(grep -oE '[0-9]+' "$step_file" 2>/dev/null | tail -1 || echo "$last_step")"
    fi
    write_metadata "$meta_file"

    return "$rc"
}

render_resolve_status() {
    printf '\n%b%-12s %-12s %-35s %-10s%b\n' \
        "${COLOR_BOLD:-}" "Issue" "Status" "Step" "Cost" "${COLOR_RESET:-}"
    printf '%-12s %-12s %-35s %-10s\n' \
        "------------" "------------" "-----------------------------------" "----------"

    local found=0
    local run_dir
    for run_dir in "$SWCTL_TMP_DIR"/resolve/*/; do
        [ -d "$run_dir" ] || continue
        found=1
        local issue_id status step cost
        issue_id="$(basename "$run_dir")"
        status="$(cat "$run_dir/status" 2>/dev/null || printf 'unknown')"
        step="$(cat "$run_dir/step" 2>/dev/null || printf '-')"
        cost="$(cat "$run_dir/cost" 2>/dev/null || printf '-')"

        local sc=""
        case "$status" in
            done)            sc="${COLOR_GREEN:-}" ;;
            failed)          sc="${COLOR_RED:-}" ;;
            approval_needed) sc="${COLOR_RED:-}" ;;
            running)         sc="${COLOR_YELLOW:-}" ;;
        esac

        printf '%-12s %b%-12s%b %-35s %-10s\n' \
            "#$issue_id" \
            "$sc" "$status" "${COLOR_RESET:-}" \
            "${step:0:35}" \
            "\$$cost"
    done

    [ "$found" -eq 1 ] || printf '  (no active resolve sessions)\n'
    printf '\n'
}

tui_resolve_flow() {
    local repo="shopware/shopware"
    local issues=""

    # Source selection
    info "Select issue source:"
    printf '  1) Fetch from GitHub\n'
    printf '  2) Enter manually\n'
    printf '  Choice: '
    local choice=""
    read -r -n 1 choice
    printf '\n'

    case "$choice" in
        1)
            local labels_input=""
            printf '  Labels filter (empty for all): '
            read -r labels_input
            local fetched
            fetched="$(fetch_github_issues "$repo" "$labels_input" 2>/dev/null)"
            if [ -z "$fetched" ]; then
                warn "No issues found."; return
            fi
            if command -v fzf >/dev/null 2>&1; then
                issues="$(printf '%s\n' "$fetched" | fzf --multi --prompt='Select issues (TAB to multi-select)> ' --height=50% --reverse | awk '{print $1}')"
            else
                printf '%s\n' "$fetched"
                printf '\nEnter issue numbers (space-separated): '
                read -r issues
                issues="$(printf '%s' "$issues" | tr ' ' '\n')"
            fi
            ;;
        2)
            printf '  Issue numbers (space-separated): '
            local manual_input=""
            read -r manual_input
            issues="$(printf '%s' "$manual_input" | tr ' ' '\n')"
