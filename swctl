write_compose_volume_override() {
    COMPOSE_VOLUME_OVERRIDE="$SWCTL_TMP_DIR/${COMPOSE_PROJECT}.volumes.override.yml"
    local vendor_is_shared=0
    local node_is_shared=0

    case "$VENDOR_VOLUME" in vendor-base-*) vendor_is_shared=1 ;; esac
    case "$NODE_MODULES_VOLUME" in node_modules-base-*) node_is_shared=1 ;; esac

    # Ensure shared base volumes exist before marking them external
    if [ "$vendor_is_shared" -eq 1 ]; then
        docker volume inspect "$VENDOR_VOLUME" >/dev/null 2>&1 || \
            docker volume create "$VENDOR_VOLUME" >/dev/null
    fi
    if [ "$node_is_shared" -eq 1 ]; then
        docker volume inspect "$NODE_MODULES_VOLUME" >/dev/null 2>&1 || \
            docker volume create "$NODE_MODULES_VOLUME" >/dev/null
    fi

    {
        printf 'volumes:\n'
        printf '  vendor:\n'
        printf '    name: %s\n' "$VENDOR_VOLUME"
        if [ "$vendor_is_shared" -eq 1 ]; then
            printf '    external: true\n'
        else
            printf '    labels:\n'
            printf '      swctl.managed: "true"\n'
            printf '      swctl.project: %s\n' "$SW_PROJECT_SLUG"
            printf '      swctl.issue: %s\n' "$ISSUE_ID"
        fi
        printf '  node_modules:\n'
        printf '    name: %s\n' "$NODE_MODULES_VOLUME"
        if [ "$node_is_shared" -eq 1 ]; then
            printf '    external: true\n'
        else
            printf '    labels:\n'
            printf '      swctl.managed: "true"\n'
            printf '      swctl.project: %s\n' "$SW_PROJECT_SLUG"
            printf '      swctl.issue: %s\n' "$ISSUE_ID"
        fi
    } > "$COMPOSE_VOLUME_OVERRIDE"

    local svc="${SW_SERVICE_NAME:-web}"
    local extra_volumes=""

    # Share media/thumbnail from project root to avoid duplicating large assets.
    # Use :ro when cloning an existing DB (media already matches), :cached for fresh installs
    # (system:install needs to write media files).
    if [ "$SW_RUNTIME" = "orbstack" ]; then
        local media_mode="ro"
        if [ "${DB_STATE:-}" = "fresh" ]; then
            media_mode="cached"
        fi
        if [ -d "$PROJECT_ROOT/public/media" ]; then
            extra_volumes="${extra_volumes}      - ${PROJECT_ROOT}/public/media:/var/www/html/public/media:${media_mode}
"
        fi
        if [ -d "$PROJECT_ROOT/public/thumbnail" ]; then
            extra_volumes="${extra_volumes}      - ${PROJECT_ROOT}/public/thumbnail:/var/www/html/public/thumbnail:${media_mode}
"
        fi
    fi

    # QA mode: mount vendor from trunk as read-only bind (symlinks don't work in Docker)
    if [ "$SWCTL_MODE" = "qa" ] && [ -d "$PROJECT_ROOT/vendor" ]; then
        extra_volumes="${extra_volumes}      - ${PROJECT_ROOT}/vendor:/var/www/html/vendor:ro
"
    fi

    # Plugin mounts: bind-mount external plugin worktrees into custom/plugins/
    if [ -n "${PLUGIN_WORKTREE_PATHS:-}" ] && [ -n "${LINKED_PLUGINS:-}" ]; then
        local saved_ifs="$IFS"
        IFS=','
        local pw_arr=($PLUGIN_WORKTREE_PATHS)
        local pl_arr=($LINKED_PLUGINS)
        IFS="$saved_ifs"
        local i
        for i in "${!pw_arr[@]}"; do
            local pw_path="${pw_arr[$i]}"
            local p_name="${pl_arr[$i]}"
            if [ -n "$pw_path" ] && [ -d "$pw_path" ] && [ -n "$p_name" ]; then
                extra_volumes="${extra_volumes}      - ${pw_path}:/var/www/html/custom/plugins/${p_name}:cached
"
            fi
        done
    fi

    if [ -n "$extra_volumes" ]; then
        printf '\nservices:\n  %s:\n    volumes:\n%s' "$svc" "$extra_volumes" \
            >> "$COMPOSE_VOLUME_OVERRIDE"
    fi
}

app_container_id() {
    local compose_project="$1"
    local service="${SW_SERVICE_NAME:-app}"
    local result
    result="$(docker ps -q \
        --filter "label=com.docker.compose.project=${compose_project}" \
        --filter "label=com.docker.compose.service=${service}" \
        2>/dev/null | sed -n '1p')"
    if [ -z "$result" ]; then
        # Fallback: try both service names for backward compatibility
        local alt_service="app"
        [ "$service" = "app" ] && alt_service="web"
        result="$(docker ps -q \
            --filter "label=com.docker.compose.project=${compose_project}" \
            --filter "label=com.docker.compose.service=${alt_service}" \
            2>/dev/null | sed -n '1p')"
    fi
    printf '%s' "$result"
}

app_container_exists_any_state() {
    local compose_project="$1"
    local service="${SW_SERVICE_NAME:-app}"
    local result
    result="$(docker ps -aq \
        --filter "label=com.docker.compose.project=${compose_project}" \
        --filter "label=com.docker.compose.service=${service}" \
        2>/dev/null | sed -n '1p')"
    if [ -z "$result" ]; then
        local alt_service="app"
        [ "$service" = "app" ] && alt_service="web"
        result="$(docker ps -aq \
            --filter "label=com.docker.compose.project=${compose_project}" \
            --filter "label=com.docker.compose.service=${alt_service}" \
            2>/dev/null | sed -n '1p')"
    fi
    printf '%s' "$result"
}

wait_for_app_container() {
    local compose_project="$1"
    local attempt=0
    while [ "$attempt" -lt 60 ]; do
        if [ -n "$(app_container_id "$compose_project")" ]; then
            return 0
        fi
        attempt=$((attempt + 1))
        sleep 1
    done

    die "App container for '$compose_project' did not start in time."
}

exec_in_container() {
    local container_id="$1"
    local command_string="$2"

    if [ -t 0 ] && [ -t 1 ]; then
        docker exec -it "$container_id" bash -lc "$command_string"
    else
        # Non-interactive: wrap command to track PID so it can be killed remotely.
        # docker exec does NOT kill the container process when the client dies.
        docker exec "$container_id" bash -c '
            bash -lc "$1" &
            child=$!
            echo "$child" > /tmp/.swctl-exec.pid
            wait "$child" 2>/dev/null
            code=$?
            rm -f /tmp/.swctl-exec.pid
            exit $code
        ' _ "$command_string"
    fi
}

cmd_kill_exec() {
    local issue_input="${1:-}"
    [ -n "$issue_input" ] || return 1

    maybe_load_project_config >/dev/null 2>&1 || true
    local meta_file
    meta_file="$(resolve_instance_file_by_issue "$issue_input" 2>/dev/null)" || return 1
    load_instance_metadata "$meta_file"

    local container_id
    container_id="$(app_container_id "$COMPOSE_PROJECT" 2>/dev/null)" || return 1
    [ -n "$container_id" ] || return 1

    # Kill all processes spawned by swctl exec / watch commands.
    # docker exec orphans get reparented to PID 0 or 1. BusyBox ps shows
    # "MainThread" for node, so we can't rely on comm names. Instead:
    # 1. Kill tracked PID tree via /proc
    # 2. Kill any orphaned process (PPID 0) that isn't a core service
    docker exec "$container_id" sh -c '
        kill_tree() {
            local pid=$1
            # Kill children first (depth-first)
            for child in $(ps -o pid,ppid 2>/dev/null | awk -v p="$pid" "\$2==p {print \$1}"); do
                kill_tree "$child"
            done
            kill -TERM "$pid" 2>/dev/null
        }

        # 1. Kill tracked PID tree
        pid=$(cat /tmp/.swctl-exec.pid 2>/dev/null)
        rm -f /tmp/.swctl-exec.pid
        [ -n "$pid" ] && kill_tree "$pid"

        # 2. Kill orphaned exec processes (PPID 0, not core services)
        #    Core services: PID 1 (supervisord), caddy, php-fpm, ps itself
        for p in $(ps -o pid,ppid,comm 2>/dev/null | awk "\$2==0 && \$1!=1 {print \$1}"); do
            # Read cmdline to check if it is a core service
            cmdline=$(cat /proc/$p/cmdline 2>/dev/null | tr "\0" " ")
            case "$cmdline" in
                *supervisord*|*caddy*|*php-fpm*|*ps*) continue ;;
            esac
            kill_tree "$p"
        done

        sleep 1

        # 3. Force kill any survivors
        for p in $(ps -o pid,ppid 2>/dev/null | awk "\$2==0 && \$1!=1 {print \$1}"); do
            cmdline=$(cat /proc/$p/cmdline 2>/dev/null | tr "\0" " ")
            case "$cmdline" in
                *supervisord*|*caddy*|*php-fpm*|*ps*) continue ;;
            esac
            kill -9 "$p" 2>/dev/null
        done
    ' 2>/dev/null || true
    ok "Killed exec process for '$issue_input'."
}

run_app_command() {
    local compose_project="$1"
    local command_string="$2"
    local container_id

    container_id="$(app_container_id "$compose_project")"
    [ -n "$container_id" ] || die "No running app container found for '$compose_project'."
    exec_in_container "$container_id" "$command_string"
}

fix_volume_ownership() {
    local compose_project="$1"
    local container_id
    container_id="$(app_container_id "$compose_project")"
    [ -n "$container_id" ] || return 0
    docker exec -u root "$container_id" bash -c \
        "chown ${SW_UID}:${SW_GID} /var/www/html/vendor /var/www/html/node_modules 2>/dev/null" || true
}

bootstrap_dependencies() {
    local compose_project="$1"
    local package_install_cmd=""
    local vendor_needs_install=0
    local node_needs_install=0

    fix_volume_ownership "$compose_project"

    # --- Composer / vendor ---
    if [ "$((MIGRATION_CHANGES + ENTITY_CHANGES + COMPOSER_CHANGES))" -gt 0 ]; then
        # Dedicated vendor volume — always install
        vendor_needs_install=1
        info "Dependency changes detected. Will run composer install."
    elif run_app_command "$compose_project" "test -f composer.json && test ! -f vendor/autoload.php" >/dev/null 2>&1; then
        # Shared base volume is empty (first-time populate)
        vendor_needs_install=1
        info "Shared vendor volume is empty. Will populate with composer install."
    else
        info "Reusing existing vendor volume. Skipping composer install."
    fi

    # --- Node modules ---
    package_install_cmd="$(detect_package_install_command "$WORKTREE_PATH" || true)"
    if [ -n "$package_install_cmd" ]; then
        if [ "$((MIGRATION_CHANGES + ENTITY_CHANGES + PACKAGE_CHANGES))" -gt 0 ]; then
            # Dedicated node_modules volume — always install
            node_needs_install=1
            info "Package changes detected. Will run: $package_install_cmd"
        elif run_app_command "$compose_project" "test ! -f node_modules/.package-lock.json && test ! -f node_modules/.modules.yaml" >/dev/null 2>&1; then
            # Shared base volume is empty (first-time populate)
            node_needs_install=1
            info "Shared node_modules volume is empty. Will populate."
        else
            info "Reusing existing node_modules volume. Skipping npm/pnpm install."
        fi
    fi

    # --- Run installs (in parallel when both needed) ---
    if [ "$vendor_needs_install" -eq 1 ] && [ "$node_needs_install" -eq 1 ]; then
        info "Running composer install and $package_install_cmd in parallel."
        run_app_command "$compose_project" "composer install --no-interaction" &
        local composer_pid=$!
        run_app_command "$compose_project" "$package_install_cmd" &
        local node_pid=$!
        wait "$composer_pid" || warn "composer install failed."
        wait "$node_pid" || warn "Frontend dependency install failed."
    elif [ "$vendor_needs_install" -eq 1 ]; then
        run_app_command "$compose_project" "composer install --no-interaction" \
            || warn "composer install failed. Continue after fixing the image or composer setup."
    elif [ "$node_needs_install" -eq 1 ]; then
        run_app_command "$compose_project" "$package_install_cmd" \
            || warn "Frontend dependency install failed."
    fi

    ensure_jwt_keys "$compose_project"
}

ensure_install_lock() {
    local compose_project="$1"
    run_app_command "$compose_project" "touch install.lock" || true
}

ensure_jwt_keys() {
    local compose_project="$1"
    run_app_command "$compose_project" \
        "test -f config/jwt/private.pem || (mkdir -p config/jwt && openssl genrsa -out config/jwt/private.pem 2048 2>/dev/null && openssl rsa -in config/jwt/private.pem -outform PEM -pubout -out config/jwt/public.pem 2>/dev/null && echo 'Generated JWT keys')" \
        || true
}

update_sales_channel_domain() {
    local compose_project="$1"
    local app_url="$2"

    # Each worktree has its own cloned DB — safe to update all non-headless domains.
    # Write a tiny PHP helper, execute it inside the container (uses DATABASE_URL
    # from .env.local), then remove it. This safely updates only the cloned DB.
    info "Updating sales channel domains to '$app_url'."
    cat > "$WORKTREE_PATH/.swctl-update-domain.php" <<'PHPEOF'
<?php
// Replace the base domain in all non-headless sales channel domains.
// E.g. http://web.trunk.orb.local/de-de → http://web.sw-123.orb.local/de-de
$newBase = $argv[1] ?? '';
$url = getenv('DATABASE_URL') ?: '';
if (!$url) {
    $env = file_get_contents(__DIR__ . '/.env.local');
    preg_match('/DATABASE_URL=(.+)/', $env, $m);
    $url = trim($m[1] ?? '');
}
$p = parse_url($url);
$pdo = new PDO(
    sprintf('mysql:host=%s;port=%s;dbname=%s', $p['host'], $p['port'] ?? 3306, ltrim($p['path'] ?? '', '/')),
    $p['user'] ?? 'root', $p['pass'] ?? ''
);
$rows = $pdo->query("SELECT HEX(id) as id, url FROM sales_channel_domain WHERE url NOT LIKE '%headless%'")->fetchAll(PDO::FETCH_ASSOC);
$count = 0;
foreach ($rows as $row) {
    $oldUrl = $row['url'];
    $oldParts = parse_url($oldUrl);
    $oldBase = ($oldParts['scheme'] ?? 'http') . '://' . ($oldParts['host'] ?? '') . (isset($oldParts['port']) ? ':' . $oldParts['port'] : '');
    $newUrl = str_replace($oldBase, $newBase, $oldUrl);
    if ($newUrl !== $oldUrl) {
        $pdo->prepare("UPDATE sales_channel_domain SET url = ? WHERE id = UNHEX(?)")->execute([$newUrl, $row['id']]);
        $count++;
    }
}
echo "Updated $count domain(s)\n";
PHPEOF
    run_app_command "$compose_project" "php .swctl-update-domain.php '$app_url'" \
        || warn "Could not update sales channel domain."
    rm -f "$WORKTREE_PATH/.swctl-update-domain.php"
}

run_install_command() {
    local compose_project="$1"
    local install_args="$2"
    local install_cmd

    install_cmd="$SW_BIN_CONSOLE system:install $install_args"
    info "Running Shopware system install for database '$DB_NAME'."
    run_app_command "$compose_project" "$install_cmd"
    ensure_install_lock "$compose_project"
}

install_admin_deps_if_needed() {
    local compose_project="$1"
    local admin_pkg="src/Administration/Resources/app/administration/package.json"
    local storefront_pkg="src/Storefront/Resources/app/storefront/package.json"

    # If worktree's admin/storefront package.json differs from trunk's, the cloned
    # node_modules from trunk is missing new deps. Run npm install inside the container.
    local needs_admin=0 needs_storefront=0

    if [ -f "$WORKTREE_PATH/$admin_pkg" ] && [ -f "$PROJECT_ROOT/$admin_pkg" ]; then
        if ! diff -q "$PROJECT_ROOT/$admin_pkg" "$WORKTREE_PATH/$admin_pkg" >/dev/null 2>&1; then
            needs_admin=1
        fi
    fi
    if [ -f "$WORKTREE_PATH/$storefront_pkg" ] && [ -f "$PROJECT_ROOT/$storefront_pkg" ]; then
        if ! diff -q "$PROJECT_ROOT/$storefront_pkg" "$WORKTREE_PATH/$storefront_pkg" >/dev/null 2>&1; then
            needs_storefront=1
        fi
    fi

    if [ "$needs_admin" -eq 1 ]; then
        info "Admin package.json differs from trunk. Running npm install for admin."
        run_app_command "$compose_project" "cd src/Administration/Resources/app/administration && npm install --no-audit --no-fund" \
            || warn "Admin npm install failed."
    fi
    if [ "$needs_storefront" -eq 1 ]; then
        info "Storefront package.json differs from trunk. Running npm install for storefront."
        run_app_command "$compose_project" "cd src/Storefront/Resources/app/storefront && npm install --no-audit --no-fund" \
            || warn "Storefront npm install failed."
    fi
}

run_frontend_build_if_needed() {
    local compose_project="$1"
    local is_first_create="${2:-0}"

    # QA mode: all frontend assets are synced from project root. No builds needed.
    if [ "$SWCTL_MODE" = "qa" ]; then
        info "QA mode: skipping frontend builds (using synced assets)."
        return
    fi

    # Install missing deps when worktree's package.json diverged from trunk
    install_admin_deps_if_needed "$compose_project"

    local needs_admin_build=0
    local needs_storefront_build=0

    # Only build if actual code changes — synced artifacts from trunk handle the baseline.
    if [ "${ADMIN_CHANGES:-0}" -gt 0 ]; then
        needs_admin_build=1
    fi
    if [ "${STOREFRONT_CHANGES:-0}" -gt 0 ]; then
        needs_storefront_build=1
    fi

    if [ "$needs_admin_build" -eq 1 ] || [ "$needs_storefront_build" -eq 1 ]; then
        info "Frontend changes detected. Running bundle:dump."
        run_app_command "$compose_project" "$SW_BIN_CONSOLE bundle:dump" || warn "bundle:dump failed."

        if [ "$needs_admin_build" -eq 1 ] && [ "$needs_storefront_build" -eq 1 ]; then
            # Build admin and storefront in parallel
            info "Admin + Storefront changes detected. Building both in parallel."
            run_app_command "$compose_project" "composer build:js:admin" &
            local admin_pid=$!
            run_app_command "$compose_project" "composer build:js:storefront" &
            local storefront_pid=$!
            wait "$admin_pid" || warn "Admin JS build failed."
            wait "$storefront_pid" || warn "Storefront JS build failed."
        elif [ "$needs_admin_build" -eq 1 ]; then
            info "Admin changes detected. Running composer build:js:admin."
            run_app_command "$compose_project" "composer build:js:admin" || warn "Admin JS build failed."
        else
            info "Storefront changes detected. Running composer build:js:storefront."
            run_app_command "$compose_project" "composer build:js:storefront" || warn "Storefront JS build failed."
        fi
    else
        # No frontend changes — register synced assets. Skip full JS builds.
        run_app_command "$compose_project" "$SW_BIN_CONSOLE bundle:dump" 2>/dev/null || true
        run_app_command "$compose_project" "$SW_BIN_CONSOLE assets:install" 2>/dev/null || true
        info "Assets registered from synced files. No frontend builds needed."
    fi

    # Clear cache for any code change
    if [ "$((BACKEND_CHANGES + ADMIN_CHANGES + STOREFRONT_CHANGES + COMPOSER_CHANGES + PACKAGE_CHANGES))" -gt 0 ] && [ "${DB_STATE:-}" != "fresh" ]; then
        run_app_command "$compose_project" "$SW_BIN_CONSOLE cache:clear" || warn "cache:clear failed."
    fi
}

create_database() {
    local db_name="$1"
    mysql_exec "DROP DATABASE IF EXISTS \`${db_name}\`; CREATE DATABASE \`${db_name}\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;"
}


clone_database() {
    local source_db="$1"
    local target_db="$2"
    local db_container
    db_container="$(resolve_db_container)"

    info "Cloning database '$source_db' → '$target_db'."
    docker exec -i "$db_container" bash -c \
        "mariadb -u '$SW_DB_ROOT_USER' -p'$SW_DB_ROOT_PASSWORD' -e 'DROP DATABASE IF EXISTS \`$target_db\`; CREATE DATABASE \`$target_db\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;' && mariadb-dump -u '$SW_DB_ROOT_USER' -p'$SW_DB_ROOT_PASSWORD' --single-transaction --quick '$source_db' | mariadb -u '$SW_DB_ROOT_USER' -p'$SW_DB_ROOT_PASSWORD' '$target_db'" \
        || die "Database clone failed."
    ok "Database cloned: $target_db"
}

provision_database_and_app() {
    local compose_project="$1"
    local source_db
    source_db="$(sanitize_db_identifier "$SW_DB_SHARED_NAME")"

    # Every worktree gets its own cloned database (never touches the source).
    DB_NAME="$(sanitize_db_identifier "${SW_DB_NAME_PREFIX}_${ISSUE_ID}")"

    # Determine DB_STATE early so the compose override can adjust mount modes
    # (fresh installs need writable media mounts for system:install).
    if mysql_db_has_tables "$DB_NAME"; then
        DB_STATE="cloned"
    elif mysql_db_has_tables "$source_db"; then
        DB_STATE="cloned"
    else
        DB_STATE="fresh"
    fi

    # Write configs (needed by both DB clone and compose up)
    write_env_file
    write_compose_env_file
    write_compose_volume_override

    # Clone DB and start container
    if [ "$DB_STATE" = "fresh" ]; then
        info "Source database '$source_db' is empty. Will run fresh install."
        create_database "$DB_NAME"
        compose --project-directory "$SWCTL_TMP_DIR" $(compose_file_args) --env-file "$COMPOSE_ENV_FILE" -p "$COMPOSE_PROJECT" up -d
    elif mysql_db_has_tables "$DB_NAME"; then
        info "Database '$DB_NAME' already exists. Reusing."
        compose --project-directory "$SWCTL_TMP_DIR" $(compose_file_args) --env-file "$COMPOSE_ENV_FILE" -p "$COMPOSE_PROJECT" up -d
    else
        # Clone DB in background while container starts
        clone_database "$source_db" "$DB_NAME" &
        local clone_pid=$!
        compose --project-directory "$SWCTL_TMP_DIR" $(compose_file_args) --env-file "$COMPOSE_ENV_FILE" -p "$COMPOSE_PROJECT" up -d
        wait "$clone_pid" || die "Database clone failed."
    fi
    wait_for_app_container "$COMPOSE_PROJECT"

    if [ "$SWCTL_MODE" = "qa" ]; then
        # QA mode: no console operations. Vendor, node_modules, and theme
        # files are all synced/mounted from the project root. Just set up
        # the domain and install lock so the app responds correctly.
        update_sales_channel_domain "$COMPOSE_PROJECT" "$APP_URL"
        ensure_install_lock "$COMPOSE_PROJECT"
        return
    fi

    # Dev mode: fully automatic provisioning based on diff analysis.
    bootstrap_dependencies "$COMPOSE_PROJECT"

    if [ "$DB_STATE" = "fresh" ]; then
        run_install_command "$COMPOSE_PROJECT" "$SW_INSTALL_ARGS"
        # Populate the shared DB so future worktrees can clone from it
        # instead of running a full install every time.
        if ! mysql_db_has_tables "$source_db"; then
            info "Populating shared database '$source_db' from fresh install."
            clone_database "$DB_NAME" "$source_db"
        fi
    elif [ $((MIGRATION_CHANGES + ENTITY_CHANGES)) -gt 0 ]; then
        info "Schema changes detected. Running migrations on cloned database."
        run_app_command "$COMPOSE_PROJECT" "$SW_BIN_CONSOLE database:migrate --all && $SW_BIN_CONSOLE database:migrate-destructive --all" || warn "Migrations failed."
    fi

    update_sales_channel_domain "$COMPOSE_PROJECT" "$APP_URL"
    ensure_install_lock "$COMPOSE_PROJECT"

    # Batch post-provision commands to reduce docker exec overhead.
    # - Fresh installs: system:install already runs theme:compile → just refresh + cache:clear
    # - Cloned DB, no storefront changes: synced theme files are sufficient → refresh + cache:clear
    # - Cloned DB, with storefront changes: run_frontend_build_if_needed handles rebuild → refresh + cache:clear
    # - Only run full theme:compile when DB was cloned AND there are storefront changes AND
    #   we need the compiled output before run_frontend_build_if_needed (edge case safety)
    if [ "$DB_STATE" = "fresh" ]; then
        run_app_command "$COMPOSE_PROJECT" "$SW_BIN_CONSOLE theme:refresh 2>/dev/null; $SW_BIN_CONSOLE cache:clear" \
            || warn "Post-provision commands failed."
    elif [ "${STOREFRONT_CHANGES:-0}" -gt 0 ]; then
        run_app_command "$COMPOSE_PROJECT" \
            "$SW_BIN_CONSOLE theme:refresh 2>/dev/null; $SW_BIN_CONSOLE theme:compile --sync || echo '[WARN] theme:compile failed.'; $SW_BIN_CONSOLE cache:clear || echo '[WARN] cache:clear failed.'" \
            || warn "Post-provision commands failed."
    else
        # Cloned DB, no storefront changes — synced theme files are correct.
        run_app_command "$COMPOSE_PROJECT" "$SW_BIN_CONSOLE theme:refresh 2>/dev/null; $SW_BIN_CONSOLE cache:clear" \
            || warn "Post-provision commands failed."
    fi
}

resolve_project_context() {
    local project_name="${1:-}"
    PROJECT_TYPE="platform"
    PLUGIN_NAME=""
    PLUGIN_REPO_PATH=""
    PLUGIN_DIR=""
    PLUGIN_WORKTREE_PATH=""
    LINKED_PLUGINS=""
    PLUGIN_WORKTREE_PATHS=""
    PLATFORM_WORKTREE_PATH=""
    PLATFORM_ISSUE_ID=""

    SELECTED_PROJECT_PATH=""
    [ -n "$project_name" ] || return 0
    local entry
    entry="$(read_project "$project_name")" || die "Project '$project_name' not registered. Run 'swctl project list' to see available projects."

    PROJECT_TYPE="$(read_project_field "$entry" type)"
    local proj_path parent plugin_dir
    proj_path="$(read_project_field "$entry" path)"
    SELECTED_PROJECT_PATH="$proj_path"
    parent="$(read_project_field "$entry" parent)"
    plugin_dir="$(read_project_field "$entry" plugin_dir)"

    case "$PROJECT_TYPE" in
        plugin-external)
            PLUGIN_NAME="$(basename "$proj_path")"
            PLUGIN_REPO_PATH="$proj_path"
            local parent_entry
            parent_entry="$(read_project "$parent")" || die "Parent project '$parent' not found."
            PARENT_PROJECT_ROOT="$(read_project_field "$parent_entry" path)"
            PARENT_PROJECT_SLUG="$(read_project_field "$parent_entry" name)"
            ;;
        plugin-embedded)
            PLUGIN_NAME="$(basename "$plugin_dir")"
            PLUGIN_DIR="$plugin_dir"
            ;;
    esac
}

activate_plugin() {
    local compose_project="$1" plugin_name="$2"
    info "Activating plugin: $plugin_name"
    run_app_command "$compose_project" \
        "$SW_BIN_CONSOLE plugin:refresh" || warn "plugin:refresh failed."
    run_app_command "$compose_project" \
        "$SW_BIN_CONSOLE plugin:install --activate $plugin_name" \
        || warn "Plugin activation failed for '$plugin_name'."
}

setup_plugin_database() {
    # Clone a separate DB for a plugin issue (no full provision — just the DB).
    local source_db
    source_db="$(sanitize_db_identifier "$SW_DB_SHARED_NAME")"
    DB_NAME="$(sanitize_db_identifier "${SW_DB_NAME_PREFIX}_${ISSUE_ID}")"

    if mysql_db_has_tables "$DB_NAME"; then
        DB_STATE="cloned"
        info "Database '$DB_NAME' already exists. Reusing."
    elif mysql_db_has_tables "$source_db"; then
        DB_STATE="cloned"
        info "Cloning database '$source_db' → '$DB_NAME'..."
        clone_database "$source_db" "$DB_NAME"
        ok "Database cloned."
    else
        DB_STATE="fresh"
        info "Source database '$source_db' is empty. Creating fresh database."
        create_database "$DB_NAME"
    fi
}

ensure_platform_worktree() {
    # For external plugins: create or reuse a platform worktree from the parent project.
    # Sets PLATFORM_WORKTREE_PATH, loads parent config, and provisions if new.
    local issue_id="$1"
    local branch="$2"
    local parent_meta
    parent_meta="$(instance_dir "$PARENT_PROJECT_SLUG")/${issue_id}.env"

    if [ -f "$parent_meta" ]; then
        # Reuse existing platform worktree
        local saved_project_type="$PROJECT_TYPE"
        local saved_plugin_name="$PLUGIN_NAME"
        local saved_plugin_repo="$PLUGIN_REPO_PATH"
        load_instance_metadata "$parent_meta"
        PLATFORM_WORKTREE_PATH="$WORKTREE_PATH"
        PLATFORM_ISSUE_ID="$ISSUE_ID"
        # Restore plugin context
        PROJECT_TYPE="$saved_project_type"
        PLUGIN_NAME="$saved_plugin_name"
        PLUGIN_REPO_PATH="$saved_plugin_repo"
        info "Reusing existing platform worktree: $PLATFORM_WORKTREE_PATH"
        return 0
    fi

    # Create new platform worktree by loading parent config and running the platform flow
    info "Creating platform worktree for parent project '$PARENT_PROJECT_SLUG'."
    load_project_config "$PARENT_PROJECT_ROOT/.swctl.conf"

    ISSUE_ID="$(sanitize_slug "$ISSUE")"
    WORKTREE_ID="$ISSUE_ID"
    BASE_REF="$(git_base_ref)"
    COMPOSE_PROJECT="$(sanitize_slug "${SW_PROJECT_SLUG}-${ISSUE_ID}")"

    if [ "$SW_RUNTIME" = "orbstack" ]; then
        DOMAIN="${SW_SERVICE_NAME}.${COMPOSE_PROJECT}.orb.local"
        APP_URL="http://${DOMAIN}"
    else
        DOMAIN="${SW_PROJECT_SLUG}-${ISSUE_ID}.${SW_DOMAIN_SUFFIX}"
        APP_URL="http://${DOMAIN}"
    fi

    TRAEFIK_ROUTER="$(sanitize_router_id "${SW_PROJECT_SLUG}_${ISSUE_ID}")"
    TRAEFIK_SERVICE="$TRAEFIK_ROUTER"
    WORKTREE_PATH="${SW_WORKTREE_ROOT}/${SW_WORKTREE_PREFIX}-${ISSUE_ID}"

    create_worktree

    DIFF_FILES="$(git -C "$PROJECT_ROOT" diff --name-only "${BASE_REF}...${BRANCH}" 2>/dev/null || true)"
    count_changes "$DIFF_FILES"
    sync_build_artifacts
    sync_worktree_deps
    VENDOR_VOLUME="$(resolve_vendor_volume "$ISSUE_ID")"
    NODE_MODULES_VOLUME="$(resolve_node_modules_volume "$ISSUE_ID")"

    provision_database_and_app "$COMPOSE_PROJECT"
    run_frontend_build_if_needed "$COMPOSE_PROJECT" 1

    PLATFORM_WORKTREE_PATH="$WORKTREE_PATH"
    PLATFORM_ISSUE_ID="$ISSUE_ID"

    # Write platform metadata (will be updated later with plugin linkage)
    write_metadata "$(instance_file "$SW_PROJECT_SLUG" "$ISSUE_ID")"
    ok "Platform worktree ready: $PLATFORM_WORKTREE_PATH"
}

list_available_plugins() {
    # List plugins with their own git repo in <project_root>/custom/plugins/*
    local project_root="$1"
    local plugins_dir="$project_root/custom/plugins"
    [ -d "$plugins_dir" ] || return 0
    for plugin_path in "$plugins_dir"/*/; do
        [ -d "$plugin_path" ] || continue
        local pname
        pname="$(basename "$plugin_path")"
        [ "$pname" = "*" ] && continue
        [ -f "$plugin_path/composer.json" ] || continue
        if [ -d "$plugin_path/.git" ]; then
            printf '%s\n' "$pname"
        fi
    done
}

cmd_create() {
    SWCTL_MODE="${SWCTL_MODE:-dev}"
    local selected_project=""
    local selected_plugin=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --qa)      SWCTL_MODE="qa"; shift ;;
            --dev)     SWCTL_MODE="dev"; shift ;;
            --project) selected_project="$2"; shift 2 ;;
            --plugin)  selected_plugin="$2"; shift 2 ;;
            *)         break ;;
        esac
    done
    export SWCTL_MODE
    ISSUE="${1:-}"
    BRANCH="${2:-}"
    [ -n "$ISSUE" ] || die "Usage: swctl create [--qa|--dev] [--project <name>] [--plugin <name>] <issue> [<branch>]"

    if [ -z "$BRANCH" ]; then
        if [ "$SWCTL_MODE" = "qa" ]; then
            die "QA mode requires a branch: swctl create --qa <issue> <branch>"
        fi
        # Dev mode: prompt for new branch name
        BRANCH="$(prompt_text "New branch name for issue '$ISSUE'")"
        [ -n "$BRANCH" ] || die "Branch name cannot be empty."
        info "Will create new branch '$BRANCH' from ${SW_BASE_BRANCH:-trunk}."
    fi

    require_cmd git
    ensure_docker

    # Resolve project context (platform vs plugin)
    resolve_project_context "$selected_project"

    # If --plugin was given with a platform project, set up plugin-external context dynamically
    if [ -n "$selected_plugin" ]; then
        if [ "$PROJECT_TYPE" != "platform" ]; then
            die "--plugin can only be used with a platform project, not '$PROJECT_TYPE'."
        fi
        local plugin_repo_path="${SELECTED_PROJECT_PATH:-$PROJECT_ROOT}/custom/plugins/$selected_plugin"
        [ -d "$plugin_repo_path" ] || die "Plugin not found: $plugin_repo_path"
        [ -d "$plugin_repo_path/.git" ] || die "Plugin '$selected_plugin' has no git repository at: $plugin_repo_path"
        PROJECT_TYPE="plugin-external"
        PLUGIN_NAME="$selected_plugin"
        PLUGIN_REPO_PATH="$(cd "$plugin_repo_path" && pwd -P)"
        # Read parent info from the platform project
        local parent_entry
        parent_entry="$(read_project "$selected_project")" || die "Project '$selected_project' not registered."
        PARENT_PROJECT_ROOT="$(read_project_field "$parent_entry" path)"
        PARENT_PROJECT_SLUG="$(read_project_field "$parent_entry" name)"
    fi

    # If --project was given, use the registered path to locate .swctl.conf
    local project_config_arg=""
    if [ -n "${SELECTED_PROJECT_PATH:-}" ]; then
        project_config_arg="$SELECTED_PROJECT_PATH/.swctl.conf"
    fi

    case "$PROJECT_TYPE" in
        plugin-external)
            info "Plugin (external): $PLUGIN_NAME → parent: $PARENT_PROJECT_SLUG"
            load_project_config "$PARENT_PROJECT_ROOT/.swctl.conf"
            ensure_infra_ready

            ISSUE_ID="$(sanitize_slug "$ISSUE")"
            WORKTREE_ID="$ISSUE_ID"

            # Write early metadata for the plugin instance
            local plugin_slug
            plugin_slug="$(sanitize_slug "$PLUGIN_NAME")"
            SWCTL_ACTIVE_META_FILE="$(instance_file "$plugin_slug" "$ISSUE_ID")"
            STATUS="creating"
            FAILED_AT=""
            DB_NAME="${DB_NAME:-}"
            DB_STATE="${DB_STATE:-}"
            VENDOR_VOLUME="${VENDOR_VOLUME:-}"
            NODE_MODULES_VOLUME="${NODE_MODULES_VOLUME:-}"
            MIGRATION_CHANGES="${MIGRATION_CHANGES:-0}"
            ENTITY_CHANGES="${ENTITY_CHANGES:-0}"
            FRONTEND_CHANGES="${FRONTEND_CHANGES:-0}"
            WORKTREE_PATH=""
            write_metadata "$SWCTL_ACTIVE_META_FILE"

            trap 'if [ "${STATUS:-}" = "creating" ]; then STATUS=failed; FAILED_AT="${SWCTL_LAST_ERROR:-unknown}"; write_metadata "$SWCTL_ACTIVE_META_FILE" 2>/dev/null; fi' EXIT

            # Use trunk code — no platform git worktree needed
            PLATFORM_WORKTREE_PATH="$PARENT_PROJECT_ROOT"
            PLATFORM_ISSUE_ID="trunk"
            WORKTREE_PATH="$PARENT_PROJECT_ROOT"

            # Each plugin issue gets its own compose project (separate container + DB)
            COMPOSE_PROJECT="$(sanitize_slug "${plugin_slug}-${ISSUE_ID}")"

            if [ "$SW_RUNTIME" = "orbstack" ]; then
                DOMAIN="${SW_SERVICE_NAME}.${COMPOSE_PROJECT}.orb.local"
                APP_URL="http://${DOMAIN}"
            else
                DOMAIN="${plugin_slug}-${ISSUE_ID}.${SW_DOMAIN_SUFFIX}"
                APP_URL="http://${DOMAIN}"
            fi
            TRAEFIK_ROUTER="$(sanitize_router_id "${plugin_slug}_${ISSUE_ID}")"
            TRAEFIK_SERVICE="$TRAEFIK_ROUTER"

            # 1. Clone a separate database for this plugin issue
            setup_plugin_database

            # 2. Reuse trunk's vendor/node_modules volumes
            VENDOR_VOLUME="$(resolve_vendor_volume "base")"
            NODE_MODULES_VOLUME="$(resolve_node_modules_volume "base")"

            # 3. Write compose env file (passes DB_NAME, APP_URL, etc. to container)
            write_compose_env_file

            # 4. Create plugin worktree from plugin repo
            local plugin_issue_id
            plugin_issue_id="$ISSUE_ID"
            PLUGIN_WORKTREE_PATH="${SW_WORKTREE_ROOT}/${PLUGIN_NAME}-${plugin_issue_id}"

            if [ ! -d "$PLUGIN_WORKTREE_PATH" ]; then
                info "Creating plugin worktree: $PLUGIN_WORKTREE_PATH"
                git -C "$PLUGIN_REPO_PATH" fetch --all --prune 2>/dev/null || true
                if git -C "$PLUGIN_REPO_PATH" rev-parse --verify "origin/$BRANCH" >/dev/null 2>&1; then
                    git -C "$PLUGIN_REPO_PATH" worktree add "$PLUGIN_WORKTREE_PATH" -b "swctl/${plugin_issue_id}" "origin/$BRANCH" 2>/dev/null \
                        || git -C "$PLUGIN_REPO_PATH" worktree add "$PLUGIN_WORKTREE_PATH" "origin/$BRANCH" 2>/dev/null \
                        || die "Failed to create plugin worktree."
                elif git -C "$PLUGIN_REPO_PATH" rev-parse --verify "$BRANCH" >/dev/null 2>&1; then
                    git -C "$PLUGIN_REPO_PATH" worktree add "$PLUGIN_WORKTREE_PATH" "$BRANCH" 2>/dev/null \
                        || die "Failed to create plugin worktree."
                else
                    die "Branch '$BRANCH' not found in plugin repo: $PLUGIN_REPO_PATH"
                fi
                ok "Plugin worktree created: $PLUGIN_WORKTREE_PATH"
            else
                info "Plugin worktree already exists: $PLUGIN_WORKTREE_PATH"
            fi

            # 5. Track plugin linkage + write compose volume override (mounts plugin)
            LINKED_PLUGINS="$PLUGIN_NAME"
            PLUGIN_WORKTREE_PATHS="$PLUGIN_WORKTREE_PATH"
            write_compose_volume_override

            # 6. Start container (new compose project: trunk code + plugin mount + cloned DB)
            compose --project-directory "$SWCTL_TMP_DIR" $(compose_file_args) --env-file "$COMPOSE_ENV_FILE" -p "$COMPOSE_PROJECT" up -d
            wait_for_app_container "$COMPOSE_PROJECT"

            # 7. No write_env_file — DATABASE_URL is passed via compose environment
            #    (avoids clobbering trunk's .env.local when multiple plugins run)

            # 8. Run install/migrations if needed on the cloned DB
            bootstrap_dependencies "$COMPOSE_PROJECT"
            if [ "$DB_STATE" = "fresh" ]; then
                run_install_command "$COMPOSE_PROJECT" "$SW_INSTALL_ARGS"
            fi

            # 9. Activate plugin
            activate_plugin "$COMPOSE_PROJECT" "$PLUGIN_NAME"

            update_sales_channel_domain "$COMPOSE_PROJECT" "$APP_URL"
            ensure_install_lock "$COMPOSE_PROJECT"
            run_app_command "$COMPOSE_PROJECT" "$SW_BIN_CONSOLE cache:clear" || warn "cache:clear failed."

            # 10. Write final metadata
            STATUS="complete"
            FAILED_AT=""
            trap - EXIT
            write_metadata "$SWCTL_ACTIVE_META_FILE"

            ok "Plugin '$PLUGIN_NAME' is ready."
            info "URL: ${APP_URL}"
            info "Platform: ${PLATFORM_WORKTREE_PATH} (trunk — no worktree)"
            info "Plugin: ${PLUGIN_WORKTREE_PATH}"
            info "Database: ${DB_NAME}"
            ;;

        plugin-embedded)
            info "Plugin (embedded): $PLUGIN_NAME"
            load_project_config ${project_config_arg:+"$project_config_arg"}
            ensure_infra_ready

            git -C "$PROJECT_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "Project root is not a Git repository: $PROJECT_ROOT"

            ISSUE_ID="$(sanitize_slug "$ISSUE")"
            WORKTREE_ID="$ISSUE_ID"
            BASE_REF="$(git_base_ref)"
            COMPOSE_PROJECT="$(sanitize_slug "${SW_PROJECT_SLUG}-${ISSUE_ID}")"

            if [ "$SW_RUNTIME" = "orbstack" ]; then
                DOMAIN="${SW_SERVICE_NAME}.${COMPOSE_PROJECT}.orb.local"
                APP_URL="http://${DOMAIN}"
            else
                DOMAIN="${SW_PROJECT_SLUG}-${ISSUE_ID}.${SW_DOMAIN_SUFFIX}"
                APP_URL="http://${DOMAIN}"
            fi

            TRAEFIK_ROUTER="$(sanitize_router_id "${SW_PROJECT_SLUG}_${ISSUE_ID}")"
            TRAEFIK_SERVICE="$TRAEFIK_ROUTER"
            WORKTREE_PATH="${SW_WORKTREE_ROOT}/${SW_WORKTREE_PREFIX}-${ISSUE_ID}"

            # Write early metadata so failed creates are tracked
            SWCTL_ACTIVE_META_FILE="$(instance_file "$SW_PROJECT_SLUG" "$ISSUE_ID")"
            STATUS="creating"
            FAILED_AT=""
            DB_NAME="${DB_NAME:-}"
            DB_STATE="${DB_STATE:-}"
            VENDOR_VOLUME="${VENDOR_VOLUME:-}"
            NODE_MODULES_VOLUME="${NODE_MODULES_VOLUME:-}"
            MIGRATION_CHANGES="${MIGRATION_CHANGES:-0}"
            ENTITY_CHANGES="${ENTITY_CHANGES:-0}"
            FRONTEND_CHANGES="${FRONTEND_CHANGES:-0}"
            write_metadata "$SWCTL_ACTIVE_META_FILE"

            trap 'if [ "${STATUS:-}" = "creating" ]; then STATUS=failed; FAILED_AT="${SWCTL_LAST_ERROR:-unknown}"; write_metadata "$SWCTL_ACTIVE_META_FILE" 2>/dev/null; fi' EXIT

            create_worktree
            check_branch_staleness

            # Diff analysis — focus on plugin directory for change detection
            DIFF_FILES="$(git -C "$PROJECT_ROOT" diff --name-only "${BASE_REF}...${BRANCH}" || true)"
            count_changes "$DIFF_FILES"

            sync_build_artifacts
            sync_worktree_deps
            VENDOR_VOLUME="$(resolve_vendor_volume "$ISSUE_ID")"
            NODE_MODULES_VOLUME="$(resolve_node_modules_volume "$ISSUE_ID")"

            info "Mode: ${SWCTL_MODE} | Plugin: ${PLUGIN_NAME}"
            info "Strategy: vendor=${VENDOR_VOLUME} node_modules=${NODE_MODULES_VOLUME}"

            provision_database_and_app "$COMPOSE_PROJECT"
            run_frontend_build_if_needed "$COMPOSE_PROJECT" 1
            activate_plugin "$COMPOSE_PROJECT" "$PLUGIN_NAME"

            STATUS="complete"
            FAILED_AT=""
            trap - EXIT
            write_metadata "$SWCTL_ACTIVE_META_FILE"

            ok "Worktree '${WORKTREE_ID}' with plugin '${PLUGIN_NAME}' is ready."
            info "URL: ${APP_URL}"
            info "Worktree: ${WORKTREE_PATH}"
            ;;

        platform|*)
            # --- Original platform flow ---
            load_project_config ${project_config_arg:+"$project_config_arg"}
            ensure_infra_ready

            git -C "$PROJECT_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "Project root is not a Git repository: $PROJECT_ROOT"

            ISSUE_ID="$(sanitize_slug "$ISSUE")"
            WORKTREE_ID="$ISSUE_ID"
            BASE_REF="$(git_base_ref)"
            COMPOSE_PROJECT="$(sanitize_slug "${SW_PROJECT_SLUG}-${ISSUE_ID}")"

            if [ "$SW_RUNTIME" = "orbstack" ]; then
                DOMAIN="${SW_SERVICE_NAME}.${COMPOSE_PROJECT}.orb.local"
                APP_URL="http://${DOMAIN}"
            else
                DOMAIN="${SW_PROJECT_SLUG}-${ISSUE_ID}.${SW_DOMAIN_SUFFIX}"
                APP_URL="http://${DOMAIN}"
            fi

            TRAEFIK_ROUTER="$(sanitize_router_id "${SW_PROJECT_SLUG}_${ISSUE_ID}")"
            TRAEFIK_SERVICE="$TRAEFIK_ROUTER"
            WORKTREE_PATH="${SW_WORKTREE_ROOT}/${SW_WORKTREE_PREFIX}-${ISSUE_ID}"

            # Write early metadata so failed creates are tracked
            SWCTL_ACTIVE_META_FILE="$(instance_file "$SW_PROJECT_SLUG" "$ISSUE_ID")"
            STATUS="creating"
            FAILED_AT=""
            DB_NAME="${DB_NAME:-}"
            DB_STATE="${DB_STATE:-}"
            VENDOR_VOLUME="${VENDOR_VOLUME:-}"
            NODE_MODULES_VOLUME="${NODE_MODULES_VOLUME:-}"
            MIGRATION_CHANGES="${MIGRATION_CHANGES:-0}"
            ENTITY_CHANGES="${ENTITY_CHANGES:-0}"
            FRONTEND_CHANGES="${FRONTEND_CHANGES:-0}"
            write_metadata "$SWCTL_ACTIVE_META_FILE"

            # On any exit while STATUS=creating, mark as failed
            trap 'if [ "${STATUS:-}" = "creating" ]; then STATUS=failed; FAILED_AT="${SWCTL_LAST_ERROR:-unknown}"; write_metadata "$SWCTL_ACTIVE_META_FILE" 2>/dev/null; fi' EXIT

            local step_start create_start
            create_start=$SECONDS

            step_start=$SECONDS
            create_worktree
            check_branch_staleness
            info "[timing] create_worktree: $((SECONDS - step_start))s"

            step_start=$SECONDS
            DIFF_FILES="$(git -C "$PROJECT_ROOT" diff --name-only "${BASE_REF}...${BRANCH}" || true)"
            count_changes "$DIFF_FILES"
            info "[timing] count_changes: $((SECONDS - step_start))s"

            step_start=$SECONDS
            sync_build_artifacts
            sync_worktree_deps
            VENDOR_VOLUME="$(resolve_vendor_volume "$ISSUE_ID")"
            NODE_MODULES_VOLUME="$(resolve_node_modules_volume "$ISSUE_ID")"
            info "[timing] sync: $((SECONDS - step_start))s"

            info "Mode: ${SWCTL_MODE} | Diff: migrations=${MIGRATION_CHANGES} entity=${ENTITY_CHANGES} admin=${ADMIN_CHANGES} storefront=${STOREFRONT_CHANGES} composer=${COMPOSER_CHANGES} package=${PACKAGE_CHANGES} backend=${BACKEND_CHANGES}"
            info "Strategy: vendor=${VENDOR_VOLUME} node_modules=${NODE_MODULES_VOLUME}"

            step_start=$SECONDS
            provision_database_and_app "$COMPOSE_PROJECT"
            info "[timing] provision: $((SECONDS - step_start))s"

            step_start=$SECONDS
            run_frontend_build_if_needed "$COMPOSE_PROJECT" 1
            info "[timing] frontend: $((SECONDS - step_start))s"

            # Mark complete and remove EXIT trap
            STATUS="complete"
            FAILED_AT=""
            trap - EXIT
            write_metadata "$SWCTL_ACTIVE_META_FILE"

            ok "Worktree '${WORKTREE_ID}' is ready. (total: $((SECONDS - create_start))s)"
            info "URL: ${APP_URL}"
            info "Worktree: ${WORKTREE_PATH}"
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Batch create
# ---------------------------------------------------------------------------

parse_batch_file() {
    local file="$1"
    [ -f "$file" ] || die "Batch file not found: $file"
    while IFS= read -r line || [ -n "$line" ]; do
        line="${line%%#*}"
        line="$(printf '%s' "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
        [ -n "$line" ] || continue
        printf '%s\n' "$line"
    done < "$file"
}

parse_cli_pairs() {
    while [ $# -ge 2 ]; do
        printf '%s %s\n' "$1" "$2"
        shift 2
    done
}

parse_mr_json() {
    if ! command -v jq >/dev/null 2>&1; then
        die "jq is required for API-based batch create. Install it with: brew install jq"
    fi
    jq -r '.[] | "\(.iid) \(.source_branch)"'
}

parse_pr_json() {
    if ! command -v jq >/dev/null 2>&1; then
        die "jq is required for API-based batch create. Install it with: brew install jq"
    fi
    jq -r '.[] | "\(.number) \(.head.ref)"'
}

fetch_gitlab_mrs() {
    local project_id="$1"
    local api_url="${SWCTL_GITLAB_URL:-https://gitlab.com}/api/v4"
    local token="${SWCTL_GITLAB_TOKEN:-}"

    [ -n "$token" ] || die "SWCTL_GITLAB_TOKEN is not set."

    curl -sSf -H "PRIVATE-TOKEN: $token" \
        "${api_url}/projects/${project_id}/merge_requests?state=opened&per_page=100" \
        | parse_mr_json
}

fetch_github_prs() {
    local repo="$1"
    local token="${SWCTL_GITHUB_TOKEN:-}"
    # Load from token file if not set via env
    if [ -z "$token" ] && [ -f "$SWCTL_GITHUB_TOKEN_FILE" ]; then
        token="$(cat "$SWCTL_GITHUB_TOKEN_FILE")"
    fi
    local auth_header=""

    if [ -n "$token" ]; then
        auth_header="Authorization: token $token"
    fi

    curl -sSf ${auth_header:+-H "$auth_header"} \
        "https://api.github.com/repos/${repo}/pulls?state=open&per_page=100" \
        | parse_pr_json
}

select_from_list() {
    local label="$1"
    local pairs=()

    while IFS= read -r line; do
        [ -n "$line" ] || continue
        pairs+=("$line")
    done

    if [ ${#pairs[@]} -eq 0 ]; then
        warn "No open ${label}s found."
        return 1
    fi

    if command -v fzf >/dev/null 2>&1; then
        printf '%s\n' "${pairs[@]}" | fzf --multi --prompt="Select ${label}s> " --height=40% --reverse
        return
    fi

    local i=1
    for pair in "${pairs[@]}"; do
        printf '  [%d] %s\n' "$i" "$pair"
        i=$((i + 1))
    done
    local selection
    selection="$(prompt_text "Enter numbers (comma-separated, or 'all')")"
    if [ "$selection" = "all" ]; then
        printf '%s\n' "${pairs[@]}"
        return
    fi
    local old_ifs="$IFS"
    IFS=',' read -r -a indices <<< "$selection"
    IFS="$old_ifs"
    local idx
    for idx in "${indices[@]}"; do
        idx="$(printf '%s' "$idx" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
        if [ "$idx" -ge 1 ] 2>/dev/null && [ "$idx" -le "${#pairs[@]}" ]; then
            printf '%s\n' "${pairs[$((idx - 1))]}"
        fi
    done
}

batch_create_sequential() {
    local pairs="$1"
    local job_dir="$2"
    local issue="" branch=""

    while IFS=' ' read -r issue branch; do
        [ -n "$issue" ] && [ -n "$branch" ] || continue
        info "Creating worktree for $issue ($branch)..."
        if cmd_create "$issue" "$branch" >"$job_dir/${issue}.log" 2>&1; then
            touch "$job_dir/${issue}.ok"
            ok "Created $issue"
        else
            touch "$job_dir/${issue}.fail"
            err "Failed $issue"
        fi
    done <<< "$pairs"
}

batch_create_parallel() {
    local pairs="$1"
    local job_dir="$2"
    local max_jobs="${3:-4}"
    local pids=()
    local running=0
    local issue="" branch=""

    while IFS=' ' read -r issue branch; do
        [ -n "$issue" ] && [ -n "$branch" ] || continue

        while [ "$running" -ge "$max_jobs" ]; do
            wait -n 2>/dev/null || true
            running=$((running - 1))
        done

        (
            cmd_create "$issue" "$branch" >"$job_dir/${issue}.log" 2>&1 \
                && touch "$job_dir/${issue}.ok" \
                || touch "$job_dir/${issue}.fail"
        ) &

        pids+=($!)
        running=$((running + 1))
        info "Started background job for $issue (PID $!)"
    done <<< "$pairs"

    local pid
    for pid in "${pids[@]}"; do
        wait "$pid" 2>/dev/null || true
    done
}

cmd_batch_create() {
    local pairs=""
    local parallel=0
    local max_jobs=4
    SWCTL_MODE="${SWCTL_MODE:-dev}"
    export SWCTL_MODE

    while [ $# -gt 0 ]; do
        case "$1" in
            --qa)
                SWCTL_MODE="qa"; shift ;;
            --dev)
                SWCTL_MODE="dev"; shift ;;
            --file|-f)
                shift
                [ -n "${1:-}" ] || die "Missing argument for --file."
                pairs="$(parse_batch_file "$1")"
                shift
                ;;
            --gitlab)
                shift
                [ -n "${1:-}" ] || die "Missing argument for --gitlab."
                pairs="$(fetch_gitlab_mrs "$1" | select_from_list "MR")"
                shift
                ;;
            --github)
                shift
                [ -n "${1:-}" ] || die "Missing argument for --github."
                pairs="$(fetch_github_prs "$1" | select_from_list "PR")"
                shift
                ;;
            --parallel|-p)
                parallel=1
                shift
                ;;
            --jobs|-j)
                shift
                [ -n "${1:-}" ] || die "Missing argument for --jobs."
                max_jobs="$1"
                shift
                ;;
            -*)
                die "Unknown flag: $1"
                ;;
            *)
                pairs="$(parse_cli_pairs "$@")"
                break
                ;;
        esac
    done

    [ -n "$pairs" ] || die "No issue/branch pairs provided.\nUsage: swctl batch create [--file <path>|--gitlab <id>|--github <owner/repo>] [--parallel [-j N]] [ISSUE BRANCH ...]"

    # In QA mode, skip pairs without a branch (no linked PR/MR)
    if [ "$SWCTL_MODE" = "qa" ]; then
        local filtered=""
        local skipped=0
        while IFS=' ' read -r issue branch; do
            [ -n "$issue" ] || continue
            if [ -z "$branch" ]; then
                warn "Skipping issue '$issue': no linked PR/MR (QA mode)."
                skipped=$((skipped + 1))
                continue
            fi
            filtered="${filtered:+$filtered
}$issue $branch"
        done <<< "$pairs"
        [ "$skipped" -gt 0 ] && warn "Skipped $skipped issue(s) with no linked branch."
        pairs="$filtered"
        [ -n "$pairs" ] || die "No issue/branch pairs remaining after filtering (all lacked linked PRs)."
    fi

    local total=0
    local succeeded=0
    local failed=0
    local job_dir="$SWCTL_TMP_DIR/batch.$$"
    mkdir -p "$job_dir"
    trap 'rm -rf "$job_dir"' EXIT

    total="$(printf '%s\n' "$pairs" | grep -c '.' || true)"
    info "Batch creating $total worktree(s)$([ "$parallel" -eq 1 ] && printf ' in parallel (max %s jobs)' "$max_jobs")."

    if [ "$parallel" -eq 1 ]; then
        batch_create_parallel "$pairs" "$job_dir" "$max_jobs"
    else
        batch_create_sequential "$pairs" "$job_dir"
    fi

    succeeded="$(find "$job_dir" -name '*.ok' 2>/dev/null | wc -l | tr -d ' ')"
    failed="$(find "$job_dir" -name '*.fail' 2>/dev/null | wc -l | tr -d ' ')"

    printf '\n'
    ok "Batch complete: $succeeded succeeded, $failed failed out of $total."

    local fail_file issue_id
    for fail_file in "$job_dir"/*.fail; do
        [ -f "$fail_file" ] || continue
        issue_id="$(basename "$fail_file" .fail)"
        err "Failed: $issue_id"
        cat "$job_dir/${issue_id}.log" >&2
    done

    rm -rf "$job_dir"
    trap - EXIT
    [ "$failed" -eq 0 ]
}

cmd_batch() {
    local subcmd="${1:-}"
    shift || true

    case "$subcmd" in
        create) cmd_batch_create "$@" ;;
        *)      die "Usage: swctl batch create [--file <path>|--gitlab <id>|--github <owner/repo>] [--parallel [-j N]] [ISSUE BRANCH ...]" ;;
    esac
}

truncate_text() {
    local max="$1"
    local value="$2"
    if [ "${#value}" -le "$max" ]; then
        printf '%s' "$value"
        return
    fi
    if [ "$max" -le 3 ]; then
        printf '%s' "${value:0:$max}"
        return
    fi
    printf '%s...' "${value:0:$((max - 3))}"
}

status_label() {
    local compose_project="$1"
    if [ -n "$(app_container_id "$compose_project")" ]; then
        printf '%b● Running%b' "$COLOR_GREEN" "$COLOR_RESET"
        return
    fi

    if [ -n "$(app_container_exists_any_state "$compose_project")" ]; then
        printf '%b○ Stopped%b' "$COLOR_RED" "$COLOR_RESET"
        return
    fi

    printf '%b○ Missing%b' "$COLOR_YELLOW" "$COLOR_RESET"
}

render_status_table() {
    local scope="${1:-all}"
    local file=""
    local found=0

    printf '%-24s %-4s %-40s %-16s %-8s\n' "Issue" "Mode" "Domain" "Container" "DB"
    printf '%-24s %-4s %-40s %-16s %-8s\n' "------------------------" "----" "----------------------------------------" "----------------" "--------"

    while IFS= read -r file; do
        [ -n "$file" ] || continue
        found=1
        load_instance_metadata "$file"
        printf '%-24s %-4s %-40s %-16b %-8s\n' \
            "$(truncate_text 24 "$ISSUE_ID")" \
            "${SWCTL_MODE:-dev}" \
            "$(truncate_text 40 "$DOMAIN")" \
            "$(status_label "$COMPOSE_PROJECT")" \
            "$DB_STATE"
    done <<EOF
$(list_instance_files "$scope")
EOF

    if [ "$found" -eq 0 ]; then
        printf '%s\n' "No tracked worktrees."
    fi
}

cmd_status() {
    if maybe_load_project_config >/dev/null 2>&1; then
        render_status_table "project"
        return
    fi

    render_status_table "all"
}

cmd_exec() {
    local issue_input="${1:-}"
    local command_string="${2:-}"
    local meta_file=""

    [ -n "$issue_input" ] || die "Usage: swctl exec <issue> '<cmd>'"
    [ -n "$command_string" ] || die "Usage: swctl exec <issue> '<cmd>'"

    maybe_load_project_config >/dev/null 2>&1 || true
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || die "No tracked worktree found for issue '$issue_input'."
    load_instance_metadata "$meta_file"

    # Vite watch commands proxy /api to APP_URL, but inside the container
    # APP_URL resolves to the container's own IP on port 80 while Caddy
    # listens on port 8000. Override APP_URL for the Vite process only.
    case "$command_string" in
        *watch:admin*|*watch:storefront*|*"npm run dev"*)
            command_string="APP_URL=http://localhost:8000 $command_string"
            ;;
    esac

    run_app_command "$COMPOSE_PROJECT" "$command_string"
}

