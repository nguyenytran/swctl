}

install_admin_deps_if_needed() {
    local compose_project="$1"
    local admin_pkg="src/Administration/Resources/app/administration/package.json"
    local storefront_pkg="src/Storefront/Resources/app/storefront/package.json"

    # If worktree's admin/storefront package.json differs from trunk's, the cloned
    # node_modules from trunk is missing new deps. Run npm install inside the container.
    local needs_admin=0 needs_storefront=0

    if [ -f "$WORKTREE_PATH/$admin_pkg" ] && [ -f "$PROJECT_ROOT/$admin_pkg" ]; then
        if ! diff -q "$PROJECT_ROOT/$admin_pkg" "$WORKTREE_PATH/$admin_pkg" >/dev/null 2>&1; then
            needs_admin=1
        fi
    fi
    if [ -f "$WORKTREE_PATH/$storefront_pkg" ] && [ -f "$PROJECT_ROOT/$storefront_pkg" ]; then
        if ! diff -q "$PROJECT_ROOT/$storefront_pkg" "$WORKTREE_PATH/$storefront_pkg" >/dev/null 2>&1; then
            needs_storefront=1
        fi
    fi

    if [ "$needs_admin" -eq 1 ]; then
        info "Admin package.json differs from trunk. Running npm install for admin."
        run_app_command "$compose_project" "cd src/Administration/Resources/app/administration && npm install --no-audit --no-fund" \
            || warn "Admin npm install failed."
    fi
    if [ "$needs_storefront" -eq 1 ]; then
        info "Storefront package.json differs from trunk. Running npm install for storefront."
        run_app_command "$compose_project" "cd src/Storefront/Resources/app/storefront && npm install --no-audit --no-fund" \
            || warn "Storefront npm install failed."
    fi
}

run_frontend_build_if_needed() {
    local compose_project="$1"
    local is_first_create="${2:-0}"
    local force_plugin_build="${3:-0}"

    # Delegate to workflow build hook if available
    if [ -n "${SWCTL_WORKFLOW_DIR:-}" ] && [ -f "$SWCTL_WORKFLOW_DIR/hooks/build.sh" ]; then
        FORCE_PLUGIN_BUILD="$force_plugin_build" run_workflow_hook "build"
        return
    fi

    # QA mode: all frontend assets are synced from project root. No builds needed
    # UNLESS a plugin has admin/storefront extensions that weren't in the synced
    # assets (force_plugin_build=1).
    if [ "$SWCTL_MODE" = "qa" ] && [ "$force_plugin_build" -ne 1 ]; then
        info "QA mode: skipping frontend builds (using synced assets)."
        return
    fi

    # Install missing deps when worktree's package.json diverged from trunk
    install_admin_deps_if_needed "$compose_project"

    local needs_admin_build=0
    local needs_storefront_build=0

    # Only build if actual code changes — synced artifacts from trunk handle the baseline.
    if [ "${ADMIN_CHANGES:-0}" -gt 0 ]; then
        needs_admin_build=1
    fi
    if [ "${STOREFRONT_CHANGES:-0}" -gt 0 ]; then
        needs_storefront_build=1
    fi

    if [ "$needs_admin_build" -eq 1 ] || [ "$needs_storefront_build" -eq 1 ]; then
        info "Frontend changes detected. Running bundle:dump."
        run_app_command "$compose_project" "$SW_BIN_CONSOLE bundle:dump" || warn "bundle:dump failed."

        if [ "$needs_admin_build" -eq 1 ] && [ "$needs_storefront_build" -eq 1 ]; then
            # composer build:js:admin and build:js:storefront each run
            # bundle:dump + feature:dump + npm build + assets:install.
            # Running them separately duplicates the shared PHP steps.
            # Instead: run shared prep once, npm builds in parallel, cleanup once.
            info "Admin + Storefront changes detected. Building with parallel npm."
            run_app_command "$compose_project" "$SW_BIN_CONSOLE feature:dump" || warn "feature:dump failed."
            run_app_command "$compose_project" "$SW_BIN_CONSOLE admin:generate-entity-schema-types" 2>/dev/null || true
            run_app_command "$compose_project" 'set -e
ADMIN_DIR=src/Administration/Resources/app/administration
STOREFRONT_DIR=src/Storefront/Resources/app/storefront
export PROJECT_ROOT="$PWD"

# Admin npm build (background)
( cd "$ADMIN_DIR" && export PATH="$PWD/node_modules/.bin:$PATH" && npm run build ) &
ADMIN_PID=$!

# Storefront npm build (background)
( cd "$STOREFRONT_DIR" && export PATH="$PWD/node_modules/.bin:$PATH" && npm run production ) &
STOREFRONT_PID=$!

# Wait for both
ADMIN_OK=0; STOREFRONT_OK=0
wait $ADMIN_PID || ADMIN_OK=1
wait $STOREFRONT_PID || STOREFRONT_OK=1

# Storefront post-steps
cd "$STOREFRONT_DIR" && node copy-to-vendor.js
cd "$PROJECT_ROOT"

[ $ADMIN_OK -eq 0 ] || echo "[WARN] Admin npm build failed."
[ $STOREFRONT_OK -eq 0 ] || echo "[WARN] Storefront npm build failed."
exit $((ADMIN_OK + STOREFRONT_OK))
' || warn "Parallel JS build had errors."
            run_app_command "$compose_project" "$SW_BIN_CONSOLE theme:compile --sync" 2>/dev/null || true
            run_app_command "$compose_project" "$SW_BIN_CONSOLE assets:install" || warn "assets:install failed."
        elif [ "$needs_admin_build" -eq 1 ]; then
            info "Admin changes detected. Running composer build:js:admin."
            run_app_command "$compose_project" "composer build:js:admin" || warn "Admin JS build failed."
        else
            info "Storefront changes detected. Running composer build:js:storefront."
            run_app_command "$compose_project" "composer build:js:storefront" || warn "Storefront JS build failed."
        fi
    else
        # No frontend changes — register synced assets. Skip full JS builds.
        run_app_command "$compose_project" "$SW_BIN_CONSOLE bundle:dump" 2>/dev/null || true
        run_app_command "$compose_project" "$SW_BIN_CONSOLE assets:install" 2>/dev/null || true
        info "Assets registered from synced files. No frontend builds needed."
    fi

    # Clear cache for any code change
    if [ "$((BACKEND_CHANGES + ADMIN_CHANGES + STOREFRONT_CHANGES + COMPOSER_CHANGES + PACKAGE_CHANGES))" -gt 0 ] && [ "${DB_STATE:-}" != "fresh" ]; then
        run_app_command "$compose_project" "$SW_BIN_CONSOLE cache:clear" || warn "cache:clear failed."
    fi
}

create_database() {
    local db_name="$1"
    mysql_exec "DROP DATABASE IF EXISTS \`${db_name}\`; CREATE DATABASE \`${db_name}\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;"
}


clone_database() {
    local source_db="$1"
    local target_db="$2"
    local db_container
    db_container="$(resolve_db_container)"

    info "Cloning database '$source_db' → '$target_db'."
    docker exec -i "$db_container" bash -c \
        "mariadb -u '$SW_DB_ROOT_USER' -p'$SW_DB_ROOT_PASSWORD' -e 'DROP DATABASE IF EXISTS \`$target_db\`; CREATE DATABASE \`$target_db\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;' && mariadb-dump -u '$SW_DB_ROOT_USER' -p'$SW_DB_ROOT_PASSWORD' --single-transaction --quick '$source_db' | mariadb -u '$SW_DB_ROOT_USER' -p'$SW_DB_ROOT_PASSWORD' '$target_db'" \
        || die "Database clone failed."
    ok "Database cloned: $target_db"
}

provision_database_and_app() {
    local compose_project="$1"
    local source_db
    source_db="$(sanitize_db_identifier "$SW_DB_SHARED_NAME")"

    # Every worktree gets its own cloned database (never touches the source).
    DB_NAME="$(sanitize_db_identifier "${SW_DB_NAME_PREFIX}_${ISSUE_ID}")"

    # Determine DB_STATE early so the compose override can adjust mount modes
    # (fresh installs need writable media mounts for system:install).
    if mysql_db_has_tables "$DB_NAME"; then
        DB_STATE="cloned"
    elif mysql_db_has_tables "$source_db"; then
        DB_STATE="cloned"
    else
        DB_STATE="fresh"
    fi

    # Write configs (needed by both DB clone and compose up)
    write_env_file
    write_compose_env_file
    write_compose_volume_override

    # Clone DB and start container.
    # Database operations are serialized per DB host to prevent concurrent
    # CREATE/DROP/DUMP from overloading MariaDB (parallel dumps cause lock contention).
    if [ "$DB_STATE" = "fresh" ]; then
        info "Source database '$source_db' is empty. Will run fresh install."
        swctl_lock "db-$SW_DB_HOST" create_database "$DB_NAME"
        compose --project-directory "$SWCTL_TMP_DIR" $(compose_file_args) --env-file "$COMPOSE_ENV_FILE" -p "$COMPOSE_PROJECT" up -d
    elif mysql_db_has_tables "$DB_NAME"; then
        info "Database '$DB_NAME' already exists. Reusing."
        compose --project-directory "$SWCTL_TMP_DIR" $(compose_file_args) --env-file "$COMPOSE_ENV_FILE" -p "$COMPOSE_PROJECT" up -d
    else
        # Clone DB in background while container starts
        swctl_lock "db-$SW_DB_HOST" clone_database "$source_db" "$DB_NAME" &
        local clone_pid=$!
        compose --project-directory "$SWCTL_TMP_DIR" $(compose_file_args) --env-file "$COMPOSE_ENV_FILE" -p "$COMPOSE_PROJECT" up -d
        wait "$clone_pid" || die "Database clone failed."
    fi
    wait_for_app_container "$COMPOSE_PROJECT"

    # Export helpers so workflow hooks can call them
    export -f update_sales_channel_domain ensure_install_lock bootstrap_dependencies \
             run_install_command run_app_command clone_database mysql_db_has_tables \
             install_admin_deps_if_needed ensure_jwt_keys fix_volume_ownership \
             info warn ok die sanitize_db_identifier detect_package_install_command 2>/dev/null || true
    # Aliases for hooks
    _swctl_update_sales_channel_domain() { update_sales_channel_domain "$@"; }
    _swctl_ensure_install_lock() { ensure_install_lock "$@"; }
    _swctl_bootstrap_dependencies() { bootstrap_dependencies "$@"; }
    _swctl_install_admin_deps_if_needed() { install_admin_deps_if_needed "$@"; }

    # Delegate to workflow hooks (provision → post-provision)
    run_workflow_hook "provision"
    run_workflow_hook "post-provision"

    # Restart PHP-FPM workers to flush OPcache.  OrbStack probes the container
    # right after "compose up", which can pollute the FPM OPcache with bytecode
    # compiled before provisioning finished.
    restart_php_fpm "$compose_project"
}

resolve_project_context() {
    local project_name="${1:-}"
    PROJECT_TYPE="platform"
    PLUGIN_NAME=""
    PLUGIN_REPO_PATH=""
    PLUGIN_DIR=""
    PLUGIN_WORKTREE_PATH=""
    LINKED_PLUGINS=""
    PLUGIN_WORKTREE_PATHS=""
    PLATFORM_WORKTREE_PATH=""
    PLATFORM_ISSUE_ID=""

    SELECTED_PROJECT_PATH=""
    [ -n "$project_name" ] || return 0
    local entry
    entry="$(read_project "$project_name")" || die "Project '$project_name' not registered. Run 'swctl project list' to see available projects."

    PROJECT_TYPE="$(read_project_field "$entry" type)"
    local proj_path parent plugin_dir proj_workflow
    proj_path="$(read_project_field "$entry" path)"
    SELECTED_PROJECT_PATH="$proj_path"
    parent="$(read_project_field "$entry" parent)"
    plugin_dir="$(read_project_field "$entry" plugin_dir)"
    proj_workflow="$(read_project_field "$entry" workflow)"
    # Set workflow from project registration (overridden by .swctl.conf if present)
    if [ "$proj_workflow" != "-" ] && [ -n "$proj_workflow" ]; then
        SWCTL_WORKFLOW="$proj_workflow"
    fi

    case "$PROJECT_TYPE" in
        plugin-external)
            PLUGIN_NAME="$(basename "$proj_path")"
            PLUGIN_REPO_PATH="$proj_path"
            local parent_entry
            parent_entry="$(read_project "$parent")" || die "Parent project '$parent' not found."
            PARENT_PROJECT_ROOT="$(read_project_field "$parent_entry" path)"
            PARENT_PROJECT_SLUG="$(read_project_field "$parent_entry" name)"
            ;;
        plugin-embedded)
            PLUGIN_NAME="$(basename "$plugin_dir")"
            PLUGIN_DIR="$plugin_dir"
            ;;
    esac
}

activate_plugin() {
    local compose_project="$1" plugin_name="$2"

    # Delegate to workflow hook if available
    if [ -n "${SWCTL_WORKFLOW_DIR:-}" ] && [ -f "$SWCTL_WORKFLOW_DIR/hooks/activate-plugin.sh" ]; then
        PLUGIN_NAME="$plugin_name" run_workflow_hook "activate-plugin"
        return
    fi

    # Fallback: inline Shopware commands
    info "Activating plugin: $plugin_name"
    run_app_command "$compose_project" \
        "$WORKFLOW_CONSOLE plugin:refresh" || warn "plugin:refresh failed."
    run_app_command "$compose_project" \
        "$WORKFLOW_CONSOLE plugin:install --activate $plugin_name" \
        || warn "Plugin activation failed for '$plugin_name'."
}

setup_plugin_database() {
    # Clone a separate DB for a plugin issue (no full provision — just the DB).
    local source_db
    source_db="$(sanitize_db_identifier "$SW_DB_SHARED_NAME")"
    DB_NAME="$(sanitize_db_identifier "${SW_DB_NAME_PREFIX}_${ISSUE_ID}")"

    if mysql_db_has_tables "$DB_NAME"; then
        DB_STATE="cloned"
        info "Database '$DB_NAME' already exists. Reusing."
    elif mysql_db_has_tables "$source_db"; then
        DB_STATE="cloned"
        info "Cloning database '$source_db' → '$DB_NAME'..."
        clone_database "$source_db" "$DB_NAME"
        ok "Database cloned."
    else
        DB_STATE="fresh"
        info "Source database '$source_db' is empty. Creating fresh database."
        create_database "$DB_NAME"
    fi
}

ensure_platform_worktree() {
    # For external plugins: create or reuse a platform worktree from the parent project.
    # Sets PLATFORM_WORKTREE_PATH, loads parent config, and provisions if new.
    local issue_id="$1"
    local branch="$2"
    local parent_meta
    parent_meta="$(instance_dir "$PARENT_PROJECT_SLUG")/${issue_id}.env"

    if [ -f "$parent_meta" ]; then
        # Reuse existing platform worktree
        local saved_project_type="$PROJECT_TYPE"
        local saved_plugin_name="$PLUGIN_NAME"
        local saved_plugin_repo="$PLUGIN_REPO_PATH"
        load_instance_metadata "$parent_meta"
        PLATFORM_WORKTREE_PATH="$WORKTREE_PATH"
        PLATFORM_ISSUE_ID="$ISSUE_ID"
        # Restore plugin context
        PROJECT_TYPE="$saved_project_type"
        PLUGIN_NAME="$saved_plugin_name"
        PLUGIN_REPO_PATH="$saved_plugin_repo"
        info "Reusing existing platform worktree: $PLATFORM_WORKTREE_PATH"
        return 0
    fi

    # Create new platform worktree by loading parent config and running the platform flow
    info "Creating platform worktree for parent project '$PARENT_PROJECT_SLUG'."
    load_project_config "$PARENT_PROJECT_ROOT/.swctl.conf"

    ISSUE_ID="$(sanitize_slug "$ISSUE")"
    WORKTREE_ID="$ISSUE_ID"
    BASE_REF="$(git_base_ref)"
    COMPOSE_PROJECT="$(sanitize_slug "${SW_PROJECT_SLUG}-${ISSUE_ID}")"

    if [ "$SW_RUNTIME" = "orbstack" ]; then
        DOMAIN="${SW_SERVICE_NAME}.${COMPOSE_PROJECT}.orb.local"
        APP_URL="http://${DOMAIN}"
    else
        DOMAIN="${SW_PROJECT_SLUG}-${ISSUE_ID}.${SW_DOMAIN_SUFFIX}"
        APP_URL="http://${DOMAIN}"
    fi

    TRAEFIK_ROUTER="$(sanitize_router_id "${SW_PROJECT_SLUG}_${ISSUE_ID}")"
    TRAEFIK_SERVICE="$TRAEFIK_ROUTER"
    WORKTREE_PATH="${SW_WORKTREE_ROOT}/${SW_WORKTREE_PREFIX}-${ISSUE_ID}"

    create_worktree

    DIFF_FILES="$(git -C "$PROJECT_ROOT" diff --name-only "${BASE_REF}...${BRANCH}" 2>/dev/null || true)"
    count_changes "$DIFF_FILES"
    sync_build_artifacts
    sync_worktree_deps
    VENDOR_VOLUME="$(resolve_vendor_volume "$ISSUE_ID")"
    NODE_MODULES_VOLUME="$(resolve_node_modules_volume "$ISSUE_ID")"

    provision_database_and_app "$COMPOSE_PROJECT"
    run_frontend_build_if_needed "$COMPOSE_PROJECT" 1

    PLATFORM_WORKTREE_PATH="$WORKTREE_PATH"
    PLATFORM_ISSUE_ID="$ISSUE_ID"

    # Write platform metadata (will be updated later with plugin linkage)
    write_metadata "$(instance_file "$SW_PROJECT_SLUG" "$ISSUE_ID")"
    ok "Platform worktree ready: $PLATFORM_WORKTREE_PATH"
}

list_available_plugins() {
    # List plugins with their own git repo in <project_root>/custom/plugins/*
    local project_root="$1"
    local plugins_dir="$project_root/custom/plugins"
    [ -d "$plugins_dir" ] || return 0
    for plugin_path in "$plugins_dir"/*/; do
        [ -d "$plugin_path" ] || continue
        local pname
        pname="$(basename "$plugin_path")"
        [ "$pname" = "*" ] && continue
        [ -f "$plugin_path/composer.json" ] || continue
        if [ -d "$plugin_path/.git" ]; then
            printf '%s\n' "$pname"
        fi
    done
}

read_plugin_deps() {
    # Read .swctl.deps.yaml from a plugin directory and print dependency names.
    local plugin_dir="$1"
    local deps_file="$plugin_dir/.swctl.deps.yaml"
    [ -f "$deps_file" ] || return 0
    python3 -c "
import yaml, sys
with open(sys.argv[1]) as f:
    data = yaml.safe_load(f)
for dep in data.get('dependencies', []):
    print(dep)
" "$deps_file" 2>/dev/null
}

create_dep_plugin_worktree() {
    # Create a git worktree for a dependency plugin at its default branch.
    local dep_name="$1"
    local dep_repo="${PROJECT_ROOT}/custom/plugins/${dep_name}"
    local dep_target="${WORKTREE_PATH}/custom/plugins/${dep_name}"

    if [ ! -d "$dep_repo/.git" ]; then
        warn "Dependency plugin repo not found: $dep_repo — skipping."
        return 1
    fi

    if [ -d "$dep_target/.git" ] || [ -f "$dep_target/.git" ]; then
        info "Dependency plugin already exists: $dep_name"
        return 0
    fi

    # Determine the dep's default branch
    local dep_default_branch
    dep_default_branch="$(git -C "$dep_repo" symbolic-ref --short HEAD 2>/dev/null)" || dep_default_branch="main"

    info "Creating dependency worktree: $dep_name (at $dep_default_branch)"
    mkdir -p "$(dirname "$dep_target")"
    rm -rf "$dep_target" 2>/dev/null || true

    git -C "$dep_repo" fetch --all --prune 2>/dev/null || true
    git -C "$dep_repo" worktree add --detach "$dep_target" "origin/$dep_default_branch" 2>/dev/null \
        || git -C "$dep_repo" worktree add --detach "$dep_target" "$dep_default_branch" 2>/dev/null \
        || { warn "Failed to create worktree for dependency: $dep_name"; return 1; }

    ok "Dependency plugin nested: custom/plugins/${dep_name} (detached at $dep_default_branch)"
}

cmd_create() {
    SWCTL_MODE="${SWCTL_MODE:-dev}"
    local selected_project=""
    local selected_plugin=""
    local selected_deps=""
    local adopt_worktree_path=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --qa)      SWCTL_MODE="qa"; shift ;;
            --dev)     SWCTL_MODE="dev"; shift ;;
            --project) selected_project="$2"; shift 2 ;;
            --plugin)  selected_plugin="$2"; shift 2 ;;
            --deps)    selected_deps="$2"; shift 2 ;;
            --adopt-worktree) adopt_worktree_path="$2"; shift 2 ;;
            *)         break ;;
        esac
    done
    export SWCTL_MODE
    ISSUE="${1:-}"
    BRANCH="${2:-}"
    [ -n "$ISSUE" ] || die "Usage: swctl create [--qa|--dev] [--project <name>] [--plugin <name>] <issue> [<branch>]"

    # When adopting an external worktree, the branch belongs to the PLUGIN,
    # not the trunk.  Record it for metadata but don't use it for the trunk
    # worktree (which will be created in detached mode at BASE_REF).
    if [ -n "${adopt_worktree_path:-}" ] && [ -z "$BRANCH" ]; then
        BRANCH="$(git -C "$adopt_worktree_path" rev-parse --abbrev-ref HEAD 2>/dev/null)" || true
        if [ -z "$BRANCH" ] || [ "$BRANCH" = "HEAD" ]; then
            BRANCH="$(git -C "$adopt_worktree_path" rev-parse --short HEAD 2>/dev/null)" || true
            info "Adopted worktree is detached at: ${BRANCH:-unknown}"
        else
            info "Inferred plugin branch from adopted worktree: $BRANCH"
        fi
    fi

    if [ -z "$BRANCH" ]; then
        if [ "$SWCTL_MODE" = "qa" ]; then
            die "QA mode requires a branch: swctl create --qa <issue> <branch>"
        fi
        # Dev mode: prompt for new branch name
        BRANCH="$(prompt_text "New branch name for issue '$ISSUE'")"
        [ -n "$BRANCH" ] || die "Branch name cannot be empty."
        info "Will create new branch '$BRANCH' from ${SW_BASE_BRANCH:-trunk}."
    fi

    require_cmd git
    ensure_docker

    # Resolve project context (platform vs plugin)
    resolve_project_context "$selected_project"

    # If --plugin was given with a platform project, set up plugin-external context dynamically
    if [ -n "$selected_plugin" ]; then
        if [ "$PROJECT_TYPE" != "platform" ]; then
            die "--plugin can only be used with a platform project, not '$PROJECT_TYPE'."
        fi
        local plugin_repo_path="${SELECTED_PROJECT_PATH:-$PROJECT_ROOT}/custom/plugins/$selected_plugin"
        [ -d "$plugin_repo_path" ] || die "Plugin not found: $plugin_repo_path"
        [ -d "$plugin_repo_path/.git" ] || die "Plugin '$selected_plugin' has no git repository at: $plugin_repo_path"
        PROJECT_TYPE="plugin-external"
        PLUGIN_NAME="$selected_plugin"
        PLUGIN_REPO_PATH="$(cd "$plugin_repo_path" && pwd -P)"
        # Read parent info from the platform project
        local parent_entry
        parent_entry="$(read_project "$selected_project")" || die "Project '$selected_project' not registered."
        PARENT_PROJECT_ROOT="$(read_project_field "$parent_entry" path)"
        PARENT_PROJECT_SLUG="$(read_project_field "$parent_entry" name)"
    fi

    # If --project was given, use the registered path to locate .swctl.conf
    local project_config_arg=""
    if [ -n "${SELECTED_PROJECT_PATH:-}" ]; then
        project_config_arg="$SELECTED_PROJECT_PATH/.swctl.conf"
    fi

    case "$PROJECT_TYPE" in
        plugin-external)
            # Create a standard trunk worktree, then nest the plugin's git
            # worktree inside it at custom/plugins/<PluginName>/.
            # Since custom/ is gitignored, the plugin dir is empty in the
            # trunk worktree — we fill it with the plugin's own branch.
            info "Plugin (external): $PLUGIN_NAME → parent: $PARENT_PROJECT_SLUG"
            load_project_config "$PARENT_PROJECT_ROOT/.swctl.conf"
            ensure_infra_ready

            git -C "$PROJECT_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1 \
                || die "Project root is not a Git repository: $PROJECT_ROOT"

            ISSUE_ID="$(sanitize_slug "$ISSUE")"
            WORKTREE_ID="$ISSUE_ID"
            BASE_REF="$(git_base_ref)"

            # Use trunk's naming — this IS a trunk worktree
            COMPOSE_PROJECT="$(sanitize_slug "${SW_PROJECT_SLUG}-${ISSUE_ID}")"

            if [ "$SW_RUNTIME" = "orbstack" ]; then
                DOMAIN="${SW_SERVICE_NAME}.${COMPOSE_PROJECT}.orb.local"
                APP_URL="http://${DOMAIN}"
            else
                DOMAIN="${SW_PROJECT_SLUG}-${ISSUE_ID}.${SW_DOMAIN_SUFFIX}"
                APP_URL="http://${DOMAIN}"
            fi
            TRAEFIK_ROUTER="$(sanitize_router_id "${SW_PROJECT_SLUG}_${ISSUE_ID}")"
            TRAEFIK_SERVICE="$TRAEFIK_ROUTER"
            WORKTREE_PATH="${SW_WORKTREE_ROOT}/${SW_WORKTREE_PREFIX}-${ISSUE_ID}"

            # Early metadata — stored under trunk project slug
            SWCTL_ACTIVE_META_FILE="$(instance_file "$SW_PROJECT_SLUG" "$ISSUE_ID")"
            STATUS="creating"
            FAILED_AT=""
            DB_NAME="${DB_NAME:-}"
            DB_STATE="${DB_STATE:-}"
            VENDOR_VOLUME="${VENDOR_VOLUME:-}"
            NODE_MODULES_VOLUME="${NODE_MODULES_VOLUME:-}"
            MIGRATION_CHANGES=0; ENTITY_CHANGES=0; COMPOSER_CHANGES=0
            PACKAGE_CHANGES=0; ADMIN_CHANGES=0; STOREFRONT_CHANGES=0
            BACKEND_CHANGES=0; FRONTEND_CHANGES=0
            write_metadata "$SWCTL_ACTIVE_META_FILE"

            trap 'if [ "${STATUS:-}" = "creating" ]; then STATUS=failed; FAILED_AT="${SWCTL_LAST_ERROR:-unknown}"; write_metadata "$SWCTL_ACTIVE_META_FILE" 2>/dev/null; fi' EXIT

            # 1. Create trunk worktree at BASE_REF — the branch belongs to the
            # plugin, not the trunk.  Detached mode avoids creating a spurious
            # branch in the trunk repo.
            mkdir -p "$SW_WORKTREE_ROOT"
            if ! worktree_exists "$WORKTREE_PATH"; then
                git -C "$PROJECT_ROOT" worktree add --detach "$WORKTREE_PATH" "$BASE_REF"
                ok "Created trunk worktree (detached at $BASE_REF)."
            fi
            sync_lock_files

            # 2. Nest plugin git worktree inside trunk worktree
            local plugin_target="${WORKTREE_PATH}/custom/plugins/${PLUGIN_NAME}"
            PLUGIN_WORKTREE_PATH="$plugin_target"

            if [ -n "${adopt_worktree_path:-}" ]; then
                # Adopt an existing external worktree (from Claude Code / Codex)
                # by moving it into the trunk worktree via git worktree move.
                # This preserves uncommitted changes and updates git's internal pointers.
                info "Adopting external worktree: $adopt_worktree_path"
                [ -f "$adopt_worktree_path/.git" ] || [ -d "$adopt_worktree_path/.git" ] \
                    || die "Not a git worktree: $adopt_worktree_path"
                mkdir -p "$(dirname "$plugin_target")"
                rm -rf "$plugin_target" 2>/dev/null || true
                # Copy the worktree and update git's internal pointers.
                # (~/.codex/ and ~/.claude/ are typically on a different APFS volume,
                # so git worktree move would fail with "Cross-device link".)
                cp -a "$adopt_worktree_path" "$plugin_target" \
                    || die "Failed to copy worktree from $adopt_worktree_path to $plugin_target"
                # The .git file contains "gitdir: /path/to/repo/.git/worktrees/<name>".
                # Update that repo entry's gitdir to point to the new location.
                local wt_gitdir
                wt_gitdir="$(sed 's/^gitdir: //' "$plugin_target/.git" 2>/dev/null)" || true
                if [ -n "$wt_gitdir" ] && [ -f "$wt_gitdir/gitdir" ]; then
                    printf '%s\n' "$plugin_target" > "$wt_gitdir/gitdir"
                fi
                rm -rf "$adopt_worktree_path" 2>/dev/null || true
                ok "Adopted worktree moved to: custom/plugins/${PLUGIN_NAME}"
            elif [ ! -d "$plugin_target/.git" ] && [ ! -f "$plugin_target/.git" ]; then
                info "Creating plugin worktree at: $plugin_target"
                mkdir -p "$(dirname "$plugin_target")"
                rm -rf "$plugin_target" 2>/dev/null || true
                git -C "$PLUGIN_REPO_PATH" fetch --all --prune 2>/dev/null || true
                if git -C "$PLUGIN_REPO_PATH" rev-parse --verify "origin/$BRANCH" >/dev/null 2>&1; then
                    # Try: new local branch from remote → existing local branch → detached
                    git -C "$PLUGIN_REPO_PATH" worktree add "$plugin_target" \
                        -b "swctl/${ISSUE_ID}" "origin/$BRANCH" 2>/dev/null \
                        || git -C "$PLUGIN_REPO_PATH" worktree add "$plugin_target" \
                            "$BRANCH" 2>/dev/null \
                        || git -C "$PLUGIN_REPO_PATH" worktree add --detach "$plugin_target" \
                            "origin/$BRANCH" 2>/dev/null \
                        || die "Failed to create plugin worktree."
                elif git -C "$PLUGIN_REPO_PATH" rev-parse --verify "$BRANCH" >/dev/null 2>&1; then
                    git -C "$PLUGIN_REPO_PATH" worktree add "$plugin_target" "$BRANCH" 2>/dev/null \
                        || die "Failed to create plugin worktree."
                else
                    die "Branch '$BRANCH' not found in plugin repo: $PLUGIN_REPO_PATH"
                fi
                ok "Plugin worktree nested at: custom/plugins/${PLUGIN_NAME}"
            else
                info "Plugin worktree already exists at: $plugin_target"
            fi

            # Ensure plugin worktree is on a named branch (not detached HEAD).
            # Detached HEAD can happen when the local branch is already checked
            # out in another worktree, so the fallback used a remote ref.
            local plugin_head
            plugin_head="$(git -C "$plugin_target" rev-parse --abbrev-ref HEAD 2>/dev/null)" || true
            if [ "$plugin_head" = "HEAD" ]; then
                git -C "$plugin_target" checkout -b "swctl/${ISSUE_ID}" 2>/dev/null \
                    && info "Created plugin branch: swctl/${ISSUE_ID}" \
                    || warn "Plugin worktree is in detached HEAD."
            fi

            # 2b. Resolve plugin dependencies (--deps flag or .swctl.deps.yaml)
            local dep_plugins=""
            local dep_worktree_paths=""
            local deps
            if [ -n "${selected_deps:-}" ]; then
                # Deps explicitly provided via --deps flag (from UI)
                deps="$(echo "$selected_deps" | tr ',' '\n')"
            else
                # Auto-read from plugin's .swctl.deps.yaml
                deps="$(read_plugin_deps "$plugin_target")"
            fi
            if [ -n "$deps" ]; then
                info "Plugin dependencies declared: $(echo "$deps" | tr '\n' ', ' | sed 's/,$//')"
                while IFS= read -r dep_name; do
                    [ -n "$dep_name" ] || continue
                    [ "$dep_name" = "$PLUGIN_NAME" ] && continue  # skip self
                    if create_dep_plugin_worktree "$dep_name"; then
                        dep_plugins="${dep_plugins:+${dep_plugins},}${dep_name}"
                        dep_worktree_paths="${dep_worktree_paths:+${dep_worktree_paths},}${WORKTREE_PATH}/custom/plugins/${dep_name}"
                    fi
                done <<< "$deps"
            fi

            # 3. Standard trunk flow: diff, sync, provision
            # For plugin-external: diff the plugin repo against its own default
            # branch, not the platform's BASE_REF.
            if [ -n "${adopt_worktree_path:-}" ]; then
                # When adopting, the trunk has no changes — the work is in the
                # plugin worktree.  Plugin detection below forces the needed builds.
                DIFF_FILES=""
                count_changes ""
            else
                local plugin_default_branch
                plugin_default_branch="$(git -C "$PLUGIN_REPO_PATH" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@' || echo main)"
                local plugin_base_ref
                if git -C "$PLUGIN_REPO_PATH" rev-parse --verify "origin/${plugin_default_branch}" >/dev/null 2>&1; then
                    plugin_base_ref="origin/${plugin_default_branch}"
                elif git -C "$PLUGIN_REPO_PATH" rev-parse --verify "${plugin_default_branch}" >/dev/null 2>&1; then
                    plugin_base_ref="${plugin_default_branch}"
                else
                    plugin_base_ref="HEAD~1"
                fi
                DIFF_FILES="$(git -C "$PLUGIN_REPO_PATH" diff --name-only "${plugin_base_ref}...origin/${BRANCH}" 2>/dev/null || true)"
                count_changes "$DIFF_FILES"
            fi

            # Plugin has admin/storefront extensions → force builds so the bundle
            # includes them.  The synced JS from trunk was compiled without this
            # plugin's source present in custom/plugins/.
            # Check primary plugin AND dependency plugins for extensions.
            local plugin_has_extensions=0
            local all_plugin_dirs="$plugin_target"
            if [ -n "$dep_worktree_paths" ]; then
                all_plugin_dirs="$all_plugin_dirs $(echo "$dep_worktree_paths" | tr ',' ' ')"
            fi
            for _pdir in $all_plugin_dirs; do
                if find "$_pdir" -maxdepth 4 -path "*/Resources/app/administration" -type d 2>/dev/null | grep -q .; then
                    ADMIN_CHANGES=$((ADMIN_CHANGES + 1))
                    plugin_has_extensions=1
                    info "$(basename "$_pdir") has admin extensions — admin build will be triggered."
                fi
                if find "$_pdir" -maxdepth 4 -path "*/Resources/app/storefront" -type d 2>/dev/null | grep -q .; then
                    STOREFRONT_CHANGES=$((STOREFRONT_CHANGES + 1))
                    plugin_has_extensions=1
                    info "$(basename "$_pdir") has storefront extensions — storefront build will be triggered."
                fi
            done

            sync_build_artifacts
            sync_worktree_deps
            VENDOR_VOLUME="$(resolve_vendor_volume "$ISSUE_ID")"
            NODE_MODULES_VOLUME="$(resolve_node_modules_volume "$ISSUE_ID")"

            # Track plugin linkage in metadata (primary + dependencies)
            LINKED_PLUGINS="${PLUGIN_NAME}${dep_plugins:+,${dep_plugins}}"
            PLUGIN_WORKTREE_PATHS="${PLUGIN_WORKTREE_PATH}${dep_worktree_paths:+,${dep_worktree_paths}}"
            PLATFORM_WORKTREE_PATH="$WORKTREE_PATH"
            PLATFORM_ISSUE_ID="$ISSUE_ID"

            info "Mode: ${SWCTL_MODE} | Plugin: ${PLUGIN_NAME}"
            info "Strategy: vendor=${VENDOR_VOLUME} node_modules=${NODE_MODULES_VOLUME}"

            provision_database_and_app "$COMPOSE_PROJECT"

            # Ensure the nested plugin is properly registered before the admin
            # build.  The cloned DB has the plugin record but plugin:refresh
            # updates paths/metadata to match the current worktree filesystem.
            # (Safe here because the plugin IS at custom/plugins/<Name>/ — the
            # same relative path as in trunk.)
            run_app_command "$COMPOSE_PROJECT" "$SW_BIN_CONSOLE plugin:refresh" 2>/dev/null || warn "plugin:refresh failed."

            # Activate dependency plugins so they're available for testing.
            if [ -n "$dep_plugins" ]; then
                local _old_ifs="$IFS"
                IFS=','
                for _dep in $dep_plugins; do
                    run_app_command "$COMPOSE_PROJECT" \
                        "$SW_BIN_CONSOLE plugin:install --activate $_dep" 2>/dev/null \
                        || warn "Failed to activate dependency: $_dep"
                done
                IFS="$_old_ifs"
            fi

            run_frontend_build_if_needed "$COMPOSE_PROJECT" 1 "$plugin_has_extensions"

            # Publish plugin assets (admin JS, storefront JS, public files)
            # to public/bundles/<name>/ so the browser can load them.
            run_app_command "$COMPOSE_PROJECT" "$SW_BIN_CONSOLE assets:install" 2>/dev/null || warn "assets:install failed."

            STATUS="complete"
            FAILED_AT=""
            trap - EXIT
            write_metadata "$SWCTL_ACTIVE_META_FILE"

            ok "Worktree '${WORKTREE_ID}' with plugin '${PLUGIN_NAME}' is ready."
            info "URL: ${APP_URL}"
            info "Worktree: ${WORKTREE_PATH}"
            info "Plugin: ${PLUGIN_WORKTREE_PATH}"
            ;;

        plugin-embedded)
            info "Plugin (embedded): $PLUGIN_NAME"
            load_project_config ${project_config_arg:+"$project_config_arg"}
            ensure_infra_ready

            git -C "$PROJECT_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "Project root is not a Git repository: $PROJECT_ROOT"

            ISSUE_ID="$(sanitize_slug "$ISSUE")"
            WORKTREE_ID="$ISSUE_ID"
            BASE_REF="$(git_base_ref)"
            COMPOSE_PROJECT="$(sanitize_slug "${SW_PROJECT_SLUG}-${ISSUE_ID}")"

            if [ "$SW_RUNTIME" = "orbstack" ]; then
                DOMAIN="${SW_SERVICE_NAME}.${COMPOSE_PROJECT}.orb.local"
                APP_URL="http://${DOMAIN}"
            else
                DOMAIN="${SW_PROJECT_SLUG}-${ISSUE_ID}.${SW_DOMAIN_SUFFIX}"
                APP_URL="http://${DOMAIN}"
            fi

            TRAEFIK_ROUTER="$(sanitize_router_id "${SW_PROJECT_SLUG}_${ISSUE_ID}")"
            TRAEFIK_SERVICE="$TRAEFIK_ROUTER"
            WORKTREE_PATH="${SW_WORKTREE_ROOT}/${SW_WORKTREE_PREFIX}-${ISSUE_ID}"

            # Write early metadata so failed creates are tracked
            SWCTL_ACTIVE_META_FILE="$(instance_file "$SW_PROJECT_SLUG" "$ISSUE_ID")"
            STATUS="creating"
            FAILED_AT=""
            DB_NAME="${DB_NAME:-}"
            DB_STATE="${DB_STATE:-}"
            VENDOR_VOLUME="${VENDOR_VOLUME:-}"
            NODE_MODULES_VOLUME="${NODE_MODULES_VOLUME:-}"
            MIGRATION_CHANGES="${MIGRATION_CHANGES:-0}"
            ENTITY_CHANGES="${ENTITY_CHANGES:-0}"
            FRONTEND_CHANGES="${FRONTEND_CHANGES:-0}"
            write_metadata "$SWCTL_ACTIVE_META_FILE"

            trap 'if [ "${STATUS:-}" = "creating" ]; then STATUS=failed; FAILED_AT="${SWCTL_LAST_ERROR:-unknown}"; write_metadata "$SWCTL_ACTIVE_META_FILE" 2>/dev/null; fi' EXIT

            create_worktree
            check_branch_staleness

            # Diff analysis — focus on plugin directory for change detection
            DIFF_FILES="$(git -C "$PROJECT_ROOT" diff --name-only "${BASE_REF}...${BRANCH}" || true)"
            count_changes "$DIFF_FILES"

            sync_build_artifacts
            sync_worktree_deps
            VENDOR_VOLUME="$(resolve_vendor_volume "$ISSUE_ID")"
            NODE_MODULES_VOLUME="$(resolve_node_modules_volume "$ISSUE_ID")"

            info "Mode: ${SWCTL_MODE} | Plugin: ${PLUGIN_NAME}"
            info "Strategy: vendor=${VENDOR_VOLUME} node_modules=${NODE_MODULES_VOLUME}"

            provision_database_and_app "$COMPOSE_PROJECT"
            run_frontend_build_if_needed "$COMPOSE_PROJECT" 1
            activate_plugin "$COMPOSE_PROJECT" "$PLUGIN_NAME"

            STATUS="complete"
            FAILED_AT=""
            trap - EXIT
            write_metadata "$SWCTL_ACTIVE_META_FILE"

            ok "Worktree '${WORKTREE_ID}' with plugin '${PLUGIN_NAME}' is ready."
            info "URL: ${APP_URL}"
            info "Worktree: ${WORKTREE_PATH}"
            ;;

        platform|*)
            # --- Original platform flow ---
            load_project_config ${project_config_arg:+"$project_config_arg"}
            ensure_infra_ready

            git -C "$PROJECT_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "Project root is not a Git repository: $PROJECT_ROOT"

            ISSUE_ID="$(sanitize_slug "$ISSUE")"
            WORKTREE_ID="$ISSUE_ID"
            BASE_REF="$(git_base_ref)"
            COMPOSE_PROJECT="$(sanitize_slug "${SW_PROJECT_SLUG}-${ISSUE_ID}")"

            if [ "$SW_RUNTIME" = "orbstack" ]; then
                DOMAIN="${SW_SERVICE_NAME}.${COMPOSE_PROJECT}.orb.local"
                APP_URL="http://${DOMAIN}"
            else
                DOMAIN="${SW_PROJECT_SLUG}-${ISSUE_ID}.${SW_DOMAIN_SUFFIX}"
                APP_URL="http://${DOMAIN}"
            fi

            TRAEFIK_ROUTER="$(sanitize_router_id "${SW_PROJECT_SLUG}_${ISSUE_ID}")"
            TRAEFIK_SERVICE="$TRAEFIK_ROUTER"
            WORKTREE_PATH="${SW_WORKTREE_ROOT}/${SW_WORKTREE_PREFIX}-${ISSUE_ID}"

            # Write early metadata so failed creates are tracked
            SWCTL_ACTIVE_META_FILE="$(instance_file "$SW_PROJECT_SLUG" "$ISSUE_ID")"
            STATUS="creating"
            FAILED_AT=""
            DB_NAME="${DB_NAME:-}"
            DB_STATE="${DB_STATE:-}"
            VENDOR_VOLUME="${VENDOR_VOLUME:-}"
            NODE_MODULES_VOLUME="${NODE_MODULES_VOLUME:-}"
            MIGRATION_CHANGES="${MIGRATION_CHANGES:-0}"
            ENTITY_CHANGES="${ENTITY_CHANGES:-0}"
            FRONTEND_CHANGES="${FRONTEND_CHANGES:-0}"
            write_metadata "$SWCTL_ACTIVE_META_FILE"

            # On any exit while STATUS=creating, mark as failed
            trap 'if [ "${STATUS:-}" = "creating" ]; then STATUS=failed; FAILED_AT="${SWCTL_LAST_ERROR:-unknown}"; write_metadata "$SWCTL_ACTIVE_META_FILE" 2>/dev/null; fi' EXIT

            local step_start create_start
            create_start=$SECONDS

            step_start=$SECONDS
            create_worktree
            check_branch_staleness
            info "[timing] create_worktree: $((SECONDS - step_start))s"

            step_start=$SECONDS
            DIFF_FILES="$(git -C "$PROJECT_ROOT" diff --name-only "${BASE_REF}...${BRANCH}" || true)"
            count_changes "$DIFF_FILES"
            info "[timing] count_changes: $((SECONDS - step_start))s"

            # Resolve dependency plugins (--deps flag) for platform worktrees
            local dep_plugins=""
            local dep_worktree_paths=""
            if [ -n "${selected_deps:-}" ]; then
                local deps
                deps="$(echo "$selected_deps" | tr ',' '\n')"
                if [ -n "$deps" ]; then
                    info "Plugin dependencies declared: $(echo "$deps" | tr '\n' ', ' | sed 's/,$//')"
                    while IFS= read -r dep_name; do
                        [ -n "$dep_name" ] || continue
                        if create_dep_plugin_worktree "$dep_name"; then
                            dep_plugins="${dep_plugins:+${dep_plugins},}${dep_name}"
                            dep_worktree_paths="${dep_worktree_paths:+${dep_worktree_paths},}${WORKTREE_PATH}/custom/plugins/${dep_name}"
                        fi
                    done <<< "$deps"
                fi
            fi

            # Check dependency plugins for admin/storefront extensions
            local plugin_has_extensions=0
            if [ -n "$dep_worktree_paths" ]; then
                for _pdir in $(echo "$dep_worktree_paths" | tr ',' ' '); do
                    if find "$_pdir" -maxdepth 4 -path "*/Resources/app/administration" -type d 2>/dev/null | grep -q .; then
                        ADMIN_CHANGES=$((ADMIN_CHANGES + 1))
                        plugin_has_extensions=1
                        info "$(basename "$_pdir") has admin extensions — admin build will be triggered."
                    fi
                    if find "$_pdir" -maxdepth 4 -path "*/Resources/app/storefront" -type d 2>/dev/null | grep -q .; then
                        STOREFRONT_CHANGES=$((STOREFRONT_CHANGES + 1))
                        plugin_has_extensions=1
                        info "$(basename "$_pdir") has storefront extensions — storefront build will be triggered."
                    fi
                done
            fi

            # Track dependency plugin linkage in metadata
            if [ -n "$dep_plugins" ]; then
                LINKED_PLUGINS="${dep_plugins}"
                PLUGIN_WORKTREE_PATHS="${dep_worktree_paths}"
            fi

            step_start=$SECONDS
            sync_build_artifacts
            sync_worktree_deps
            VENDOR_VOLUME="$(resolve_vendor_volume "$ISSUE_ID")"
            NODE_MODULES_VOLUME="$(resolve_node_modules_volume "$ISSUE_ID")"
            info "[timing] sync: $((SECONDS - step_start))s"

            info "Mode: ${SWCTL_MODE} | Diff: migrations=${MIGRATION_CHANGES} entity=${ENTITY_CHANGES} admin=${ADMIN_CHANGES} storefront=${STOREFRONT_CHANGES} composer=${COMPOSER_CHANGES} package=${PACKAGE_CHANGES} backend=${BACKEND_CHANGES}"
            info "Strategy: vendor=${VENDOR_VOLUME} node_modules=${NODE_MODULES_VOLUME}"

            step_start=$SECONDS
            provision_database_and_app "$COMPOSE_PROJECT"
            info "[timing] provision: $((SECONDS - step_start))s"

            # Activate dependency plugins after provisioning
            if [ -n "$dep_plugins" ]; then
                run_app_command "$COMPOSE_PROJECT" "$SW_BIN_CONSOLE plugin:refresh" 2>/dev/null || warn "plugin:refresh failed."
                local _old_ifs="$IFS"
                IFS=','
                for _dep in $dep_plugins; do
                    run_app_command "$COMPOSE_PROJECT" \
                        "$SW_BIN_CONSOLE plugin:install --activate $_dep" 2>/dev/null \
                        || warn "Failed to activate dependency: $_dep"
                done
                IFS="$_old_ifs"
            fi

            step_start=$SECONDS
            run_frontend_build_if_needed "$COMPOSE_PROJECT" 1 "$plugin_has_extensions"
            info "[timing] frontend: $((SECONDS - step_start))s"

            # Mark complete and remove EXIT trap
            STATUS="complete"
            FAILED_AT=""
            trap - EXIT
            write_metadata "$SWCTL_ACTIVE_META_FILE"

            ok "Worktree '${WORKTREE_ID}' is ready. (total: $((SECONDS - create_start))s)"
            info "URL: ${APP_URL}"
            info "Worktree: ${WORKTREE_PATH}"
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Batch create
# ---------------------------------------------------------------------------

parse_batch_file() {
    local file="$1"
    [ -f "$file" ] || die "Batch file not found: $file"
    while IFS= read -r line || [ -n "$line" ]; do
        line="${line%%#*}"
        line="$(printf '%s' "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
        [ -n "$line" ] || continue
        printf '%s\n' "$line"
    done < "$file"
}

parse_cli_pairs() {
    while [ $# -ge 2 ]; do
        printf '%s %s\n' "$1" "$2"
        shift 2
    done
}

parse_mr_json() {
    if ! command -v jq >/dev/null 2>&1; then
        die "jq is required for API-based batch create. Install it with: brew install jq"
    fi
    jq -r '.[] | "\(.iid) \(.source_branch)"'
}

parse_pr_json() {
    if ! command -v jq >/dev/null 2>&1; then
        die "jq is required for API-based batch create. Install it with: brew install jq"
    fi
    jq -r '.[] | "\(.number) \(.head.ref)"'
}

fetch_gitlab_mrs() {
    local project_id="$1"
    local api_url="${SWCTL_GITLAB_URL:-https://gitlab.com}/api/v4"
    local token="${SWCTL_GITLAB_TOKEN:-}"

    [ -n "$token" ] || die "SWCTL_GITLAB_TOKEN is not set."

    curl -sSf -H "PRIVATE-TOKEN: $token" \
        "${api_url}/projects/${project_id}/merge_requests?state=opened&per_page=100" \
        | parse_mr_json
}

fetch_github_prs() {
    local repo="$1"
    local token=""
    if [ -f "$SWCTL_GITHUB_TOKEN_FILE" ]; then
        token="$(cat "$SWCTL_GITHUB_TOKEN_FILE")"
    fi
    local auth_header=""

    if [ -n "$token" ]; then
        auth_header="Authorization: token $token"
    fi

    curl -sSf ${auth_header:+-H "$auth_header"} \
        "https://api.github.com/repos/${repo}/pulls?state=open&per_page=100" \
        | parse_pr_json
}

select_from_list() {
    local label="$1"
    local pairs=()

    while IFS= read -r line; do
        [ -n "$line" ] || continue
        pairs+=("$line")
    done

    if [ ${#pairs[@]} -eq 0 ]; then
        warn "No open ${label}s found."
        return 1
    fi

    if command -v fzf >/dev/null 2>&1; then
        printf '%s\n' "${pairs[@]}" | fzf --multi --prompt="Select ${label}s> " --height=40% --reverse
        return
    fi

    local i=1
    for pair in "${pairs[@]}"; do
        printf '  [%d] %s\n' "$i" "$pair"
        i=$((i + 1))
    done
    local selection
    selection="$(prompt_text "Enter numbers (comma-separated, or 'all')")"
    if [ "$selection" = "all" ]; then
        printf '%s\n' "${pairs[@]}"
        return
    fi
    local old_ifs="$IFS"
    IFS=',' read -r -a indices <<< "$selection"
    IFS="$old_ifs"
    local idx
    for idx in "${indices[@]}"; do
        idx="$(printf '%s' "$idx" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
        if [ "$idx" -ge 1 ] 2>/dev/null && [ "$idx" -le "${#pairs[@]}" ]; then
            printf '%s\n' "${pairs[$((idx - 1))]}"
        fi
    done
}

batch_create_sequential() {
    local pairs="$1"
    local job_dir="$2"
    local issue="" branch=""

    while IFS=' ' read -r issue branch; do
        [ -n "$issue" ] && [ -n "$branch" ] || continue
        info "Creating worktree for $issue ($branch)..."
        if cmd_create "$issue" "$branch" >"$job_dir/${issue}.log" 2>&1; then
            touch "$job_dir/${issue}.ok"
            ok "Created $issue"
        else
            touch "$job_dir/${issue}.fail"
            err "Failed $issue"
        fi
    done <<< "$pairs"
}

batch_create_parallel() {
    local pairs="$1"
    local job_dir="$2"
    local max_jobs="${3:-4}"
    local pids=()
    local running=0
    local issue="" branch=""

    while IFS=' ' read -r issue branch; do
        [ -n "$issue" ] && [ -n "$branch" ] || continue

        while [ "$running" -ge "$max_jobs" ]; do
            wait -n 2>/dev/null || true
            running=$((running - 1))
        done

        (
            cmd_create "$issue" "$branch" >"$job_dir/${issue}.log" 2>&1 \
                && touch "$job_dir/${issue}.ok" \
                || touch "$job_dir/${issue}.fail"
        ) &

        pids+=($!)
        running=$((running + 1))
        info "Started background job for $issue (PID $!)"
    done <<< "$pairs"

    local pid
    for pid in "${pids[@]}"; do
        wait "$pid" 2>/dev/null || true
    done
}

cmd_batch_create() {
    local pairs=""
    local parallel=0
    local max_jobs=4
    SWCTL_MODE="${SWCTL_MODE:-dev}"
    export SWCTL_MODE

    while [ $# -gt 0 ]; do
        case "$1" in
            --qa)
                SWCTL_MODE="qa"; shift ;;
            --dev)
                SWCTL_MODE="dev"; shift ;;
            --file|-f)
                shift
                [ -n "${1:-}" ] || die "Missing argument for --file."
                pairs="$(parse_batch_file "$1")"
                shift
                ;;
            --gitlab)
                shift
                [ -n "${1:-}" ] || die "Missing argument for --gitlab."
                pairs="$(fetch_gitlab_mrs "$1" | select_from_list "MR")"
                shift
                ;;
            --github)
                shift
                [ -n "${1:-}" ] || die "Missing argument for --github."
                pairs="$(fetch_github_prs "$1" | select_from_list "PR")"
                shift
                ;;
            --parallel|-p)
                parallel=1
                shift
                ;;
            --jobs|-j)
                shift
                [ -n "${1:-}" ] || die "Missing argument for --jobs."
                max_jobs="$1"
                shift
                ;;
            -*)
                die "Unknown flag: $1"
                ;;
            *)
                pairs="$(parse_cli_pairs "$@")"
                break
                ;;
        esac
    done

    [ -n "$pairs" ] || die "No issue/branch pairs provided.\nUsage: swctl batch create [--file <path>|--gitlab <id>|--github <owner/repo>] [--parallel [-j N]] [ISSUE BRANCH ...]"

    # In QA mode, skip pairs without a branch (no linked PR/MR)
    if [ "$SWCTL_MODE" = "qa" ]; then
        local filtered=""
        local skipped=0
        while IFS=' ' read -r issue branch; do
            [ -n "$issue" ] || continue
            if [ -z "$branch" ]; then
                warn "Skipping issue '$issue': no linked PR/MR (QA mode)."
                skipped=$((skipped + 1))
                continue
            fi
            filtered="${filtered:+$filtered
}$issue $branch"
        done <<< "$pairs"
        [ "$skipped" -gt 0 ] && warn "Skipped $skipped issue(s) with no linked branch."
        pairs="$filtered"
        [ -n "$pairs" ] || die "No issue/branch pairs remaining after filtering (all lacked linked PRs)."
    fi

    local total=0
    local succeeded=0
    local failed=0
    local job_dir="$SWCTL_TMP_DIR/batch.$$"
    mkdir -p "$job_dir"
    trap 'rm -rf "$job_dir"' EXIT

    total="$(printf '%s\n' "$pairs" | grep -c '.' || true)"
    info "Batch creating $total worktree(s)$([ "$parallel" -eq 1 ] && printf ' in parallel (max %s jobs)' "$max_jobs")."

    if [ "$parallel" -eq 1 ]; then
        batch_create_parallel "$pairs" "$job_dir" "$max_jobs"
    else
        batch_create_sequential "$pairs" "$job_dir"
    fi

    succeeded="$(find "$job_dir" -name '*.ok' 2>/dev/null | wc -l | tr -d ' ')"
    failed="$(find "$job_dir" -name '*.fail' 2>/dev/null | wc -l | tr -d ' ')"

    printf '\n'
    ok "Batch complete: $succeeded succeeded, $failed failed out of $total."

    local fail_file issue_id
    for fail_file in "$job_dir"/*.fail; do
        [ -f "$fail_file" ] || continue
        issue_id="$(basename "$fail_file" .fail)"
        err "Failed: $issue_id"
        cat "$job_dir/${issue_id}.log" >&2
    done

    rm -rf "$job_dir"
    trap - EXIT
    [ "$failed" -eq 0 ]
}

cmd_batch() {
    local subcmd="${1:-}"
    shift || true

    case "$subcmd" in
        create) cmd_batch_create "$@" ;;
        *)      die "Usage: swctl batch create [--file <path>|--gitlab <id>|--github <owner/repo>] [--parallel [-j N]] [ISSUE BRANCH ...]" ;;
    esac
}

truncate_text() {
    local max="$1"
    local value="$2"
    if [ "${#value}" -le "$max" ]; then
        printf '%s' "$value"
        return
    fi
    if [ "$max" -le 3 ]; then
        printf '%s' "${value:0:$max}"
        return
    fi
    printf '%s...' "${value:0:$((max - 3))}"
}

status_label() {
    local compose_project="$1"
    if [ -n "$(app_container_id "$compose_project")" ]; then
        printf '%b● Running%b' "$COLOR_GREEN" "$COLOR_RESET"
        return
    fi

    if [ -n "$(app_container_exists_any_state "$compose_project")" ]; then
        printf '%b○ Stopped%b' "$COLOR_RED" "$COLOR_RESET"
        return
    fi

    printf '%b○ Missing%b' "$COLOR_YELLOW" "$COLOR_RESET"
}

render_status_table() {
    local scope="${1:-all}"
    local file=""
    local found=0

    printf '%-24s %-4s %-40s %-16s %-8s\n' "Issue" "Mode" "Domain" "Container" "DB"
    printf '%-24s %-4s %-40s %-16s %-8s\n' "------------------------" "----" "----------------------------------------" "----------------" "--------"

    while IFS= read -r file; do
        [ -n "$file" ] || continue
        found=1
        load_instance_metadata "$file"
        printf '%-24s %-4s %-40s %-16b %-8s\n' \
            "$(truncate_text 24 "$ISSUE_ID")" \
            "${SWCTL_MODE:-dev}" \
            "$(truncate_text 40 "$DOMAIN")" \
            "$(status_label "$COMPOSE_PROJECT")" \
            "$DB_STATE"
    done <<EOF
$(list_instance_files "$scope")
EOF

    if [ "$found" -eq 0 ]; then
        printf '%s\n' "No tracked worktrees."
    fi
}

cmd_status() {
    if maybe_load_project_config >/dev/null 2>&1; then
        render_status_table "project"
        return
    fi

    render_status_table "all"
}

cmd_exec() {
