cmd_refresh() {
    local issue_input="${1:-}"
    SWCTL_ACTIVE_META_FILE=""

    [ -n "$issue_input" ] || die "Usage: swctl refresh <issue>"

    maybe_load_project_config >/dev/null 2>&1 || true
    SWCTL_ACTIVE_META_FILE="$(resolve_instance_file_by_issue "$issue_input")" || die "No tracked worktree found for issue '$issue_input'."
    load_instance_metadata "$SWCTL_ACTIVE_META_FILE"

    # Resume failed/interrupted creates
    if [ "${STATUS:-complete}" = "failed" ] || [ "${STATUS:-complete}" = "creating" ]; then
        info "Worktree '$ISSUE_ID' has status '${STATUS}'. Resuming provisioning..."
        STATUS="creating"
        load_project_config ${CONFIG_PATH:+"$CONFIG_PATH"}
        ensure_infra_ready

        # Recompute derived variables not stored in metadata
        WORKTREE_ID="${WORKTREE_ID:-$ISSUE_ID}"
        if [ -z "${COMPOSE_PROJECT:-}" ]; then
            COMPOSE_PROJECT="$(sanitize_slug "${SW_PROJECT_SLUG}-${ISSUE_ID}")"
        fi
        TRAEFIK_ROUTER="$(sanitize_router_id "${SW_PROJECT_SLUG}_${ISSUE_ID}")"
        TRAEFIK_SERVICE="$TRAEFIK_ROUTER"
        if [ -z "${WORKTREE_PATH:-}" ]; then
            WORKTREE_PATH="${SW_WORKTREE_ROOT}/${SW_WORKTREE_PREFIX}-${ISSUE_ID}"
        fi
        if [ -z "${DOMAIN:-}" ]; then
            if [ "$SW_RUNTIME" = "orbstack" ]; then
                DOMAIN="${SW_SERVICE_NAME}.${COMPOSE_PROJECT}.orb.local"
            else
                DOMAIN="${SW_PROJECT_SLUG}-${ISSUE_ID}.${SW_DOMAIN_SUFFIX}"
            fi
            APP_URL="http://${DOMAIN}"
        fi

        # On any exit while STATUS=creating, mark as failed
        trap 'if [ "${STATUS:-}" = "creating" ]; then STATUS=failed; FAILED_AT="${SWCTL_LAST_ERROR:-unknown}"; write_metadata "$SWCTL_ACTIVE_META_FILE" 2>/dev/null; fi' EXIT

        # 1. Ensure worktree exists
        if [ -n "$WORKTREE_PATH" ] && [ ! -d "$WORKTREE_PATH" ]; then
            create_worktree
        fi

        # 2. Re-compute diff and changes
        BASE_REF="$(git_base_ref)"
        DIFF_FILES="$(git -C "$PROJECT_ROOT" diff --name-only "${BASE_REF}...${BRANCH}" 2>/dev/null || true)"
        count_changes "$DIFF_FILES"

        # 3. Re-sync artifacts and deps
        sync_build_artifacts
        sync_worktree_deps
        VENDOR_VOLUME="$(resolve_vendor_volume "$ISSUE_ID")"
        NODE_MODULES_VOLUME="$(resolve_node_modules_volume "$ISSUE_ID")"

        # 4. Re-provision DB + app
        provision_database_and_app "$COMPOSE_PROJECT"

        # 5. Frontend build
        run_frontend_build_if_needed "$COMPOSE_PROJECT" 1

        # 6. Activate plugin if needed
        if [ -n "${PLUGIN_NAME:-}" ]; then
            activate_plugin "$COMPOSE_PROJECT" "$PLUGIN_NAME"
        fi

        # 7. Mark complete
        STATUS="complete"
        FAILED_AT=""
        trap - EXIT
        write_metadata "$SWCTL_ACTIVE_META_FILE"

        ok "Worktree '$ISSUE_ID' successfully provisioned."
        info "URL: ${APP_URL}"
        return
    fi

    # --- Normal refresh: pull + rebuild ---

    # Remember the old HEAD before pulling
    local old_head
    old_head="$(git -C "$WORKTREE_PATH" rev-parse HEAD 2>/dev/null)"

    # Pull latest changes
    info "Pulling latest changes for '$ISSUE_ID' (branch: $BRANCH)."
    git -C "$WORKTREE_PATH" pull --ff-only origin "$BRANCH" 2>/dev/null \
        || git -C "$WORKTREE_PATH" fetch origin "$BRANCH" && git -C "$WORKTREE_PATH" reset --hard "origin/$BRANCH" 2>/dev/null \
        || warn "Could not pull latest changes. Continuing with current state."

    local new_head
    new_head="$(git -C "$WORKTREE_PATH" rev-parse HEAD 2>/dev/null)"

    if [ "$old_head" = "$new_head" ]; then
        info "No new commits. Nothing to refresh."
        return
    fi

    ok "Updated $old_head → $new_head"

    # Diff between old and new HEAD to detect what changed
    local diff_files
    diff_files="$(git -C "$WORKTREE_PATH" diff --name-only "$old_head...$new_head" 2>/dev/null || true)"
    count_changes "$diff_files"

    info "Changes since last build: migrations=${MIGRATION_CHANGES} entity=${ENTITY_CHANGES} admin=${ADMIN_CHANGES} storefront=${STOREFRONT_CHANGES} composer=${COMPOSER_CHANGES} package=${PACKAGE_CHANGES} backend=${BACKEND_CHANGES}"

    # Re-sync gitignored files if needed
    sync_build_artifacts

    local compose_project="$COMPOSE_PROJECT"

    # Run migrations if schema changed
    if [ $((MIGRATION_CHANGES + ENTITY_CHANGES)) -gt 0 ]; then
        info "Schema changes detected. Running migrations."
        run_app_command "$compose_project" "$SW_BIN_CONSOLE database:migrate --all && $SW_BIN_CONSOLE database:migrate-destructive --all" || warn "Migrations failed."
    fi

    # Composer install if dependencies changed (dev mode only)
    if [ "$((COMPOSER_CHANGES))" -gt 0 ] && [ "${SWCTL_MODE:-dev}" = "dev" ]; then
        info "Composer changes detected. Running composer install."
        run_app_command "$compose_project" "composer install --no-interaction" || warn "Composer install failed."
    fi

    # Rebuild frontend if admin/storefront changed
    if [ "${ADMIN_CHANGES:-0}" -gt 0 ]; then
        info "Admin changes detected. Running composer build:js:admin."
        run_app_command "$compose_project" "composer build:js:admin" || warn "Admin JS build failed."
    fi

    if [ "${STOREFRONT_CHANGES:-0}" -gt 0 ]; then
        info "Storefront changes detected. Running composer build:js:storefront."
        run_app_command "$compose_project" "composer build:js:storefront" || warn "Storefront JS build failed."
    fi

    # Always clear cache after any update
    run_app_command "$compose_project" "$SW_BIN_CONSOLE cache:clear" || warn "cache:clear failed."

    # Update metadata with new HEAD
    STATUS="complete"
    write_metadata "$SWCTL_ACTIVE_META_FILE"

    ok "Refreshed '$ISSUE_ID'. Changes applied."
    info "URL: ${APP_URL}"
}

