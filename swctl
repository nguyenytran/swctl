    maybe_load_project_config >/dev/null 2>&1 || true
    local meta_file=""
    meta_file="$(resolve_instance_file_by_issue "$issue_input")" || die "No instance for '$issue_input'."
    load_instance_metadata "$meta_file"

    local backend="${RESOLVE_BACKEND:-claude}"
    local ai_bin
    ai_bin="$(_ai_backend_binary "$backend")" || die "Unknown resolve backend '$backend'."

    local backend_label
    case "$backend" in
        claude) backend_label="Claude" ;;
        codex)  backend_label="Codex" ;;
        *)      die "Unsupported resolve backend '$backend'." ;;
    esac

    info "[resolve] Opening interactive $backend_label session for #$ISSUE_ID"
    info "Worktree: $WORKTREE_PATH"
    info "Branch: $BRANCH"

    cd "$WORKTREE_PATH" || die "Cannot cd to $WORKTREE_PATH"

    case "$backend" in
        claude)
            if [ -n "${CLAUDE_SESSION_ID:-}" ]; then
