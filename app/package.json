{
  "name": "swctl-ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx --env-file-if-exists=.env watch server/index.ts\"",
    "build": "vite build",
    "server": "tsx --env-file-if-exists=.env server/index.ts",
    "start": "node --env-file-if-exists=.env dist-server/index.js",
    "mcp": "tsx --env-file-if-exists=.env mcp/index.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.7.0",
    "tsx": "^4.19.0",
    "vue": "^3.5.0",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vue-tsc": "^3.2.6"
  }
