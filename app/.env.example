# swctl UI server port (used by server, vite proxy, and MCP)
SWCTL_UI_PORT=3000

# Full URL override for MCP server (takes precedence over SWCTL_UI_PORT)
# SWCTL_UI_URL=http://swctl.orb.local

# Path to the swctl bash script
# SWCTL_PATH=/swctl/swctl

# Shopware project root directory
# PROJECT_ROOT=/project

# swctl state directory (instances metadata, tokens, checkout state)
# SWCTL_STATE_DIR=~/.local/state/swctl

# Root directory for the file browser
# SWCTL_BROWSE_ROOT=

# Editor command for "Open in editor" links
# SWCTL_EDITOR=code

# GitHub OAuth Device Flow client ID (enables GitHub login in UI)
# SWCTL_GITHUB_CLIENT_ID=
